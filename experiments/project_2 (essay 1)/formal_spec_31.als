module REQ_INV_MAN_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-INV-MAN-01
 * Title       : Inventory Dashboard Display
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Inventory_Management_Team, Operations_Team, Finance_Team extends Actor {}
-- Inventory_Management_Team: represents stakeholder 'Inventory Management Team'
-- Operations_Team: represents stakeholder 'Operations Team'
-- Finance_Team: represents stakeholder 'Finance Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Inventory_API, Request_API, Inventory_Dashboard extends Interface {}

fact interface_properties {
    Inventory_API.kind = API  -- The system will use this API to fetch current stock levels.
    Request_API.kind = API  -- This API will provide the count of pending requests.
    Inventory_Dashboard.kind = UI  -- The requirement interacts with this user interface to display the data.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The user can view the summary section on the inventory dashboard


----------------------------------------------------------------------
-- Core operation: REQ_INV_MAN_01
----------------------------------------------------------------------

sig REQ_INV_MAN_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_INV_MAN_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_INV_MAN_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_INV_MAN_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_INV_MAN_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_INV_MAN_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_INV_MAN_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_INV_MAN_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_INV_MAN_01 {
    some op: REQ_INV_MAN_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_INV_MAN_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_INV_MAN_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_INV_MAN_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_INV_MAN_01_well_formed {
    all op: REQ_INV_MAN_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_INV_MAN_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_INV_MAN_01 |
        op.post = Post1 &&
        op.grant = Read &&
        Inventory_Dashboard in op.target &&
        some c: op.channel | c.authenticated = True &&
        op.pre = PreIdle
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_INV_MAN_01 |
        op.post = Post1 =>
            (op.grant = Read &&
             Inventory_Dashboard in op.target &&
             some c: op.channel | c.authenticated = True &&
             op.pre = PreIdle)
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Reachability predicates for REQ_INV_MAN_01 liveness criteria

-- Criterion 1: See current stock levels for each item
pred ac_reach_1 {
  some op: REQ_INV_MAN_01 |
    op.grant = Read &&
    some (op.target & (Inventory_Dashboard + Inventory_API)) &&
    (some c: op.channel | c.authenticated = True) &&
    op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: See a list of units approaching expiration
pred ac_reach_2 {
  some op: REQ_INV_MAN_01 |
    op.grant = Read &&
    Inventory_API in op.target &&
    (some c: op.channel | c.kind = API && c.authenticated = True) &&
    op.post = Post1
}
run ac_reach_2 for 5

-- Criterion 3: See a count of pending requests
pred ac_reach_3 {
  some op: REQ_INV_MAN_01 |
    op.grant = Read &&
    Request_API in op.target &&
    (some c: op.channel | c.authenticated = True) &&
    op.post = Post1
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- ?? NEW SAFETY ASSERTIONS ??????????????????????????????????????????????

-- Edge case 1: No items in stock ? operation must ! grant Write/Execute if target is empty.
-- We model "empty stock" as: a Resource that has no owner || is inaccessible to any actor.
-- Safety: If a resource is inaccessible to all actors (i.e., it has no accessible actors),
-- then no REQ_INV_MAN_01 operation on that resource should grant Write || Execute permission.
assert ec_safe_1 {
    all op: REQ_INV_MAN_01 |
        (all r: op.target | no r.accessible) =>
            (op.grant != Write && op.grant != Execute)
}
check ec_safe_1 for 5

-- Edge case 2: Large number of pending requests ? no two operations on the same target
-- can have incompatible grants that would cause a conflict (e.g., one grants Write, another grants Read).
-- Safety: For any two distinct operations sharing a target, their grants must be compatible.
-- We define compatibility as: both grants are the same, || one is Admin && the other is any.
-- For simplicity, we assert: no two ops on same target have different non-Admin grants.
assert ec_safe_2 {
    all disj op1, op2: REQ_INV_MAN_01 |
        some (op1.target & op2.target) =>
            (op1.grant = op2.grant || op1.grant = Admin || op2.grant = Admin)
}
check ec_safe_2 for 5

-- Edge case 3: Expiration date ! set ? we model this as: a Resource may have no owner
-- (i.e., owner is undefined). But the sig says owner is one Actor, so we cannot have null.
-- Instead, we interpret "expiration ! set" as: the resource's accessible set is empty,
-- meaning no actor can access it. Safety: an operation on such a resource must ! succeed
-- (i.e., post must equal pre, meaning no state change).
assert ec_safe_3 {
    all op: REQ_INV_MAN_01 |
        (some r: op.target | no r.accessible) =>
            op.post = op.pre
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-INV-DIS-01
pred tc_TC_INV_DIS_01_holds {
    some op: REQ_INV_MAN_01 |
        op.initiator in Inventory_Management_Team &&
        some r: op.target | r.owner = Inventory_Management_Team &&
        some c: op.channel | c.kind = UI &&
        op.grant = Read &&
        op.post = Post1
}
run tc_TC_INV_DIS_01_holds for 5

assert tc_TC_INV_DIS_01_contract {
    all op: REQ_INV_MAN_01 |
        (op.initiator in Inventory_Management_Team &&
         some c: op.channel | c.kind = UI &&
         op.grant = Read) =>
        (op.post = Post1 && some r: op.target | r.owner = Inventory_Management_Team)
}
check tc_TC_INV_DIS_01_contract for 5

-- Scenario TC-INV-DIS-02
pred tc_TC_INV_DIS_02_holds {
    some op: REQ_INV_MAN_01 |
        op.initiator in Inventory_Management_Team &&
        some r: op.target | r.owner = Inventory_Management_Team &&
        some c: op.channel | c = Inventory_Dashboard &&
        op.grant = Read &&
        op.post = Post1
}
run tc_TC_INV_DIS_02_holds for 5

assert tc_TC_INV_DIS_02_contract {
    all op: REQ_INV_MAN_01 |
        (op.initiator in Inventory_Management_Team &&
         some c: op.channel | c = Inventory_Dashboard &&
         op.grant = Read) =>
        (op.post = Post1 && some r: op.target | r.owner = Inventory_Management_Team)
}
check tc_TC_INV_DIS_02_contract for 5

-- Scenario TC-INV-DIS-03
pred tc_TC_INV_DIS_03_holds {
    some op: REQ_INV_MAN_01 |
        op.initiator in Inventory_Management_Team &&
        some c: op.channel | c = Request_API &&
        op.grant = Read &&
        op.post = Post1
}
run tc_TC_INV_DIS_03_holds for 5

assert tc_TC_INV_DIS_03_contract {
    all op: REQ_INV_MAN_01 |
        (op.initiator in Inventory_Management_Team &&
         some c: op.channel | c = Request_API &&
         op.grant = Read) =>
        (op.post = Post1)
}
check tc_TC_INV_DIS_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: minimize channel count per operation to reduce latency (NFR: response time < 200ms)
fact nfr_fact_performance_channel_limit {
    all op: REQ_INV_MAN_01 | #op.channel <= 2
}

-- Availability proxy: require at least two redundant channels per operation to ensure uptime (NFR: 99.9% availability)
assert nfr_assert_availability_redundant_channels {
    all op: REQ_INV_MAN_01 | #op.channel >= 2
}
check nfr_assert_availability_redundant_channels for 5

-- Scalability proxy: every actor can initiate at least one operation, ensuring the system handles all actors simultaneously (NFR: support all actors)
assert nfr_assert_scalability_all_actors {
    all a: Actor | some op: REQ_INV_MAN_01 | op.initiator = a
}
check nfr_assert_scalability_all_actors for 5

-- Usability proxy: limit the number of authenticated interfaces to a small bound, simplifying user interaction (NFR: intuitive authentication)
fact nfr_fact_usability_authenticated_limit {
    #(Interface & {i: Interface | i.authenticated = True}) <= 3
}

