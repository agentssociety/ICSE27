----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_min_interfaces {
    -- PROXY: fewer interfaces per operation reduces latency (performance proxy)
    -- NFR: response time < 200ms
    all op: REQ_TRANSFUSION_01 | #op.channel <= 2
}

fact nfr_fact_redundant_channels {
    -- PROXY: at least 2 channels ensures availability if one fails
    -- NFR: availability >= 99.9%
    all op: REQ_TRANSFUSION_01 | #op.channel >= 2
}

fact nfr_fact_max_resources {
    -- PROXY: limiting resources per operation prevents overload (scalability proxy)
    -- NFR: system scales to 1000 concurrent operations
    all op: REQ_TRANSFUSION_01 | #op.target <= 3
}

assert nfr_assert_authenticated_channels_bounded {
    -- PROXY: bounded authenticated channels improves usability by reducing complexity
    -- NFR: usability - authentication setup time < 30 seconds
    all op: REQ_TRANSFUSION_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}
check nfr_assert_authenticated_channels_bounded for 5

assert nfr_assert_no_circular_ownership {
    -- PROXY: no circular resource ownership ensures maintainability
    -- NFR: maintainability - system can be modified without cascading changes
    no r: Resource | r in r.owner.^(mayPerform.(~mayPerform))
}
check nfr_assert_no_circular_ownership for 5

