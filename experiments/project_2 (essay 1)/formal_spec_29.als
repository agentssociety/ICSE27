module REQ_BBA_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BBA-01
 * Title       : Automate Expiration of Blood Units Older than 42 Days
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Administrators, Medical_Staff, Regulatory_Authorities extends Actor {}
-- Blood_Bank_Administrators: represents stakeholder 'Blood Bank Administrators'
-- Medical_Staff: represents stakeholder 'Medical Staff'
-- Regulatory_Authorities: represents stakeholder 'Regulatory Authorities'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Blood_Units_Database, System_Clock_API extends Interface {}

fact interface_properties {
    Blood_Units_Database.kind = Database  -- The system will interact with this database to retrieve and update the collection dates and statuses of blood units.
    System_Clock_API.kind = API  -- This API provides real-time date and time, which is used by the system to calculate the age of blood units.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system must have access to the current date and time.
-- Pre2: system is in state where The system must store the collection date of each blood unit.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The status of the blood unit is updated to 'expired'.
-- Post2: system reaches state where The unit should no longer be available for transfusion or use.


----------------------------------------------------------------------
-- Core operation: REQ_BBA_01
----------------------------------------------------------------------

sig REQ_BBA_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BBA_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BBA_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BBA_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BBA_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BBA_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BBA_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BBA_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BBA_01 {
    some op: REQ_BBA_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BBA_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BBA_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BBA_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BBA_01_well_formed {
    all op: REQ_BBA_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BBA_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Predicate: Post1 reachability ? blood unit status updated to 'expired'
pred ps_reach_Post1 {
    some op: REQ_BBA_01 |
        op.post = Post1 &&
        op.grant = Write &&
        Blood_Units_Database in op.target &&
        op.initiator in Blood_Bank_Administrators &&
        op.pre != Post1
}
run ps_reach_Post1 for 5

-- Assertion: Post1 semantics ? when reached, blood unit is expired
assert ps_valid_Post1 {
    all op: REQ_BBA_01 |
        (op.post = Post1) =>
            (op.grant = Write &&
             Blood_Units_Database in op.target &&
             op.initiator in Blood_Bank_Administrators &&
             op.pre != Post1)
}
check ps_valid_Post1 for 5

-- Predicate: Post2 reachability ? unit no longer available for transfusion
pred ps_reach_Post2 {
    some op: REQ_BBA_01 |
        op.post = Post2 &&
        op.grant = Admin &&
        Blood_Units_Database in op.target &&
        op.initiator in Blood_Bank_Administrators &&
        op.pre != Post2 &&
        op.pre = Post1
}
run ps_reach_Post2 for 5

-- Assertion: Post2 semantics ? when reached, unit is unavailable for transfusion
assert ps_valid_Post2 {
    all op: REQ_BBA_01 |
        (op.post = Post2) =>
            (op.grant = Admin &&
             Blood_Units_Database in op.target &&
             op.initiator in Blood_Bank_Administrators &&
             op.pre = Post1)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: Given a blood unit has a collection date
-- This maps to: there exists an operation that accesses a Blood_Units_Database resource
-- && the pre-state is Pre1 (representing initial state with collection date)
pred ac_reach_1 {
    some op: REQ_BBA_01 |
        Blood_Units_Database in op.target &&
        op.pre = Pre1 &&
        op.grant in op.initiator.mayPerform
}
run ac_reach_1 for 5

-- Criterion 2: When the current date is more than 42 days after the collection date
-- This maps to: operation uses System_Clock_API to check date, reaches Post1 state
pred ac_reach_2 {
    some op: REQ_BBA_01 |
        System_Clock_API in op.channel &&
        Blood_Units_Database in op.target &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.grant = Read
}
run ac_reach_2 for 5

-- Criterion 3: Then the blood unit is automatically marked as expired
-- This maps to: operation writes to Blood_Units_Database, reaches Post2 state
pred ac_reach_3 {
    some op: REQ_BBA_01 |
        Write in op.initiator.mayPerform &&
        Blood_Units_Database in op.target &&
        op.pre = Post1 &&
        op.post = Post2 &&
        (some c: op.channel | c.authenticated = True)
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_BBA_01 |
    (op.pre = Pre1) => (all c: op.channel | c.authenticated = True)
}
check ec_safe_1 for 5

assert ec_safe_2 {
  all op: REQ_BBA_01 |
    (op.pre = Pre2) => (op.initiator in Medical_Staff)
}
check ec_safe_2 for 5

assert ec_safe_3 {
  all op: REQ_BBA_01 |
    (op.post = Post1) => (op.initiator in Blood_Bank_Administrators)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_bba_01_holds {
    some op: REQ_BBA_01 |
        op.pre = Pre1 &&
        op.post = Post1 &&
        Blood_Units_Database in op.target &&
        Write in op.initiator.mayPerform
}
run tc_bba_01_holds for 5

assert tc_bba_01_contract {
    all op: REQ_BBA_01 |
        (op.pre = Pre1 && Blood_Units_Database in op.target) =>
        op.post = Post1
}
check tc_bba_01_contract for 5

pred tc_bba_02_holds {
    some op: REQ_BBA_01 |
        op.pre = Pre2 &&
        op.post = Post2 &&
        System_Clock_API in op.channel
}
run tc_bba_02_holds for 5

assert tc_bba_02_contract {
    all op: REQ_BBA_01 |
        (op.pre = Pre2 && System_Clock_API in op.channel) =>
        (op.post = Post2 && op.post != op.pre)
}
check tc_bba_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_response_time {
    -- PROXY: limiting channels reduces negotiation overhead, bounding latency
    -- NFR: response_time <= 5 seconds
    all op: REQ_BBA_01 | #op.channel <= 3
}

fact nfr_fact_throughput {
    -- PROXY: limiting targets per operation reduces serialization, increasing throughput
    -- NFR: throughput >= 10,000 units processed per hour
    all op: REQ_BBA_01 | #op.target <= 5
}

fact nfr_fact_uptime {
    -- PROXY: requiring redundant channels ensures service continuity during failures
    -- NFR: uptime >= 99.9%
    all op: REQ_BBA_01 | #op.channel >= 2
}

fact nfr_fact_downtime {
    -- PROXY: limiting concurrent operations reduces risk of cascading failures
    -- NFR: downtime < 1 minute per month
    all op1, op2: REQ_BBA_01 | op1 != op2 => op1.channel != op2.channel
}

fact nfr_fact_concurrency {
    -- PROXY: ensuring distinct initiators allows simultaneous operations
    -- NFR: supports >= 50 concurrent users
    all disj op1, op2: REQ_BBA_01 | op1.initiator != op2.initiator
}

fact nfr_fact_growth {
    -- PROXY: allowing multiple targets per operation supports scaling
    -- NFR: can scale to handle 50% increase in blood units
    all op: REQ_BBA_01 | #op.target >= 1
}

assert nfr_assert_error_handling {
    -- PROXY: ensuring channels are authenticated bounds error-prone interfaces
    -- NFR: provide clear && concise error messages
    all op: REQ_BBA_01 | #op.channel <= 4
}
check nfr_assert_error_handling for 5

assert nfr_assert_interface_behavior {
    -- PROXY: requiring at least one channel enables scheduled refresh
    -- NFR: system automatically refreshes status daily at midnight
    all op: REQ_BBA_01 | some op.channel
}
check nfr_assert_interface_behavior for 5

