----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- NFR: Performance (response time < 200ms)
-- Proxy: Minimizing channel count reduces latency
fact nfr_fact_performance_low_latency {
    all op: REQ_BB_01 | #op.channel <= 2
}

-- NFR: Availability (uptime > 99.9%)
-- Proxy: Redundant channels ensure availability if one fails
fact nfr_fact_availability_redundant_channels {
    all op: REQ_BB_01 | #op.channel >= 2
}

-- NFR: Scalability (supports all actor types)
-- Proxy: Each actor should be able to initiate an operation
assert nfr_assert_scalability_all_actors {
    all a: Actor | some op: REQ_BB_01 | op.initiator = a
}
check nfr_assert_scalability_all_actors for 5

-- NFR: Usability (authentication process is simple)
-- Proxy: Limited number of authenticated interfaces reduces complexity
fact nfr_fact_usability_simple_auth {
    #({i: Interface | i.authenticated = True}) <= 3
}

