module REQ_BB_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BB-01
 * Title       : Blood Stock Alert System
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Manager, Inventory_Management_Team extends Actor {}
-- Blood_Bank_Manager: represents stakeholder 'Blood Bank Manager'
-- Inventory_Management_Team: represents stakeholder 'Inventory Management Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig External_System, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Inventory_API, Email_SMS_Gateway extends Interface {}

fact interface_properties {
    Inventory_API.kind = API  -- The system will call this API to get the current inventory levels of each blood type.
    Email_SMS_Gateway.kind = External_System  -- The system will use this external service to send alerts via email, SMS or in-app notifications.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The blood bank has inventory levels for each blood type.

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The system sends an alert to the blood bank manager.


----------------------------------------------------------------------
-- Core operation: REQ_BB_01
----------------------------------------------------------------------

sig REQ_BB_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BB_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BB_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BB_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BB_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BB_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BB_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BB_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BB_01 {
    some op: REQ_BB_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BB_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BB_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BB_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BB_01_well_formed {
    all op: REQ_BB_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BB_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_BB_01 |
        op.post = Post1
        && (some c: op.channel | c.kind = Email_SMS_Gateway)
        && op.initiator = External_System
        && Admin in op.initiator.mayPerform
        && op.pre != op.post
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_BB_01 |
        op.post = Post1 => {
            (some c: op.channel | c.kind = Email_SMS_Gateway)
            && Admin in op.initiator.mayPerform
            && op.initiator != Blood_Bank_Manager
        }
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES for REQ_BB_01 ??????????????????????????????????

-- Criterion 1: The system raises an alert when the stock of any blood type falls below 5 units.
-- Semantic mapping: This is represented by a state transition where the post-state (Post1) 
-- captures the alert condition. The operation must involve a permission that allows monitoring 
-- (Read) && a channel capable of notification (Email_SMS_Gateway).
pred ac_reach_1 {
    some op: REQ_BB_01 |
        Read in op.initiator.mayPerform &&          -- Monitoring permission
        some op.target &&                           -- Affects at least one resource
        (some c: op.channel | c.kind = Email_SMS_Gateway) &&  -- Uses notification channel
        op.post = Post1                             -- Reaches the alert state
}

run ac_reach_1 for 5

-- Criterion 2: Alerts can be sent via email, SMS, || in-app notification.
-- Semantic mapping: The operation uses a communication channel of type Email_SMS_Gateway 
-- (representing email/SMS) || Inventory_API (representing in-app notification). 
-- The initiator must have the Execute permission to trigger the alert sending.
pred ac_reach_2 {
    some op: REQ_BB_01 |
        Execute in op.initiator.mayPerform &&       -- Permission to send alerts
        some op.target &&                           -- Affects at least one resource
        (some c: op.channel | 
            c.kind = Email_SMS_Gateway ||           -- Email/SMS channel
            c.kind = Inventory_API) &&              -- In-app notification channel
        (some c: op.channel | c.encrypted = True)   -- Secure channel for alert delivery
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Inventory data delay || incorrectness
-- Safety: When inventory data is delayed || incorrect, the operation must !
-- proceed with stale data ? i.e., if the pre-state reflects inaccurate inventory,
-- the post-state must ! reflect a successful update that depends on that data.
-- We model "inaccurate" as: the pre-state contains a Resource whose owner is
-- Inventory_Management_Team but the initiator is ! that team, yet the operation
-- still claims to modify that resource.
assert ec_safe_1 {
    all op: REQ_BB_01 |
        (some r: op.target | 
            r.owner = Inventory_Management_Team && 
            op.initiator != Inventory_Management_Team) =>
        op.post = op.pre  -- no change if inventory data might be stale
}
check ec_safe_1 for 5

-- Edge case 2: Simultaneous stock drops for different blood types
-- Safety: Two operations that affect different resources (different blood types)
-- must ! interfere with each other's postconditions.  Since we have no
-- explicit concurrency model, we express this as: any single operation that
-- targets multiple resources must have a consistent grant across all of them.
-- "Consistent" means the same permission applies to all targets.
-- We introduce a helper sig to represent a blood-type resource.
sig BloodTypeResource in Resource {}
fact blood_type_resources {
    -- At least one resource is a blood type
    some BloodTypeResource
}
assert ec_safe_2 {
    all op: REQ_BB_01 |
        (some op.target & BloodTypeResource) =>
        (all r1, r2: op.target & BloodTypeResource |
            r1.owner = r2.owner)  -- same owner for all blood-type targets
}
check ec_safe_2 for 5

