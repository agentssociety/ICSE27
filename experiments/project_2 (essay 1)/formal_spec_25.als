module REQ_INV_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-INV-01
 * Title       : Track Blood Units by Type, Rh Factor, and Donation Date
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Inventory_Manager, Blood_Donation_Center, Hospital_Administration extends Actor {}
-- Inventory_Manager: represents stakeholder 'Inventory Manager'
-- Blood_Donation_Center: represents stakeholder 'Blood Donation Center'
-- Hospital_Administration: represents stakeholder 'Hospital Administration'

-- Assign permissions to actors based on typical role requirements
fact actorPermissions {
    Inventory_Manager.mayPerform = Read + Write + Execute
    Blood_Donation_Center.mayPerform = Read
    Hospital_Administration.mayPerform = Read + Admin
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource representing blood unit records
one sig BloodUnitDataResource extends Resource {}

fact bloodUnitResourceSetup {
    BloodUnitDataResource.owner = Inventory_Manager
    BloodUnitDataResource.accessible = {a: Actor | Admin in a.mayPerform} + Inventory_Manager
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig BloodUnitDB, DateCalculationAPI extends Interface {}

fact interface_properties {
    BloodUnitDB.kind = Database  -- Stores all recorded blood units with their type, Rh factor, and donation date.
    DateCalculationAPI.kind = API  -- Used to calculate the expiration date based on the donation date and blood unit type/Rh factor.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The system must be operational and accessible.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where All received blood units are recorded with their respective type, Rh factor, and donation date.
-- Post2: system reaches state where Units nearing or past their expiration date are flagged for attention.


----------------------------------------------------------------------
-- Core operation: REQ_INV_01
----------------------------------------------------------------------

sig REQ_INV_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_INV_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_INV_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_INV_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_INV_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_INV_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_INV_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_INV_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_INV_01 {
    some op: REQ_INV_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_INV_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_INV_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_INV_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_INV_01_well_formed {
    all op: REQ_INV_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_INV_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? Post-state reachability && semantic verification ?????????????

-- Post1: All received blood units are recorded with their respective type, Rh factor, && donation date.
pred ps_reach_Post1 {
    some op: REQ_INV_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        op.pre != Post1 &&
        some op.target &&
        op.grant = Write  -- recording => write access to unit data
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_INV_01 |
        (op.post = Post1) =>
            (Write in op.initiator.mayPerform &&
             op.pre != Post1 &&
             some op.target)
}
check ps_valid_Post1 for 5

-- Post2: Units nearing || past their expiration date are flagged for attention.
pred ps_reach_Post2 {
    some op: REQ_INV_01 |
        op.post = Post2 &&
        Read in op.initiator.mayPerform &&
        op.pre != Post2 &&
        some op.target &&
        op.grant = Read  -- flagging requires reading unit data
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_INV_01 |
        (op.post = Post2) =>
            (Read in op.initiator.mayPerform &&
             op.pre != Post2 &&
             some op.target)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES ??????????????????????????????????????????????

-- Criterion 1: Blood unit received, logged with blood type, Rh factor, donation date
pred ac_reach_1 {
    some op: REQ_INV_01 |
        -- Inventory_Manager performs the logging operation
        op.initiator = Inventory_Manager &&
        -- Write permission is required to record data
        Write in op.initiator.mayPerform &&
        -- Target includes BloodUnitDataResource (the data representing blood units)
        BloodUnitDataResource in op.target &&
        -- Channel must be authenticated && encrypted for secure logging
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        -- State transitions from Pre1 (initial state) to Post1 (blood unit recorded)
        op.pre = Pre1 &&
        op.post = Post1
}

run ac_reach_1 for 5

-- Criterion 2: Blood unit with known donation date, expiration calculated, system can flag near/past expiration
pred ac_reach_2 {
    some op: REQ_INV_01 |
        -- Inventory_Manager performs the calculation
        op.initiator = Inventory_Manager &&
        -- Read permission is sufficient for checking dates
        Read in op.initiator.mayPerform &&
        -- Target includes BloodUnitDataResource (the data used for calculation)
        BloodUnitDataResource in op.target &&
        -- Channel must be authenticated for accessing date information
        (some c: op.channel | c.authenticated = True) &&
        -- State transitions from Post1 (blood unit recorded with donation date) to Post2 (expiration calculated)
        op.pre = Post1 &&
        op.post = Post2
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Incorrect donation date format must ! lead to invalid state transitions
-- If the date format is incorrect, the system should ! proceed to a post-state
-- that assumes valid date processing (e.g., Post2 which may represent successful calculation)
assert ec_safe_1 {
    all op: REQ_INV_01 |
        -- If the channel used is DateCalculationAPI && the operation involves
        -- date-sensitive resources, incorrect format should ! lead to Post2
        (DateCalculationAPI in op.channel && 
         BloodUnitDataResource in op.target) =>
            (op.post != Post2)
}
check ec_safe_1 for 5

-- Edge case 2: Missing Rh factor information must ! cause undefined behavior
-- Blood units with missing Rh factor should still be handled safely
-- by ensuring the operation does ! proceed to a state that assumes complete data
assert ec_safe_2 {
    all op: REQ_INV_01 |
        -- If the operation targets BloodUnitDataResource && uses Inventory_Manager
        -- as initiator, missing Rh factor should ! lead to Post1
        (BloodUnitDataResource in op.target && 
         op.initiator = Inventory_Manager) =>
            (op.post != Post1)
}
check ec_safe_2 for 5

-- Edge case 3: New blood types must ! cause system failure
-- The system should handle unknown blood types gracefully by ensuring
-- that operations involving new types do ! result in invalid states
assert ec_safe_3 {
    all op: REQ_INV_01 |
        -- If the operation uses Database interface && targets BloodUnitDataResource,
        -- new blood types should ! cause transition to Post2
        (Database in op.channel.kind && 
         BloodUnitDataResource in op.target) =>
            (op.post != Post2)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_INV_01_holds {
    some op: REQ_INV_01 |
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        some r: op.target | r.owner = op.initiator &&
        op.post = Post1
}

run tc_INV_01_holds for 5

assert tc_INV_01_contract {
    all op: REQ_INV_01 {
        (Write in op.initiator.mayPerform &&
         op.grant = Write &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         some r: op.target | r.owner = op.initiator) =>
        op.post = Post1
    }
}

check tc_INV_01_contract for 5

pred tc_INV_02_holds {
    some op: REQ_INV_01 |
        some c: op.channel | c.authenticated = False &&
        op.post = Post2
}

run tc_INV_02_holds for 5

assert tc_INV_02_contract {
    all op: REQ_INV_01 {
        (some c: op.channel | c.authenticated = False) =>
        op.post = Post2
    }
}

check tc_INV_02_contract for 5

pred tc_INV_03_holds {
    some op: REQ_INV_01 |
        some c: op.channel | c = DateCalculationAPI &&
        op.post = Post1
}

run tc_INV_03_holds for 5

assert tc_INV_03_contract {
    all op: REQ_INV_01 {
        (some c: op.channel | c = DateCalculationAPI) =>
        op.post = Post1
    }
}

check tc_INV_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_throughput {
    -- PROXY: limiting channels && targets per operation bounds latency; 1000 units/day ? 42/hour, each operation uses ?2 channels
    all op: REQ_INV_01 | #op.channel <= 2 && #op.target <= 5
}

fact nfr_fact_availability_redundancy {
    -- PROXY: requiring at least 2 redundant channels ensures 99.5% availability by tolerating single-channel failure
    all op: REQ_INV_01 | #op.channel >= 2
}

fact nfr_fact_scalability_capacity {
    -- PROXY: horizontal scaling requires all actors to be able to initiate operations simultaneously; max concurrent operations = #Actor
    all a: Actor | some op: REQ_INV_01 | op.initiator = a
}

fact nfr_fact_usability_error_guidance {
    -- PROXY: clear error messages imply bounded authenticated channel count; too many auth channels confuse users
    all op: REQ_INV_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 3
}

assert nfr_assert_all_operations_have_post {
    -- PROXY: every operation must have a defined post-state for reliability; undefined states indicate system failure
    all op: REQ_INV_01 | one op.post
}
check nfr_assert_all_operations_have_post for 5

assert nfr_assert_no_circular_ownership {
    -- PROXY: maintainability requires no circular resource ownership chains; owner fields form a DAG
    no r: Resource | r.owner in r.owner.^(Resource <: owner)
}
check nfr_assert_no_circular_ownership for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security requirement: data about blood units stored securely  
-- Assert that any operation targeting BloodUnitDataResource requires encrypted & authenticated channel  
assert sr_assert_bloodunit_encryption {
    all op : REQ_INV_01 |
        (BloodUnitDataResource in op.target) =>
            (all c : op.channel | c.encrypted = True && c.authenticated = True)
}
check sr_assert_bloodunit_encryption for 5

-- Assert that only owner || Admin may access BloodUnitDataResource (integrity + confidentiality)  
assert sr_assert_bloodunit_access_control {
    all op : REQ_INV_01 |
        (BloodUnitDataResource in op.target) =>
            (op.initiator = BloodUnitDataResource.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_bloodunit_access_control for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Added concrete resource BloodUnitDataResource to represent blood unit records
-- Summary 2: Fixed type errors where BloodUnitDB and DateCalculationAPI were incorrectly used as Resources
-- Summary 3: Assigned permissions to actors (Inventory_Manager: Read+Write+Execute, Blood_Donation_Center: Read, Hospital_Administration: Read+Admin)
-- Summary 4: Corrected ps_reach_Post1 to require Write permission
-- Summary 5: Fixed predicates to use BloodUnitDataResource as target and DateCalculationAPI as channel
-- Summary 6: Ensured owner and accessibility for BloodUnitDataResource are consistent with security constraints
-- Assumption 1: Permissions are assigned based on typical role requirements; assumption may be refined with stakeholder input
-- Assumption 2: BloodUnitDataResource ownership is assigned to Inventory_Manager; other actors may access only if they have Admin permission
-- Assumption 3: Non-functional facts (performance, availability, scalability) are proxy constraints and may not precisely reflect real system behavior
-- Open issue 1: The model abstracts away concrete data attributes (blood type, Rh factor, donation date) into states and resources; direct verification of data recording is not possible
-- Open issue 2: Edge case assertions (ec_safe_1/2/3) rely on arbitrary implications that may not capture the domain semantics precisely
-- Open issue 3: NFR facts (e.g., #op.channel >= 2) may be too restrictive and could be relaxed for practical analysis


