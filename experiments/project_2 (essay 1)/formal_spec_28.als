module REQ_BB_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BB-01
 * Title       : Automatic Release of Reserved Units for Scheduled Transfusions
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Manager, Clinical_Team, IT_Support extends Actor {}
-- Blood_Bank_Manager: represents stakeholder 'Blood Bank Manager'
-- Clinical_Team: represents stakeholder 'Clinical Team'
-- IT_Support: represents stakeholder 'IT Support'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Scheduling_API, Blood_Inventory_Database extends Interface {}

fact interface_properties {
    Scheduling_API.kind = API  -- The requirement interacts with the Scheduling API to confirm scheduled transfusions and manage reservations.
    Blood_Inventory_Database.kind = Database  -- The requirement updates the Blood Inventory Database to reserve units and track their usage status.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The system supports scheduling transfusions in advance
-- Pre2: system is in state where A defined timeframe for unit release is configured
-- Pre3: system is in state where Units are reserved only for confirmed scheduled transfusions

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The reservation is automatically released if not used within the configured timeframe


----------------------------------------------------------------------
-- Core operation: REQ_BB_01
----------------------------------------------------------------------

sig REQ_BB_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BB_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BB_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BB_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BB_01 | op.initiator in op.target.accessible
}

-- INV-5: At least one operation must produce a state change.
fact at_least_one_state_change {
    some op: REQ_BB_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BB_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BB_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BB_01 {
    some op: REQ_BB_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BB_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BB_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BB_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BB_01_well_formed {
    all op: REQ_BB_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BB_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_BB_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        op.initiator = IT_Support &&
        one c: op.channel | c.authenticated = False &&
        op.grant in (op.target.owner).mayPerform
}

assert ps_valid_Post1 {
    all op: REQ_BB_01 |
        (op.post = Post1) =>
            (op.pre = Pre1 &&
             op.initiator = IT_Support &&
             not (op.initiator = Blood_Bank_Manager or op.initiator = Clinical_Team) &&
             some c: op.channel | c.authenticated = False &&
             op.grant in (op.target.owner).mayPerform)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES for REQ_BB_01 ??????????????????????????????

-- Criterion 1: Given a scheduled transfusion with reserved units
pred ac_reach_1 {
    some op: REQ_BB_01 |
        -- The operation involves the Blood_Bank_Manager && Scheduling_API
        op.initiator = Blood_Bank_Manager &&
        -- The target includes the Scheduling_API resource
        Scheduling_API in op.target &&
        -- The operation uses a scheduling interface
        (some c: op.channel | c.kind in (IfaceKind - Database)) &&
        -- The grant is a permission related to scheduling (e.g., Write)
        Write in op.initiator.mayPerform &&
        -- State transitions from a pre-state representing "units reserved"
        op.pre = Pre1 &&
        op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: When the scheduled time passes without the units being used
pred ac_reach_2 {
    some op: REQ_BB_01 |
        -- The operation is triggered by time passage (no direct actor)
        -- Represented as an automated system operation
        op.initiator = Blood_Bank_Manager &&
        -- The target includes the blood inventory database
        Blood_Inventory_Database in op.target &&
        -- The operation uses an authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        -- The grant involves the Read permission to check reservation status
        Read in op.initiator.mayPerform &&
        -- The pre-state indicates the scheduled time has passed
        op.pre = Pre2 &&
        -- The post-state shows the units remain unused
        op.post = Post1
}
run ac_reach_2 for 5

-- Criterion 3: Then the reservation is automatically released
pred ac_reach_3 {
    some op: REQ_BB_01 |
        -- The operation is automated (system-initiated)
        op.initiator = Blood_Bank_Manager &&
        -- The target includes both scheduling && inventory resources
        (Scheduling_API + Blood_Inventory_Database) in op.target &&
        -- The operation uses multiple channels for coordination
        (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
        -- The grant involves Write permission to modify the reservation
        Write in op.initiator.mayPerform &&
        -- The pre-state has the reservation active (units reserved)
        op.pre = Pre3 &&
        -- The post-state has the reservation released (units freed)
        op.post = Post1
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sigs for edge-case semantics
sig CancellationRecord { op: REQ_BB_01, resource: Resource, time: State }
sig OverlapRecord { resource: Resource, first: REQ_BB_01, second: REQ_BB_01 }
sig OutageRecord { op: REQ_BB_01, reason: Bool }

-- Edge case 1: cancellation before timeframe
-- Safety: only Blood_Bank_Manager || IT_Support may cancel a scheduled transfusion
assert ec_safe_1 {
  all op: REQ_BB_01 |
    (op.grant = Admin && op.pre = Pre2 && op.post = Post1) =>   -- Pre2 = scheduled, Post1 = released
    (op.initiator = Blood_Bank_Manager || op.initiator = IT_Support)
}

-- Edge case 2: multi?patient reservation within timeframe
-- Safety: two distinct operations with grant = Write must share the same initiator when targeting the same resource
assert ec_safe_2 {
  all op1, op2: REQ_BB_01 |
    (op1 != op2 &&
     some r: Resource | (r in op1.target && r in op2.target && op1.grant = Write && op2.grant = Write))
    =>
    op1.initiator = op2.initiator
}

-- Edge case 3: system outage prevents automatic release
-- Safety: if any channel is unauthenticated && unencrypted, no state change is allowed
assert ec_safe_3 {
  all op: REQ_BB_01 |
    (some iface: op.channel | iface.encrypted = False && iface.authenticated = False)
    => op.post = op.pre
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? Scenario TC-BB-01: Automatic release of unused reservation ????????
-- Input: A reservation is ! used within the configured timeframe.
-- Expected: The reservation is automatically released; units become available.
-- Represented as: operation's target resource's owner changes (released),
--   && post-state differs from pre-state.

pred tc_BB_01_holds {
    some op: REQ_BB_01 |
        -- initiator is an actor who can perform the release (e.g., Blood_Bank_Manager)
        Blood_Bank_Manager in op.initiator &&
        -- target resource is a reservation (we model as resource with owner)
        some r: op.target | r.owner = op.initiator &&
        -- the reservation is released: owner changes in post-state
        op.post != op.pre &&
        -- channel is secure (authenticated && encrypted)
        all c: op.channel | c.encrypted = True && c.authenticated = True
}

run tc_BB_01_holds for 5

assert tc_BB_01_contract {
    all op: REQ_BB_01 |
        -- Pre-condition: initiator is Blood_Bank_Manager, reservation exists
        (Blood_Bank_Manager in op.initiator &&
         some r: op.target | r.owner = op.initiator &&
         all c: op.channel | c.encrypted = True && c.authenticated = True) =>
        -- Post-condition: state changes (release occurred)
        op.post != op.pre
}

check tc_BB_01_contract for 5

-- ?? Scenario TC-BB-02: Reservation ! released prematurely on cancellation ??
-- Input: A scheduled transfusion is canceled before the timeframe expires.
-- Expected: The reservation remains intact until cancellation is confirmed.
-- Represented as: operation's state does NOT change (no release).

pred tc_BB_02_holds {
    some op: REQ_BB_01 |
        -- initiator is Clinical_Team (cancelling)
        Clinical_Team in op.initiator &&
        -- target resource is a reservation
        some r: op.target | r.owner = op.initiator &&
        -- state does NOT change (reservation remains)
        op.post = op.pre &&
        -- channel secure
        all c: op.channel | c.encrypted = True && c.authenticated = True
}

run tc_BB_02_holds for 5

assert tc_BB_02_contract {
    all op: REQ_BB_01 |
        -- Pre-condition: Clinical_Team cancels before expiry
        (Clinical_Team in op.initiator &&
         some r: op.target | r.owner = op.initiator &&
         all c: op.channel | c.encrypted = True && c.authenticated = True) =>
        -- Post-condition: state unchanged (no release)
        op.post = op.pre
}

check tc_BB_02_contract for 5

-- ?? Scenario TC-BB-03: Multiple reservations managed independently ??????
-- Input: Multiple reservations for different patients.
-- Expected: Each reservation is managed independently; unused units released only
--   when their respective timeframe expires.
-- Represented as: operation targets multiple resources, each with its own owner,
--   && state changes for at least one resource (release).

pred tc_BB_03_holds {
    some op: REQ_BB_01 |
        -- initiator is Blood_Bank_Manager
        Blood_Bank_Manager in op.initiator &&
        -- multiple target resources (at least two)
        #op.target > 1 &&
        -- each resource has a different owner (different patients)
        all r1, r2: op.target | r1 != r2 => r1.owner != r2.owner &&
        -- at least one resource is released (state changes)
        op.post != op.pre &&
        -- channel secure
        all c: op.channel | c.encrypted = True && c.authenticated = True
}

run tc_BB_03_holds for 5

assert tc_BB_03_contract {
    all op: REQ_BB_01 |
        -- Pre-condition: multiple independent reservations
        (Blood_Bank_Manager in op.initiator &&
         #op.target > 1 &&
         all r1, r2: op.target | r1 != r2 => r1.owner != r2.owner &&
         all c: op.channel | c.encrypted = True && c.authenticated = True) =>
        -- Post-condition: state changes (some release occurs)
        op.post != op.pre
}

check tc_BB_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- NFR: Performance proxy -- minimize channel count to reduce latency
fact nfr_fact_performance_latency {
    -- PROXY: fewer channels per operation reduces communication overhead
    all op: REQ_BB_01 | #op.channel <= 2
}

-- NFR: Availability proxy -- require redundant channels for critical operations
fact nfr_fact_availability_redundancy {
    -- PROXY: at least one operation uses multiple channels for redundancy
    some op: REQ_BB_01 | #op.channel >= 2
}

-- NFR: Scalability proxy -- all actors can potentially initiate operations
fact nfr_fact_scalability_coverage {
    -- PROXY: every actor type can be an initiator of some operation
    all a: Actor | some op: REQ_BB_01 | op.initiator = a
}

-- NFR: Reliability proxy -- every operation has a unique defined post-state
assert nfr_assert_reliability_poststate {
    -- PROXY: defined post-states ensure operation completion
    all op: REQ_BB_01 | one op.post
}
check nfr_assert_reliability_poststate for 5

-- NFR: Usability proxy -- limit authenticated channels to improve user experience
fact nfr_fact_usability_auth_limit {
    -- PROXY: fewer authenticated channels reduces login overhead
    all op: REQ_BB_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

-- NFR: Maintainability proxy -- no circular resource ownership chains (removed due to type error, see open_issues)

