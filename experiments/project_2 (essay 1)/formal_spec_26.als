module REQ_BT_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BT-01
 * Title       : Accept and Log Transfusion Requests
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Technicians, Healthcare_Providers, IT_Team extends Actor {}
-- Blood_Bank_Technicians: represents stakeholder 'Blood Bank Technicians'
-- Healthcare_Providers: represents stakeholder 'Healthcare Providers'
-- IT_Team: represents stakeholder 'IT Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Concrete resources representing database records and API data
sig DatabaseResource extends Resource {}
sig APIResource extends Resource {}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig TransfusionRequestAPI, TransfusionRequestDB extends Interface {}

fact interface_properties {
    TransfusionRequestAPI.kind = API  -- Interface for receiving transfusion requests from healthcare providers.
    TransfusionRequestDB.kind = Database  -- Database where all transfusion requests will be stored with a unique identifier.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where A healthcare provider submits a transfusion request.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The system accepts the transfusion request.
-- Post2: system reaches state where The request is stored in the database with all necessary details.
-- Post3: system reaches state where The request has a unique identifier for tracking.


----------------------------------------------------------------------
-- Core operation: REQ_BT_01
----------------------------------------------------------------------

sig REQ_BT_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BT_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BT_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BT_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BT_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BT_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BT_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BT_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BT_01 {
    some op: REQ_BT_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BT_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BT_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BT_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BT_01_well_formed {
    all op: REQ_BT_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BT_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Predicates for post-state reachability

-- Post1: The system accepts the transfusion request.
pred ps_reach_Post1 {
    some op: REQ_BT_01 |
        op.post = Post1 &&
        op.initiator in Blood_Bank_Technicians &&
        op.grant = Write &&
        op.pre = Pre1 &&
        some c: op.channel | c in TransfusionRequestAPI && c.authenticated = True
}
run ps_reach_Post1 for 5

-- Post2: The request is stored in the database with all necessary details.
pred ps_reach_Post2 {
    some op: REQ_BT_01 |
        op.post = Post2 &&
        op.initiator in Blood_Bank_Technicians &&
        op.grant = Write &&
        some r: op.target | r in DatabaseResource &&
        op.pre = Post1 &&
        some c: op.channel | c in TransfusionRequestDB && c.authenticated = True
}
run ps_reach_Post2 for 5

-- Post3: The request has a unique identifier for tracking.
pred ps_reach_Post3 {
    some op: REQ_BT_01 |
        op.post = Post3 &&
        op.initiator in IT_Team &&
        op.grant = Admin &&
        some r: op.target | r in DatabaseResource &&
        op.pre = Post2 &&
        some c: op.channel | c in TransfusionRequestDB && c.authenticated = True
}
run ps_reach_Post3 for 5

-- Assertions for post-state semantic verification

-- Post1: Whenever the system accepts a transfusion request, the initiator is a blood bank technician,
-- the grant is Write, the pre-state is Pre1, && the channel is the TransfusionRequestAPI && authenticated.
assert ps_valid_Post1 {
    all op: REQ_BT_01 |
        op.post = Post1 => (
            op.initiator in Blood_Bank_Technicians &&
            op.grant = Write &&
            op.pre = Pre1 &&
            some c: op.channel | c in TransfusionRequestAPI && c.authenticated = True
        )
}
check ps_valid_Post1 for 5

-- Post2: Whenever a request is stored in the database, the initiator is a blood bank technician,
-- the grant is Write, the target includes a database resource, the pre-state is Post1,
-- && the channel is the TransfusionRequestDB && authenticated.
assert ps_valid_Post2 {
    all op: REQ_BT_01 |
        op.post = Post2 => (
            op.initiator in Blood_Bank_Technicians &&
            op.grant = Write &&
            some r: op.target | r in DatabaseResource &&
            op.pre = Post1 &&
            some c: op.channel | c in TransfusionRequestDB && c.authenticated = True
        )
}
check ps_valid_Post2 for 5

-- Post3: Whenever the request has a unique identifier, the initiator is part of the IT team,
-- the grant is Admin, the target includes a database resource, the pre-state is Post2,
-- && the channel is the TransfusionRequestDB && authenticated.
assert ps_valid_Post3 {
    all op: REQ_BT_01 |
        op.post = Post3 => (
            op.initiator in IT_Team &&
            op.grant = Admin &&
            some r: op.target | r in DatabaseResource &&
            op.pre = Post2 &&
            some c: op.channel | c in TransfusionRequestDB && c.authenticated = True
        )
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES ??????????????????????????????

-- Criterion 1: The request is accepted && logged in the database with a unique ID.
pred ac_reach_1 {
    some op: REQ_BT_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        some op.channel &&
        op.post = Post1 &&
        some (op.target & DatabaseResource) &&
        one op.grant
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
    all op: REQ_BT_01 |
        (op.initiator in Healthcare_Providers && no (op.target & DatabaseResource)) =>
        op.post = op.pre
}

assert ec_safe_2 {
    all op1, op2: REQ_BT_01 |
        op1 != op2 && op1.target = op2.target && op1.grant = op2.grant
        => (op1.post = op1.pre || op2.post = op2.pre)
}

pred dbUp(s: State) {
    s = Pre1
}

assert ec_safe_3 {
    all op: REQ_BT_01 |
        ! dbUp[op.pre] => op.post = op.pre
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? SCENARIO TC-BT-01: Complete transfusion request ????????????????
-- Input:  All required fields present (patient details, blood type, etc.)
-- Expected: System accepts request, logs it in database with unique ID.
-- Pre-condition: initiator is a Healthcare_Provider (|| authorized actor)
--               target is some Resource (e.g., Database || API)
--               channel is encrypted && authenticated
-- Post-condition: post != pre (state change) &&
--                some Resource in target gets a new owner (logged)

pred tc_BT_01_holds {
    some op: REQ_BT_01 |
        -- Input: complete request (all fields present)
        op.initiator in Healthcare_Providers &&
        some r: op.target | r in DatabaseResource + APIResource &&
        -- channel is secure
        all c: op.channel | c.encrypted = True &&
        -- Expected: accept & log with unique ID
        op.grant in (Write + Read) &&
        op.post != op.pre &&
        -- unique ID: some target resource has owner = op.initiator
        some r: op.target | r.owner = op.initiator
}

run tc_BT_01_holds for 5

assert tc_BT_01_contract {
    all op: REQ_BT_01 |
        -- Pre: complete request, authorized initiator
        (op.initiator in Healthcare_Providers &&
         some r: op.target | r in DatabaseResource + APIResource &&
         all c: op.channel | c.encrypted = True &&
         op.grant in (Write + Read)) =>
        -- Post: state changes, resource logged
        (op.post != op.pre &&
         some r: op.target | r.owner = op.initiator)
}

check tc_BT_01_contract for 5

-- ?? SCENARIO TC-BT-02: Incomplete transfusion request ????????????????
-- Input: Missing patient details (incomplete target || missing fields)
-- Expected: System rejects with error message to healthcare provider.
-- Pre-condition: initiator is Healthcare_Provider
--               target is empty || missing required fields
--               channel is authenticated
-- Post-condition: no state change (post = pre) &&
--                error: grant = Read only (no write)

pred tc_BT_02_holds {
    some op: REQ_BT_01 |
        -- Incomplete: target has no database or API resource
        no r: op.target | r in DatabaseResource + APIResource &&
        -- initiator is authorized (must be in Healthcare_Providers)
        op.initiator in Healthcare_Providers &&
        -- Expected: reject with error, no state change
        op.grant = Read &&
        op.post = op.pre &&
        -- error message: channel must be authenticated
        some c: op.channel | c.authenticated = True
}

run tc_BT_02_holds for 5

assert tc_BT_02_contract {
    all op: REQ_BT_01 |
        -- Pre: incomplete request (no database or API resource in target, initiator is Healthcare_Provider, channel authenticated)
        (no r: op.target | r in DatabaseResource + APIResource &&
         op.initiator in Healthcare_Providers &&
         some c: op.channel | c.authenticated = True) =>
        -- Post: reject, no state change
        (op.grant = Read &&
         op.post = op.pre)
}

check tc_BT_02_contract for 5

-- ?? SCENARIO TC-BT-03: Duplicate request ????????????????????????????
-- Input: Same patient && blood type as existing request
-- Expected: System accepts but logs as duplicate with warning.
-- Pre-condition: initiator is Healthcare_Provider
--               target contains duplicate resource (same owner)
--               channel is secure
-- Post-condition: state changes (post != pre) &&
--                duplicate logged with warning (grant includes Read)

pred tc_BT_03_holds {
    some op: REQ_BT_01 |
        -- Duplicate: target has same owner as another operation (here we assume duplicate if target includes a resource already owned by initiator)
        op.initiator in Healthcare_Providers &&
        some r: op.target | r in DatabaseResource + APIResource &&
        all c: op.channel | c.encrypted = True &&
        -- Duplicate condition: same resource already owned (we check if any resource in target has owner = initiator)
        some r2: Resource | r2 in op.target && r2.owner = op.initiator &&
        -- Expected: state change with warning
        op.grant in (Read + Write) &&
        op.post != op.pre
}

run tc_BT_03_holds for 5

assert tc_BT_03_contract {
    all op: REQ_BT_01 |
        -- Pre: duplicate request (target includes a resource owned by initiator, channel encrypted, initiator Healthcare_Provider)
        (op.initiator in Healthcare_Providers &&
         some r: op.target | r in DatabaseResource + APIResource &&
         all c: op.channel | c.encrypted = True &&
         some r2: Resource | r2 in op.target && r2.owner = op.initiator) =>
        -- Post: state changes, duplicate logged
        (op.post != op.pre &&
         op.grant in (Read + Write))
}

check tc_BT_03_contract for 5

