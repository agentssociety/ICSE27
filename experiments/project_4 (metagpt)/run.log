"""
Entry point for the ATM Withdrawal System Flask application.

This module initializes the Flask app, configures extensions (SQLAlchemy,
Flask-Migrate, Flask-Bcrypt, Flask-JWT-Extended, Flask-RESTful),
registers all API endpoints, and provides the main execution block.
"""

import os
from flask import Flask
from flask_migrate import Migrate
from flask_restful import Api
from flask_jwt_extended import JWTManager

from config import Config, config_mapping
from models import db, bcrypt
from api.auth_api import AuthLogin, AuthLogout
from api.transaction_api import Withdrawal, TransactionHistory
from api.admin_api import FlaggedList, ReviewFlagged, AccountLock


def create_app(config_name: str = 'default') -> Flask:
    """
    Create and configure the Flask application.

    Args:
        config_name: The name of the configuration to load (e.g., 'development',
                     'production', 'default'). Defaults to 'default'.

    Returns:
        A fully configured Flask application instance.
    """
    app = Flask(__name__)

    # Load configuration from the mapping
    config_class_name = config_mapping.get(config_name, 'DevelopmentConfig')
    config_obj = Config
    # If a class name is provided, import it from config module
    # (config_mapping contains class names, not objects)
    # Better: use from config import DevelopmentConfig etc.
    # We'll import the appropriate class.
    # For simplicity and to follow the existing config.py, we use getattr.
    from config import DevelopmentConfig, ProductionConfig
    config_classes = {
        'DevelopmentConfig': DevelopmentConfig,
        'ProductionConfig': ProductionConfig,
        'Config': Config
    }
    app.config.from_object(config_classes.get(config_class_name, Config))

    # Initialize extensions
    db.init_app(app)
    bcrypt.init_app(app)
    jwt = JWTManager(app)  # noqa: F841  (must be kept for JWT to work)

    # Set up Flask-Migrate
    migrate = Migrate(app, db)  # noqa: F841

    # Set up Flask-RESTful API
    api = Api(app)

    # Register authentication endpoints
    api.add_resource(AuthLogin, '/auth/login')
    api.add_resource(AuthLogout, '/auth/logout')

    # Register transaction endpoints
    api.add_resource(Withdrawal, '/withdraw')
    api.add_resource(TransactionHistory, '/history')

    # Register admin endpoints
    api.add_resource(FlaggedList, '/admin/flagged')
    api.add_resource(ReviewFlagged, '/admin/review')
    api.add_resource(AccountLock, '/admin/account/lock')

    # Optional: create tables automatically in development mode
    @app.cli.command('initdb')
    def initdb_command():
        """Initialize the database by creating all tables."""
        with app.app_context():
            db.create_all()
        print('Initialized the default database.')

    @app.cli.command('seed')
    def seed_command():
        """Seed the database with sample data (for development)."""
        from models import User
        from utils import hash_pin
        with app.app_context():
            # Create a sample user (card: 1111222233334444, pin: 1234)
            if not User.query.filter_by(card_number='1111222233334444').first():
                user = User(
                    card_number='1111222233334444',
                    pin_hash=hash_pin('1234'),
                    account_number='00000001',
                    balance=5000.00,
                    daily_limit=1000.00,
                    daily_withdrawn_today=0.00,
                    last_withdrawal_date=None,
                    is_locked=False,
                    failed_attempts=0
                )
                db.session.add(user)
                db.session.commit()
                print('Seeded sample user: card 1111222233334444, PIN 1234, balance 5000.')
            else:
                print('Sample user already exists.')

    # Return the configured app
    return app


if __name__ == '__main__':
    # Determine the configuration to use from environment variable
    env_config = os.environ.get('FLASK_ENV', 'development')
    application = create_app(config_name=env_config)

    # Run the application
    application.run(
        host='0.0.0.0',
        port=int(os.environ.get('PORT', 5000)),
        debug=application.config.get('DEBUG', False)
    )
