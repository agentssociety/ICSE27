```html
{% extends "base.html" %}

{% block title %}Inventory - Blood Bank Management{% endblock %}

{% block content %}
<div class="row mb-4">
    <div class="col-12">
        <h1 class="display-5">Blood Unit Inventory</h1>
        <p class="text-muted">Manage and view all blood units in the system</p>
    </div>
</div>

<!-- Add Blood Unit Form -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-plus-circle"></i> Add New Blood Unit
                </h5>
            </div>
            <div class="card-body">
                <form method="POST" action="{{ url_for('main.add_blood_unit') }}">
                    {{ add_form.hidden_tag() }}
                    <div class="mb-3">
                        {{ add_form.abo_type.label(class="form-label") }}
                        {{ add_form.abo_type(class="form-select") }}
                        {% for error in add_form.abo_type.errors %}
                            <div class="text-danger small">{{ error }}</div>
                        {% endfor %}
                    </div>
                    <div class="mb-3">
                        {{ add_form.rh_factor.label(class="form-label") }}
                        {{ add_form.rh_factor(class="form-select") }}
                        {% for error in add_form.rh_factor.errors %}
                            <div class="text-danger small">{{ error }}</div>
                        {% endfor %}
                    </div>
                    <div class="mb-3">
                        {{ add_form.collection_date.label(class="form-label") }}
                        {{ add_form.collection_date(class="form-control") }}
                        {% for error in add_form.collection_date.errors %}
                            <div class="text-danger small">{{ error }}</div>
                        {% endfor %}
                    </div>
                    <div class="d-grid">
                        {{ add_form.submit(class="btn btn-success") }}
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Filter Form -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-funnel"></i> Filter Inventory
                </h5>
            </div>
            <div class="card-body">
                <form method="GET" action="{{ url_for('main.inventory') }}">
                    <div class="row g-3">
                        <div class="col-md-4">
                            {{ filter_form.status.label(class="form-label") }}
                            {{ filter_form.status(class="form-select") }}
                        </div>
                        <div class="col-md-4">
                            {{ filter_form.abo_type.label(class="form-label") }}
                            {{ filter_form.abo_type(class="form-select") }}
                        </div>
                        <div class="col-md-4">
                            {{ filter_form.rh_factor.label(class="form-label") }}
                            {{ filter_form.rh_factor(class="form-select") }}
                        </div>
                    </div>
                    <div class="d-grid mt-3">
                        {{ filter_form.submit(class="btn btn-outline-secondary") }}
                        <a href="{{ url_for('main.inventory') }}" class="btn btn-outline-danger mt-2">Clear Filters</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Blood Units Table -->
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="bi bi-table"></i> Blood Units
                </h5>
                <span class="badge bg-light text-dark">{{ units|length }} unit(s)</span>
            </div>
            <div class="card-body">
                {% if units %}
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>ABO Type</th>
                                <th>Rh Factor</th>
                                <th>Collection Date</th>
                                <th>Expiry Date</th>
                                <th>Status</th>
                                <th>Reservation</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for unit in units %}
                            <tr>
                                <td>{{ unit.id }}</td>
                                <td><strong>{{ unit.abo_type }}</strong></td>
                                <td>{{ unit.rh_factor | capitalize }}</td>
                                <td>{{ unit.collection_date.strftime('%Y-%m-%d') }}</td>
                                <td>{{ unit.expiry_date.strftime('%Y-%m-%d') }}</td>
                                <td>
                                    {% if unit.status == 'available' %}
                                        <span class="badge bg-success">Available</span>
                                    {% elif unit.status == 'reserved' %}
                                        <span class="badge bg-info">Reserved</span>
                                    {% elif unit.status == 'issued' %}
                                        <span class="badge bg-secondary">Issued</span>
                                    {% elif unit.status == 'expired' %}
                                        <span class="badge bg-danger">Expired</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if unit.reservation %}
                                        <span class="small">Request #{{ unit.reservation.request_id }}</span>
                                    {% else %}
                                        <span class="text-muted">None</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if unit.status == 'reserved' %}
                                    <form action="{{ url_for('main.issue_blood_unit', unit_id=unit.id) }}" method="POST" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Issue this unit">
                                            <i class="bi bi-check-lg"></i> Issue
                                        </button>
                                    </form>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle"></i> No blood units found matching the current filters.
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    // Optional: confirm before issuing a unit
    document.querySelectorAll('form[action*="/issue"]').forEach(form => {
        form.addEventListener('submit', function(e) {
            if (!confirm('Are you sure you want to issue this blood unit?')) {
                e.preventDefault();
            }
        });
    });
</script>
{% endblock %}
```
