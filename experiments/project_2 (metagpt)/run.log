```javascript
/**
 * main.js - Blood Bank Management System Frontend Script
 *
 * Provides interactive functionalities such as confirmation dialogs,
 * auto-refresh, and other UI enhancements for the dashboard, inventory,
 * requests, and alerts pages.
 *
 * This script is designed to work with Bootstrap 5 and Flask templates.
 * It follows a modular pattern and uses an IIFE to avoid global scope pollution.
 */

(function() {
    'use strict';

    // ==========================================================================
    // Configuration
    // ==========================================================================
    const CONFIG = {
        // Default auto-refresh intervals (in milliseconds).
        // These can be overridden by data attributes on the <body> element.
        dashboardRefreshInterval: 60000,   // 60 seconds
        alertsRefreshInterval: 30000       // 30 seconds
    };

    // ==========================================================================
    // Utility Functions
    // ==========================================================================

    /**
     * Returns the auto-refresh interval (in milliseconds) for the current page.
     * If the <body> element has a `data-auto-refresh` attribute, its value (in seconds)
     * is used; otherwise, returns the default based on the page path.
     *
     * @returns {number|null} Refresh interval in ms, or null if no auto-refresh.
     */
    function getAutoRefreshInterval() {
        const body = document.body;
        // Check for explicit data attribute (value in seconds)
        const explicit = body.getAttribute('data-auto-refresh');
        if (explicit !== null) {
            const seconds = parseInt(explicit, 10);
            return (isNaN(seconds) || seconds <= 0) ? null : seconds * 1000;
        }

        // No explicit attribute, fall back to page-specific defaults
        const path = window.location.pathname;
        if (path === '/' || path === '/dashboard') {
            return CONFIG.dashboardRefreshInterval;
        }
        if (path === '/alerts') {
            return CONFIG.alertsRefreshInterval;
        }
        return null;
    }

    /**
     * Starts auto-refresh if an interval is configured.
     * The page will reload after the specified delay.
     */
    function enableAutoRefresh() {
        const interval = getAutoRefreshInterval();
        if (interval === null) {
            return;
        }
        // Only set timer if not already running (prevents duplicates)
        if (window._autoRefreshTimer) {
            clearTimeout(window._autoRefreshTimer);
        }
        window._autoRefreshTimer = setTimeout(function() {
            window.location.reload();
        }, interval);
        // Optionally, log the auto-refresh (helpful for debugging)
        console.debug('[BloodBank] Auto-refresh scheduled in', interval / 1000, 'seconds.');
    }

    /**
     * Binds a confirmation dialog to a form submission.
     * When the form is submitted, a `confirm()` dialog is shown with the message
     * from the form's `data-confirm-message` attribute, or a default message.
     *
     * @param {HTMLFormElement} form - The form element to bind.
     */
    function bindConfirmDialog(form) {
        // Avoid double-binding
        if (form.dataset._confirmBound) {
            return;
        }
        form.dataset._confirmBound = 'true';

        form.addEventListener('submit', function(event) {
            // Use custom message or fallback
            const message = form.getAttribute('data-confirm-message') ||
                            'Are you sure you want to perform this action?';
            if (!confirm(message)) {
                event.preventDefault();
                event.stopPropagation();
            }
        });
    }

    /**
     * Binds confirmation dialogs to all forms that have a `data-confirm` attribute
     * (or match specific actions like `/issue`, `/cancel`, `/resolve`).
     */
    function bindAllConfirmDialogs() {
        // Select all forms that either:
        // - have a `data-confirm` attribute (set to "true" or "1")
        // - or whose action URL contains `/issue`, `/cancel`, or `/resolve`
        const forms = document.querySelectorAll(
            'form[data-confirm="true"], ' +
            'form[action*="/issue"], ' +
            'form[action*="/cancel"], ' +
            'form[action*="/resolve"]'
        );

        forms.forEach(function(form) {
            bindConfirmDialog(form);
        });
    }

    /**
     * Restarts the auto-refresh timer if it was stopped (e.g., after a form
     * submission that didn't cause a full page reload). This can be called
     * after an AJAX operation if needed.
     */
    function restartAutoRefresh() {
        if (window._autoRefreshTimer) {
            clearTimeout(window._autoRefreshTimer);
        }
        enableAutoRefresh();
    }

    // ==========================================================================
    // Initialization
    // ==========================================================================

    /**
     * Main initialisation function, called after the DOM is ready.
     */
    function init() {
        // 1. Bind confirmation dialogs to relevant forms
        bindAllConfirmDialogs();

        // 2. Enable auto-refresh if configured
        enableAutoRefresh();

        // 3. (Optional) Attach a listener so that after any Ajax-style navigation
        //    (not used in this version) the auto-refresh can be restarted.
        //    For now, it's just a placeholder.

        console.debug('[BloodBank] Frontend scripts initialised.');
    }

    // ==========================================================================
    // DOM Ready (support both modern and older browsers)
    // ==========================================================================
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        // DOMContentLoaded has already fired
        init();
    }

})();
```

**Explanation of the code:**

- **Configuration object:** Contains default refresh intervals for dashboard and alerts pages.
- **Utility functions:**
  - `getAutoRefreshInterval()`: Reads an optional `data-auto-refresh` attribute on `<body>` (value in seconds) or falls back to page-specific defaults. Returns `null` to disable auto-refresh.
  - `enableAutoRefresh()`: Schedules a one-time page reload after the interval, storing the timer ID to prevent duplicates.
  - `bindConfirmDialog(form)`: Attaches a `submit` event listener that shows a `confirm()` dialog using either a custom `data-confirm-message` attribute or a default message. Checks for double-binding.
  - `bindAllConfirmDialogs()`: Queries all forms that either have `data-confirm="true"` or whose action URL contains `/issue`, `/cancel`, or `/resolve` (the three action endpoints in the application). Calls `bindConfirmDialog()` for each.
  - `restartAutoRefresh()`: Clears the existing timer and restarts auto-refresh (useful for future AJAX interactions).
- **Initialization (`init()`):** Called on DOM ready, performs all bindings.
- **IIFE:** Wraps the code to avoid polluting the global namespace.
- **Compatibility:** Uses `document.readyState` to support both modern and older browsers.

This script integrates seamlessly with the existing Flask templates (where forms have actions like `/inventory/{id}/issue`, `/requests/{id}/cancel`, `/alerts/{id}/resolve`). It also respects any `data-auto-refresh` attribute on the `<body>` tag for custom refresh intervals, while providing sensible defaults for the dashboard and alerts pages. The confirmation dialogs will enhance user experience without breaking existing functionality.
