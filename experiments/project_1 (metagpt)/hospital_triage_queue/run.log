            "Maintain a queue ordered by urgency (ascending) then arrival time (ascending)."
        ],
        [
            "P0",
            "Re-order the queue immediately upon new patient arrival or re-triage of existing patient."
        ],
        [
            "P0",
            "Allow physician to take the patient at the head of the queue, removing them from the queue."
        ],
        [
            "P1",
            "Display a live dashboard showing queue with patient name, urgency level, and waiting time (updated in real-time)."
        ]
