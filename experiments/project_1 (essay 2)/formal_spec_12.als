module REQ_DASH_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-DASH-01
 * Title       : Real-time Patient Queue Dashboard
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Triage_Nurses, Physicians, Hospital_Management, IT_Team extends Actor {}
-- Triage_Nurses: represents stakeholder 'Triage Nurses'
-- Physicians: represents stakeholder 'Physicians'
-- Hospital_Management: represents stakeholder 'Hospital Management'
-- IT_Team: represents stakeholder 'IT Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Patient_Data_API, Live_Dashboard_Interface extends Interface {}

fact interface_properties {
    Patient_Data_API.kind = API  -- The requirement interacts with this API to fetch real-time patient data, including urgency levels and wait times.
    Live_Dashboard_Interface.kind = UI  -- This interface is where the requirement is implemented, providing a visual display of patient urgency levels and estimated wait times.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The system has real-time data updates enabled
-- Pre2: system is in state where Patients are already triaged and assigned an urgency level
-- Pre3: system is in state where Estimated wait times are calculated based on current queue and resource availability

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Each patient's urgency level is displayed on the dashboard in real time
-- Post2: system reaches state where An estimated wait time for each patient is displayed on the dashboard in real time


----------------------------------------------------------------------
-- Core operation: REQ_DASH_01
----------------------------------------------------------------------

sig REQ_DASH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_DASH_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_DASH_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_DASH_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_DASH_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_DASH_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_DASH_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_DASH_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_DASH_01 {
    some op: REQ_DASH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_DASH_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_DASH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_DASH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_DASH_01_well_formed {
    all op: REQ_DASH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_DASH_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_DASH_01 |
        op.post = Post1 &&
        op.initiator in Triage_Nurses &&
        op.target in Live_Dashboard_Interface &&
        op.channel in UI &&
        op.grant in Read &&
        op.pre != Post1 &&
        op.initiator.mayPerform in Read
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_DASH_01 |
        (op.post = Post1) =>
            (some p: Patient_Data_API | p in op.target) &&
            (op.initiator in Triage_Nurses) &&
            (Read in op.initiator.mayPerform) &&
            (op.channel in UI) &&
            (op.pre != Post1)
}
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_DASH_01 |
        op.post = Post2 &&
        op.initiator in Physicians &&
        op.target in Patient_Data_API &&
        op.channel in API &&
        op.grant in Read &&
        op.pre != Post2 &&
        op.initiator.mayPerform in Read
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_DASH_01 |
        (op.post = Post2) =>
            (some p: Patient_Data_API | p in op.target) &&
            (op.initiator in Physicians) &&
            (Read in op.initiator.mayPerform) &&
            (op.channel in API) &&
            (op.pre != Post2)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_DASH_01 |
        Read in op.initiator.mayPerform &&
        Patient_Data_API in op.target &&
        Live_Dashboard_Interface in op.channel &&
        op.grant = Read &&
        Live_Dashboard_Interface.kind = UI
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_DASH_01 |
    (op.pre != op.post) => (Write in op.initiator.mayPerform)
}
check ec_safe_1 for 5

assert ec_safe_2 {
  all op: REQ_DASH_01 |
    all c: op.channel | c.authenticated = True
}
check ec_safe_2 for 5

assert ec_safe_3 {
  all op: REQ_DASH_01 |
    Patient_Data_API in op.target
}
check ec_safe_3 for 5

assert ec_safe_4 {
  all op: REQ_DASH_01 |
    some c: op.channel | c.encrypted = True && c.authenticated = True
}
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-DASH-01: dashboard updates every 5 seconds on status change
-- input: patient status changes ? output: dashboard refresh with updated urgency && wait times
pred tc_DASH_01_holds {
    some op: REQ_DASH_01 |
        -- input: initiator is a physician || triage nurse (status change initiator)
        (op.initiator in Physicians + Triage_Nurses) &&
        -- input: target includes Patient_Data_API resource
        (Patient_Data_API in op.target) &&
        -- input: channel includes UI interface (dashboard)
        (UI in op.channel) &&
        -- expected: channel authenticated && encrypted for secure display
        (all c: op.channel | c.authenticated = True && c.encrypted = True) &&
        -- expected: post state differs from pre state (state change occurred)
        op.post != op.pre
}
run  tc_DASH_01_holds    for 5

assert tc_DASH_01_contract {
    all op: REQ_DASH_01 |
        -- if a status change occurs via a physician/triage nurse on Patient_Data_API
        ((op.initiator in Physicians + Triage_Nurses) &&
         (Patient_Data_API in op.target)) =>
        -- then the system must update via an authenticated UI channel
        (some c: op.channel | c.authenticated = True && c.kind = UI) &&
        -- && state must change (dashboard refresh)
        op.post != op.pre
}
check tc_DASH_01_contract for 5

-- Scenario TC-DASH-02: high load with 150 patients, system stays responsive
-- input: high patient load (150 patients) ? output: no performance degradation
pred tc_DASH_02_holds {
    some op: REQ_DASH_01 |
        -- input: system under high load, many patients being processed
        (op.initiator in Triage_Nurses + Hospital_Management) &&
        -- input: target includes Live_Dashboard_Interface resource
        (Live_Dashboard_Interface in op.target) &&
        -- expected: channel uses API for efficient data handling
        (API in op.channel) &&
        -- expected: channel is authenticated && encrypted for security
        (all c: op.channel | c.authenticated = True && c.encrypted = True) &&
        -- expected: state changes indicating processing occurred
        op.post != op.pre
}
run  tc_DASH_02_holds    for 5

assert tc_DASH_02_contract {
    all op: REQ_DASH_01 |
        -- if the system processes patient load via triage nurses/hospital management
        ((op.initiator in Triage_Nurses + Hospital_Management) &&
         (Live_Dashboard_Interface in op.target)) =>
        -- then it must use authenticated API channels for responsiveness
        (API in op.channel) &&
        (all c: op.channel | c.authenticated = True) &&
        -- && state must change (processing occurred)
        op.post != op.pre
}
check tc_DASH_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: limit channels per operation to reduce complexity (performance)
fact nfr_fact_performance_max_channels {
    all op: REQ_DASH_01 | #op.channel <= 2
}

-- Proxy: require at least 2 authenticated interfaces for redundancy (availability)
assert nfr_assert_availability_redundant_auth {
    #(Interface.authenticated & True) >= 2
}
check nfr_assert_availability_redundant_auth for 5

-- Proxy: allow multiple distinct initiators to have operations (scalability)
assert nfr_assert_scalability_multiple_initiators {
    some disj op1, op2: REQ_DASH_01 | op1.initiator != op2.initiator
}
check nfr_assert_scalability_multiple_initiators for 5

-- Proxy: ensure at least one UI channel is used (usability)
assert nfr_assert_usability_ui_channel {
    some op: REQ_DASH_01 | op.channel.kind = UI
}
check nfr_assert_usability_ui_channel for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security Requirement 1: Live dashboard accessibility restricted to Triage_Nurses && Physicians
-- Only actors with Read permission over Live_Dashboard_Interface may access the dashboard
fact sr_fact_dashboard_access_control {
    all op: REQ_DASH_01 |
        some r: op.target | r = Live_Dashboard_Interface =>
            op.initiator in Triage_Nurses + Physicians
            && Read in op.initiator.mayPerform
}

assert sr_assert_dashboard_access_restricted {
    all op: REQ_DASH_01 |
        some r: op.target | r = Live_Dashboard_Interface =>
            op.initiator in Triage_Nurses + Physicians
            && Read in op.initiator.mayPerform
}
check sr_assert_dashboard_access_restricted for 5

-- Security Requirement 2: Data encryption using TLS 1.2 || higher
-- Represented by requiring all channels to be encrypted
assert sr_assert_encryption_in_transit {
    all op: REQ_DASH_01 |
        all c: op.channel |
            c.encrypted = True
}
check sr_assert_encryption_in_transit for 5