module REQ_NURS_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-NURS-01
 * Title       : Queue Reordering on Patient Addition and Urgency Change
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Triage_Nurses, System_Administrators, Doctors extends Actor {}
-- Triage_Nurses: represents stakeholder 'Triage Nurses'
-- System_Administrators: represents stakeholder 'System Administrators'
-- Doctors: represents stakeholder 'Doctors'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resources: the queue database and patient API (as data objects)
one sig Patient_API_Resource, Queue_Database_Resource extends Resource {}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Patient_API_Interface, Queue_Database_Interface extends Interface {}

fact interface_properties {
    Patient_API_Interface.kind = API  -- The requirement interacts with the Patient API to retrieve and update patient information.
    Queue_Database_Interface.kind = Database  -- The requirement interacts with the Queue Database to store and reorder patient data.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The system has a functional triage queue.
-- Pre2: system is in state where Patients have an assigned urgency level (critical, urgent, non-urgent).
-- Pre3: system is in state where Nurses have access to update patients' urgency levels.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The queue is reordered correctly after a new patient is added or an existing patient's urgency level is changed.
-- Post2: system reaches state where All patients in the queue are visible and accessible by nurses.
-- Post3: system reaches state where No errors occur during the reordering process.


----------------------------------------------------------------------
-- Core operation: REQ_NURS_01
----------------------------------------------------------------------

sig REQ_NURS_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_NURS_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_NURS_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_NURS_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_NURS_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_NURS_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_NURS_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_NURS_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_NURS_01 {
    some op: REQ_NURS_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_NURS_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_NURS_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_NURS_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_NURS_01_well_formed {
    all op: REQ_NURS_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_NURS_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? POST-STATE REACHABILITY VERIFICATION ??????????????????????????????

-- Post1: The queue is reordered correctly after a new patient is added ||
-- an existing patient's urgency level is changed.
pred ps_reach_Post1 {
    some op: REQ_NURS_01 |
        op.post = Post1 &&
        -- Initiator must be a nurse (Triage_Nurses) with Write permission to modify queue
        op.initiator = Triage_Nurses &&
        Write in op.initiator.mayPerform &&
        -- Target involves a Database resource (the queue)
        Queue_Database_Resource in op.target &&
        -- Channel must be authenticated (Patient_API_Interface is the interface to queue)
        some c: op.channel | c.authenticated = True &&
        -- Pre-state is ! Post1, indicating a state change occurred
        op.pre != Post1
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_NURS_01 |
        (op.post = Post1) =>
            -- Initiator is a nurse with write capability
            op.initiator = Triage_Nurses &&
            Write in op.initiator.mayPerform &&
            -- At least one target is a Database (queue)
            Queue_Database_Resource in op.target &&
            -- An authenticated channel is used
            some c: op.channel | c.authenticated = True &&
            -- State changed from pre to post
            op.pre != Post1
}

check ps_valid_Post1 for 5

-- Post2: All patients in the queue are visible && accessible by nurses.
pred ps_reach_Post2 {
    some op: REQ_NURS_01 |
        op.post = Post2 &&
        -- Initiator is a nurse who can read the queue
        op.initiator = Triage_Nurses &&
        Read in op.initiator.mayPerform &&
        -- Target includes a Database (the queue)
        Queue_Database_Resource in op.target &&
        -- Initiator must be in accessible set of the resource (queue accessible by nurses)
        op.initiator in Queue_Database_Resource.accessible &&
        -- Channel is authenticated for secure access
        some c: op.channel | c.authenticated = True &&
        -- State transition from a different pre-state
        op.pre != Post2
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_NURS_01 |
        (op.post = Post2) =>
            op.initiator = Triage_Nurses &&
            Read in op.initiator.mayPerform &&
            Queue_Database_Resource in op.target &&
            op.initiator in Queue_Database_Resource.accessible &&
            some c: op.channel | c.authenticated = True &&
            op.pre != Post2
}

check ps_valid_Post2 for 5

-- Post3: No errors occur during the reordering process.
pred ps_reach_Post3 {
    some op: REQ_NURS_01 |
        op.post = Post3 &&
        -- Initiator is a nurse performing the reorder
        op.initiator = Triage_Nurses &&
        Write in op.initiator.mayPerform &&
        -- Target includes a Database (the queue being reordered)
        Queue_Database_Resource in op.target &&
        -- Channel must be both authenticated && encrypted (secure reorder)
        some c: op.channel | c.authenticated = True && c.encrypted = True &&
        -- The grant permission must be Write (to reorder)
        op.grant = Write &&
        -- State changed from pre to post
        op.pre != Post3
}

run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_NURS_01 |
        (op.post = Post3) =>
            op.initiator = Triage_Nurses &&
            Write in op.initiator.mayPerform &&
            Queue_Database_Resource in op.target &&
            some c: op.channel | c.authenticated = True && c.encrypted = True &&
            op.grant = Write &&
            op.pre != Post3
}

check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_NURS_01 |
    op.pre = Pre1 &&
    op.post = Post1 &&
    Queue_Database_Resource in op.target &&
    op.grant = Write &&
    some c: op.channel | c.authenticated = True
}

run ac_reach_1 for 5

pred ac_reach_2 {
  some op: REQ_NURS_01 |
    op.pre = Pre2 &&
    op.post = Post2 &&
    op.initiator = Triage_Nurses &&
    op.grant = Write &&
    Queue_Database_Resource in op.target &&
    some c: op.channel | c.authenticated = True
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: unrecognized urgency level ? operation must start from a recognized pre-state
assert ec_safe_1 {
    all op: REQ_NURS_01 |
        op.pre in Pre1+Pre2+Pre3
}
check ec_safe_1 for 5

-- Edge case 2: concurrent updates on same resource ? grants must be identical to avoid conflict
assert ec_safe_2 {
    all disj op1, op2: REQ_NURS_01 |
        (some op1.target & op2.target) => op1.grant = op2.grant
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? TC-NURS-01: Critical patient placed at front of queue ????????????????
-- Input: Adding a new 'critical' urgency level patient should place them at the front of the queue.
-- Expected: The new critical patient is placed at the front of the queue.

pred tc_NURS_01_holds {
    some op: REQ_NURS_01 |
        -- New patient (target resource) is being added (state change)
        op.pre = Pre1 && op.post = Post1 &&
        -- Initiator is a triage nurse with appropriate permission
        op.initiator = Triage_Nurses &&
        Write in op.initiator.mayPerform &&
        -- Grant permission is Write (adding/updating patient record)
        op.grant = Write &&
        -- Target is a patient resource (Queue_Database_Resource)
        Queue_Database_Resource in op.target &&
        -- Channel is authenticated && encrypted (secure connection)
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        -- Postcondition: critical patient at front of queue
        -- (modeled as: state change from pre to post)
        op.post != op.pre
}
run  tc_NURS_01_holds    for 5

assert tc_NURS_01_contract {
    all op: REQ_NURS_01 |
        -- Precondition: adding new patient with critical urgency
        (op.pre = Pre1 && op.initiator = Triage_Nurses && 
         op.grant = Write && Queue_Database_Resource in op.target &&
         all c: op.channel | c.authenticated = True && c.encrypted = True) =>
        -- Postcondition: state changes (patient placed at front)
        (op.post != op.pre)
}
check tc_NURS_01_contract for 5

-- ?? TC-NURS-02: Existing non-urgent patient upgraded to critical ????????
-- Input: Changing an existing 'non-urgent' patient to 'critical' urgency level should move them to the front of the queue.
-- Expected: The existing non-urgent patient is moved to the front of the queue.

pred tc_NURS_02_holds {
    some op: REQ_NURS_01 |
        -- Existing patient (target) being updated
        Queue_Database_Resource in op.target &&
        -- Initiator is triage nurse
        op.initiator = Triage_Nurses &&
        Write in op.initiator.mayPerform &&
        -- Grant permission is Write (update operation)
        op.grant = Write &&
        -- Channel is authenticated && encrypted
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        -- Pre-state is Pre2 (non-urgent patient state)
        op.pre = Pre2 &&
        -- Post-state is Post2 (critical patient at front)
        op.post = Post2 &&
        -- State changes (patient moved to front)
        op.post != op.pre
}
run  tc_NURS_02_holds    for 5

assert tc_NURS_02_contract {
    all op: REQ_NURS_01 |
        -- Precondition: updating existing patient from non-urgent to critical
        (op.pre = Pre2 && op.initiator = Triage_Nurses && 
         op.grant = Write && Queue_Database_Resource in op.target &&
         all c: op.channel | c.authenticated = True && c.encrypted = True) =>
        -- Postcondition: state changes (patient moved to front)
        (op.post = Post2 && op.post != op.pre)
}
check tc_NURS_02_contract for 5

-- ?? TC-NURS-03: Concurrent updates from multiple nurses ??????????????????
-- Input: Concurrent updates from multiple nurses changing patients' urgency levels should result in a correct queue order.
-- Expected: All concurrent changes are applied correctly, && the queue is reordered accordingly.

pred tc_NURS_03_holds {
    -- Multiple operations by different triage nurses
    some disj op1, op2: REQ_NURS_01 |
        -- Both initiated by triage nurses
        op1.initiator = Triage_Nurses && op2.initiator = Triage_Nurses &&
        op1.initiator != op2.initiator &&
        -- Both have Write permission
        Write in op1.initiator.mayPerform && Write in op2.initiator.mayPerform &&
        -- Both use secure channels
        all c: op1.channel | c.authenticated = True && c.encrypted = True &&
        all c: op2.channel | c.authenticated = True && c.encrypted = True &&
        -- Different targets (different patients)
        op1.target != op2.target &&
        Queue_Database_Resource in op1.target && Queue_Database_Resource in op2.target &&
        -- Pre-state is Pre3 (initial queue state)
        op1.pre = Pre3 && op2.pre = Pre3 &&
        -- Post-state is Post3 (reordered queue)
        op1.post = Post3 && op2.post = Post3 &&
        -- Both operations cause state change
        op1.post != op1.pre && op2.post != op2.pre
}
run  tc_NURS_03_holds    for 5

assert tc_NURS_03_contract {
    all op1, op2: REQ_NURS_01 |
        -- Precondition: concurrent updates by different nurses
        (op1 != op2 &&
         op1.initiator = Triage_Nurses && op2.initiator = Triage_Nurses &&
         op1.initiator != op2.initiator &&
         Write in op1.initiator.mayPerform && Write in op2.initiator.mayPerform &&
         all c: op1.channel | c.authenticated = True && c.encrypted = True &&
         all c: op2.channel | c.authenticated = True && c.encrypted = True &&
         op1.target != op2.target &&
         Queue_Database_Resource in op1.target && Queue_Database_Resource in op2.target &&
         op1.pre = Pre3 && op2.pre = Pre3) =>
        -- Postcondition: both operations converge to correct final state
        (op1.post = Post3 && op2.post = Post3 &&
         op1.post != op1.pre && op2.post != op2.pre)
}
check tc_NURS_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- NFR: performance - Queue reordering should complete within 2 seconds.
-- Proxy: bounding the number of resources && channels per operation limits complexity, approximating fast execution.
fact nfr_fact_performance {
    all op: REQ_NURS_01 | #op.target <= 2 && #op.channel <= 2
}

-- NFR: availability - 99.9% uptime during regular operations.
-- Proxy: requiring at least two interfaces in the system provides redundancy, a proxy for high availability.
fact nfr_fact_availability {
    #Interface >= 2
}

-- NFR: scalability - System should handle up to 100 concurrent users without performance degradation.
-- Proxy: limiting the number of actors that can access a resource reduces contention, enabling more concurrent operations.
fact nfr_fact_scalability {
    all r: Resource | #r.accessible <= 3
}

-- NFR: usability - Error messages should be clear && actionable.
-- Proxy: restricting the number of channels per operation to at most two keeps the interface simple, making errors easier to diagnose.
fact nfr_fact_usability {
    all op: REQ_NURS_01 | #op.channel <= 2
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- ?? Security Properties for REQ_NURS_01 ??

-- Requirement 1: Access to update patients' urgency levels is restricted to authorized personnel (nurses).
-- Nurses are Triage_Nurses actors; only they may perform Write on Patient_API_Resource resources.
assert sr_assert_nurse_only_urgency_update {
    all op: REQ_NURS_01 |
        (Write in op.initiator.mayPerform) =>
        (op.initiator = Triage_Nurses &&
         Patient_API_Resource in op.target)
}
check sr_assert_nurse_only_urgency_update for 5

-- Requirement 2: The system must ensure data integrity && prevent unauthorized access to patient information.
-- Integrity: only the resource owner || an Admin may write to a resource.
assert sr_assert_data_integrity {
    all op: REQ_NURS_01 |
        (Write in op.initiator.mayPerform) =>
        (op.initiator = op.target.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_data_integrity for 5

-- Access control on patient information: only authorized actors may read Patient_API_Resource resources.
assert sr_assert_patient_data_confidentiality {
    all op: REQ_NURS_01 |
        (Read in op.initiator.mayPerform) =>
        (op.initiator = Triage_Nurses || op.initiator = Doctors || op.initiator = System_Administrators)
}
check sr_assert_patient_data_confidentiality for 5

-- Least-privilege: initiator must hold exactly the granted permission (no excess privileges).
assert sr_assert_least_privilege {
    all op: REQ_NURS_01 |
        op.grant in op.initiator.mayPerform &&
        all p: Permission | p in op.initiator.mayPerform =>
            (some op2: REQ_NURS_01 | op2.initiator = op.initiator && op2.grant = p)
}
check sr_assert_least_privilege for 5

-- Encryption requirement: all channels used for patient data must be encrypted.
assert sr_assert_encrypted_patient_channel {
    all op: REQ_NURS_01 |
        Patient_API_Resource in op.target =>
        all c: op.channel | c.encrypted = True
}
check sr_assert_encrypted_patient_channel for 5


