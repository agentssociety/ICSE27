Queue Reordering on Patient Addition and Urgency Change\n- Take Next Patient from Sorted 
Queue\n"""\n\n\n@dataclass(eq=True, frozen=True)\nclass Actor:\n    mayPerform: set[Permission]\n\n    def 
__hash__(self) -> int:\n        return id(self)\n\n    def checkPermission(self, actorId: str, requiredPermission:
Permission) -> bool:\n        return requiredPermission in self.mayPerform\n\n\nclass Permission(Enum):\n    READ 
= "read"\n    WRITE = "write"\n    EXECUTE = "execute"\n    ADMIN = "admin"\n\n\nclass State(Enum):\n    PRE1 = 
