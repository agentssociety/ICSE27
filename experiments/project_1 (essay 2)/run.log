'@startuml\nskinparam defaultFontName Arial\nskinparam defaultFontSize 12\nskinparam packageStyle 
rectangle\nskinparam backgroundColor #FEFEFE\nskinparam class {\n    BackgroundColor #F0F8FF\n    BorderColor 
#4682B4\n    FontColor #000000\n}\nskinparam enum {\n    BackgroundColor #E6E6FA\n    BorderColor 
#6A5ACD\n}\nskinparam interface {\n    BackgroundColor #FFF0F5\n    BorderColor #DB7093\n}\nskinparam note {\n    
BackgroundColor #FFFFE0\n    BorderColor #DAA520\n}\n\npackage "Domain Model" {\n    class Actor {\n        
mayPerform: set Permission\n    }\n    class Triage_Nurses\n    class Physicians\n    class Hospital_Management\n 
class IT_Team\n\n    class Resource {\n        owner: one Actor\n        accessible: set Actor\n  + 
isAccessible(initiator: Actor) : Bool\n    }\n\n    class Interface {\n        kind: one IfaceKind\n        
encrypted: one Bool\n        authenticated: one Bool\n  + isAuthenticated() : Bool\n    }\n\n    class State\n\n  
enum Permission {\n        Read\n        Write\n        Execute\n        Admin\n    }\n\n    enum IfaceKind {\n   
API\n        UI\n    }\n\n    enum Bool {\n        True\n        False\n    }\n\n    class Pre1\n{\n  + 
isEnabled() : Bool\n}\n    class Pre2\n{\n  + isTriaged() : Bool\n}\n    class Pre3\n{\n  + isCalculated() : 
Bool\n}\n    class Post1\n    class Post2\n}\n\npackage "Application" {\n    class REQ_DASH_01 {\n        
initiator: one Actor\n        target: some Resource\n        channel: some Interface\n        grant: one 
Permission\n        pre: one State\n        post: one State\n  + create(initiator, target, channel, grant) : 
REQ_DASH_01\n  + transitionToPostState()\n  + setPostState(Post1)\n  + setPostState(Post2)\n  + create(initiator, 
target, channel, grant)\n  + setPreState(Pre1)\n  + setPreState(Pre2)\n    }\n    note right of REQ_DASH_01\n     
Invariants:\n        - inv_operation_requires_channel: some op.channel\n        - inv_operation_requires_target: 
some op.target\n        - inv_initiator_is_authorized: grant in initiator.mayPerform\n        - 
inv_resource_access_control: initiator in target.accessible\n        - inv_state_must_change: pre != post\n       
- inv_authenticated_channel_required: some c: op.channel | c.authenticated = True\n    end note\n}\n\npackage 
"Infrastructure — Ports" {\n    class Patient_Data_API\n    class Live_Dashboard_Interface\n}\n\n\' Inheritance 
relationships\nTriage_Nurses --|> Actor\nPhysicians --|> Actor\nHospital_Management --|> Actor\nIT_Team --|> 
Actor\n\nPre1 --|> State\nPre2 --|> State\nPre3 --|> State\nPost1 --|> State\nPost2 --|> State\n\nPatient_Data_API
--|> Interface\nLive_Dashboard_Interface --|> Interface\n\n\' Association relationships\nREQ_DASH_01 "1" --> "1" 
Actor : initiator\nREQ_DASH_01 "1" --> "1..*" Resource : target\nREQ_DASH_01 "1" --> "1..*" Interface : 
channel\nREQ_DASH_01 "1" --> "1" Permission : grant\nREQ_DASH_01 "1" --> "1" State : pre\nREQ_DASH_01 "1" --> "1" 
State : post\n\nResource "1" --> "1" Actor : owner\nResource "1" --> "0..*" Actor : accessible\n\n@enduml', 
'sequence_diagram': '@startuml\ntitle Live Dashboard Sequence Diagrams\n\n\' Participants grouped by layers\nbox 
"Controller" #LightBlue\nparticipant DashboardController\nend box\n\nbox "Application" #LightGreen\nparticipant 
DashboardService\nend box\n\nbox "Domain" #LightYellow\nparticipant "REQ_DASH_01" as REQ\nparticipant "State" as 
State\nparticipant "Pre1" as Pre1\nparticipant "Pre2" as Pre2\nparticipant "Pre3" as Pre3\nparticipant "Post1" as 
Post1\nparticipant "Post2" as Post2\nparticipant "Actor" as Actor\nparticipant "Resource" as Resource\nparticipant
"Interface" as Interface\nparticipant "Permission" as Permission\nend box\n\nbox "Infrastructure" 
#LightCoral\nparticipant "AuthService" as Auth\nparticipant "EncryptionService" as Enc\nparticipant "Database" as 
DB\nend box\n\nbox "External" #LightGray\nparticipant "Triage_Nurses" as Nurse\nparticipant "Physicians" as 
Doc\nparticipant "Hospital_Management" as Mgmt\nparticipant "IT_Team" as IT\nparticipant "PatientDataAPI" as 
API\nparticipant "LiveDashboardUI" as UI\nend box\n\n\' =============================================\n== Main 
Flow - View Live Dashboard ==\n\' =============================================\n\nNurse -> DashboardController : 
GET /dashboard (200 OK)\nactivate DashboardController\n\nDashboardController -> DashboardService : 
executeOperation(initiator: Actor, target: Resource, channel: Interface, grant: Permission) : 
REQ_DASH_01\nactivate DashboardService\n\nDashboardService -> REQ : create(initiator, target, channel, grant) : 
REQ_DASH_01\nactivate REQ\nreturn\n\n\' Check preconditions\nDashboardService -> Pre1 : isEnabled() : 
Bool\nactivate Pre1\nreturn True\n\nDashboardService -> Pre2 : isTriaged() : Bool\nactivate Pre2\nreturn 
True\n\nDashboardService -> Pre3 : isCalculated() : Bool\nactivate Pre3\nreturn True\n\n\' Check permissions and 
access\nDashboardService -> Auth : checkPermission(initiator: Actor, grant: Permission) : Bool\nactivate 
Auth\nreturn True\n\nDashboardService -> Resource : isAccessible(initiator: Actor) : Bool\nactivate 
Resource\nreturn True\n\n\' Check channel security\nDashboardService -> Interface : isAuthenticated() : 
Bool\nactivate Interface\nreturn True\n\nDashboardService -> Enc : isEncrypted(channel: Interface) : 
Bool\nactivate Enc\nreturn True\n\n\' Transition to post-state\nDashboardService -> REQ : 
transitionToPostState()\nactivate REQ\nREQ -> REQ : setPostState(Post1)\nnote right: State change: pre != 
post\nREQ -> REQ : setPostState(Post2)\ndeactivate REQ\n\n\' Update dashboard via UI\nDashboardService -> UI : 
updateDashboard(urgency: List, waitTimes: List) [TLS][authenticated]\nactivate UI\nUI -> UI : displayUrgency()\nUI
-> UI : displayWaitTimes()\ndeactivate UI\n\n\' Loop every 5 seconds\nloop every 5 seconds\n  DashboardService -> 
API : fetchPatientData() [TLS][authenticated]\n  activate API\n  API --> DashboardService : patientData\n  
deactivate API\n  DashboardService -> UI : refreshDashboard(data)\n  activate UI\n  deactivate 
UI\nend\n\ndeactivate DashboardService\ndeactivate DashboardController\n\n\' Error paths\nalt Permission denied or
not accessible\n  DashboardService -> DashboardController : return 403 Forbidden\n  note right: initiator lacks 
Read permission or not in accessible set\nelse Channel not authenticated or encrypted\n  DashboardService -> 
DashboardController : return 401 Unauthorized\n  note right: channel must be authenticated and encrypted\nelse 
Preconditions not met\n  DashboardService -> DashboardController : return 412 Precondition Failed\n  note right: 
Pre1, Pre2, Pre3 must be satisfied\nend\n\n\' =============================================\n== Flow tc_dash_01 - 
Patient Status Change Triggers Dashboard Update ==\n\' =============================================\n\nDoc -> API
: POST /patient/status (changeStatus) [TLS][authenticated]\nactivate API\nAPI -> DB : 
updatePatientStatus(patientId, newUrgency)\nactivate DB\nDB --> API : success\ndeactivate DB\nAPI --> Doc : 200 
OK\ndeactivate API\n\nAPI -> DashboardService : notifyStatusChange(patientId)\nactivate 
DashboardService\nDashboardService -> REQ : create(initiator, target, channel, grant)\nactivate REQ\nREQ -> REQ : 
setPreState(Pre1)\nREQ -> REQ : setPostState(Post1)\nREQ -> REQ : setPostState(Post2)\ndeactivate 
REQ\nDashboardService -> UI : updateDashboard(urgency, waitTimes) [TLS][authenticated]\nactivate UI\nUI -> UI : 
refreshDisplay()\ndeactivate UI\ndeactivate DashboardService\n\n\' 
=============================================\n== Flow tc_dash_02 - High Load (150 patients) ==\n\' 
=============================================\n\nNurse -> API : GET /patients/batch?count=150 
[TLS][authenticated]\nactivate API\nAPI -> DB : queryPatients(limit=150)\nactivate DB\nDB --> API : 
patientList\ndeactivate DB\nAPI --> Nurse : 200 OK (150 patients)\ndeactivate API\n\nAPI -> DashboardService : 
processHighLoad(patientList)\nactivate DashboardService\nDashboardService -> REQ : create(initiator, target, 
channel, grant)\nactivate REQ\nREQ -> REQ : setPreState(Pre2)\nREQ -> REQ : setPostState(Post1)\nREQ -> REQ : 
setPostState(Post2)\ndeactivate REQ\nDashboardService -> UI : updateDashboard(urgency, waitTimes) 
[TLS][authenticated]\nactivate UI\nUI -> UI : displayBatch()\ndeactivate UI\ndeactivate 
