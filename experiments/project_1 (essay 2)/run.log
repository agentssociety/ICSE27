}\n}\n\npackage "Exceptions" {\n    class EmptyQueueException <<exception>> {\n        - message: String\n    
}\n\n    class AuthenticationException <<exception>> {\n        - message: String\n    }\n\n    class 
AuthorizationException <<exception>> {\n        - message: String\n    }\n}\n\nPatientQueueController --> 
PatientQueueService : uses\nPatientQueueService --> PatientQueueAPI : dependency\nPatientQueueService --> 
AuthenticationAuthorizationService : dependency\nPatientQueueService --> PatientQueue : uses\nPatientQueueService 
--> PatientQueueResource : uses\nPatientQueueService ..> EmptyQueueException : throws\nPatientQueueService ..> 
AuthenticationException : throws\nPatientQueueService ..> AuthorizationException : throws\n\n@enduml', 
'sequence_diagram': '@startuml\n!theme plain\n\nbox "Controller Layer" #LightBlue\n  participant 
"PatientQueueController" as CONTROLLER\nend box\n\nbox "Application Layer" #LightGreen\n  participant 
"PatientQueueService" as SERVICE\n  participant "AuthService" as AUTH\nend box\n\nbox "Domain Layer" 
#LightYellow\n  participant "PatientQueue" as QUEUE\n  participant "Patient" as PATIENT\n  participant "Physician"
as PHYSICIAN\n  participant "PatientQueueResource" as RESOURCE\nend box\n\nbox "Infrastructure Layer" 
#LightCoral\n  participant "PatientQueueRepository" as REPO\nend box\n\nbox "External Systems" #LightGray\n  
participant "Authentication and Authorization Service" as EXTAUTH\n  participant "Patient Queue API" as 
EXTERNAL_API\nend box\n\n== Flow: Physician Takes Next Patient ==\n\nCONTROLLER -> CONTROLLER : 
authenticateRequest(headers: HttpHeaders) : AuthToken\nnote right: Extract JWT from Authorization 
header\n\nCONTROLLER -> AUTH : verifyToken(token: AuthToken) : AuthResult\nAUTH -> EXTAUTH : [TLS] 
verifyIdentity(token: AuthToken) : IdentityResponse\nEXTAUTH --> AUTH : identityResponse: IdentityResponse\nAUTH 
-> AUTH : extractRole(identityResponse: IdentityResponse) : Role\nAUTH -> AUTH : 
extractPermissions(identityResponse: IdentityResponse) : Set<Permission>\n\nalt Authentication or Authorization 
Fails\n    AUTH --> CONTROLLER : authResult: AuthResult{success: false, error: "Invalid token"}\n    CONTROLLER 
--> CONTROLLER : return 401 Unauthorized\n    note right: Error response: {"error": "Authentication failed"}\n    
== Flow: Authentication Failure ==\n    CONTROLLER --> CONTROLLER : return 401 Unauthorized\n    note right: 
Post-state: No state change\nelse Authentication Succeeds\n    AUTH --> CONTROLLER : authResult: 
AuthResult{success: true, role: Role.PHYSICIAN, permissions: [READ, WRITE, EXECUTE, ADMIN]}\n    \n    CONTROLLER 
-> SERVICE : getNextPatient(authResult: AuthResult) : PatientResponse\n    \n    SERVICE -> SERVICE : 
checkPermission(authResult: AuthResult, requiredPermission: Permission.WRITE) : boolean\n    \n    alt 
Insufficient Permissions\n        SERVICE --> CONTROLLER : error: "Insufficient permissions"\n        CONTROLLER 
--> CONTROLLER : return 403 Forbidden\n        note right: Post-state: No state change\n    else Permissions 
Valid\n        SERVICE -> QUEUE : getTopPatient() : Patient\n        QUEUE -> QUEUE : verifyQueueSorted()\n       
\n        alt Queue is Empty\n            QUEUE --> SERVICE : null\n            SERVICE --> CONTROLLER : response:
PatientResponse{patient: null, message: "Queue is empty"}\n            CONTROLLER --> CONTROLLER : return 200 OK 
with empty queue message\n            note right: Post-state: PostEmpty - Queue is empty, no patient retrieved\n  
== Flow: Empty Queue ==\n            CONTROLLER --> CONTROLLER : return 200 OK\n            note right: Response: 
{"message": "No patients in queue"}\n        else Queue Has Patients\n            QUEUE --> SERVICE : patient: 
Patient\n            note right: Patient has urgency level determining position\n            \n            SERVICE
-> REPO : removePatient(patient: Patient) : boolean\n            REPO -> QUEUE : remove(patient: Patient) : void\n
QUEUE -> QUEUE : reSortQueue()\n            note right: Invariant: queue sorted by urgency at all times\n         
QUEUE --> REPO : void\n            REPO --> SERVICE : success: true\n            \n            SERVICE -> PATIENT 
: getDetails() : PatientDetails\n            PATIENT --> SERVICE : details: PatientDetails\n            \n        
SERVICE --> CONTROLLER : response: PatientResponse{patient: details, message: "Success"}\n            CONTROLLER 
--> CONTROLLER : return 200 OK with patient details\n            note right: Post-state: Post1 - Patient removed 
from queue\\nPost2 - Physician receives patient details\n        end\n    end\nend\n\n== Flow: Concurrent Addition
While Retrieving ==\n\nCONTROLLER -> SERVICE : getNextPatient(authResult: AuthResult) : PatientResponse\nSERVICE 
-> QUEUE : getTopPatient() : Patient\nnote right #FFB: Concurrent addPatient() may occur here\nQUEUE -> QUEUE : 
lockQueue()\nnote right: Acquire write lock to ensure consistency\nQUEUE -> QUEUE : getTopPatient() : 
Patient\nQUEUE -> QUEUE : unlockQueue()\nQUEUE --> SERVICE : patient: Patient\nnote right: Returns top of updated 
queue after concurrent additions\n\n== Flow: Nurse Views Queue (Read Only) ==\n\nCONTROLLER -> AUTH : 
verifyToken(token: AuthToken) : AuthResult\nAUTH -> EXTAUTH : [TLS] verifyIdentity(token: AuthToken) : 
IdentityResponse\nEXTAUTH --> AUTH : identityResponse: IdentityResponse\nAUTH --> CONTROLLER : authResult: 
AuthResult{role: Role.NURSE, permissions: [READ]}\n\nCONTROLLER -> SERVICE : viewQueue(authResult: AuthResult) : 
QueueViewResponse\nSERVICE -> SERVICE : checkPermission(authResult: AuthResult, requiredPermission: 
Permission.READ) : boolean\n\nalt Insufficient Permissions\n    SERVICE --> CONTROLLER : error: "Insufficient 
permissions"\n    CONTROLLER --> CONTROLLER : return 403 Forbidden\nelse Permissions Valid\n    SERVICE -> QUEUE :
getSortedPatients() : List<Patient>\n    QUEUE --> SERVICE : patients: List<Patient>\n    SERVICE --> CONTROLLER :
response: QueueViewResponse{patients: patients}\n    CONTROLLER --> CONTROLLER : return 200 OK with queue 
view\nend\n\n== Flow: Administrative Staff Views Queue ==\n\nCONTROLLER -> AUTH : verifyToken(token: AuthToken) : 
AuthResult\nAUTH -> EXTAUTH : [TLS] verifyIdentity(token: AuthToken) : IdentityResponse\nEXTAUTH --> AUTH : 
identityResponse: IdentityResponse\nAUTH --> CONTROLLER : authResult: AuthResult{role: Role.ADMIN_STAFF, 
permissions: [READ]}\n\nCONTROLLER -> SERVICE : viewQueue(authResult: AuthResult) : QueueViewResponse\nSERVICE -> 
RESOURCE : checkOwnership(authResult: AuthResult) : boolean\nnote right: AdministrativeStaff is owner of 
PatientQueueResource\n\nalt Not Owner\n    SERVICE --> CONTROLLER : error: "Access denied"\n    CONTROLLER --> 
CONTROLLER : return 403 Forbidden\nelse Is Owner\n    SERVICE -> QUEUE : getSortedPatients() : List<Patient>\n    
QUEUE --> SERVICE : patients: List<Patient>\n    SERVICE --> CONTROLLER : response: QueueViewResponse{patients: 
patients}\n    CONTROLLER --> CONTROLLER : return 200 OK with queue view\nend\n\n@enduml', 'domain_model_context':
