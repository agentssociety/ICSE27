  old = """@dataclass                                                                                             
  class Actor:                                                                                                    
      mayPerform: set[Permission]                                                                                 
                                                                                                                  
      def checkPermission(self, actorId: str, requiredPermission: Permission) -> bool:                            
          return requiredPermission in self.mayPerform"""                                                         
                                                                                                                  
  new = """@dataclass(eq=True, frozen=True)                                                                       
  class Actor:                                                                                                    
      mayPerform: set[Permission]                                                                                 
                                                                                                                  
      def __hash__(self) -> int:                                                                                  
          return id(self)                                                                                         
                                                                                                                  
      def checkPermission(self, actorId: str, requiredPermission: Permission) -> bool:                            
          return requiredPermission in self.mayPerform"""                                                         
                                                                                                                  
