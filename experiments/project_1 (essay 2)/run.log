data;\n}\n\nexport async function createPatient(patient: PatientCreate): Promise<PatientResponse> {\n  const { 
data } = await api.post<PatientResponse>('/v1/patients', patient);\n  return data;\n}\n\nexport async function 
updatePatient(id: number, patient: PatientUpdate): Promise<PatientResponse> {\n  const { data } = await 
api.put<PatientResponse>(`/v1/patients/${id}`, patient);\n  return data;\n}\n\nexport async function 
deletePatient(id: number): Promise<void> {\n  await api.delete(`/v1/patients/${id}`);\n}\n\nexport async function 
