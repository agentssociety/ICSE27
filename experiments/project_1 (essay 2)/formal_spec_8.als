module REQ_TRIAGE_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-TRIAGE-01
 * Title       : Assign Urgency Level to Patient
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Triage_Nurses, Hospital_Management, Patient_Care_Team extends Actor {}
-- Triage_Nurses: represents stakeholder 'Triage Nurses'
-- Hospital_Management: represents stakeholder 'Hospital Management'
-- Patient_Care_Team: represents stakeholder 'Patient Care Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Patient_Database, Queue_Management_API extends Interface {}

fact interface_properties {
    Patient_Database.kind = Database  -- The requirement interacts with the database to retrieve patient information, store urgency levels, and update queue positions.
    Queue_Management_API.kind = API  -- The requirement uses an API to communicate with the queue management system for updating patient priorities based on assigned urgency levels.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The system updates the patient's urgency level in the database
-- Post2: system reaches state where The system recalculates and updates the patient's position in the queue based on the new urgency level


----------------------------------------------------------------------
-- Core operation: REQ_TRIAGE_01
----------------------------------------------------------------------

sig REQ_TRIAGE_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_TRIAGE_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_TRIAGE_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_TRIAGE_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_TRIAGE_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_TRIAGE_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_TRIAGE_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_TRIAGE_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_TRIAGE_01 {
    some op: REQ_TRIAGE_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_TRIAGE_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_TRIAGE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_TRIAGE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_TRIAGE_01_well_formed {
    all op: REQ_TRIAGE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_TRIAGE_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post-State Reachability Verification for REQ_TRIAGE_01 --

-- Predicate for Post1 (update urgency in database)
pred ps_reach_Post1 {
    some op: REQ_TRIAGE_01 |
        op.post = Post1 &&
        op.initiator = Triage_Nurses &&
        Write in op.initiator.mayPerform &&
        Write in op.grant &&
        op.pre = PreIdle &&
        (some r: Resource | r in op.target && r.owner in (Triage_Nurses + Patient_Care_Team)) &&
        (some i: Interface | i in op.channel && i.encrypted = True && i.authenticated = True)
}

-- Predicate for Post2 (recalculate queue position)
pred ps_reach_Post2 {
    some op: REQ_TRIAGE_01 |
        op.post = Post2 &&
        op.initiator = Triage_Nurses &&
        Write in op.initiator.mayPerform &&
        Write in op.grant &&
        op.pre = Post1 &&   -- assumes urgency update occurred first
        (some r: Resource | r in op.target && r.owner in (Triage_Nurses + Patient_Care_Team)) &&
        (some i: Interface | i in op.channel && i.kind = API)   -- API channel for queue recalculation
}

-- Run commands for reachability predicates
run ps_reach_Post1 for 5
run ps_reach_Post2 for 5

-- Semantic validity assertion for Post1
assert ps_valid_Post1 {
    all op: REQ_TRIAGE_01 |
        (op.post = Post1) =>
            (op.initiator = Triage_Nurses &&
             Write in op.initiator.mayPerform &&
             Write in op.grant &&
             op.pre = PreIdle &&
             (some r: Resource | r in op.target && r.owner in (Triage_Nurses + Patient_Care_Team)) &&
             (some i: Interface | i in op.channel && i.encrypted = True && i.authenticated = True))
}

-- Semantic validity assertion for Post2
assert ps_valid_Post2 {
    all op: REQ_TRIAGE_01 |
        (op.post = Post2) =>
            (op.initiator = Triage_Nurses &&
             Write in op.initiator.mayPerform &&
             Write in op.grant &&
             op.pre = Post1 &&
             (some r: Resource | r in op.target && r.owner in (Triage_Nurses + Patient_Care_Team)) &&
             (some i: Interface | i in op.channel && i.kind = API))
}

-- Check commands for semantic assertions
check ps_valid_Post1 for 5
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES ?????????????????????????????????????????????????
-- Criterion 1: Given a patient has been registered with symptoms
-- This maps to: a triage nurse (initiator) with Write permission performs an operation
-- on a resource (patient data) after registration, using an authenticated channel.
pred ac_reach_1 {
    some op: REQ_TRIAGE_01 |
        // Triage nurse is the initiator
        Triage_Nurses in op.initiator &&
        // Nurse has Write permission (to register symptoms)
        Write in op.initiator.mayPerform &&
        // Target is a patient-related resource
        some t: op.target | t in Patient_Database ||
        // Channel is authenticated (secure communication)
        (some c: op.channel | c.authenticated = True) &&
        // Pre-state is PreIdle (initial state before registration)
        op.pre = PreIdle
}
run ac_reach_1 for 5

-- Criterion 2: When the triage nurse assigns an urgency level from 1 to 5
-- This maps to: a triage nurse performs an update operation on a queue resource,
-- using an authenticated channel, resulting in a state change.
pred ac_reach_2 {
    some op: REQ_TRIAGE_01 |
        // Triage nurse is the initiator
        Triage_Nurses in op.initiator &&
        // Nurse has Write permission (to assign urgency)
        Write in op.initiator.mayPerform &&
        // Target is the queue management API || database
        (some t: op.target | t in Queue_Management_API) &&
        // Channel is authenticated && encrypted
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        // State changes from PreIdle to Post1 (urgency assigned)
        op.pre = PreIdle &&
        op.post = Post1
}
run ac_reach_2 for 5

-- Criterion 3: Then the patient's priority in the queue is updated according to the assigned level
-- This maps to: the operation completes with the queue resource updated,
-- reaching a final state where priority is set.
pred ac_reach_3 {
    some op: REQ_TRIAGE_01 |
        // Triage nurse is the initiator
        Triage_Nurses in op.initiator &&
        // Nurse has Write permission
        Write in op.initiator.mayPerform &&
        // Target is the queue management API
        (some t: op.target | t in Queue_Management_API) &&
        // Channel is authenticated
        (some c: op.channel | c.authenticated = True) &&
        // State transitions from Post1 (urgency assigned) to Post2 (priority updated)
        op.pre = Post1 &&
        op.post = Post2 &&
        // The initiator is authorized for the resource (queue)
        op.target.accessible = op.initiator
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- ?? EDGE CASE 1: Urgency level outside 1?5 ??????????????????????????
-- If any operation assigns a "permission"/access that would correspond to
-- an urgency level outside the valid range, the operation must be invalid
-- (i.e., pre && post states must be identical).
assert ec_safe_1 {
    all op: REQ_TRIAGE_01 |
        -- Assume Read, Write, Execute, Admin represent urgency levels 1?4;
        -- if the grant is ! one of these 4, the operation must be a no?op.
        (op.grant ! in Read+Write+Execute+Admin) => (op.post = op.pre)
}
check ec_safe_1 for 5

-- ?? EDGE CASE 2: Multiple simultaneous urgency assignments ??????????
-- No two distinct operations can target the same resource unless their
-- grants are compatible (identical) && they share the same initiator.
-- This prevents conflicting concurrent assignments.
assert ec_safe_2 {
    all disj op1, op2: REQ_TRIAGE_01 |
        some (op1.target & op2.target) =>
            (op1.grant = op2.grant && op1.initiator = op2.initiator)
}
check ec_safe_2 for 5

-- ?? EDGE CASE 3: Queue temporarily unavailable ??????????????????????
-- If the queue (Database) is ! accessible to the initiator, the
-- operation must be a no?op (pre equals post).  The queue is represented
-- by the Patient_Database resource; its owner is Triage_Nurses.
assert ec_safe_3 {
    all op: REQ_TRIAGE_01 |
        -- If the initiator is ! in the set of actors that may access
        -- Patient_Database, then nothing changes.
        (op.initiator ! in Patient_Database.accessible) =>
            (op.post = op.pre)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_TRIAGE_01_holds {
    some op: REQ_TRIAGE_01 |
        op.initiator = Triage_Nurses &&
        op.grant = Write &&
        Patient_Database in op.target &&
        some c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.post = Post1
}

run tc_TRIAGE_01_holds for 5

assert tc_TRIAGE_01_contract {
    all op: REQ_TRIAGE_01 |
        (op.initiator = Triage_Nurses &&
         op.grant = Write &&
         Patient_Database in op.target &&
         some c: op.channel | c.encrypted = True && c.authenticated = True) =>
        op.post = Post1
}

check tc_TRIAGE_01_contract for 5

pred tc_TRIAGE_02_holds {
    some op: REQ_TRIAGE_01 |
        op.initiator = Triage_Nurses &&
        op.grant = Write &&
        Patient_Database in op.target &&
        some c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.post = Post2
}

run tc_TRIAGE_02_holds for 5

assert tc_TRIAGE_02_contract {
    all op: REQ_TRIAGE_01 |
        (op.initiator = Triage_Nurses &&
         op.grant = Write &&
         Patient_Database in op.target &&
         some c: op.channel | c.encrypted = True && c.authenticated = True) =>
        op.post = Post2
}

check tc_TRIAGE_02_contract for 5

pred tc_TRIAGE_03_holds {
    some disj op1, op2: REQ_TRIAGE_01 |
        op1.initiator = Triage_Nurses &&
        op1.grant = Write &&
        Patient_Database in op1.target &&
        op1.post = Post1 &&
        op2.initiator = Triage_Nurses &&
        op2.grant = Write &&
        Queue_Management_API in op2.target &&
        op2.post = Post1 &&
        op1.pre = op2.pre &&
        op1.post = op2.post
}

run tc_TRIAGE_03_holds for 5

assert tc_TRIAGE_03_contract {
    all op1, op2: REQ_TRIAGE_01 |
        (op1.initiator = Triage_Nurses &&
         op1.grant = Write &&
         Patient_Database in op1.target &&
         op2.initiator = Triage_Nurses &&
         op2.grant = Write &&
         Queue_Management_API in op2.target &&
         op1.pre = op2.pre) =>
        op1.post = op2.post
}

check tc_TRIAGE_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

assert nfr_assert_performance {
    -- PROXY: limiting channels && targets per operation reduces latency
    -- NFR: respond within 2 seconds to urgency level assignment
    all op: REQ_TRIAGE_01 | #op.channel <= 2 && #op.target <= 1
}
check nfr_assert_performance for 5

assert nfr_assert_availability {
    -- PROXY: requiring at least 2 channels per operation ensures redundancy for 99.9% uptime
    -- NFR: system available 99.9% of the time
    all op: REQ_TRIAGE_01 | #op.channel >= 2
}
check nfr_assert_availability for 5

assert nfr_assert_scalability {
    -- PROXY: ensuring no target resource is shared between operations prevents contention, allowing simultaneous handling of many patients
    -- NFR: handle up to 100 patients simultaneously without degradation
    all disj op1, op2: REQ_TRIAGE_01 | no (op1.target & op2.target)
}
check nfr_assert_scalability for 5

assert nfr_assert_usability {
    -- PROXY: all interfaces share the same kind, ensuring consistent interaction && clear error messages
    -- NFR: error messages should be clear && actionable
    all i, j: Interface | i.kind = j.kind
}
check nfr_assert_usability for 5

