module REQ_MED_01

// Alloy 6 ? Structural & Behavioral Model for Formal Verification
// Requirement : REQ-MED-01
// Title       : Take Next Patient from Sorted Queue
// Type        : Functional
// Priority    : High
// Generated by: deepseek/deepseek-v4-flash


----------------------------------------------------------------------
// Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

// Partial order: a permission subsumes another if it grants strictly more.
// Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
// Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Physicians, Nurses, Administrative_Staff extends Actor {}
// Physicians: represents stakeholder 'Physicians'
// Nurses: represents stakeholder 'Nurses'
// Administrative_Staff: represents stakeholder 'Administrative Staff'

fact permission_assignment {
    Physicians.mayPerform = Read + Write + Execute + Admin
    Nurses.mayPerform = Read
    Administrative_Staff.mayPerform = Read
}

----------------------------------------------------------------------
// Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

// Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

one sig PatientQueueResource extends Resource {}

fact patient_queue_access {
    PatientQueueResource.owner = Administrative_Staff
    PatientQueueResource.accessible = Physicians + Nurses + Administrative_Staff
}

----------------------------------------------------------------------
// Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig External_System, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      // transport-layer security
    authenticated : one Bool       // requires caller identity
}

one sig Patient_Queue_API, Authentication_and_Authorization_Service extends Interface {}

fact interface_properties {
    Patient_Queue_API.kind = API  // The system interacts with the Patient Queue API to retrieve the top patient from the queue.
    Authentication_and_Authorization_Service.kind = External_System  // The system uses the Authentication and Authorization Service to ensure that only authorized physicians can access the queue system.
}


----------------------------------------------------------------------
// System states and transitions
----------------------------------------------------------------------

abstract sig State {}

// Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
// Pre1: system is in state where The patient queue is sorted by urgency.
// Pre2: system is in state where A physician has access to the queue system.

// Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, PostEmpty extends State {}
// Post1: system reaches state where The patient at the top of the queue is removed from the queue.
// Post2: system reaches state where The physician receives the details of the next patient for attendance.
// PostEmpty: system reaches state where queue is empty and no patient retrieved.


----------------------------------------------------------------------
// Core operation: REQ_MED_01
----------------------------------------------------------------------

sig REQ_MED_01 {
    initiator  : one  Actor,          // who triggers the operation
    target     : some Resource,        // what data/objects are affected
    channel    : some Interface,       // how the operation is communicated
    grant      : one  Permission,      // what permission is exercised
    pre        : one  State,           // precondition that must hold
    post       : one  State            // postcondition that is established
}


----------------------------------------------------------------------
// Structural well-formedness invariants
----------------------------------------------------------------------

// INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_MED_01 | some op.channel
}

// INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_MED_01 | some op.target
}

// INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_MED_01 | op.grant in op.initiator.mayPerform
}

// INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_MED_01 | op.initiator in op.target.accessible
}

// INV-5: The operation must produce a state change.
// pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_MED_01 | op.pre != op.post
}

// INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_MED_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
// Post-state reachability constraints
----------------------------------------------------------------------

// Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_MED_01 | op.post in Post1 + Post2 + PostEmpty
}



----------------------------------------------------------------------
// Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_MED_01 {
    some op: REQ_MED_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_MED_01 for 5


----------------------------------------------------------------------
// Core safety assertions (model-checkable)
----------------------------------------------------------------------

// SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_MED_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

// SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_MED_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

// SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_MED_01_well_formed {
    all op: REQ_MED_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_MED_01_well_formed for 5


----------------------------------------------------------------------
// Post-state reachability verification
----------------------------------------------------------------------

// Predicate: Post1 is reachable (patient removed from queue)
pred ps_reach_Post1 {
    some op: REQ_MED_01 |
        op.post = Post1 &&
        op.initiator in Physicians &&
        PatientQueueResource in op.target &&
        Write in op.grant &&
        some ch: op.channel | ch.authenticated = True &&
        op.pre = Pre1
}
run ps_reach_Post1 for 5

// Assertion: whenever Post1, it represents removal from queue
assert ps_valid_Post1 {
    all op: REQ_MED_01 |
        op.post = Post1 =>
            (op.initiator in Physicians &&
             PatientQueueResource in op.target &&
             Write in op.grant &&
             op.pre = Pre1)
}
check ps_valid_Post1 for 5

// Predicate: Post2 is reachable (physician receives next patient details)
pred ps_reach_Post2 {
    some op: REQ_MED_01 |
        op.post = Post2 &&
        op.initiator in Physicians &&
        PatientQueueResource in op.target &&
        Read in op.grant &&
        some ch: op.channel | ch.authenticated = True &&
        op.pre = Pre2
}
run ps_reach_Post2 for 5

// Assertion: whenever Post2, it represents physician receiving details
assert ps_valid_Post2 {
    all op: REQ_MED_01 |
        op.post = Post2 =>
            (op.initiator in Physicians &&
             PatientQueueResource in op.target &&
             Read in op.grant &&
             op.pre = Pre2)
}
check ps_valid_Post2 for 5

// Predicate: PostEmpty is reachable (empty queue notification)
pred ps_reach_PostEmpty {
    some op: REQ_MED_01 |
        op.post = PostEmpty &&
        op.initiator in Physicians &&
        PatientQueueResource in op.target &&
        Read in op.grant &&
        some ch: op.channel | ch.authenticated = True &&
        op.pre = Pre1  // Using Pre1 to indicate sorted queue but empty
}
run ps_reach_PostEmpty for 5

assert ps_valid_PostEmpty {
    all op: REQ_MED_01 |
        op.post = PostEmpty =>
            (op.initiator in Physicians &&
             PatientQueueResource in op.target &&
             Read in op.grant)
}
check ps_valid_PostEmpty for 5

----------------------------------------------------------------------
// Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_MED_01 |
        op.initiator = Physicians &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        some c: op.channel | c.authenticated = True && c.encrypted = True
}
run ac_reach_1 for 5

----------------------------------------------------------------------
// Edge case safety assertions
----------------------------------------------------------------------

// helper sigs for edge case 1
sig QueueEmptyState in State {}
// QueueResource is now PatientQueueResource; we keep the name for backward compatibility but use the actual sig.

assert ec_safe_1 {
    all op: REQ_MED_01 |
        (op.initiator = Physicians && op.grant = Read && PatientQueueResource in op.target && op.pre in QueueEmptyState) =>
        op.post = PostEmpty
}
check ec_safe_1 for 5

assert ec_safe_2 {
    no disj op1, op2: REQ_MED_01 |
        (op1.grant = Read && op2.grant = Write) && some (op1.target & op2.target)
}
check ec_safe_2 for 5

----------------------------------------------------------------------
// Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

// TC-MED-01: Retrieve next patient from empty queue
pred tc_MED_01_holds {
    some op: REQ_MED_01 |
        op.pre = QueueEmptyState &&
        op.post = PostEmpty &&
        op.grant = Read &&
        PatientQueueResource in op.target &&
        some c: op.channel | c.authenticated = True && c.encrypted = True
}
run tc_MED_01_holds for 5

assert tc_MED_01_contract {
    all op: REQ_MED_01 |
        (op.pre = QueueEmptyState && op.grant = Read && PatientQueueResource in op.target) =>
        op.post = PostEmpty
}
check tc_MED_01_contract for 5

// TC-MED-02: Retrieve next patient when queue has patients
pred tc_MED_02_holds {
    some op: REQ_MED_01 |
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.grant = Write &&
        PatientQueueResource in op.target &&
        some c: op.channel | c.authenticated = True && c.encrypted = True
}
run tc_MED_02_holds for 5

assert tc_MED_02_contract {
    all op: REQ_MED_01 |
        (op.pre = Pre1 && op.grant = Write && PatientQueueResource in op.target) =>
        op.post = Post1
}
check tc_MED_02_contract for 5

----------------------------------------------------------------------
// Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    // PROXY: bounding interface && resource count per operation limits processing time,
    // reflecting the <= 5 second response time NFR
    all op : REQ_MED_01 | #op.channel <= 2 && #op.target <= 3
}

fact nfr_fact_availability {
    // PROXY: every resource must be involved in some operation,
    // ensuring the system remains responsive && available (uptime 99.9%)
    all r : Resource | some op : REQ_MED_01 | r in op.target
}

assert nfr_assert_scalability {
    // PROXY: every actor role can initiate an operation,
    // supporting concurrent users (10,000 patients per day)
    all a : Actor | some op : REQ_MED_01 | op.initiator = a
}
check nfr_assert_scalability for 5

fact nfr_fact_usability {
    // PROXY: limiting the number of authenticated channels per operation
    // reduces complexity, enabling clear error messages && intuitive interface
    all op : REQ_MED_01 | #(op.channel & {i : Interface | i.authenticated = True}) <= 1
}

----------------------------------------------------------------------
// Security properties
----------------------------------------------------------------------

// Security requirements: Authentication && authorization checks are performed to ensure that only authorized personnel can access the queue system.
// Specifies that any operation targeting the PatientQueueResource must use an authenticated channel,
// && the initiator must be a recognized medical role (Physicians, Nurses, Administrative_Staff) holding the required permission.
assert sr_assert_queue_access_control {
  all op: REQ_MED_01 |
    PatientQueueResource in op.target =>
      (op.initiator in (Physicians + Nurses + Administrative_Staff) &&
       op.grant in op.initiator.mayPerform &&
       all c: op.channel | c.authenticated = True)
}
check sr_assert_queue_access_control for 5

// Additional generic property: Every operation must have all channels authenticated (stronger than required by fact).
// This verifies that authentication is consistently applied across all channels used.
assert sr_assert_all_channels_authenticated {
  all op: REQ_MED_01 |
    all c: op.channel | c.authenticated = True
}
check sr_assert_all_channels_authenticated for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed type error: Patient_Queue_API (Interface) used as target, replaced with PatientQueueResource (Resource).
-- Summary 2: Assigned permissions to actors (Physicians: Read+Write+Execute+Admin, others: Read).
-- Summary 3: Corrected grant permissions for queue removal from Execute to Write.
-- Summary 4: Added PostEmpty state for empty queue scenario and adjusted predicates/assertions.
-- Summary 5: Added fact for PatientQueueResource ownership and accessibility.
-- Summary 6: Preserved original structure and module name.
-- Assumption 1: Physicians have full permissions (Read, Write, Execute, Admin) to perform queue operations.
-- Assumption 2: Patient queue is represented by PatientQueueResource, owned by Administrative_Staff, accessible to all medical roles.
-- Assumption 3: Empty queue leads to a distinct post-state (PostEmpty) rather than no operation.
-- Open issue 1: TC-MED-02 (concurrent addition while retrieving) is not modeled; current model assumes atomic single operations.
-- Open issue 2: Non-functional requirements (performance, availability, scalability) are represented by coarse proxies; temporal properties not captured.
-- Open issue 3: Queue ordering and emptiness are modeled via static states; dynamic behavior of queue content is abstracted.


