----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: limiting target resources per operation bounds processing time (performance proxy)
-- NFR: sorting should complete within 10 seconds for a queue of up to 500 patients
fact nfr_fact_performance_sorting {
    all op: REQ_NURS_01 | #op.target <= 500
}

-- Proxy: requiring at least one redundant channel ensures failover capacity (availability proxy)
-- NFR: the system must be available 99.9% of the time
fact nfr_fact_availability_redundancy {
    all op: REQ_NURS_01 | #op.channel >= 2
}

-- Proxy: asserting all actors can be initiators simultaneously ensures capacity headroom (scalability proxy)
-- NFR: the system must support an increase in patient volume by 50% without performance degradation
assert nfr_assert_scalability_capacity {
    all a: Actor | some op: REQ_NURS_01 | op.initiator = a
}
check nfr_assert_scalability_capacity for 5

-- Proxy: limiting authenticated channels per operation reduces cognitive load on users (usability proxy)
-- NFR: error messages should clearly indicate issues with sorting && provide guidance on how to resolve them
fact nfr_fact_usability_error_clarity {
    all op: REQ_NURS_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

