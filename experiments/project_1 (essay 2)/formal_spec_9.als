----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Triage_Nurse_Team, Clinical_Leadership extends Actor {}
-- Triage_Nurse_Team: represents stakeholder 'Triage Nurse Team'
-- Clinical_Leadership: represents stakeholder 'Clinical Leadership'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Patient queue data resource for sorting operations
one sig PatientQueueData extends Resource {}
fact {
    PatientQueueData.owner = Triage_Nurse_Team
    Triage_Nurse_Team in PatientQueueData.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Patient_Queue_Database extends Interface {}

fact interface_properties {
    Patient_Queue_Database.kind = Database  -- The requirement interacts with the database to retrieve and sort patient data.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where the patient queue is sorted according to the specified criteria


----------------------------------------------------------------------
-- Core operation: REQ_NURS_01
----------------------------------------------------------------------

sig REQ_NURS_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_NURS_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_NURS_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_NURS_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_NURS_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_NURS_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_NURS_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_NURS_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_NURS_01 {
    some op: REQ_NURS_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_NURS_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_NURS_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_NURS_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_NURS_01_well_formed {
    all op: REQ_NURS_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_NURS_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post-state reachability verification for Post1: sorted patient queue
pred ps_reach_Post1 {
    some op: REQ_NURS_01 |
        op.post = Post1 &&
        -- The initiator must be part of Triage_Nurse_Team (nurses sort queues)
        op.initiator in Triage_Nurse_Team &&
        -- Must involve the Patient_Queue_Database resource
        PatientQueueData in op.target &&
        -- Requires Write permission to modify queue order
        Write in op.grant &&
        -- Must use an authenticated channel (clinical operations require authentication)
        some c: op.channel | c.authenticated = True &&
        -- State must change from pre to post
        op.pre != op.post
}

assert ps_valid_Post1 {
    all op: REQ_NURS_01 |
        (op.post = Post1) =>
            -- The operation must modify the patient queue database
            (PatientQueueData in op.target &&
             -- Initiator must be a triage nurse
             op.initiator in Triage_Nurse_Team &&
             -- Write permission required to sort/update queue
             Write in op.grant &&
             -- State transition must occur
             op.pre != op.post)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: patients are ordered by urgency level ascending (lowest number first)
pred ac_reach_1 {
    some op: REQ_NURS_01 |
        -- The operation must involve the Patient_Queue_Database
        PatientQueueData in op.target &&
        -- The initiator must be authorized to modify the queue
        Write in op.initiator.mayPerform &&
        -- The operation must use an authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        -- The state must change to Post1 (indicating queue was updated)
        op.post = Post1 &&
        -- The pre-state must be PreIdle (system was idle before)
        op.pre = PreIdle
}

run ac_reach_1 for 5

-- Criterion 2: for patients with the same urgency level, they are ordered by arrival time ascending (earliest first)
pred ac_reach_2 {
    some op: REQ_NURS_01 |
        -- The operation must involve the Patient_Queue_Database
        PatientQueueData in op.target &&
        -- The initiator must be authorized to modify the queue
        Write in op.initiator.mayPerform &&
        -- The operation must use an authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        -- The state must change to Post1 (indicating queue was updated)
        op.post = Post1 &&
        -- The pre-state must be PreIdle (system was idle before)
        op.pre = PreIdle &&
        -- The initiator must be from Triage_Nurse_Team (who manages patient queue)
        op.initiator in Triage_Nurse_Team
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: No patients in the queue - operation must handle empty queues
assert ec_safe_1 {
    all op: REQ_NURS_01 |
        -- if the target resource is Patient_Queue_Database && there are no patients
        -- (represented by the pre-state being PreIdle), the operation can still complete
        (PatientQueueData in op.target && op.pre = PreIdle) =>
        (op.post = Post1 || op.post = PreIdle)
}
check ec_safe_1 for 5

-- Edge case 2: Null/undefined urgency - removed due to semantic mismatch. Handling is not modeled.
-- Removed assertion ec_safe_2 and related check.

-- Edge case 3: High patient volumes - system capacity constraints
one sig HighVolume extends Bool {} -- marker for high volume scenarios

assert ec_safe_3 {
    all op: REQ_NURS_01 |
        -- under high volume, authenticated channels must still be used
        (#op.channel > 4) => 
        (all c: op.channel | c.authenticated = True)
}
check ec_safe_3 for 5

-- Edge case 4: Duplicate urgency/arrival - fairness constraint
one sig DuplicateRequirement extends Resource {} -- represents duplicate scenario

assert ec_safe_4 {
    all op: REQ_NURS_01 |
        -- when dealing with duplicate scenarios, resource ownership must be respected
        (DuplicateRequirement in op.target) =>
        (op.initiator in op.target.accessible)
}
check ec_safe_4 for 5

