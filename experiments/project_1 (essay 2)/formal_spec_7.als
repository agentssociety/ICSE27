module REQ_TRIAGE_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-TRIAGE-01
 * Title       : Register New Patient with Symptoms
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


// ----------------------------------------------------------------------
// Permission lattice
// ----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

// Partial order: a permission subsumes another if it grants strictly more.
// Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


// ----------------------------------------------------------------------
// Actor / Role hierarchy
// ----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Triage_Nurses, Medical_Staff, System_Administrators extends Actor {}
// Triage_Nurses: represents stakeholder 'Triage Nurses'
// Medical_Staff: represents stakeholder 'Medical Staff'
// System_Administrators: represents stakeholder 'System Administrators'


// ----------------------------------------------------------------------
// Resources (data / objects under operation)
// ----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

// Concrete resources for the triage registration process
sig PatientRecord extends Resource {}
sig SymptomData extends Resource {}
sig QueueEntry extends Resource {}

// Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


// ----------------------------------------------------------------------
// Interfaces (communication channels)
// ----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API, System extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      // transport-layer security
    authenticated : one Bool       // requires caller identity
}

one sig Symptom_Validation_API, Patient_Database, Evaluation_Queue_System extends Interface {}

fact interface_properties {
    Symptom_Validation_API.kind = API  // The registration process must validate symptom input using the Symptom Validation API to ensure accuracy and relevance.
    Patient_Database.kind = Database  // The system must store new patient information in the Patient Database, including their symptoms.
    Evaluation_Queue_System.kind = System  // The newly registered patient must be added to the Evaluation Queue using the Evaluation Queue Management System.
}


// ----------------------------------------------------------------------
// System states and transitions
// ----------------------------------------------------------------------

abstract sig State {}

// Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
// Pre1: system is in state where A triage nurse is logged into the system with appropriate permissions.
// Pre2: system is in state where There are available slots in the evaluation queue.

// Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
// Post1: system reaches state where The new patient's symptom information is stored in the system.
// Post2: system reaches state where The new patient is listed as a pending evaluation in the queue.


// ----------------------------------------------------------------------
// Core operation: REQ_TRIAGE_01
// ----------------------------------------------------------------------

sig REQ_TRIAGE_01 {
    initiator  : one  Actor,          // who triggers the operation
    target     : some Resource,        // what data/objects are affected
    channel    : some Interface,       // how the operation is communicated
    grant      : one  Permission,      // what permission is exercised
    pre        : one  State,           // precondition that must hold
    post       : one  State            // postcondition that is established
}


// ----------------------------------------------------------------------
// Structural well-formedness invariants
// ----------------------------------------------------------------------

// INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_TRIAGE_01 | some op.channel
}

// INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_TRIAGE_01 | some op.target
}

// INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_TRIAGE_01 | op.grant in op.initiator.mayPerform
}

// INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_TRIAGE_01 | op.initiator in op.target.accessible
}

// INV-5: The operation must produce a state change.
// pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_TRIAGE_01 | op.pre != op.post
}

// INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_TRIAGE_01 | some c: op.channel | c.authenticated = True
}


// ----------------------------------------------------------------------
// Post-state reachability constraints
// ----------------------------------------------------------------------

// Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_TRIAGE_01 | op.post in Post1 + Post2
}



// ----------------------------------------------------------------------
// Liveness: at least one valid operation exists
// ----------------------------------------------------------------------

pred show_REQ_TRIAGE_01 {
    some op: REQ_TRIAGE_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_TRIAGE_01 for 5


// ----------------------------------------------------------------------
// Core safety assertions (model-checkable)
// ----------------------------------------------------------------------

// SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_TRIAGE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

// SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_TRIAGE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

// SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_TRIAGE_01_well_formed {
    all op: REQ_TRIAGE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_TRIAGE_01_well_formed for 5


// ----------------------------------------------------------------------
// Post-state reachability verification
// ----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_TRIAGE_01 |
        op.post = Post1 &&
        op.initiator = Triage_Nurses &&
        Write in op.initiator.mayPerform &&
        PatientRecord in op.target &&
        SymptomData in op.target &&
        some iface: op.channel | iface.authenticated = True
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_TRIAGE_01 |
        (op.post = Post1) =>
            (PatientRecord in op.target &&
             op.grant = Write &&
             Write in op.initiator.mayPerform)
}
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_TRIAGE_01 |
        op.post = Post2 &&
        op.initiator = Triage_Nurses &&
        Write in op.initiator.mayPerform &&
        QueueEntry in op.target &&
        some iface: op.channel | iface.authenticated = True
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_TRIAGE_01 |
        (op.post = Post2) =>
            (QueueEntry in op.target &&
             op.grant = Write &&
             Write in op.initiator.mayPerform)
}
check ps_valid_Post2 for 5

// ----------------------------------------------------------------------
// Acceptance criterion reachability predicates
// ----------------------------------------------------------------------

// Criterion 1: system displays registration form for new patients
pred ac_reach_1 {
    some op: REQ_TRIAGE_01 |
        // Triage nurses can initiate registration
        op.initiator in Triage_Nurses &&
        // Grant must be Write || Execute for form display
        (Write in op.initiator.mayPerform || Execute in op.initiator.mayPerform) &&
        // Affects the PatientRecord resource (patient registration)
        PatientRecord in op.target &&
        // Uses an authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        // State transitions to some defined post-state
        op.post in Post1 + Post2
}

run ac_reach_1 for 5

// Criterion 2: system accepts patient symptom input during registration
pred ac_reach_2 {
    some op: REQ_TRIAGE_01 |
        // Triage nurses perform this action
        op.initiator in Triage_Nurses &&
        // Write permission required to input symptom data
        Write in op.initiator.mayPerform &&
        // Accesses SymptomData resource
        SymptomData in op.target &&
        // Uses encrypted channel for sensitive medical data
        (some c: op.channel | c.encrypted = True) &&
        // State transitions to Post2 (symptom input completed)
        op.post = Post2 &&
        // Grant is Write permission
        op.grant = Write
}

run ac_reach_2 for 5

// Criterion 3: newly registered patient added to evaluation queue
pred ac_reach_3 {
    some op: REQ_TRIAGE_01 |
        // Triage nurses manage queue addition
        op.initiator in Triage_Nurses &&
        // Write permission for queue management
        Write in op.initiator.mayPerform &&
        // Must affect both PatientRecord (patient record) && QueueEntry
        PatientRecord in op.target &&
        QueueEntry in op.target &&
        // Uses authenticated && encrypted channel
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        // Grant is Write for queue operation
        op.grant = Write &&
        // State transitions to Post2 (queue update completed)
        op.post = Post2
}

run ac_reach_3 for 5

// ----------------------------------------------------------------------
// Edge case safety assertions
// ----------------------------------------------------------------------

// Edge case 1: Invalid symptom information must not lead to inconsistent state
// If the initiator does not have permission to validate symptoms (SymptomData access),
// the operation must not change the system state (no erroneous updates)
assert ec_safe_1 {
    all op: REQ_TRIAGE_01 |
        (SymptomData in op.target) && (Read not in op.initiator.mayPerform) =>
            op.post = op.pre
}
check ec_safe_1 for 5

// Edge case 2: No symptoms provided - operation with empty target should be impossible
// Since target is declared as "some Resource", this is structurally prevented,
// but we assert that any operation with only PatientRecord (no SymptomData) must preserve state
assert ec_safe_2 {
    all op: REQ_TRIAGE_01 |
        ( PatientRecord in op.target && SymptomData not in op.target ) => op.post = op.pre
}
check ec_safe_2 for 5

// Edge case 3: Evaluation queue full - concurrent operations on same target
// must not conflict; different initiators cannot both modify the same resource
// without proper authorization
assert ec_safe_3 {
    all op1, op2: REQ_TRIAGE_01 |
        (op1 != op2 && some (op1.target & op2.target) && op1.initiator != op2.initiator) =>
            (Write not in op1.initiator.mayPerform) || (Write not in op2.initiator.mayPerform)
}
check ec_safe_3 for 5

// Edge case 4: Multiple patients registered simultaneously - each operation
// must use authenticated channels to ensure patient data integrity
assert ec_safe_4 {
    all op: REQ_TRIAGE_01 |
        (PatientRecord in op.target) => 
            all c: op.channel | c.authenticated = True
}
check ec_safe_4 for 5

// ----------------------------------------------------------------------
// Behavioral contract predicates (test scenarios)
// ----------------------------------------------------------------------

// Scenario TC-TRIAGE-01: Register a new patient with valid symptoms.
pred tc_triage_01_holds {
    some op: REQ_TRIAGE_01 |
        op.initiator = Triage_Nurses &&
        PatientRecord in op.target &&
        QueueEntry in op.target &&
        SymptomData in op.target &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_triage_01_holds for 5

assert tc_triage_01_contract {
    all op: REQ_TRIAGE_01 |
        (op.initiator = Triage_Nurses &&
         PatientRecord in op.target &&
         QueueEntry in op.target &&
         SymptomData in op.target &&
         op.grant = Write &&
         op.pre = Pre1) =>
        op.post = Post1
}
check tc_triage_01_contract for 5

// Scenario TC-TRIAGE-02: Attempt to register a new patient without providing any symptoms.
pred tc_triage_02_holds {
    some op: REQ_TRIAGE_01 |
        op.initiator = Triage_Nurses &&
        PatientRecord in op.target &&
        SymptomData not in op.target &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post2
}
run tc_triage_02_holds for 5

assert tc_triage_02_contract {
    all op: REQ_TRIAGE_01 |
        (op.initiator = Triage_Nurses &&
         PatientRecord in op.target &&
         SymptomData not in op.target &&
         op.grant = Write &&
         op.pre = Pre1) =>
        op.post = Post2
}
check tc_triage_02_contract for 5

// Scenario TC-TRIAGE-03: Simulate simultaneous registration of multiple patients.
pred tc_triage_03_holds {
    some disj op1, op2: REQ_TRIAGE_01 |
        op1.initiator = Triage_Nurses &&
        op2.initiator = Triage_Nurses &&
        PatientRecord in op1.target &&
        QueueEntry in op1.target &&
        SymptomData in op1.target &&
        PatientRecord in op2.target &&
        QueueEntry in op2.target &&
        SymptomData in op2.target &&
        op1.grant = Write &&
        op2.grant = Write &&
        op1.pre = Pre1 &&
        op2.pre = Pre1 &&
        op1.post = Post1 &&
        op2.post = Post1
}
run tc_triage_03_holds for 5

assert tc_triage_03_contract {
    all op: REQ_TRIAGE_01 |
        (op.initiator = Triage_Nurses &&
         PatientRecord in op.target &&
         QueueEntry in op.target &&
         SymptomData in op.target &&
         op.grant = Write &&
         op.pre = Pre1) =>
        op.post = Post1
}
check tc_triage_03_contract for 5

// ----------------------------------------------------------------------
// Non-functional requirement invariants
// ----------------------------------------------------------------------

fact nfr_fact_performance {
    // PROXY: limiting channels && targets per operation reduces latency
    // NFR: registration must complete within 30 seconds
    all op: REQ_TRIAGE_01 |
        #op.channel <= 2 && #op.target <= 3
}

fact nfr_fact_availability {
    // PROXY: multiple interfaces provide redundancy for 99.5% uptime
    // NFR: system available 99.5% of peak hours
    #Interface >= 2
}

fact nfr_fact_scalability {
    // PROXY: every actor can initiate an operation, supporting many simultaneous users
    // NFR: handle 1,000 new registrations per hour
    all a: Actor |
        some op: REQ_TRIAGE_01 |
            op.initiator = a
}

fact nfr_fact_usability {
    // PROXY: few interfaces imply simple, intuitive design with minimal form fields
    // NFR: clear error messages && intuitive interface
    #Interface <= 3
}

// ----------------------------------------------------------------------
// Security properties
// ----------------------------------------------------------------------

// Encryption at rest helper sig
sig DataAtRestEncryption {
    resource: one Resource,
    encrypted: one Bool
}

// Encryption in transit (requirement 1)
assert sr_assert_encryption_in_transit {
    all op: REQ_TRIAGE_01 |
        all c: op.channel |
            c.encrypted = True
}
check sr_assert_encryption_in_transit for 5

// Encryption at rest (requirement 1)
assert sr_assert_encryption_at_rest {
    all r: Resource |
        some d: DataAtRestEncryption |
            d.resource = r && d.encrypted = True
}
check sr_assert_encryption_at_rest for 5

// Access restriction to registration system (requirement 2)
assert sr_assert_registration_access_restriction {
    all op: REQ_TRIAGE_01 |
        (QueueEntry in op.target) =>
        (op.initiator in Triage_Nurses + Medical_Staff)
}
check sr_assert_registration_access_restriction for 5


