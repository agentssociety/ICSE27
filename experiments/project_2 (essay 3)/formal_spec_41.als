module REQ_TRANSFUSION_MATCH_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-TRANSFUSION-MATCH-01
 * Title       : Automated Blood Unit Matching based on ABO/Rh Compatibility Rules
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Transfusion_Service_Users, Clinical_Staff, IT_Department extends Actor {}
-- Transfusion_Service_Users: represents stakeholder 'Transfusion Service Users'
-- Clinical_Staff: represents stakeholder 'Clinical Staff'
-- IT_Department: represents stakeholder 'IT Department'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Blood_Unit_API, Transfusion_Request_Database extends Interface {}

fact interface_properties {
    Blood_Unit_API.kind = API  -- The system will interact with a Blood Unit API to retrieve and update information about available blood units.
    Transfusion_Request_Database.kind = Database  -- The system will store and manage transfusion requests in this database.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The system must have access to up-to-date and accurate ABO/Rh compatibility data for all available blood units
-- Pre2: system is in state where A transfusion request is submitted by a user authorized to make such requests
-- Pre3: system is in state where The system's database of blood units is not empty

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The system returns only compatible blood units that are safe for the patient to receive
-- Post2: system reaches state where The transfusion request is recorded in the system with details of the matched blood unit(s)
-- Post3: system reaches state where Any incompatible blood units are excluded from consideration


----------------------------------------------------------------------
-- Core operation: REQ_TRANSFUSION_MATCH_01
----------------------------------------------------------------------

sig REQ_TRANSFUSION_MATCH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_TRANSFUSION_MATCH_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_TRANSFUSION_MATCH_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_TRANSFUSION_MATCH_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_TRANSFUSION_MATCH_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_TRANSFUSION_MATCH_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_TRANSFUSION_MATCH_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_TRANSFUSION_MATCH_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_TRANSFUSION_MATCH_01 {
    some op: REQ_TRANSFUSION_MATCH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_TRANSFUSION_MATCH_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_TRANSFUSION_MATCH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_TRANSFUSION_MATCH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_TRANSFUSION_MATCH_01_well_formed {
    all op: REQ_TRANSFUSION_MATCH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_TRANSFUSION_MATCH_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_TRANSFUSION_MATCH_01 |
        op.post = Post1 &&
        op.pre != Post1 &&
        op.grant = Read &&
        (Blood_Unit_API in op.target) &&
        (op.channel.encrypted = True) &&
        (op.channel.authenticated = True) &&
        (Transfusion_Service_Users in op.initiator.mayPerform)
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_TRANSFUSION_MATCH_01 |
        (op.post = Post1) =>
            (op.grant = Read &&
             (Blood_Unit_API in op.target) &&
             (op.channel.authenticated = True) &&
             (op.channel.encrypted = True))
}
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_TRANSFUSION_MATCH_01 |
        op.post = Post2 &&
        op.pre != Post2 &&
        op.grant = Write &&
        (Transfusion_Request_Database in op.target) &&
        (op.channel.authenticated = True) &&
        (Clinical_Staff in op.initiator.mayPerform)
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_TRANSFUSION_MATCH_01 |
        (op.post = Post2) =>
            (op.grant = Write &&
             (Transfusion_Request_Database in op.target) &&
             (op.channel.authenticated = True))
}
check ps_valid_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_TRANSFUSION_MATCH_01 |
        op.post = Post3 &&
        op.pre != Post3 &&
        op.grant = Execute &&
        (Blood_Unit_API in op.target) &&
        (op.channel.authenticated = True) &&
        (IT_Department in op.initiator.mayPerform)
}
run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_TRANSFUSION_MATCH_01 |
        (op.post = Post3) =>
            (op.grant = Execute &&
             (Blood_Unit_API in op.target) &&
             (op.channel.authenticated = True))
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_TRANSFUSION_MATCH_01 |
        op.pre = Pre1 &&
        Transfusion_Request_Database in op.target &&
        op.initiator = Clinical_Staff
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_TRANSFUSION_MATCH_01 |
        op.initiator = Clinical_Staff &&
        op.grant = Write &&
        some c: op.channel | c.authenticated = True
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_TRANSFUSION_MATCH_01 |
        op.post = Post1 &&
        Blood_Unit_API in op.target &&
        op.initiator = Clinical_Staff
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge Case 1: Unknown ABO/Rh type must ! lead to incompatible transfusion
-- We represent unknown type by absence of Permission. An op with unknown type cannot grant transfusion.
assert ec_safe_1 {
    all op: REQ_TRANSFUSION_MATCH_01 |
        -- If initiator lacks Blood_Unit_API access, then no transfusion grant occurs
        (Blood_Unit_API !in op.initiator.mayPerform) =>
            (op.grant != Read)
}
check ec_safe_1 for 5

-- Edge Case 2: Incompatible blood units must never receive a grant
-- We model incompatibility: if target resource owner is ! in accessible set, grant must be denied
assert ec_safe_2 {
    all op: REQ_TRANSFUSION_MATCH_01 |
        -- For each target resource, if initiator is ! in its accessible set, grant cannot be Read (transfusion)
        (some t: op.target | op.initiator !in t.accessible) =>
            (op.grant != Read)
}
check ec_safe_2 for 5

-- Edge Case 3: Insufficient compatible units must prevent transfusion grant
-- We model insufficiency: if fewer than 2 resources are accessible to initiator, grant is denied
assert ec_safe_3 {
    all op: REQ_TRANSFUSION_MATCH_01 |
        (#{t: op.target | op.initiator in t.accessible} < 2) =>
            (op.grant != Read)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicate for TC-TRANSFUSION-MATCH-01: Verifies that a request for AB+ blood (represented by Pre1) results in only compatible units (Post1)
pred tc_TRANSFUSION_MATCH_01_holds {
    some op: REQ_TRANSFUSION_MATCH_01 |
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.initiator = Clinical_Staff &&
        Read in Clinical_Staff.mayPerform &&
        op.grant = Read &&
        Blood_Unit_API in op.target &&
        all c: op.channel | c.encrypted = True && c.authenticated = True
}
run tc_TRANSFUSION_MATCH_01_holds for 5

-- Assertion for TC-TRANSFUSION-MATCH-01: Whenever the pre-state is Pre1, the post-state must be Post1
assert tc_TRANSFUSION_MATCH_01_contract {
    all op: REQ_TRANSFUSION_MATCH_01 |
        op.pre = Pre1 => op.post = Post1
}
check tc_TRANSFUSION_MATCH_01_contract for 5

-- Predicate for TC-TRANSFUSION-MATCH-02: Verifies that an unknown ABO/Rh type request (Pre2) results in an error message (Post2)
pred tc_TRANSFUSION_MATCH_02_holds {
    some op: REQ_TRANSFUSION_MATCH_01 |
        op.pre = Pre2 &&
        op.post = Post2 &&
        op.initiator = Clinical_Staff &&
        Read in Clinical_Staff.mayPerform &&
        op.grant = Read &&
        Blood_Unit_API in op.target &&
        all c: op.channel | c.encrypted = True && c.authenticated = True
}
run tc_TRANSFUSION_MATCH_02_holds for 5

-- Assertion for TC-TRANSFUSION-MATCH-02: Whenever the pre-state is Pre2, the post-state must be Post2
assert tc_TRANSFUSION_MATCH_02_contract {
    all op: REQ_TRANSFUSION_MATCH_01 |
        op.pre = Pre2 => op.post = Post2
}
check tc_TRANSFUSION_MATCH_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: minimize channel && resource count to reduce latency
fact nfr_fact_performance {
    all op: REQ_TRANSFUSION_MATCH_01 | #op.channel <= 2 && #op.target <= 2
}

-- Availability proxy: require at least two channels for redundancy
fact nfr_fact_availability {
    all op: REQ_TRANSFUSION_MATCH_01 | #op.channel >= 2
}

-- Scalability proxy: every actor must be an initiator in some operation
assert nfr_assert_scalability {
    all a: Actor | some op: REQ_TRANSFUSION_MATCH_01 | op.initiator = a
}
check nfr_assert_scalability for 5

-- Usability proxy: limit channel count to keep interface simple
assert nfr_assert_usability {
    all op: REQ_TRANSFUSION_MATCH_01 | #op.channel <= 3
}
check nfr_assert_usability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security Requirement 1: Access to ABO/Rh compatibility data must be restricted to authorized personnel only
-- This is modeled as a confidentiality constraint: only authorized actors can access resources containing compatibility data
fact sr_fact_abo_rh_access_control {
    all op: REQ_TRANSFUSION_MATCH_01 |
        -- If the operation involves blood unit API (which contains ABO/Rh data),
        -- only authorized clinical staff can access it
        (Blood_Unit_API in op.target) =>
            (op.initiator in Clinical_Staff || op.initiator in Transfusion_Service_Users)
}

assert sr_assert_abo_rh_access_control {
    all op: REQ_TRANSFUSION_MATCH_01 |
        (Blood_Unit_API in op.target) =>
            (op.initiator in Clinical_Staff || op.initiator in Transfusion_Service_Users)
}
check sr_assert_abo_rh_access_control for 5

-- Security Requirement 2: All data transmitted between UI && backend must be encrypted using TLS 1.2 || higher
-- Modeled as encryption-in-transit for all channels used in the operation
assert sr_assert_encryption_in_transit {
    all op: REQ_TRANSFUSION_MATCH_01 |
        all c: op.channel |
            c.encrypted = True
}
check sr_assert_encryption_in_transit for 5

-- Security Requirement 3: HIPAA compliance for patient data protection
-- This requires: authentication, encryption, access control, && auditability
fact sr_fact_hipaa_compliance {
    all op: REQ_TRANSFUSION_MATCH_01 |
        -- Authentication required on all channels
        (all c: op.channel | c.authenticated = True) &&
        -- Encryption required on all channels
        (all c: op.channel | c.encrypted = True) &&
        -- Only authorized personnel can access patient data
        (Transfusion_Request_Database in op.target) =>
            (op.initiator in Clinical_Staff || op.initiator in Transfusion_Service_Users)
}

assert sr_assert_hipaa_compliance {
    all op: REQ_TRANSFUSION_MATCH_01 |
        (all c: op.channel | c.authenticated = True) &&
        (all c: op.channel | c.encrypted = True) &&
        (Transfusion_Request_Database in op.target) =>
            (op.initiator in Clinical_Staff || op.initiator in Transfusion_Service_Users)
}
check sr_assert_hipaa_compliance for 5

-- Additional security property: Least privilege - initiator must have exactly the permission needed
assert sr_assert_least_privilege {
    all op: REQ_TRANSFUSION_MATCH_01 |
        op.grant in op.initiator.mayPerform &&
        -- No excessive permissions: the initiator should ! have more than what's needed
        no p: Permission | p in op.initiator.mayPerform && p ! in op.grant && p != Read
}
check sr_assert_least_privilege for 5

-- Additional security property: Separation of duties - no single actor can both initiate && approve
assert sr_assert_separation_of_duties {
    all op: REQ_TRANSFUSION_MATCH_01 |
        -- If operation requires Admin permission, initiator cannot also be the resource owner
        (Admin in op.grant) =>
            (no r: op.target | r.owner = op.initiator)
}
check sr_assert_separation_of_duties for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines ABO/Rh compatibility matching with permission-based access control
-- Summary 2: Includes structural invariants, safety assertions, and test case contracts
-- Summary 3: Non-functional requirements modeled as constraints on channel/resource counts
-- Summary 4: Security properties enforce encryption, authentication, and access control
-- Assumption 1: ABO/Rh compatibility is abstracted via permission and resource access sets
-- Assumption 2: Unknown ABO/Rh type is modeled as lack of Blood_Unit_API access
-- Assumption 3: Insufficient compatible units is modeled as fewer than 2 accessible resources
-- Assumption 4: Performance and availability are proxied by channel and resource count limits
-- Open issue 1: Conflicting facts nfr_fact_performance (<=2 channels) and nfr_fact_availability (>=2 channels) may cause inconsistency
-- Open issue 2: Edge case assertions ec_safe_1, ec_safe_2, ec_safe_3 may be too restrictive or not match intended semantics
-- Open issue 3: Test case contracts tc_TRANSFUSION_MATCH_01_contract and tc_TRANSFUSION_MATCH_02_contract are too strong (pre implies post unconditionally)
-- Open issue 4: Least privilege assertion sr_assert_least_privilege may be unsatisfiable due to 'no p: Permission | p in op.initiator.mayPerform && p ! in op.grant && p != Read'


