module REQ_INV_MAN_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-INV-MAN-01
 * Title       : Automatically mark blood units as expired based on shelf life
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */

----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Inventory_Manager, Clinical_Team, Quality_Assurance extends Actor {}
-- Inventory_Manager: represents stakeholder 'Inventory Manager'
-- Clinical_Team: represents stakeholder 'Clinical Team'
-- Quality_Assurance: represents stakeholder 'Quality Assurance'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- A blood unit is a resource with a collection date (modeled as a field for future refinement).
sig BloodUnit extends Resource {
    collectionDate : one Int  -- abstraction of time; negative values indicate indefinite shelf life
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Blood_Unit_Database, Scheduling_API extends Interface {}

fact interface_properties {
    Blood_Unit_Database.kind = Database  -- Reads from and writes to the blood unit database to retrieve collection dates, update expiration status, and remove expired units.
    Scheduling_API.kind = API  -- Interacts with a scheduling system to trigger the periodic or scheduled expiration check operations.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system has accurate collection dates for all blood units.
-- Pre2: system is in state where The shelf life duration is predefined and consistent across all blood units.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The specified blood unit is marked as expired in the system's database.
-- Post2: system reaches state where The specified blood unit is no longer available for use in patient treatments.


----------------------------------------------------------------------
-- Core operation: REQ_INV_MAN_01
----------------------------------------------------------------------

sig REQ_INV_MAN_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_INV_MAN_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_INV_MAN_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_INV_MAN_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_INV_MAN_01 | op.initiator in op.target.accessible
}

-- INV-5: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_INV_MAN_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_INV_MAN_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_INV_MAN_01 {
    some op: REQ_INV_MAN_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_INV_MAN_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_INV_MAN_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_INV_MAN_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_INV_MAN_01_well_formed {
    all op: REQ_INV_MAN_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post
}
check REQ_INV_MAN_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_INV_MAN_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        some b: BloodUnit | b in op.target &&
        op.grant = Write &&
        some c: op.channel | c.authenticated = True &&
        op.pre != op.post
}

assert ps_valid_Post1 {
    all op: REQ_INV_MAN_01 |
        op.post = Post1 => {
            Write in op.initiator.mayPerform
            some b: BloodUnit | b in op.target
            op.grant = Write
            some c: op.channel | c.authenticated = True
        }
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_INV_MAN_01 |
        op.post = Post2 &&
        Admin in op.initiator.mayPerform &&
        some b: BloodUnit | b in op.target &&
        op.grant = Admin &&
        some c: op.channel | c.authenticated = True &&
        op.pre != op.post
}

assert ps_valid_Post2 {
    all op: REQ_INV_MAN_01 |
        op.post = Post2 => {
            Admin in op.initiator.mayPerform
            some b: BloodUnit | b in op.target
            op.grant = Admin
            some c: op.channel | c.authenticated = True
        }
}

run ps_reach_Post2 for 5
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Liveness predicate for Criterion 1:
-- A blood unit is marked as expired when its shelf life, calculated from the collection date, is exceeded.
pred ac_reach_1 {
    some op: REQ_INV_MAN_01 |
        -- The initiator must have Write permission (to mark something as expired)
        Write in op.initiator.mayPerform &&
        -- The operation targets some blood unit (the resource)
        some b: BloodUnit | b in op.target &&
        -- A secure communication channel is used (encrypted && authenticated)
        (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
        -- The operation results in state Post1 (expired marking)
        op.post = Post1
}

run ac_reach_1 for 5

-- Liveness predicate for Criterion 2:
-- The system removes the expired blood unit from the available inventory.
pred ac_reach_2 {
    some op: REQ_INV_MAN_01 |
        -- The initiator must have Write permission (to remove from inventory)
        Write in op.initiator.mayPerform &&
        -- The operation targets some blood unit (the expired blood unit)
        some b: BloodUnit | b in op.target &&
        -- A secure communication channel is used (encrypted && authenticated)
        (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
        -- The operation results in state Post2 (removal from inventory)
        op.post = Post2
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: discrepancy between collection date && system clock
-- Safety: if the initiator is ! an Inventory_Manager, the operation cannot
-- change the state in a way that would depend on a date-based decision
assert ec_safe_1 {
    all op: REQ_INV_MAN_01 |
        -- If the initiator is ! Inventory_Manager, post must equal pre
        -- (no state-changing operation without proper role)
        (Inventory_Manager !in op.initiator) => (op.post = op.pre)
}
check ec_safe_1 for 5

-- Edge case 2: blood units with indefinite shelf life
-- Safety: if a resource has no owner (impossible in the model, but as edge case
-- we check that indefinite shelf life means no state change is required)
assert ec_safe_2 {
    all op: REQ_INV_MAN_01 |
        -- If the operation targets a blood unit with a negative collectionDate (indefinite)
        -- and the initiator is Quality_Assurance, the post state must be reachable
        -- regardless of shelf life duration
        (some b: BloodUnit | b in op.target && b.collectionDate < 0 && Quality_Assurance in op.initiator) =>
            (op.post = Post1 || op.post = Post2)
}
check ec_safe_2 for 5

-- Edge case 3: dynamic shelf life based on regulatory updates
-- Safety: only Admin can change resources that might affect regulatory compliance
assert ec_safe_3 {
    all op: REQ_INV_MAN_01 |
        -- If the operation targets a blood unit && the grant is ! Admin, the post state must equal pre
        (some b: BloodUnit | b in op.target && Admin !in op.grant) =>
            (op.post = op.pre)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_inv_man_01_holds {
    some op: REQ_INV_MAN_01 |
        op.initiator = Inventory_Manager &&
        some b: BloodUnit | b in op.target &&
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_inv_man_01_holds for 5

assert tc_inv_man_01_contract {
    all op: REQ_INV_MAN_01 |
        (op.initiator = Inventory_Manager &&
         some b: BloodUnit | b in op.target &&
         op.grant = Write &&
         Write in op.initiator.mayPerform &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_inv_man_01_contract for 5

pred tc_inv_man_02_holds {
    some op: REQ_INV_MAN_01 |
        op.initiator = Inventory_Manager &&
        no (op.target & BloodUnit) &&  // no expired unit targeted (target contains no BloodUnit)
        op.grant = Read &&
        Read in op.initiator.mayPerform &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.pre = Pre2 &&
        op.post = Post2
}
run tc_inv_man_02_holds for 5

assert tc_inv_man_02_contract {
    all op: REQ_INV_MAN_01 |
        (op.initiator = Inventory_Manager &&
         no (op.target & BloodUnit) &&
         op.grant = Read &&
         Read in op.initiator.mayPerform &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre2) =>
        (op.post = Post2)
}
check tc_inv_man_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_perf_channel_limit {
    -- PROXY: Limiting the number of channels per operation reduces overhead && latency.
    -- NFR: No significant performance degradation during expiration check operations.
    all op: REQ_INV_MAN_01 | #op.channel <= 2
}

fact nfr_fact_avail_redundancy {
    -- PROXY: Requiring at least two channels per operation provides redundancy for failover.
    -- NFR: 99.9% uptime of the system during scheduled expiration checks.
    all op: REQ_INV_MAN_01 | #op.channel >= 2
}

fact nfr_fact_scala_resource_limit {
    -- PROXY: Limiting the number of resources per operation prevents heavy contention.
    -- NFR: The system should handle up to 10,000 blood units per day without delays.
    all op: REQ_INV_MAN_01 | #op.target <= 3
}

assert nfr_assert_usability_simple {
    -- PROXY: Requiring all channels to be both authenticated && encrypted ensures clear, secure communication.
    -- NFR: Error messages && notifications for expired units are clear && easy to understand.
    all op: REQ_INV_MAN_01 | all c: op.channel | c.authenticated = True && c.encrypted = True
}
check nfr_assert_usability_simple for 5

