module REQ_BLOOD_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BLOOD-01
 * Title       : Reserve and Auto-Release Blood Units Based on Pending Requests
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Manager, IT_Team, Stakeholder_Committee extends Actor {}
-- Blood_Bank_Manager: represents stakeholder 'Blood Bank Manager'
-- IT_Team: represents stakeholder 'IT Team'
-- Stakeholder_Committee: represents stakeholder 'Stakeholder Committee'

fact permission_assignments {
    Blood_Bank_Manager.mayPerform = Read + Write
    IT_Team.mayPerform = Read
    Stakeholder_Committee.mayPerform = Read
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Concrete resource representing the blood inventory
one sig BloodInventory extends Resource {}

fact resource_setup {
    BloodInventory.owner = Blood_Bank_Manager
    BloodInventory.accessible = Blood_Bank_Manager
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Blood_Inventory_Database, Inventory_Management_API, Blood_Bank_Manager_Interface extends Interface {}

fact interface_properties {
    Blood_Inventory_Database.kind = Database  -- The system interacts with this database to retrieve and update blood unit information, reservation statuses, and inventory levels.
    Inventory_Management_API.kind = API  -- This API is used to communicate with the Blood Inventory Management System to check availability and update inventory after a reservation or release.
    Blood_Bank_Manager_Interface.kind = UI  -- The system interfaces with this UI to allow blood bank managers to view pending requests, manage reservations, and receive notifications about the status of their reservations.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where A pending request exists with a specified blood type and component requirements
-- Pre2: system is in state where The system has access to the necessary inventory of blood units
-- Pre3: system is in state where The reservation timeout period is configured in the system settings

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where All reserved blood units are marked as unavailable for other requests
-- Post2: system reaches state where Unused or expired reserved blood units are automatically released and made available again
-- Post3: system reaches state where All units previously reserved for a cancelled request are returned to the inventory pool


----------------------------------------------------------------------
-- Core operation: REQ_BLOOD_01
----------------------------------------------------------------------

sig REQ_BLOOD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BLOOD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BLOOD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BLOOD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BLOOD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BLOOD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BLOOD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BLOOD_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BLOOD_01 {
    some op: REQ_BLOOD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BLOOD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BLOOD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BLOOD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BLOOD_01_well_formed {
    all op: REQ_BLOOD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BLOOD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Predicate: Post1 reachability (reserved units marked unavailable)
pred ps_reach_Post1 {
    some op: REQ_BLOOD_01 |
        op.post = Post1 &&
        op.pre != Post1 &&
        Write in op.initiator.mayPerform &&
        some r: Resource | r in op.target &&
        BloodInventory in op.target &&
        Inventory_Management_API in op.channel
}
run ps_reach_Post1 for 5

-- Assertion: Post1 semantics (reserved units marked unavailable)
assert ps_valid_Post1 {
    all op: REQ_BLOOD_01 |
        (op.post = Post1) =>
            (Write in op.initiator.mayPerform &&
             op.pre != Post1 &&
             some r: Resource | r in op.target &&
             BloodInventory in op.target)
}
check ps_valid_Post1 for 5

-- Predicate: Post2 reachability (unused/expired units released)
pred ps_reach_Post2 {
    some op: REQ_BLOOD_01 |
        op.post = Post2 &&
        op.pre != Post2 &&
        Write in op.initiator.mayPerform &&
        Blood_Bank_Manager in op.initiator &&
        BloodInventory in op.target &&
        Inventory_Management_API in op.channel
}
run ps_reach_Post2 for 5

-- Assertion: Post2 semantics (unused/expired units released)
assert ps_valid_Post2 {
    all op: REQ_BLOOD_01 |
        (op.post = Post2) =>
            (Write in op.initiator.mayPerform &&
             op.pre != Post2 &&
             Blood_Bank_Manager in op.initiator &&
             BloodInventory in op.target)
}
check ps_valid_Post2 for 5

-- Predicate: Post3 reachability (cancelled request units returned)
pred ps_reach_Post3 {
    some op: REQ_BLOOD_01 |
        op.post = Post3 &&
        op.pre != Post3 &&
        Write in op.initiator.mayPerform &&
        Blood_Bank_Manager in op.initiator &&
        BloodInventory in op.target &&
        Inventory_Management_API in op.channel
}
run ps_reach_Post3 for 5

-- Assertion: Post3 semantics (cancelled request units returned)
assert ps_valid_Post3 {
    all op: REQ_BLOOD_01 |
        (op.post = Post3) =>
            (Write in op.initiator.mayPerform &&
             op.pre != Post3 &&
             Blood_Bank_Manager in op.initiator &&
             BloodInventory in op.target)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: Reserve matching blood units && mark them as reserved
pred ac_reach_1 {
    some op: REQ_BLOOD_01 |
        -- Initiator must have Write permission to modify inventory
        Write in op.initiator.mayPerform &&
        -- Operation affects the blood inventory database
        BloodInventory in op.target &&
        -- Uses authenticated channel for security
        (some c: op.channel | c.authenticated = True) &&
        -- State transitions from Pre1 to Post1 (reservation state)
        op.pre = Pre1 &&
        op.post = Post1 &&
        -- Grant permission is Write for reservation
        op.grant = Write
}
run ac_reach_1 for 5

-- Criterion 2: Release reserved units after timeout
pred ac_reach_2 {
    some op: REQ_BLOOD_01 |
        -- Initiator must have Write permission to modify inventory
        Write in op.initiator.mayPerform &&
        -- Operation affects the blood inventory database
        BloodInventory in op.target &&
        -- Uses authenticated channel for security
        (some c: op.channel | c.authenticated = True) &&
        -- State transitions from Post1 (reserved) to Post2 (released)
        op.pre = Post1 &&
        op.post = Post2 &&
        -- Grant permission is Write for release
        op.grant = Write
}
run ac_reach_2 for 5

-- Criterion 3: Release all units when request is cancelled
pred ac_reach_3 {
    some op: REQ_BLOOD_01 |
        -- Initiator must have Write permission to modify inventory
        Write in op.initiator.mayPerform &&
        -- Operation affects the blood inventory database
        BloodInventory in op.target &&
        -- Uses authenticated channel for security
        (some c: op.channel | c.authenticated = True) &&
        -- State transitions from Post1 (reserved) to Post3 (cancelled/released)
        op.pre = Post1 &&
        op.post = Post3 &&
        -- Grant permission is Write for cancellation
        op.grant = Write
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Reservation timeout set to zero should ! cause undefined behavior
-- A zero timeout means immediate expiration; the operation must still complete
-- with a valid post-state transition
assert ec_safe_1 {
    all op: REQ_BLOOD_01 |
        -- If the operation involves reservation (Write permission) && timeout is zero,
        -- the post-state must still be reachable && valid
        (Write in op.grant) =>
            (op.post in Post1 + Post2 + Post3)
}
check ec_safe_1 for 5

-- Edge case 2: Simultaneous requests for same blood type && components
-- No two operations with overlapping targets can both claim exclusive access
-- without proper coordination
assert ec_safe_2 {
    all disj op1, op2: REQ_BLOOD_01 |
        -- If both operations target overlapping resources && require Write permission
        (some op1.target & op2.target) && (Write in op1.grant) && (Write in op2.grant) =>
            -- They cannot both succeed to the same post-state unless compatible
            (op1.post != op2.post) || (op1.post = op2.post && op1.pre = op2.pre)
}
check ec_safe_2 for 5

-- Edge case 3: Insufficient inventory for multiple concurrent reservations
-- When inventory is limited, operations must ! claim more units than available
assert ec_safe_3 {
    all op1, op2, op3: REQ_BLOOD_01 |
        -- If three operations target the same resource with Write permission
        (op1.target & op2.target & op3.target != none) &&
        (Write in op1.grant) && (Write in op2.grant) && (Write in op3.grant) =>
            -- At most two can succeed (limited inventory constraint)
            !(op1.post != op1.pre && op2.post != op2.pre && op3.post != op3.pre)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-BLOOD-01: Reserve a single blood unit for a pending request with a timeout period.
-- Expected: mark unit as unavailable && set a timer (represented by state change Pre1 -> Post1)

pred tc_BLOOD_01_holds {
    some op: REQ_BLOOD_01 |
        op.initiator = Blood_Bank_Manager &&
        BloodInventory in op.target &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        some c: op.channel | (c.kind = API || c.kind = UI)
}
run tc_BLOOD_01_holds for 5

assert tc_BLOOD_01_contract {
    all op: REQ_BLOOD_01 |
        (op.initiator = Blood_Bank_Manager &&
         BloodInventory in op.target &&
         op.grant = Write &&
         op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_BLOOD_01_contract for 5

-- TC-BLOOD-02: Release a reserved unit after the reservation timeout expires.
-- Expected: automatically release the unit && make it available (state Pre2 -> Post2)

pred tc_BLOOD_02_holds {
    some op: REQ_BLOOD_01 |
        op.initiator = Blood_Bank_Manager &&
        BloodInventory in op.target &&
        op.grant = Write &&
        op.pre = Pre2 &&
        op.post = Post2 &&
        some c: op.channel | (c.kind = API || c.kind = UI)
}
run tc_BLOOD_02_holds for 5

assert tc_BLOOD_02_contract {
    all op: REQ_BLOOD_01 |
        (op.initiator = Blood_Bank_Manager &&
         BloodInventory in op.target &&
         op.grant = Write &&
         op.pre = Pre2) =>
        (op.post = Post2)
}
check tc_BLOOD_02_contract for 5

-- TC-BLOOD-03: Cancel a pending request && release all associated reserved units.
-- Expected: all units previously reserved returned to inventory pool (state Pre3 -> Post3)

pred tc_BLOOD_03_holds {
    some op: REQ_BLOOD_01 |
        op.initiator = Blood_Bank_Manager &&
        BloodInventory in op.target &&
        op.grant = Write &&
        op.pre = Pre3 &&
        op.post = Post3 &&
        some c: op.channel | (c.kind = API || c.kind = UI)
}
run tc_BLOOD_03_holds for 5

assert tc_BLOOD_03_contract {
    all op: REQ_BLOOD_01 |
        (op.initiator = Blood_Bank_Manager &&
         BloodInventory in op.target &&
         op.grant = Write &&
         op.pre = Pre3) =>
        (op.post = Post3)
}
check tc_BLOOD_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: minimize channels per operation to reduce latency.
fact nfr_fact_performance {
    all op: REQ_BLOOD_01 | #op.channel <= 2
}

-- Availability: require at least two channels for redundancy.
fact nfr_fact_availability {
    all op: REQ_BLOOD_01 | #op.channel >= 2
}

-- Scalability: there exist two distinct operations by same initiator (proxy for ability to handle multiple pending requests per actor).
assert nfr_assert_scalability {
    some op1, op2: REQ_BLOOD_01 | op1 != op2 && op1.initiator = op2.initiator
}
check nfr_assert_scalability for 5

-- Usability: ensure each operation uses at most one authenticated channel (bounded number for simplicity).
fact nfr_fact_usability {
    all op: REQ_BLOOD_01 | #{c: op.channel | c.authenticated = True} <= 1
}

