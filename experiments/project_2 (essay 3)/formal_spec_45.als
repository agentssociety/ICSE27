 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Manager, Inventory_Team extends Actor {}
-- Blood_Bank_Manager: represents stakeholder 'Blood Bank Manager'
-- Inventory_Team: represents stakeholder 'Inventory Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resources relevant to dashboard display
sig StockLevels extends Resource {}
sig ExpirationData extends Resource {}
sig TransfusionRequestData extends Resource {}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Inventory_Database, Blood_Unit_Data_API, Web_Browser_or_Internal_System extends Interface {}

fact interface_properties {
    Inventory_Database.kind = Database  -- The requirement interacts with the database to retrieve current stock levels, expiration dates, and transfusion requests.
    Blood_Unit_Data_API.kind = API  -- The requirement uses this API to fetch real-time data about blood units in inventory.
    Web_Browser_or_Internal_System.kind = UI  -- The dashboard is accessed via a web browser or internal system, requiring the use of appropriate UI components and layouts.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where I am logged in as a blood bank manager

-- Concrete post-states (one per distinct postcondition).
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_INV_DASH_01
----------------------------------------------------------------------

sig REQ_INV_DASH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_INV_DASH_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_INV_DASH_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_INV_DASH_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_INV_DASH_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_INV_DASH_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_INV_DASH_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_INV_DASH_01 {
    some op: REQ_INV_DASH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_INV_DASH_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_INV_DASH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_INV_DASH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_INV_DASH_01_well_formed {
    all op: REQ_INV_DASH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_INV_DASH_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: 'Current Stock Levels' section listing each blood type with quantity
-- This requires data query/display capability: the operation must involve Read permission,
-- target the StockLevels resource, and use a UI channel.
pred ac_reach_1 {
    some op: REQ_INV_DASH_01 |
        Read in op.initiator.mayPerform &&
        StockLevels in op.target &&
        (some c: op.channel | c.kind = UI) &&
        op.grant = Read &&
        op.pre = Pre1 &&
        op.post = PostDone
}
run ac_reach_1 for 5

-- Criterion 2: 'Units Nearing Expiration' section listing unit details
-- This requires Read permission on ExpirationData resource, and displaying through UI channel.
pred ac_reach_2 {
    some op: REQ_INV_DASH_01 |
        Read in op.initiator.mayPerform &&
        ExpirationData in op.target &&
        (some c: op.channel | c.kind = UI && c.authenticated = True) &&
        op.grant = Read &&
        op.pre = Pre1 &&
        op.post = PostDone
}
run ac_reach_2 for 5

-- Criterion 3: 'Open Transfusion Requests' section listing transfusion requests
-- This requires Read permission on TransfusionRequestData resource, and using an authenticated UI channel.
pred ac_reach_3 {
    some op: REQ_INV_DASH_01 |
        Read in op.initiator.mayPerform &&
        TransfusionRequestData in op.target &&
        (some c: op.channel | c.kind = UI && c.authenticated = True) &&
        op.grant = Read &&
        op.pre = Pre1 &&
        op.post = PostDone
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: When there are no units nearing expiration, the operation should still complete without violating safety.
-- We model "nearing expiration" by checking if any resource's state is in a special expiry-related state.
sig ExpiryStatus { isExpiring: set Resource }
assert ec_safe_1 {
    all op: REQ_INV_DASH_01 |
        -- if no target resource is nearing expiration, the operation should not fail structurally
        (no r: op.target | r in ExpiryStatus.isExpiring) =>
            (op.post != op.pre)  -- state must change (operation succeeds)
}
check ec_safe_1 for 5

-- Edge case 2: How does the system handle sudden increases in transfusion requests?
-- We model "sudden increase" by checking if multiple operations target the same resource concurrently.
-- Safety: concurrent operations on the same resource must not lead to inconsistent states.
assert ec_safe_2 {
    all op1, op2: REQ_INV_DASH_01 |
        -- if two operations share a target and execute concurrently
        (op1 != op2 && some (op1.target & op2.target)) =>
            -- they must both be authorized for the same grant type on that shared resource
            (op1.grant = op2.grant)
}
check ec_safe_2 for 5

-- Edge case 3: What if a blood unit's expiration date changes while it is still in inventory?
-- Safety: If a resource's expiration status changes, the operation must still respect access control.
assert ec_safe_3 {
    all op: REQ_INV_DASH_01 |
        -- for any resource that might have its expiration status change
        some r: op.target |
            -- the initiator must still be authorized for that resource
            r in op.initiator.accessible
}
check ec_safe_3 for 5

