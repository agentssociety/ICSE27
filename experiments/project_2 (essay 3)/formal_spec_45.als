        some c: op.channel | c.authenticated = True &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_inv_dash_02_holds for 5

assert tc_inv_dash_02_contract {
    all op: REQ_INV_DASH_01 |
        (op.initiator = Blood_Bank_Manager &&
         ExpirationData in op.target &&
         some c: op.channel | c.authenticated = True &&
         op.grant = Read) =>
        op.post != op.pre
}
check tc_inv_dash_02_contract for 5

-- Predicates and assertions for scenario TC-INV-DASH-03
pred tc_inv_dash_03_holds {
    some op: REQ_INV_DASH_01 |
        op.initiator = Inventory_Team &&
        TransfusionRequestData in op.target &&
        Web_Browser_or_Internal_System in op.channel &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_inv_dash_03_holds for 5

assert tc_inv_dash_03_contract {
    all op: REQ_INV_DASH_01 |
        (op.initiator = Inventory_Team &&
         TransfusionRequestData in op.target &&
         Web_Browser_or_Internal_System in op.channel &&
         op.grant = Read) =>
        op.post != op.pre
}
check tc_inv_dash_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: proxy latency by limiting channel count per operation
fact nfr_fact_latency {
    -- NFR: response time < 200ms (proxy: max 2 channels reduces overhead)
    all op: REQ_INV_DASH_01 | #op.channel <= 2
}

-- Performance: proxy throughput by limiting target resources per operation
fact nfr_fact_throughput {
    -- NFR: throughput > 1000 ops/sec (proxy: limit resource contention)
    all op: REQ_INV_DASH_01 | #op.target <= 3
}

-- Availability: proxy uptime by requiring redundant channels
fact nfr_fact_redundancy {
    -- NFR: 99.9% uptime (proxy: at least 2 channels for failover)
    all op: REQ_INV_DASH_01 | #op.channel >= 2
}

-- Scalability: proxy by allowing all actors to initiate operations
fact nfr_fact_concurrent_actors {
    -- NFR: support 1000 concurrent users (proxy: all actors can be initiators)
    all a: Actor | some op: REQ_INV_DASH_01 | op.initiator = a
}

-- Reliability: proxy by ensuring every operation has a defined post-state
assert nfr_assert_post_state {
    -- NFR: 100% operation completion (proxy: post-state always exists)
    all op: REQ_INV_DASH_01 | one op.post
}
check nfr_assert_post_state for 5

-- Usability: proxy by limiting authenticated channels to reduce complexity
fact nfr_fast_authentication {
    -- NFR: login < 1 second (proxy: max 1 authenticated channel per operation)
    all op: REQ_INV_DASH_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

-- Maintainability: proxy by ensuring no circular resource ownership
fact nfr_no_circular_ownership {
    -- NFR: system maintainable (proxy: no resource owns its owner's resources)
    no r: Resource | r.owner in r.owner.accessible
}

