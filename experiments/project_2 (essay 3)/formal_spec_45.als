-- Predicates and assertions for scenario TC-INV-DASH-01
pred tc_inv_dash_01_holds {
    some op: REQ_INV_DASH_01 |
        (op.initiator = Blood_Bank_Manager || op.initiator = Inventory_Team) &&
        StockLevels in op.target &&
        Web_Browser_or_Internal_System in op.channel &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_inv_dash_01_holds for 5

assert tc_inv_dash_01_contract {
    all op: REQ_INV_DASH_01 |
        ((op.initiator = Blood_Bank_Manager || op.initiator = Inventory_Team) &&
         StockLevels in op.target &&
         Web_Browser_or_Internal_System in op.channel &&
         op.grant = Read) =>
        op.post != op.pre
}
check tc_inv_dash_01_contract for 5

