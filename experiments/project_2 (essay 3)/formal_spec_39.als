----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Manager, Inventory_Management_Team extends Actor {}
-- Blood_Bank_Manager: represents stakeholder 'Blood Bank Manager'
-- Inventory_Management_Team: represents stakeholder 'Inventory Management Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Inventory_Management_API extends Interface {}

fact interface_properties {
    Inventory_Management_API.kind = API  -- The system will use this API to add new blood units and retrieve all tracked units.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where A new blood unit is received

-- Concrete post-states (one per distinct postcondition).
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_BLOOD_01
----------------------------------------------------------------------

sig REQ_BLOOD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BLOOD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BLOOD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BLOOD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BLOOD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BLOOD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BLOOD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BLOOD_01 {
    some op: REQ_BLOOD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BLOOD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BLOOD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BLOOD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BLOOD_01_well_formed {
    all op: REQ_BLOOD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BLOOD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

// --- LIVENESS PREDICATES for REQ_BLOOD_01 ---

-- Criterion 1: The unit is added to the inventory with the provided details
-- Semantic mapping: An authorized Blood_Bank_Manager || Inventory_Management_Team
-- actor performs a Write operation via the Inventory_Management_API interface,
-- resulting in a new state (PostDone) that reflects the addition.
pred ac_reach_1 {
    some op: REQ_BLOOD_01 |
        // Authorized actor: must be a Blood_Bank_Manager || Inventory_Management_Team
        op.initiator in (Blood_Bank_Manager + Inventory_Management_Team) &&
        // Required permission to add unit (Write)
        Write in op.initiator.mayPerform &&
        // Grant permission is Write (adding details)
        op.grant = Write &&
        // Target resource exists (the unit being added)
        some op.target &&
        // Channel is Inventory_Management_API (the system interface)
        some c: op.channel | c in Inventory_Management_API &&
        // Post-state indicates successful completion (PostDone)
        op.post = PostDone &&
        // Pre-state is the initial state (Pre1)
        op.pre = Pre1
}

run ac_reach_1 for 5

-- Criterion 2: I can view all tracked units in the inventory
-- Semantic mapping: An authorized actor (any with Read permission) can view
-- all tracked units. This requires Read permission && access to resources.
pred ac_reach_2 {
    some op: REQ_BLOOD_01 |
        // Actor must have Read permission
        Read in op.initiator.mayPerform &&
        // Grant permission is Read (viewing)
        op.grant = Read &&
        // Target resources are accessible by the initiator
        all r: op.target | op.initiator in r.accessible &&
        // At least one resource is targeted (the units to view)
        some op.target &&
        // Channel is authenticated (secure viewing)
        (some c: op.channel | c.authenticated = True) &&
        // Post-state indicates successful read operation (PostDone)
        op.post = PostDone
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sig to represent blood units
sig BloodUnit extends Resource {
    hasCompleteData: one Bool,
    isExpired: one Bool,
    id: one Int
}

-- Edge case 1: No operation should handle a blood unit with missing ABO/Rh type || collection date.
assert ec_safe_1 {
    all op: REQ_BLOOD_01 | no bu: BloodUnit | bu in op.target && bu.hasCompleteData = False
}
check ec_safe_1 for 5

-- Edge case 2: No operation should involve an expired blood unit.
assert ec_safe_2 {
    all op: REQ_BLOOD_01 | no bu: BloodUnit | bu in op.target && bu.isExpired = True
}
check ec_safe_2 for 5

-- Edge case 3: No duplicate blood unit IDs should exist (safety against recording duplicates).
assert ec_safe_3 {
    all op: REQ_BLOOD_01 | no disj b1, b2: BloodUnit | b1.id = b2.id
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? SCENARIO TC-BLOOD-01: Adding a new blood unit ??????????????
pred tc_blood_01_holds {
    some op: REQ_BLOOD_01 |
        -- Input: Blood_Bank_Manager initiates addition of a blood unit
        op.initiator in Blood_Bank_Manager &&
        -- Input: grant = Write (adding to inventory)
        op.grant = Write &&
        -- Input: target is a BloodUnit resource (implicitly via field types)
        some t: op.target | t in BloodUnit &&
        -- Expected: state changes (unit added to inventory)
        op.post != op.pre &&
        -- Expected: channel is authenticated (secure addition)
        all c: op.channel | c.authenticated = True
}

run tc_blood_01_holds for 5

assert tc_blood_01_contract {
    all op: REQ_BLOOD_01 |
        -- Pre-condition: Blood_Bank_Manager initiates, grant is Write
        (op.initiator in Blood_Bank_Manager && op.grant = Write) =>
        -- Post-condition: state changes && target includes at least one BloodUnit
        (op.post != op.pre && some t: op.target | t in BloodUnit)
}

check tc_blood_01_contract for 5

-- ?? SCENARIO TC-BLOOD-02: Viewing all tracked units ??????????????
pred tc_blood_02_holds {
    some op: REQ_BLOOD_01 |
        -- Input: Inventory_Management_Team views inventory
        op.initiator in Inventory_Management_Team &&
        -- Input: grant = Read (viewing only)
        op.grant = Read &&
        -- Expected: state changes (viewing is a stateful operation per model)
        op.post != op.pre &&
        -- Expected: all targets are BloodUnit instances
        all t: op.target | t in BloodUnit
}

run tc_blood_02_holds for 5

assert tc_blood_02_contract {
    all op: REQ_BLOOD_01 |
        -- Pre-condition: Inventory_Management_Team initiates with Read
        (op.initiator in Inventory_Management_Team && op.grant = Read) =>
        -- Post-condition: all accessed targets are BloodUnit resources
        (all t: op.target | t in BloodUnit)
}

check tc_blood_02_contract for 5

-- ?? SCENARIO TC-BLOOD-03: Missing ABO/Rh type rejection ??????????
pred tc_blood_03_holds {
    some op: REQ_BLOOD_01 |
        -- Input: Blood_Bank_Manager attempts addition
        op.initiator in Blood_Bank_Manager &&
        -- Input: grant = Write
        op.grant = Write &&
        -- Expected: state does NOT change (rejected)
        op.post = op.pre &&
        -- Expected: no BloodUnit target was added (target set remains unchanged)
        no t: op.target | t in BloodUnit
}

run tc_blood_03_holds for 5

assert tc_blood_03_contract {
    all op: REQ_BLOOD_01 |
        -- Pre-condition: Blood_Bank_Manager attempts Write on non-BloodUnit target
        (op.initiator in Blood_Bank_Manager && op.grant = Write &&
         no t: op.target | t in BloodUnit) =>
        -- Post-condition: state unchanged (rejection)
        op.post = op.pre
}

check tc_blood_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance NFR: limiting interfaces && resources reduces latency.
fact nfr_fact_performance_latency {
    all op: REQ_BLOOD_01 | #op.channel <= 2 && #op.target <= 3
}

-- Availability NFR: at least 2 channels ensure failover capacity for uptime.
fact nfr_fact_availability_redundancy {
    all op: REQ_BLOOD_01 | #op.channel >= 2
}

-- Scalability NFR: every actor must be able to initiate an operation (system supports all actors concurrently).
assert nfr_assert_scalability_all_actors_active {
    all a: Actor | some op: REQ_BLOOD_01 | op.initiator = a
}
check nfr_assert_scalability_all_actors_active for 5

-- Usability NFR: limiting authenticated channels per operation reduces user complexity.
assert nfr_assert_usability_simple_authentication {
    all op: REQ_BLOOD_01 | #(op.channel & {c: Interface | c.authenticated = True}) <= 1
}
check nfr_assert_usability_simple_authentication for 5

