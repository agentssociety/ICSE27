          now = datetime(2024, 1, 15, 10, 0, 0)                                                                                 
          reservation = Reservation(                                                                                            
              id="RES-001",                                                                                                     
              request_id="REQ-001",                                                                                             
              unit_id=1,                                                                                                        
              reserved_at=now,                                                                                                  
          )                                                                                                                     
          reservation.release()                                                                                                 
