export const updateBloodUnit = (id: number, data: BloodUnitUpdate) => api.put<BloodUnit>(`/blood_units/${id}`, data).then(r => 
r.data);
export const deleteBloodUnit = (id: number) => api.delete(`/blood_units/${id}`).then(r => r.data);

