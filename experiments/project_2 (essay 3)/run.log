  </button>\n      </div>\n\n      {error && <p style={{ color: 'var(--danger)', marginBottom: '1rem' }}>{error}</p>}\n\n       
  {showForm && (\n        <div className=\"card\" style={{ marginBottom: '1.5rem' }}>\n          <h2                            
  className=\"section-title\">New Reservation</h2>\n          <form onSubmit={handleSubmit}>\n            <div style={{         
