  <th style={{ padding: '0.5rem' }}>Actions</th>\n              </tr>\n            </thead>\n            <tbody>\n              
  {reservations.map(r => (\n                <tr key={r.id} style={{ borderBottom: '1px solid var(--border-light)' }}>\n         
