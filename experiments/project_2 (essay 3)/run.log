#333333\n\npackage "Domain Model" {\n  enum Permission {\n    Read\n    Write\n    Admin\n    Execute\n  }\n\n  enum State 
{\n    Pre1\n    Pre2\n    Post1\n    Post2\n  + transitionTo(pre: State, post: State) : State\n  + transitionTo(pre: Pre1, 
post: Post1) : State\n  }\n\n  class Actor {\n    + mayPerform : Set(Permission)\n  }\n  note left of Actor\n    
<<invariant>>\n    Blood_Bank_Technicians : mayPerform = {Read, Write, Admin, Execute}\n    Medical_Staff : mayPerform = 
{Read, Write, Admin}\n  end note\n\n  class Resource {\n    + owner : Actor\n    + accessible : Set(Actor)\n  + 
checkAccess(initiator: Actor, target: Resource) : Bool\n  }\n  note left of Resource\n    <<invariant>>\n    owner in 
accessible\n  end note\n\n  class Transfusion_Requests_Resource extends Resource {\n    // no additional attributes\n  }\n  
note left of Transfusion_Requests_Resource\n    <<invariant>>\n    owner = Blood_Bank_Technicians\n    accessible = 
{Blood_Bank_Technicians, Medical_Staff}\n  end note\n\n  class PatientDetail {\n    + isAlphanumeric : Bool\n  + 
validateFormat(patientDetail: PatientDetail) : Bool\n  }\n\n  class BloodType {\n    + isValid : Bool\n  + 
validateType(bloodType: BloodType) : Bool\n  }\n}\n\npackage "Infrastructure — Ports" {\n  enum IfaceKind {\n    API\n    
Database\n  }\n\n  interface Interface {\n    + kind : IfaceKind\n    + encrypted : Bool\n    + authenticated : Bool\n  }\n\n
interface Transfusion_Request_Submission_API extends Interface {\n    // no additional attributes\n  }\n  note right of 
Transfusion_Request_Submission_API\n    <<invariant>>\n    kind = API\n    encrypted = True\n    authenticated = True\n  end 
note\n\n  interface Transfusion_Requests_Database extends Interface {\n    // no additional attributes\n  }\n  note right of 
Transfusion_Requests_Database\n    <<invariant>>\n    kind = Database\n    encrypted = True\n    authenticated = True\n  end 
note\n}\n\npackage "Application" {\n  class REQ_BBT_01 {\n    + initiator : Actor\n    + target : Set(Resource)\n    + 
channel : Set(Interface)\n    + grant : Permission\n    + pre : State\n    + post : State\n  + submitRequest(initiator: 
Actor, target: Resource, patientDetail: PatientDetail, bloodType: BloodType) : REQ_BBT_01\n  + 
submitMultipleRequests(requests: List<REQ_BBT_01>) : List<Result>\n  }\n  note left of REQ_BBT_01\n    <<invariant>>\n    - 
some channel (non-empty)\n    - some target (non-empty)\n    - grant in initiator.mayPerform\n    - initiator in 
target.accessible (for all target)\n    - pre != post\n    - at least one channel with authenticated = True\n    - post in 
{Post1, Post2}\n  end note\n}\n\n\' Associations for REQ_BBT_01\nREQ_BBT_01 "1" --> "1" Actor : initiator\nREQ_BBT_01 "*" -->
"*" Resource : target\nREQ_BBT_01 "*" --> "*" Interface : channel\nREQ_BBT_01 "1" --> "1" Permission : grant\nREQ_BBT_01 "1" 
--> "1" State : pre\nREQ_BBT_01 "1" --> "1" State : post\n\n\' Associations for Resource\nResource "1" --> "1" Actor : 
owner\nResource "*" --> "*" Actor : accessible\n\n\' Inheritances\nTransfusion_Requests_Resource --|> 
Resource\nTransfusion_Request_Submission_API --|> Interface\nTransfusion_Requests_Database --|> Interface\n\n@enduml', 
'sequence_diagram': '@startuml\n!theme plain\n\nbox "Controller Layer" #LightBlue\n  participant 
"Transfusion_Request_Submission_API" as API\nend box\n\nbox "Application Layer" #LightGreen\n  participant "REQ_BBT_01" as 
Controller\nend box\n\nbox "Domain Layer" #LightYellow\n  participant "Actor" as Actor\n  participant "Resource" as 
Resource\n  participant "PatientDetail" as PatientDetail\n  participant "BloodType" as BloodType\n  participant "State" as 
State\n  participant "Permission" as Permission\nend box\n\nbox "Infrastructure Layer" #LightCoral\n  participant 
"Transfusion_Requests_Database" as Database\nend box\n\n== Main Flow: Medical Staff Submits Transfusion Request ==\n\nActor 
-> API : Medical_Staff submits transfusion request [TLS]\nactivate API\n\nAPI -> Controller : submitRequest(initiator: Actor,
target: Resource, patientDetail: PatientDetail, bloodType: BloodType) : REQ_BBT_01\nactivate Controller\n\nController -> 
Actor : getPermissions(actor: Actor) : set Permission\nactivate Actor\nActor --> Controller : return permissions\ndeactivate 
Actor\n\nalt Permission Check Failed\n    Controller --> API : return Error("Insufficient permissions")\n    API --> Actor : 
HTTP 403 Forbidden\n    deactivate Controller\n    deactivate API\nelse Permission Check Passed\n    Controller -> Resource :
checkAccess(initiator: Actor, target: Resource) : Bool\n    activate Resource\n    Resource --> Controller : return 
accessGranted\n    deactivate Resource\n\n    alt Access Denied\n        Controller --> API : return Error("Access denied")\n
API --> Actor : HTTP 403 Forbidden\n        deactivate Controller\n        deactivate API\n    else Access Granted\n        
Controller -> PatientDetail : validateFormat(patientDetail: PatientDetail) : Bool\n        activate PatientDetail\n        
PatientDetail --> Controller : return isValid\n        deactivate PatientDetail\n\n        alt Invalid Patient Details\n     
Controller -> State : transitionTo(pre: State, post: State) : State\n            activate State\n            State --> 
Controller : return Post2\n            deactivate State\n            Controller --> API : return Error("Invalid patient 
details - stored for processing")\n            API --> Actor : HTTP 202 Accepted (stored for further processing)\n           
deactivate Controller\n            deactivate API\n        else Valid Patient Details\n            Controller -> BloodType : 
validateType(bloodType: BloodType) : Bool\n            activate BloodType\n            BloodType --> Controller : return 
isValid\n            deactivate BloodType\n\n            alt Invalid Blood Type\n                Controller -> State : 
transitionTo(pre: State, post: State) : State\n                activate State\n                State --> Controller : return 
Post2\n                deactivate State\n                Controller --> API : return Error("Invalid blood type - stored for 
processing")\n                API --> Actor : HTTP 202 Accepted (stored for further processing)\n                deactivate 
Controller\n                deactivate API\n            else Valid Blood Type\n                Controller -> State : 
transitionTo(pre: Pre1, post: Post1) : State\n                activate State\n                State --> Controller : return 
Post1\n                deactivate State\n\n                Controller -> Database : storeRequest(request: REQ_BBT_01) : Bool 
[encrypted at rest]\n                activate Database\n                Database --> Controller : return stored\n            
deactivate Database\n\n                alt Database Storage Failed\n                    Controller --> API : return 
Error("Storage failed")\n                    API --> Actor : HTTP 500 Internal Server Error\n                    deactivate 
Controller\n                    deactivate API\n                else Database Storage Succeeded\n                    
Controller --> API : return Success(Post1)\n                    API --> Actor : HTTP 201 Created\n                    
deactivate Controller\n                    deactivate API\n                end\n            end\n        end\n    
end\nend\n\n== Concurrent Flow: Multiple Requests Submitted Simultaneously ==\n\nActor -> API : Medical_Staff submits 
multiple requests concurrently [TLS]\nactivate API\n\nAPI -> Controller : submitMultipleRequests(requests: List<REQ_BBT_01>) 
: List<Result>\nactivate Controller\n\nloop for each request\n    Controller -> Actor : getPermissions(actor: Actor) : set 
Permission\n    activate Actor\n    Actor --> Controller : return permissions\n    deactivate Actor\n\n    Controller -> 
Resource : checkAccess(initiator: Actor, target: Resource) : Bool\n    activate Resource\n    Resource --> Controller : 
return accessGranted\n    deactivate Resource\n\n    Controller -> PatientDetail : validateFormat(patientDetail: 
PatientDetail) : Bool\n    activate PatientDetail\n    PatientDetail --> Controller : return isValid\n    deactivate 
PatientDetail\n\n    Controller -> BloodType : validateType(bloodType: BloodType) : Bool\n    activate BloodType\n    
BloodType --> Controller : return isValid\n    deactivate BloodType\n\n    Controller -> State : transitionTo(pre: Pre1, 
post: Post1) : State\n    activate State\n    State --> Controller : return Post1\n    deactivate State\n\n    Controller -> 
Database : storeRequest(request: REQ_BBT_01) : Bool [encrypted at rest]\n    activate Database\n    Database --> Controller :
return stored\n    deactivate Database\nend\n\nController --> API : return results\nAPI --> Actor : HTTP 200 OK (all requests
processed)\ndeactivate Controller\ndeactivate API\n\n== Error Flow: System Unavailable ==\n\nActor -> API : Medical_Staff 
submits transfusion request [TLS]\nactivate API\n\nAPI -> Controller : submitRequest(initiator: Actor, target: Resource, 
patientDetail: PatientDetail, bloodType: BloodType) : REQ_BBT_01\nactivate Controller\n\nController -> Database : 
checkAvailability() : Bool [encrypted at rest]\nactivate Database\n\nalt Database Unavailable\n    Database --> Controller : 
return unavailable\n    deactivate Database\n    Controller --> API : return Error("System unavailable")\n    API --> Actor :
HTTP 503 Service Unavailable\n    deactivate Controller\n    deactivate API\nelse Database Available\n    Database --> 
Controller : return available\n    deactivate Database\n    Controller --> API : return Success\n    API --> Actor : HTTP 200
OK\n    deactivate Controller\n    deactivate API\nend\n\n@enduml', 'domain_model_context': [{'name': 'Permission', 'kind': 
