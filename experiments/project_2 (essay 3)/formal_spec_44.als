module REQ_MON_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-MON-01
 * Title       : Inventory Level Monitoring and Alerting
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Inventory_Manager, Blood_Bank_Operations_Team extends Actor {}
-- Inventory_Manager: represents stakeholder 'Inventory Manager'
-- Blood_Bank_Operations_Team: represents stakeholder 'Blood Bank Operations Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, External_System extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Inventory_API, Alert_Notification_System extends Interface {}

fact interface_properties {
    Inventory_API.kind = API  -- The system interacts with the Inventory API to retrieve current inventory levels for ABO/Rh types.
    Alert_Notification_System.kind = External_System  -- The system sends alerts via the Alert Notification System, which could be an email service or a dashboard application.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where An alert is triggered for the specific ABO/Rh type with insufficient inventory


----------------------------------------------------------------------
-- Core operation: REQ_MON_01
----------------------------------------------------------------------

sig REQ_MON_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_MON_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_MON_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_MON_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_MON_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_MON_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_MON_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_MON_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_MON_01 {
    some op: REQ_MON_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_MON_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_MON_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_MON_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_MON_01_well_formed {
    all op: REQ_MON_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_MON_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_MON_01 |
        op.post = Post1 &&
        op.initiator = Inventory_Manager &&
        Write in op.initiator.mayPerform &&
        some r: op.target | r.owner = Inventory_Manager &&
        some c: op.channel | c.authenticated = True && c.encrypted = True &&
        op.pre = PreIdle
}

assert ps_valid_Post1 {
    all op: REQ_MON_01 |
        (op.post = Post1) =>
            (op.initiator = Inventory_Manager &&
             Write in op.initiator.mayPerform &&
             some r: op.target | r.owner = Inventory_Manager &&
             some c: op.channel | c.authenticated = True && c.encrypted = True &&
             op.pre = PreIdle)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: Given the current inventory for a specific ABO/Rh type is below 5 units
-- This maps to: there exists a resource (blood type) whose inventory level is below 5
-- Since we don't have explicit inventory fields, we model this as a state condition
-- where the pre-state indicates low inventory
pred ac_reach_1 {
    some op: REQ_MON_01 |
        -- The operation involves checking inventory (Read permission)
        Read in op.initiator.mayPerform &&
        -- Target is a resource (blood type inventory)
        some op.target &&
        -- The pre-state indicates low inventory condition
        op.pre = PreIdle &&
        -- The operation is performed by Inventory_Manager
        op.initiator = Inventory_Manager &&
        -- Using the API interface
        (some c: op.channel | c.kind = API)
}
run ac_reach_1 for 5

-- Criterion 2: When the system checks inventory levels
-- This maps to: an authorized actor performs an inventory check operation
pred ac_reach_2 {
    some op: REQ_MON_01 |
        -- The initiator has Read permission (checking inventory)
        Read in op.initiator.mayPerform &&
        -- The operation targets resources (inventory items)
        some op.target &&
        -- Using authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        -- The operation transitions from idle state
        op.pre = PreIdle &&
        -- The initiator is authorized for the target resources
        op.initiator in op.target.accessible
}
run ac_reach_2 for 5

-- Criterion 3: Then an alert is raised for that blood type
-- This maps to: the operation results in an alert notification state
pred ac_reach_3 {
    some op: REQ_MON_01 |
        -- The operation involves Write permission (creating alert)
        Write in op.initiator.mayPerform &&
        -- Target resources exist (blood types needing alerts)
        some op.target &&
        -- The post-state indicates alert was raised
        op.post = Post1 &&
        -- Using the alert notification system
        (some c: op.channel | c.kind = API) &&
        -- The initiator is authorized
        op.initiator = Inventory_Manager
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: If inventory data is delayed by more than 10 seconds,
-- the operation must ! proceed to post-state without a valid inventory snapshot.
assert ec_safe_1 {
  all op: REQ_MON_01 |
    -- If the operation involves Inventory_API && the pre-state is PreIdle,
    -- then the post-state must ! be Post1 unless the inventory data is current.
    (Inventory_API in op.target) && (op.pre = PreIdle) && (op.post = Post1) =>
      -- At least one channel must be authenticated to ensure data freshness
      some ch: op.channel | ch.authenticated = True
}
check ec_safe_1 for 5

-- Edge case 2: When multiple alerts for different ABO/Rh types occur simultaneously,
-- each alert must be processed through distinct channels to avoid conflict.
assert ec_safe_2 {
  all disj op1, op2: REQ_MON_01 |
    -- If both operations target Inventory_API && use Alert_Notification_System
    (Inventory_API in op1.target) && (Inventory_API in op2.target) &&
    (Alert_Notification_System in op1.channel) && (Alert_Notification_System in op2.channel) =>
      -- They must ! have the same grant unless they are the same operation
      op1.grant != op2.grant
}
check ec_safe_2 for 5

-- Edge case 3: During a network outage, no operation should use an unauthenticated channel.
assert ec_safe_3 {
  all op: REQ_MON_01 |
    -- If any channel is unauthenticated && the operation targets Inventory_API,
    -- the operation must ! reach Post1 state
    (some ch: op.channel | ch.authenticated != True) &&
    (Inventory_API in op.target) =>
      op.post != Post1
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-MON-01: inventory level above threshold (4 units) ? no alert
pred tc_MON_01_holds {
    some op : REQ_MON_01 |
        op.initiator = Inventory_Manager &&
        op.grant = Read &&
        op.post = PreIdle
}
run tc_MON_01_holds for 5

assert tc_MON_01_contract {
    all op : REQ_MON_01 |
        (op.initiator = Inventory_Manager &&
         op.grant = Read) =>
        op.post = PreIdle
}
check tc_MON_01_contract for 5

-- TC-MON-02: inventory level equal to threshold (5 units) ? no alert
pred tc_MON_02_holds {
    some op : REQ_MON_01 |
        op.initiator = Inventory_Manager &&
        op.grant = Read &&
        op.post = PreIdle
}
run tc_MON_02_holds for 5

assert tc_MON_02_contract {
    all op : REQ_MON_01 |
        (op.initiator = Inventory_Manager &&
         op.grant = Read) =>
        op.post = PreIdle
}
check tc_MON_02_contract for 5

-- TC-MON-03: inventory level below threshold (4.9 units) ? alert triggered
pred tc_MON_03_holds {
    some op : REQ_MON_01 |
        op.initiator = Inventory_Manager &&
        op.grant = Read &&
        op.post = Post1
}
run tc_MON_03_holds for 5

assert tc_MON_03_contract {
    all op : REQ_MON_01 |
        (op.initiator = Inventory_Manager &&
         op.grant = Read) =>
        op.post = Post1
}
check tc_MON_03_contract for 5

-- TC-MON-04: network outage during alert trigger ? no alert, error logged && retry
-- Here we model network outage as a channel that is ! encrypted || ! authenticated.
pred tc_MON_04_holds {
    some op : REQ_MON_01 |
        (some c : op.channel | c.encrypted = False || c.authenticated = False) &&
        op.post = PreIdle
}
run tc_MON_04_holds for 5

assert tc_MON_04_contract {
    all op : REQ_MON_01 |
        (some c : op.channel | c.encrypted = False || c.authenticated = False) =>
        op.post = PreIdle
}
check tc_MON_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: limiting target resources reduces processing time, proxying 10-second alert latency.
fact nfr_fact_performance_limit_targets {
    all op: REQ_MON_01 | #op.target <= 2
}

-- Availability: redundant channels ensure high availability (99.9% uptime proxy).
fact nfr_fact_availability_redundant_channels {
    all op: REQ_MON_01 | #op.channel >= 2
}

-- Scalability: each operation handles exactly one resource type, enabling handling of many types without degradation.
fact nfr_fact_scalability_single_target {
    all op: REQ_MON_01 | #op.target = 1
}

-- Usability: multiple channel kinds enable distinguishable alerts via email && dashboard.
fact nfr_fact_usability_multiple_channel_kinds {
    all op: REQ_MON_01 | some disj k1, k2: IfaceKind | k1 in op.channel.kind && k2 in op.channel.kind
}

-- Assertion to verify performance constraint (redundant with fact, but checkable).
assert nfr_assert_performance_small_targets {
    all op: REQ_MON_01 | #op.target <= 2
}
check nfr_assert_performance_small_targets for 5

