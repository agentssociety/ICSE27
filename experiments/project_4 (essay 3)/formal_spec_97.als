module REQ_BAL_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BAL-01
 * Title       : Decline Withdrawals Exceeding Account Balance or Daily Limit
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Bank_Users, Customer_Support, IT_Team extends Actor {}
-- Bank_Users: represents stakeholder 'Bank Users'
-- Customer_Support: represents stakeholder 'Customer Support'
-- IT_Team: represents stakeholder 'IT Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Service, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Account_Balance_Database, Daily_Withdrawal_Tracking_Service extends Interface {}

fact interface_properties {
    Account_Balance_Database.kind = Database  -- The system must query this database to retrieve the user's current account balance.
    Daily_Withdrawal_Tracking_Service.kind = Service  -- This service will be used to track and update the cumulative daily withdrawal total.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user must have an active account with a positive balance.
-- Pre2: system is in state where The system must track the user's cumulative daily withdrawal total.

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where If a withdrawal is declined, the user should receive a message indicating that the amount exceeds their balance or daily limit.


----------------------------------------------------------------------
-- Core operation: REQ_BAL_01
----------------------------------------------------------------------

sig REQ_BAL_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BAL_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BAL_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BAL_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BAL_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BAL_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BAL_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BAL_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BAL_01 {
    some op: REQ_BAL_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BAL_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BAL_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BAL_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BAL_01_well_formed {
    all op: REQ_BAL_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BAL_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_BAL_01 |
        op.post = Post1 &&
        op.initiator in Bank_Users &&
        (Account_Balance_Database in op.target || Daily_Withdrawal_Tracking_Service in op.target) &&
        op.grant = Write &&
        some ch: op.channel | ch.authenticated = True && ch.encrypted = True
}

assert ps_valid_Post1 {
    all op: REQ_BAL_01 |
        (op.post = Post1) =>
            (op.initiator in Bank_Users &&
             (Account_Balance_Database in op.target || Daily_Withdrawal_Tracking_Service in op.target) &&
             some ch: op.channel | ch.authenticated = True && ch.encrypted = True)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_BAL_01 |
        op.pre = Pre1 &&
        op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_BAL_01 |
        op.pre = Pre2 &&
        op.post = Post1
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: zero balance && zero limit
-- If the account balance && daily withdrawal limit are both zero,
-- no withdrawal operation should succeed (i.e., the post-state must equal the pre-state)
assert ec_safe_1 {
    all op: REQ_BAL_01 |
        -- Assuming Pre1 represents a state with zero balance && zero limit
        (op.pre = Pre1) => (op.post = op.pre)
}
check ec_safe_1 for 5

-- Edge case 2: error in cumulative daily withdrawal calculation
-- If there is an error in the system's calculation, the operation must !
-- produce an inconsistent post-state (i.e., the post-state must be reachable)
assert ec_safe_2 {
    all op: REQ_BAL_01 |
        -- If the pre-state is Pre2 (representing a calculation error scenario),
        -- the post-state must be one of the defined valid states
        (op.pre = Pre2) => (op.post in Post1)
}
check ec_safe_2 for 5

-- Edge case 3: withdrawal exactly at daily limit
-- If a user attempts to withdraw exactly the daily limit amount,
-- the operation must succeed (post-state changes) && the initiator must
-- have the appropriate permission (Write || Execute)
assert ec_safe_3 {
    all op: REQ_BAL_01 |
        -- Assuming Pre1 represents a state where balance equals daily limit
        (op.pre = Pre1) => (
            -- The post-state must be different (operation succeeds)
            op.post != op.pre &&
            -- The initiator must have Write || Execute permission
            (Write in op.initiator.mayPerform || Execute in op.initiator.mayPerform)
        )
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-1: Withdraw more than account balance ? decline, no state change
pred tc_1_holds {
    some op: REQ_BAL_01 |
        Write in op.initiator.mayPerform &&
        op.target = Account_Balance_Database + Daily_Withdrawal_Tracking_Service &&
        op.grant = Write &&
        op.pre = Pre2 &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.post = Pre2
}
run tc_1_holds for 5

assert tc_1_contract {
    all op: REQ_BAL_01 |
        (op.pre = Pre2 &&
         Account_Balance_Database in op.target &&
         Write in op.initiator.mayPerform &&
         Write = op.grant) =>
            op.post = op.pre
}
check tc_1_contract for 5

-- TC-2: Withdraw amount exceeding daily limit ? decline, no state change
pred tc_2_holds {
    some op: REQ_BAL_01 |
        Write in op.initiator.mayPerform &&
        op.target = Account_Balance_Database + Daily_Withdrawal_Tracking_Service &&
        op.grant = Write &&
        op.pre = Pre2 &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.post = Pre2
}
run tc_2_holds for 5

assert tc_2_contract {
    all op: REQ_BAL_01 |
        (op.pre = Pre2 &&
         Daily_Withdrawal_Tracking_Service in op.target &&
         Write in op.initiator.mayPerform &&
         Write = op.grant) =>
            op.post = op.pre
}
check tc_2_contract for 5

-- TC-3: Withdraw exactly daily limit ? approve, update daily tracking
pred tc_3_holds {
    some op: REQ_BAL_01 |
        Write in op.initiator.mayPerform &&
        op.target = Account_Balance_Database + Daily_Withdrawal_Tracking_Service &&
        op.grant = Write &&
        op.pre = Pre1 &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.post = Post1
}
run tc_3_holds for 5

assert tc_3_contract {
    all op: REQ_BAL_01 |
        (op.pre = Pre1 &&
         Daily_Withdrawal_Tracking_Service in op.target &&
         Write in op.initiator.mayPerform &&
         Write = op.grant) =>
            op.post = Post1
}
check tc_3_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Usability: clear && easy-to-understand error messages imply a bounded interface complexity.
-- PROXY: limiting the number of interfaces per operation reduces cognitive load && message clutter.
fact nfr_fact_usability_interface_limit {
    -- NFR: The error message should be clear && easy to understand.
    all op: REQ_BAL_01 | #op.channel <= 3
}

-- Usability: a single initiator per operation prevents confusion about who performed an action.
-- PROXY: unambiguous identity supports meaningful error messages.
fact nfr_fact_usability_single_initiator {
    -- NFR: The error message should be clear && easy to understand.
    all op: REQ_BAL_01 | one op.initiator
}

-- Additional invariant: each operation must use a distinct interface kind to avoid repeating errors.
-- PROXY: diverse channel kinds make error sources easier to distinguish.
fact nfr_fact_usability_distinct_channel_kinds {
    -- NFR: The error message should be clear && easy to understand.
    all op: REQ_BAL_01 | all disj c1, c2: op.channel | c1.kind != c2.kind
}

