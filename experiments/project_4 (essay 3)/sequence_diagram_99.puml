@startuml
!theme plain

box "Controller Layer" #LightBlue
    participant "Withdrawal_API" as API
end box

box "Application Layer" #LightGreen
    participant "REQ_SEC_01" as Operation
    participant "SuspiciousPattern" as Detector
end box

box "Domain Layer" #LightYellow
    participant "Actor" as Actor
    participant "Security_Team" as SecurityTeam
    participant "Finance_Team" as FinanceTeam
    participant "Operations_Team" as OpsTeam
    participant "Resource" as Resource
    participant "Account" as Account
    participant "WithdrawalTransaction" as Transaction
    participant "FlaggedTransaction" as FlaggedTx
    participant "Permission" as Permission
    participant "State" as State
end box

box "Infrastructure Layer" #LightCoral
    participant "Transaction_Database" as DB
end box

== Main Flow: Normal Withdrawal ==

API -> Operation : submitWithdrawal(amount: Int, userId: UserID, initiator: Actor) : REQ_SEC_01
note right: [encrypted] [authenticated]

Operation -> Actor : checkPermission(initiator: Actor, requiredPermission: Permission) : Bool
Operation -> Resource : checkAccessibility(initiator: Actor, target: Resource) : Bool

alt Permission check fails
    Operation --> API : return Error("Insufficient permissions")
    API --> API : return HTTP 403 Forbidden
else Accessibility check fails
    Operation --> API : return Error("Resource inaccessible")
    API --> API : return HTTP 403 Forbidden
else Authentication check fails
    Operation --> API : return Error("Authentication required")
    API --> API : return HTTP 401 Unauthorized
else All checks pass
    Operation -> State : setPreState(PreIdle)
    Operation -> Detector : evaluatePattern(transaction: WithdrawalTransaction, initiator: Actor, target: Resource) : Bool
    
    alt Pattern not suspicious
        Detector --> Operation : return false
        Operation -> State : setPostState(PreIdle)
        note right: post != Post1 - normal processing
        Operation -> Transaction : createTransaction(amount: Int, timestamp: Time, userId: UserID) : WithdrawalTransaction
        Operation -> Account : updateBalance(accountId: AccountID, amount: Int) : Money
        Operation -> DB : storeTransaction(transaction: WithdrawalTransaction) [TLS]
        DB --> Operation : return success
        Operation --> API : return WithdrawalTransaction
        API --> API : return HTTP 200 OK
        
    else Pattern suspicious
        Detector --> Operation : return true
        note right: initiator not owner of target AND grant is Write
        Operation -> State : setPostState(Post1)
        note right: Flagged for review
        Operation -> FlaggedTx : createFlaggedTransaction(transaction: WithdrawalTransaction, reason: String) : FlaggedTransaction
        Operation -> DB : storeFlaggedTransaction(flaggedTx: FlaggedTransaction) [TLS]
        DB --> Operation : return success
        Operation --> API : return FlaggedTransaction
        API --> API : return HTTP 202 Accepted
    end
end

== Flow: Security Team Suspicious Pattern Detection ==

API -> Operation : submitWithdrawal(amount: Int, userId: UserID, initiator: Security_Team) : REQ_SEC_01
note right: [encrypted] [authenticated]

Operation -> SecurityTeam : checkPermission(initiator: Security_Team, requiredPermission: Permission) : Bool
note right: Security_Team has Admin permission

Operation -> Resource : checkAccessibility(initiator: Security_Team, target: Transaction_Database) : Bool
note right: Security_Team in accessible set

alt All checks pass
    Operation -> State : setPreState(PreIdle)
    Operation -> Detector : evaluatePattern(transaction: WithdrawalTransaction, initiator: Security_Team, target: Transaction_Database) : Bool
    
    alt Pattern detected as suspicious
        Detector --> Operation : return true
        note right: Multiple rapid successive withdrawals detected
        Operation -> State : setPostState(Post1)
        Operation -> FlaggedTx : createFlaggedTransaction(transaction: WithdrawalTransaction, reason: "Rapid successive withdrawals") : FlaggedTransaction
        Operation -> DB : storeFlaggedTransaction(flaggedTx: FlaggedTransaction) [TLS]
        DB --> Operation : return success
        Operation --> API : return FlaggedTransaction
        API --> API : return HTTP 202 Accepted
    else Pattern not suspicious
        Detector --> Operation : return false
        Operation -> State : setPostState(PreIdle)
        Operation -> Transaction : createTransaction(amount: Int, timestamp: Time, userId: UserID) : WithdrawalTransaction
        Operation -> DB : storeTransaction(transaction: WithdrawalTransaction) [TLS]
        DB --> Operation : return success
        Operation --> API : return WithdrawalTransaction
        API --> API : return HTTP 200 OK
    end
else Permission check fails
    Operation --> API : return Error("Security_Team lacks required permission")
    API --> API : return HTTP 403 Forbidden
end

