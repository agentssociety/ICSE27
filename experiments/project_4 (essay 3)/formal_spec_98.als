module REQ_WD_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-WD-01
 * Title       : Atomic Withdrawal Transactions
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Finance_Team, IT_Development_Team, User_Support_Team extends Actor {}
-- Finance_Team: represents stakeholder 'Finance Team'
-- IT_Development_Team: represents stakeholder 'IT Development Team'
-- User_Support_Team: represents stakeholder 'User Support Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Concrete resources relevant to withdrawal transactions
sig UserAccount, WithdrawalLimit, TransactionLog extends Resource {}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig AccountService_API, LimitService_API, TransactionLog_Database extends Interface {}

fact interface_properties {
    AccountService_API.kind = API  -- The requirement interacts with this API to deduct the user's balance.
    LimitService_API.kind = API  -- The requirement interacts with this API to update withdrawal limits.
    TransactionLog_Database.kind = Database  -- The requirement uses this database to record transaction logs and ensure they are rolled back on failure.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user must have an existing account with sufficient funds
-- Pre2: system is in state where The system must be operational and available for transactions

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The user's balance remains unchanged after a failed withdrawal attempt
-- Post2: system reaches state where No changes are made to the withdrawal limits
-- Post3: system reaches state where Transaction logs are not recorded in case of failure


----------------------------------------------------------------------
-- Core operation: REQ_WD_01
----------------------------------------------------------------------

sig REQ_WD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_WD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_WD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_WD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_WD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_WD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_WD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_WD_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_WD_01 {
    some op: REQ_WD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_WD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_WD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_WD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_WD_01_well_formed {
    all op: REQ_WD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_WD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1: The user's balance remains unchanged after a failed withdrawal attempt
pred ps_reach_Post1 {
    some op: REQ_WD_01 |
        op.post = Post1 &&
        some ch: op.channel | ch.authenticated = False &&
        op.grant = Write
}
run ps_reach_Post1 for 5

-- Post2: No changes are made to the withdrawal limits
pred ps_reach_Post2 {
    some op: REQ_WD_01 |
        op.post = Post2 &&
        some ch: op.channel | ch.encrypted = False &&
        op.grant = Execute
}
run ps_reach_Post2 for 5

-- Post3: Transaction logs are ! recorded in case of failure
pred ps_reach_Post3 {
    some op: REQ_WD_01 |
        op.post = Post3 &&
        some ch: op.channel | ch.authenticated = False && ch.encrypted = False &&
        op.grant = Read
}
run ps_reach_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates (simplified for consistency)
----------------------------------------------------------------------

-- Criterion 1: User has sufficient balance for a withdrawal
pred ac_reach_1 {
    some op: REQ_WD_01 |
        Write in op.initiator.mayPerform &&
        op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: User initiates a withdrawal transaction
pred ac_reach_2 {
    some op: REQ_WD_01 |
        op.grant = Write &&
        some c: op.channel | c.encrypted = True && c.authenticated = True
}
run ac_reach_2 for 5

-- Criterion 3: A step in the transaction (e.g., logging) fails
pred ac_reach_3 {
    some op: REQ_WD_01 |
        op.post = Post2 &&
        op.target in TransactionLog
}
run ac_reach_3 for 5

-- Criterion 4: The entire transaction is rolled back
pred ac_reach_4 {
    some op: REQ_WD_01 |
        op.post = Post3 &&
        op.pre = Pre1 &&
        op.grant = Read &&
        (some c: op.channel | c.authenticated = True)
}
run ac_reach_4 for 5

-- Criterion 5: User's balance is unchanged
pred ac_reach_5 {
    some op: REQ_WD_01 |
        op.post = Post1 &&
        op.pre = Pre1
}
run ac_reach_5 for 5

-- Criterion 6: Withdrawal limits are unchanged
pred ac_reach_6 {
    some op: REQ_WD_01 |
        op.post = Post2 &&
        op.pre = Pre1 &&
        op.target in WithdrawalLimit
}
run ac_reach_6 for 5

-- Criterion 7: No transaction log is recorded
pred ac_reach_7 {
    some op: REQ_WD_01 |
        op.post = Post3 &&
        op.pre = Pre1 &&
        no (op.target & TransactionLog) &&
        op.grant = Read
}
run ac_reach_7 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sigs for edge case modeling
sig WithdrawalRequest { operation: REQ_WD_01, amount: Int }
sig AccountBalance { account: Actor, balance: Int }
sig LoadAlert { channel: Interface, highLoad: Bool }
sig StorageState { resource: Resource, capacity: Int, used: Int }

assert ec_safe_1 {
    all op: REQ_WD_01 |
        (some wr: WithdrawalRequest | 
            wr.operation = op && 
            some ab: AccountBalance | 
                ab.account = op.initiator && ab.balance < wr.amount) 
            => op.post = op.pre
}

assert ec_safe_2 {
    all op: REQ_WD_01 |
        (some la: LoadAlert | 
            la.channel in op.channel && la.highLoad = True) 
            => op.post = op.pre
}

assert ec_safe_3 {
    all op: REQ_WD_01 |
        (some ss: StorageState | 
            ss.resource in op.target && ss.used >= ss.capacity) 
            => op.post = op.pre
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-WD-01: Sufficient balance but logging fails ? rollback
pred tc_WD_01_holds {
    some op: REQ_WD_01 |
        op.initiator = User_Support_Team &&
        op.grant = Write &&
        op.target.owner = op.initiator &&
        some c: op.channel | (c = TransactionLog_Database && c.encrypted = False) &&
        op.post = op.pre
}
run  tc_WD_01_holds    for 5

assert tc_WD_01_contract {
    all op: REQ_WD_01 |
        (op.initiator = User_Support_Team &&
         op.grant = Write &&
         op.target.owner = op.initiator &&
         some c: op.channel | (c = TransactionLog_Database && c.encrypted = False))
        => op.post = op.pre
}
check tc_WD_01_contract for 5

-- Scenario TC-WD-02: High load during withdrawal initiation ? transaction rejected/delayed
pred tc_WD_02_holds {
    some op: REQ_WD_01 |
        op.initiator = User_Support_Team &&
        op.grant = Write &&
        op.target.owner = op.initiator &&
        some c: op.channel | (c = AccountService_API && c.encrypted = False) &&
        op.post = op.pre
}
run  tc_WD_02_holds    for 5

assert tc_WD_02_contract {
    all op: REQ_WD_01 |
        (op.initiator = User_Support_Team &&
         op.grant = Write &&
         op.target.owner = op.initiator &&
         some c: op.channel | (c = AccountService_API && c.encrypted = False))
        => op.post = op.pre
}
check tc_WD_02_contract for 5

-- Scenario TC-WD-03: Database full while logging ? rollback
pred tc_WD_03_holds {
    some op: REQ_WD_01 |
        op.initiator = User_Support_Team &&
        op.grant = Write &&
        op.target.owner = op.initiator &&
        TransactionLog in op.target &&
        some c: op.channel | (c = TransactionLog_Database && c.encrypted = False) &&
        op.post = op.pre
}
run  tc_WD_03_holds    for 5

assert tc_WD_03_contract {
    all op: REQ_WD_01 |
        (op.initiator = User_Support_Team &&
         op.grant = Write &&
         op.target.owner = op.initiator &&
         TransactionLog in op.target &&
         some c: op.channel | (c = TransactionLog_Database && c.encrypted = False))
        => op.post = op.pre
}
check tc_WD_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- Proxy: limiting channels && resources per operation reduces latency (target <5s)
    all op: REQ_WD_01 | #op.channel <= 2 && #op.target <= 3
}

fact nfr_fact_availability {
    -- Proxy: at least two interfaces exist to support 99.9% uptime via redundancy
    #Interface >= 2
}

fact nfr_fact_scalability {
    -- Proxy: every actor can initiate at least one operation (capacity for 1000 TPM)
    all a: Actor | some op: REQ_WD_01 | op.initiator = a
}

assert nfr_assert_usability {
    -- Proxy: limiting authenticated interfaces to <= 2 reduces cognitive load (clearer errors)
    #{i: Interface | i.authenticated = True} <= 2
}
check nfr_assert_usability for 5

