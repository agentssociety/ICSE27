module REQ_AUTH_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-AUTH-01
 * Title       : Logging Authentication Attempts and Transaction State Changes
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig System_Administrator, Security_Team extends Actor {}
-- System_Administrator: represents stakeholder 'System Administrator'
-- Security_Team: represents stakeholder 'Security Team'

-- Assign permissions to actors (minimal for model satisfaction)
fact actor_permissions {
    System_Administrator.mayPerform = Read + Write + Execute + Admin
    Security_Team.mayPerform = Read
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Introduce a dedicated resource for the audit log database
one sig AuditLogResource extends Resource {}

fact audit_log_ownership {
    AuditLogResource.owner = System_Administrator
    System_Administrator in AuditLogResource.accessible
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

-- Channel status for modeling network failures
sig ChannelStatus {}
one sig Operational, Failed extends ChannelStatus {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool,       -- requires caller identity
    status        : one ChannelStatus -- operational health
}

one sig Audit_Log_Database, Authentication_API extends Interface {}

fact interface_properties {
    Audit_Log_Database.kind = Database
    Authentication_API.kind = API
}

-- Default channel status to Operational to allow successful operations
fact channel_status_default {
    all i: Interface | i.status = Operational
}

----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3, Post4 extends State {}
-- Post1: system reaches state where All authentication attempts are recorded in the logs
-- Post2: system reaches state where All transaction state changes are recorded in the logs
-- Post3: system reaches state where Each log entry includes a precise timestamp
-- Post4: system reaches state where Logs are stored in a tamper-proof or append-only format


----------------------------------------------------------------------
-- Load level for modeling heavy load scenarios
----------------------------------------------------------------------

sig LoadLevel {}
one sig Normal, Heavy extends LoadLevel {}

----------------------------------------------------------------------
-- Core operation: REQ_AUTH_01
----------------------------------------------------------------------

sig REQ_AUTH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State,           -- postcondition that is established
    load       : one  LoadLevel        -- system load at operation time
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_AUTH_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_AUTH_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_AUTH_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_AUTH_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_AUTH_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_AUTH_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_AUTH_01 | op.post in Post1 + Post2 + Post3 + Post4
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_AUTH_01 {
    some op: REQ_AUTH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_AUTH_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_AUTH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_AUTH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_AUTH_01_well_formed {
    all op: REQ_AUTH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_AUTH_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1: All authentication attempts are recorded in the logs
pred ps_reach_Post1 {
    some op: REQ_AUTH_01 |
        op.post = Post1 &&
        -- Authentication API must be involved as a channel
        some c: op.channel | c.kind = Authentication_API &&
        -- The operation must involve authentication-related permission
        Read in op.grant &&
        -- Transition: pre state is ! already Post1
        op.pre != Post1 &&
        -- Initiator must have appropriate permission to record logs
        Read in op.initiator.mayPerform
}

assert ps_valid_Post1 {
    all op: REQ_AUTH_01 |
        (op.post = Post1) =>
            -- All authentication attempts are recorded: the operation
            -- must involve an authentication channel && result in a
            -- log entry being created (represented by reaching Post1 state)
            some c: op.channel | c.kind = Authentication_API &&
            Read in op.grant &&
            op.pre != Post1
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

-- Post2: All transaction state changes are recorded in the logs
pred ps_reach_Post2 {
    some op: REQ_AUTH_01 |
        op.post = Post2 &&
        -- Must involve a transaction-related permission
        Write in op.grant &&
        -- The channel must be capable of recording state changes
        some c: op.channel | c.authenticated = True &&
        -- Transition from a non-Post2 state
        op.pre != Post2 &&
        -- Initiator must have write permission
        Write in op.initiator.mayPerform
}

assert ps_valid_Post2 {
    all op: REQ_AUTH_01 |
        (op.post = Post2) =>
            -- All transaction state changes are recorded: the operation
            -- must involve write permission && an authenticated channel
            Write in op.grant &&
            some c: op.channel | c.authenticated = True &&
            op.pre != Post2
}

run ps_reach_Post2 for 5
check ps_valid_Post2 for 5

-- Post3: Each log entry includes a precise timestamp
pred ps_reach_Post3 {
    some op: REQ_AUTH_01 |
        op.post = Post3 &&
        -- Timestamp recording requires a specific interface kind
        some c: op.channel | c.kind = API &&
        -- Must involve a permission related to time-stamping
        Read in op.grant &&
        -- Transition from a state without timestamps
        op.pre != Post3 &&
        -- Initiator must have read permission
        Read in op.initiator.mayPerform
}

assert ps_valid_Post3 {
    all op: REQ_AUTH_01 |
        (op.post = Post3) =>
            -- Each log entry includes a precise timestamp: the operation
            -- must use an API channel && involve read permission
            some c: op.channel | c.kind = API &&
            Read in op.grant &&
            op.pre != Post3
}

run ps_reach_Post3 for 5
check ps_valid_Post3 for 5

-- Post4: Logs are stored in a tamper-proof || append-only format
pred ps_reach_Post4 {
    some op: REQ_AUTH_01 |
        op.post = Post4 &&
        -- Must involve write permission for append-only storage
        Write in op.grant &&
        -- The channel must support secure storage
        some c: op.channel | c.encrypted = True &&
        -- Transition from a non-secure state
        op.pre != Post4 &&
        -- Initiator must have write permission
        Write in op.initiator.mayPerform
}

assert ps_valid_Post4 {
    all op: REQ_AUTH_01 |
        (op.post = Post4) =>
            -- Logs are stored in a tamper-proof format: the operation
            -- must involve write permission && encrypted channel
            Write in op.grant &&
            some c: op.channel | c.encrypted = True &&
            op.pre != Post4
}

run ps_reach_Post4 for 5
check ps_valid_Post4 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Acceptance criterion 1: authentication attempt recorded with outcome (state Post1) in audit log
pred ac_reach_1 {
    some op: REQ_AUTH_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        AuditLogResource in op.target
}
run ac_reach_1 for 5

-- Acceptance criterion 2: state transition recorded (state Post2) in audit log
pred ac_reach_2 {
    some op: REQ_AUTH_01 |
        op.post = Post2 &&
        Write in op.initiator.mayPerform &&
        AuditLogResource in op.target
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Heavy load scenario - when system is under heavy load, logging operations must still complete
assert ec_safe_1 {
    all op: REQ_AUTH_01 |
        -- Under heavy load, the operation must still transition to a valid post state
        (op.load = Heavy) => (
            op.post in Post1 + Post2 + Post3 + Post4
        )
}
check ec_safe_1 for 5

-- Edge case 2: Network failures during logging - channels must remain functional
assert ec_safe_2 {
    all op: REQ_AUTH_01 |
        -- If any channel fails, the operation must still maintain security properties
        (some c: op.channel | c.status = Failed) => (
            -- The initiator must still be authorized
            op.grant in op.initiator.mayPerform &&
            -- Target resources must still be accessible
            all r: op.target | op.initiator in r.accessible
        )
}
check ec_safe_2 for 5

-- Edge case 3: Concurrent state changes - operations must maintain state consistency
-- Define a sig to represent concurrent operations
sig ConcurrentOp {
    ops: some REQ_AUTH_01,
    sharedTarget: Resource
}

assert ec_safe_3 {
    all c: ConcurrentOp |
        -- If multiple operations share a target resource
        (#c.ops > 1) => (
            -- Their grants must be compatible (no conflicting permissions)
            all disj o1, o2: c.ops |
                (o1.grant = Write && o2.grant = Write) => o1.initiator = o2.initiator
        )
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-AUTH-01: Successful login attempt recorded with timestamp
pred tc_TC_AUTH_01_holds {
    some op: REQ_AUTH_01 |
        AuditLogResource in op.target &&
        op.pre != op.post
}
run tc_TC_AUTH_01_holds for 5

assert tc_TC_AUTH_01_contract {
    all op: REQ_AUTH_01 |
        (AuditLogResource in op.target) => (op.pre != op.post)
}
check tc_TC_AUTH_01_contract for 5

-- TC-AUTH-02: Failed login attempt recorded with timestamp
pred tc_TC_AUTH_02_holds {
    some op: REQ_AUTH_01 |
        AuditLogResource in op.target &&
        op.pre != op.post
}
run tc_TC_AUTH_02_holds for 5

assert tc_TC_AUTH_02_contract {
    all op: REQ_AUTH_01 |
        (AuditLogResource in op.target) => (op.pre != op.post)
}
check tc_TC_AUTH_02_contract for 5

-- TC-TRANS-01: Transaction state change recorded with timestamp
pred tc_TC_TRANS_01_holds {
    some op: REQ_AUTH_01 |
        op.pre != op.post &&
        AuditLogResource in op.target
}
run tc_TC_TRANS_01_holds for 5

assert tc_TC_TRANS_01_contract {
    all op: REQ_AUTH_01 |
        (op.pre != op.post) => (AuditLogResource in op.target)
}
check tc_TC_TRANS_01_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: fewer communication channels per operation reduce latency overhead
fact nfr_fact_performance_latency {
    all op: REQ_AUTH_01 | #op.channel <= 2
}

-- Proxy: each resource is served by multiple independent operations for redundancy
fact nfr_fact_availability_redundancy {
    all r: Resource | #{op: REQ_AUTH_01 | r in op.target} >= 2
}

-- Proxy: every actor in the system must be able to initiate at least one operation
assert nfr_assert_scalability {
    all a: Actor | some op: REQ_AUTH_01 | op.initiator = a
}
check nfr_assert_scalability for 5

-- Proxy: limiting resource count per operation improves interface simplicity
fact nfr_fact_usability_simple_interfaces {
    all op: REQ_AUTH_01 | #op.target <= 2
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Requirement: Logs should be stored in a tamper-proof || append-only format
-- Introduce minimal audit log concept
one sig AuditLog {
    entries: set AuditLogEntry
}

sig AuditLogEntry {
    operation: one REQ_AUTH_01,
    timestamp: one Int
}

-- Fact: All operations must be logged
fact sr_fact_operation_logged {
    all op: REQ_AUTH_01 | one entry: AuditLogEntry | entry.operation = op
}

-- Assertion: Log entries cannot be modified after creation (append-only)
assert sr_assert_append_only_log {
    all op1, op2: REQ_AUTH_01 | op1 != op2 =>
        (all e1: AuditLogEntry | e1.operation = op1 =>
            no e2: AuditLogEntry | e2.operation = op2 && e2.timestamp = e1.timestamp)
}

check sr_assert_append_only_log for 5

-- Assertion: Each log entry has a unique timestamp (tamper-evident ordering)
assert sr_assert_unique_timestamps {
    all disj e1, e2: AuditLogEntry | e1.timestamp != e2.timestamp
}

check sr_assert_unique_timestamps for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines REQ_AUTH_01 operations with structural invariants, post-state reachability, acceptance criterion reachability, edge case safety assertions for load, network failure, and concurrency, test scenario contracts, non-functional proxies, and security properties on logging.
-- Summary 2: All references to Audit_Log_Database as a target were corrected to use AuditLogResource (a Resource).
-- Summary 3: Channel status and load level fields were added directly to Interface and REQ_AUTH_01 respectively, eliminating separate extension sigs.
-- Summary 4: Actor permissions were explicitly assigned to satisfy invariants and enable runs.
-- Assumption 1: System_Administrator has all permissions (Read, Write, Execute, Admin) and Security_Team has only Read.
-- Assumption 2: AuditLogResource is owned by System_Administrator and accessible to System_Administrator.
-- Assumption 3: All interfaces start as Operational by default.
-- Assumption 4: The append-only property is approximated by asserting unique timestamps and that each operation has exactly one log entry.
-- Open issue 1: The unused `stronger` function from the permission lattice remains; it could be removed or used in future assertions.
-- Open issue 2: The mapping from acceptance criteria to specific post-states (Post1..Post4) is a simplified abstraction; more detailed modeling may be needed.
-- Open issue 3: Static Alloy model cannot truly enforce dynamic append-only behavior; the properties checked are necessary but not sufficient.
-- Open issue 4: Some runs (e.g., ec_safe_1) may be vacuously satisfied if no operation has Heavy load; an explicit run to generate such instances is not provided.


