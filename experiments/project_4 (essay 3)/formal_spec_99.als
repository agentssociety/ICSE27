module REQ_SEC_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-SEC-01
 * Title       : Detection and Flagging of Suspicious Withdrawal Patterns
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Security_Team, Finance_Team, Operations_Team extends Actor {}
-- Security_Team: represents stakeholder 'Security Team'
-- Finance_Team: represents stakeholder 'Finance Team'
-- Operations_Team: represents stakeholder 'Operations Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Withdrawal_API, Transaction_Database extends Interface {}

fact interface_properties {
    Withdrawal_API.kind = API  -- Interface through which withdrawal requests are submitted to the system.
    Transaction_Database.kind = Database  -- Stores historical transaction data for pattern detection.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The suspicious withdrawal pattern has been identified and flagged for review.


----------------------------------------------------------------------
-- Core operation: REQ_SEC_01
----------------------------------------------------------------------

sig REQ_SEC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_SEC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_SEC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_SEC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_SEC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_SEC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_SEC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_SEC_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SEC_01 {
    some op: REQ_SEC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SEC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_SEC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_SEC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_SEC_01_well_formed {
    all op: REQ_SEC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SEC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_SEC_01 |
        op.post = Post1 &&
        Withdrawal_API in op.target &&
        op.initiator = Security_Team &&
        op.grant = Admin &&
        op.channel.encrypted = True &&
        op.channel.authenticated = True &&
        op.pre = PreIdle
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_SEC_01 |
        (op.post = Post1) => (
            Withdrawal_API in op.target &&
            op.initiator = Security_Team &&
            op.grant = Admin
        )
}
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Acceptance Criterion 1: When a withdrawal pattern involves rapid successive withdrawals || unusual amounts, then the pattern is flagged for review.
-- Mapping: 'unusual amounts' is represented by an Admin grant permission (unusual for normal operations).
-- 'Flagged for review' is represented by the post-state being Post1.
-- The operation uses the Withdrawal_API channel && affects the Transaction_Database resource.
pred ac_reach_1 {
    some op: REQ_SEC_01 |
        // Channel kind indicates withdrawal API
        (some c: op.channel | c.kind = Withdrawal_API) &&
        // Target includes the transaction database
        Transaction_Database in op.target &&
        // Unusual permission (Admin)
        op.grant = Admin &&
        // Post-state indicates flagged review
        op.post = Post1 &&
        // Pre-state is idle (before operation)
        op.pre = PreIdle
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Concurrent rapid successive withdrawals from multiple users
-- Safety: No two operations with different initiators can share the same target resource 
-- && both succeed (post != pre) within the same state transition.
assert ec_safe_1 {
    all op1, op2: REQ_SEC_01 |
        (op1 != op2 &&
         op1.target & op2.target != none &&
         op1.initiator != op2.initiator &&
         op1.post != op1.pre &&
         op2.post != op2.pre) =>
            -- If they share a target, they must use different channels to avoid race condition
            no c: Interface | c in op1.channel && c in op2.channel
}
check ec_safe_1 for 5

-- Edge case 2: Withdrawal patterns involving unusual amounts that are ! fraudulent
-- Safety: Large legitimate transactions must ! be blocked solely due to amount size.
-- We model this by ensuring that if an initiator has Admin permission, any target resource
-- can be accessed regardless of amount (represented by grant permission).
assert ec_safe_2 {
    all op: REQ_SEC_01 |
        (Admin in op.initiator.mayPerform) =>
            (op.grant in Read + Write + Execute)  -- Admin can perform any operation type
}
check ec_safe_2 for 5

-- Edge case 3: System under heavy load during withdrawal processing
-- Safety: Under heavy load (multiple concurrent operations), the system must still
-- maintain authentication requirements. No operation may bypass authentication.
assert ec_safe_3 {
    all op: REQ_SEC_01 |
        -- All channels used must be authenticated, even under heavy load
        all c: Interface | c in op.channel => c.authenticated = True
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-SEC-01: Multiple rapid successive withdrawals from a single user ? Pattern flagged && submitted for review
pred tc_SEC_01_holds {
    some op: REQ_SEC_01 |
        -- Input: multiple rapid successive withdrawals from a single user
        op.initiator in Security_Team &&
        op.grant = Execute &&
        some op.target & Transaction_Database &&
        some op.channel & Withdrawal_API &&
        -- Expected: Pattern flagged && submitted for review
        op.post = Post1 &&
        op.pre = PreIdle
}
run tc_SEC_01_holds for 5

assert tc_SEC_01_contract {
    all op: REQ_SEC_01 |
        -- Input pre-conditions
        (op.initiator in Security_Team &&
         op.grant = Execute &&
         some op.target & Transaction_Database &&
         some op.channel & Withdrawal_API &&
         op.pre = PreIdle) =>
        -- Expected post-conditions
        op.post = Post1
}
check tc_SEC_01_contract for 5

-- Scenario TC-SEC-02: Large transaction by a legitimate user ? No pattern flagged, normal processing continues
pred tc_SEC_02_holds {
    some op: REQ_SEC_01 |
        -- Input: large transaction by a legitimate user
        op.initiator in Finance_Team &&
        op.grant = Write &&
        some op.target & Transaction_Database &&
        some op.channel & API &&
        -- Expected: No pattern flagged, normal processing continues
        op.post != op.pre &&
        op.post != Post1
}
run tc_SEC_02_holds for 5

assert tc_SEC_02_contract {
    all op: REQ_SEC_01 |
        -- Input pre-conditions
        (op.initiator in Finance_Team &&
         op.grant = Write &&
         some op.target & Transaction_Database &&
         some op.channel & API) =>
        -- Expected post-conditions
        (op.post != op.pre &&
         op.post != Post1)
}
check tc_SEC_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: Detection of suspicious patterns should be completed within 100 milliseconds.
-- Proxy: Limiting the number of interfaces per operation reduces processing overhead.
fact nfr_fact_performance_latency {
    all op: REQ_SEC_01 | #op.channel <= 1
}

-- Availability: The system must be available 99.9% of the time.
-- Proxy: Requiring at least two channels ensures redundancy for continuous monitoring.
fact nfr_fact_availability_redundancy {
    all op: REQ_SEC_01 | #op.channel >= 2
}

-- Scalability: The system shall handle up to 1,000 withdrawal requests per second.
-- Proxy: Allowing all actors to be initiators in some operation ensures no single point of bottleneck.
assert nfr_assert_scalability_capacity {
    all a: Actor | some op: REQ_SEC_01 | op.initiator = a
}
check nfr_assert_scalability_capacity for 5

-- Usability: Error handling should provide clear && actionable feedback.
-- Proxy: Ensuring authenticated channels have a defined kind prevents ambiguous error states.
assert nfr_assert_usability_feedback {
    all i: Interface | i.kind = API => i.authenticated = True
}
check nfr_assert_usability_feedback for 5

-- Maintainability: No circular resource ownership ensures clean system evolution.
-- Proxy: Resource owner cannot be the same as any accessible actor.
fact nfr_fact_maintainability_no_circular {
    all r: Resource | r.owner ! in r.accessible
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- ??? SECURITY PATTERN: Suspicious Withdrawal Detection ???
-- The system shall detect suspicious withdrawal patterns without
-- false positives || negatives.  We model this by constraining the
-- relationship between the pre state (PreIdle) && the post state
-- (Post1) for withdrawal operations.  A withdrawal is "suspicious"
-- if its initiator is ! the resource owner && the grant is Write.

-- Helper predicate: a withdrawal operation is suspicious <=>
--   (1) the target is a Transaction_Database (|| any Resource with
--       financial semantics) &&
--   (2) the initiator is ! the resource owner &&
--   (3) the granted permission is Write.
-- We use the existing Resource && Actor fields.

pred is_suspicious_withdrawal [op: REQ_SEC_01] {
    -- target must be a Resource that models a transaction database
    some r: op.target | r in Transaction_Database
    -- initiator is ! the owner of that resource
    && no r: op.target | r.owner = op.initiator
    -- the permission being granted is Write
    && Write in op.grant
}

-- The detection mechanism (flag) must be present in the post state.
-- Since we have only Post1 as a concrete post state, we assert that
-- every suspicious withdrawal must result in Post1 (the flagged state).
fact sr_fact_detection_mapping {
    all op: REQ_SEC_01 |
        is_suspicious_withdrawal[op] => op.post = Post1
}

-- No false negatives: every truly suspicious withdrawal must be flagged.
-- (This is already enforced by the mapping fact above.)

-- No false positives: every flagged operation must indeed be suspicious.
assert sr_assert_no_false_positive {
    all op: REQ_SEC_01 |
        op.post = Post1 => is_suspicious_withdrawal[op]
}
check sr_assert_no_false_positive for 5

-- The detection environment must be secure: only authenticated channels
-- may carry the operation.
assert sr_assert_secure_channel_for_detection {
    all op: REQ_SEC_01 |
        is_suspicious_withdrawal[op] =>
            (all c: op.channel | c.authenticated = True)
}
check sr_assert_secure_channel_for_detection for 5


