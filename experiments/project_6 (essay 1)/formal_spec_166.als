module REQ_GROUP_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-GROUP-01
 * Title       : Group Owner/Admin Join Request Management
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Group_Owners_Admins, Group_Members, System_Administrators extends Actor {}
-- Group_Owners_Admins: represents stakeholder 'Group Owners/Admins'
-- Group_Members: represents stakeholder 'Group Members'
-- System_Administrators: represents stakeholder 'System Administrators'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resources representing the join requests database and group membership
one sig JoinRequestsResource, GroupMembershipResource extends Resource {}

-- Set ownership and access appropriately
fact resource_ownership {
    JoinRequestsResource.owner = Group_Owners_Admins
    JoinRequestsResource.accessible = Group_Owners_Admins + System_Administrators
    GroupMembershipResource.owner = Group_Owners_Admins
    GroupMembershipResource.accessible = Group_Owners_Admins + System_Administrators
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Join_Requests_Database, Group_API extends Interface {}

fact interface_properties {
    Join_Requests_Database.kind = Database
    Group_API.kind = API
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system is running and accessible.
-- Pre2: system is in state where The user is authenticated as a group owner/admin.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where Pending join requests are either approved or rejected.
-- Post2: system reaches state where Approved users are added to the private group.
-- Post3: system reaches state where Rejected requests are removed from the list.


----------------------------------------------------------------------
-- Core operation: REQ_GROUP_01
----------------------------------------------------------------------

sig REQ_GROUP_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Permission assignment to actors
----------------------------------------------------------------------

fact permission_assignment {
    Group_Owners_Admins.mayPerform = Admin
    System_Administrators.mayPerform = Admin
    Group_Members.mayPerform = Read
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_GROUP_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_GROUP_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_GROUP_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_GROUP_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_GROUP_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_GROUP_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_GROUP_01 | op.post in Post1 + Post2 + Post3
}


----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_GROUP_01 {
    some op: REQ_GROUP_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_GROUP_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_GROUP_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_GROUP_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_GROUP_01_well_formed {
    all op: REQ_GROUP_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_GROUP_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates && semantic assertions for Post1, Post2, Post3

-- Post1: Pending join requests are either approved || rejected
pred ps_reach_Post1 {
    some op: REQ_GROUP_01 |
        op.post = Post1 &&
        op.grant = Admin &&
        some c: op.channel | c.kind = API &&
        op.pre in Pre1+Pre2 &&
        op.pre != op.post
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_GROUP_01 |
        op.post = Post1 => (op.grant = Admin &&
                            some c: op.channel | c.kind = API &&
                            op.pre != op.post)
}
check ps_valid_Post1 for 5

-- Post2: Approved users are added to the private group
pred ps_reach_Post2 {
    some op: REQ_GROUP_01 |
        op.post = Post2 &&
        op.grant = Admin &&
        some c: op.channel | c.kind = API &&
        op.pre in Pre1+Pre2 &&
        op.pre != op.post
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_GROUP_01 |
        op.post = Post2 => (op.grant = Admin &&
                            some c: op.channel | c.kind = API &&
                            op.pre != op.post)
}
check ps_valid_Post2 for 5

-- Post3: Rejected requests are removed from the list
pred ps_reach_Post3 {
    some op: REQ_GROUP_01 |
        op.post = Post3 &&
        op.grant = Admin &&
        some c: op.channel | c.kind = Database &&
        op.pre in Pre1+Pre2 &&
        op.pre != op.post
}
run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_GROUP_01 |
        op.post = Post3 => (op.grant = Admin &&
                            some c: op.channel | c.kind = Database &&
                            op.pre != op.post)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Members &&
        op.grant = Read &&
        (all r: op.target | r.owner = Group_Owners_Admins) &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Owners_Admins &&
        op.grant = Admin &&
        (all r: op.target | r.owner = Group_Owners_Admins) &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post2
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Owners_Admins &&
        op.grant = Admin &&
        (all r: op.target | r.owner = Group_Owners_Admins) &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post2
}
run ac_reach_3 for 5

pred ac_reach_4 {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Owners_Admins &&
        op.grant = Admin &&
        (all r: op.target | r.owner = Group_Owners_Admins) &&
        (some c: op.channel | c.authenticated = True) &&
        (op.post = Post2 || op.post = Post3)
}
run ac_reach_4 for 5

pred ac_reach_5 {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Owners_Admins &&
        op.grant = Admin &&
        (all r: op.target | r.owner = Group_Owners_Admins) &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post2
}
run ac_reach_5 for 5

pred ac_reach_6 {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Owners_Admins &&
        op.grant = Admin &&
        (all r: op.target | r.owner = Group_Owners_Admins) &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post3
}
run ac_reach_6 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: No operation may have a pre state that is already a final state (Post1, Post2, Post3)
-- This prevents processing a request that has already been handled.
assert ec_safe_1 {
    all op: REQ_GROUP_01 | op.pre ! in (Post1 + Post2 + Post3)
}
check ec_safe_1 for 5

-- Edge case 2: Concurrent operations on the same target with the same pre state must have compatible grants
-- (same grant) to avoid conflicting approval/rejection decisions.
assert ec_safe_2 {
    all disj op1, op2: REQ_GROUP_01 |
        (op1.target = op2.target && op1.pre = op2.pre) => op1.grant = op2.grant
}
check ec_safe_2 for 5

-- Introduce helper sig to represent pending join requests
sig PendingRequest {
    resource: one Resource
}

-- Edge case 3: An operation that processes a pending request (pre = Pre1) must have a corresponding pending request for that target.
-- This ensures that no operation acts on a nonexistent request.
assert ec_safe_3 {
    all op: REQ_GROUP_01 |
        op.pre = Pre1 => some pr: PendingRequest | pr.resource = op.target
}
check ec_safe_3 for 5

-- Edge case 4: No operation may target a resource that is being deleted (pre = Pre2) while a request is being processed (pre = Pre1) on the same resource.
-- This prevents inconsistency from concurrent group deletion && request processing.
assert ec_safe_4 {
    no disj op1, op2: REQ_GROUP_01 |
        op1.target = op2.target && op1.pre = Pre1 && op2.pre = Pre2
}
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-JR-01: Display pending join requests
pred tc_JR01_holds {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Owners_Admins &&
        JoinRequestsResource in op.target &&
        some PendingRequest &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        all c: op.channel | c.authenticated = True && c.encrypted = True
}
run tc_JR01_holds for 5
assert tc_JR01_contract {
    all op: REQ_GROUP_01 |
        (op.initiator = Group_Owners_Admins &&
         JoinRequestsResource in op.target &&
         some PendingRequest &&
         op.pre = Pre1)
        => op.post = Post1
}
check tc_JR01_contract for 5

-- Scenario TC-JR-02: Approve a pending join request
pred tc_JR02_holds {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Owners_Admins &&
        GroupMembershipResource in op.target &&
        op.grant = Write &&
        some PendingRequest &&
        op.pre = Pre2 &&
        op.post = Post2 &&
        all c: op.channel | c.authenticated = True
}
run tc_JR02_holds for 5
assert tc_JR02_contract {
    all op: REQ_GROUP_01 |
        (op.initiator = Group_Owners_Admins &&
         GroupMembershipResource in op.target &&
         op.grant = Write &&
         some PendingRequest &&
         op.pre = Pre2)
        => op.post = Post2
}
check tc_JR02_contract for 5

-- Scenario TC-JR-03: Reject a pending join request
pred tc_JR03_holds {
    some op: REQ_GROUP_01 |
        op.initiator = Group_Owners_Admins &&
        JoinRequestsResource in op.target &&
        op.grant = Write &&
        some PendingRequest &&
        op.pre = Pre2 &&
        op.post = Post3 &&
        all c: op.channel | c.authenticated = True
}
run tc_JR03_holds for 5
assert tc_JR03_contract {
    all op: REQ_GROUP_01 |
        (op.initiator = Group_Owners_Admins &&
         JoinRequestsResource in op.target &&
         op.grant = Write &&
         some PendingRequest &&
         op.pre = Pre2)
        => op.post = Post3
}
check tc_JR03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting channel count reduces communication latency, targeting <5s response.
    all op: REQ_GROUP_01 | #op.channel <= 2
}

fact nfr_fact_availability {
    -- PROXY: redundant interfaces ensure system availability >= 99.9%
    #Interface > 1
}

fact nfr_fact_scalability {
    -- PROXY: at least two pending requests can exist simultaneously, indicating ability to handle concurrency
    #PendingRequest >= 2
}

fact nfr_fact_usability {
    -- PROXY: enforcing consistent interface authentication reduces user confusion, leading to clearer error messages
    all i: Interface | i.authenticated = True
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security property 1: Access to join request management is restricted to group owners/admins.
-- This means the initiator must be in the Group_Owners_Admins set when acting on JoinRequestsResource
assert sr_assert_join_request_admin_only {
    all op: REQ_GROUP_01 |
        (JoinRequestsResource in op.target) =>
        op.initiator = Group_Owners_Admins
}
check sr_assert_join_request_admin_only for 5

-- Security property 2: User details in pending requests must be encrypted at rest and in transit.
-- Encryption in transit: all channels used in the operation must be encrypted
assert sr_assert_encryption_in_transit_pending {
    all op: REQ_GROUP_01 |
        (JoinRequestsResource in op.target) =>
        (all c: op.channel | c.encrypted = True)
}
check sr_assert_encryption_in_transit_pending for 5

-- Encryption at rest: all pending request data (modeled through PendingRequest) must be accessible only via encrypted channels
-- This requires a helper sig to track encrypted storage
sig EncryptedStorage {
    stores: set PendingRequest
}
fact sr_fact_encrypted_storage {
    all pr: PendingRequest |
        some e: EncryptedStorage | pr in e.stores
}

-- Ensure that encrypted storage is only accessible through interfaces that are encrypted and required authentication
assert sr_assert_encryption_at_rest_pending {
    all op: REQ_GROUP_01 |
        (JoinRequestsResource in op.target) =>
        (all pr: PendingRequest | pr.resource in op.target =>
            (all c: op.channel | c.encrypted = True && c.authenticated = True))
}
check sr_assert_encryption_at_rest_pending for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model captures group join request management with explicit states, permissions, resources, and interfaces.
-- Summary 2: Key invariants ensure authorization, resource access control, state change, and authentication.
-- Summary 3: Test scenarios for displaying, approving, and rejecting requests are formalized.
-- Summary 4: Security assertions enforce admin-only access and encryption of pending request data.
-- Assumption 1: Group_Owners_Admins and System_Administrators are assigned Admin permission; Group_Members only Read.
-- Assumption 2: JoinRequestsResource and GroupMembershipResource are owned by Group_Owners_Admins.
-- Assumption 3: Pre/Post states abstract request lifecycle; Pre2 implies user is authenticated as admin.
-- Assumption 4: Concurrent operations on same target and pre must use same grant to avoid conflicts.
-- Open issue 1: PendingRequest is not explicitly linked to operation outcomes (approve/reject status is abstracted via states).
-- Open issue 2: The model does not handle group deletion or resource removal explicitly beyond edge case assertions.


