----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_post_creation_01_holds {
    some op: REQ_CONTENT_PUB_01 |
        -- input: user creates a post with text content only
        op.initiator in Content_Creators &&
        op.grant = Write &&
        -- expected: post successfully created, saved in database, visible to other users
        some r: op.target | r.owner = op.initiator &&
        op.post != op.pre &&
        some a: Actor | a != op.initiator && a in r.accessible
}
run tc_post_creation_01_holds for 5

assert tc_post_creation_01_contract {
    all op: REQ_CONTENT_PUB_01 |
        (op.initiator in Content_Creators && op.grant = Write) =>
        (some r: op.target | r.owner = op.initiator && op.post != op.pre &&
         some a: Actor | a != op.initiator && a in r.accessible)
}
check tc_post_creation_01_contract for 5

pred tc_post_creation_02_holds {
    some op: REQ_CONTENT_PUB_01 |
        -- input: user creates a post with both text && images
        op.initiator in Content_Creators &&
        op.grant = Write &&
        -- expected: post created, saved, visible, images stored securely && linked
        some r: op.target | r.owner = op.initiator &&
        op.post != op.pre &&
        some a: Actor | a != op.initiator && a in r.accessible &&
        some c: op.channel | c.encrypted = True
}
run tc_post_creation_02_holds for 5

assert tc_post_creation_02_contract {
    all op: REQ_CONTENT_PUB_01 |
        (op.initiator in Content_Creators && op.grant = Write) =>
        (some r: op.target | r.owner = op.initiator && op.post != op.pre &&
         some a: Actor | a != op.initiator && a in r.accessible &&
         some c: op.channel | c.encrypted = True)
}
check tc_post_creation_02_contract for 5

pred tc_post_creation_03_holds {
    some op: REQ_CONTENT_PUB_01 |
        -- input: user tries to create a post without content || images
        op.initiator in Content_Creators &&
        op.grant = Write &&
        -- expected: system rejects request, error message displayed
        -- no resource is created || modified
        no r: op.target | r.owner = op.initiator &&
        op.post = op.pre
}
run tc_post_creation_03_holds for 5

assert tc_post_creation_03_contract {
    all op: REQ_CONTENT_PUB_01 |
        (op.initiator in Content_Creators && op.grant = Write &&
         no r: op.target | r.owner = op.initiator) =>
        op.post = op.pre
}
check tc_post_creation_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_latency {
    -- PROXY: minimizing target count reduces processing time for text+image posts
    -- NFR: respond within 2 seconds for creating/saving post with text && images
    all op: REQ_CONTENT_PUB_01 | #op.target <= 3
}

fact nfr_fact_availability_redundancy {
    -- PROXY: requiring multiple channels ensures failover capability
    -- NFR: system must be available 99.9% of the time
    all op: REQ_CONTENT_PUB_01 | #op.channel >= 2
}

fact nfr_fact_scalability_concurrent {
    -- PROXY: all actors must be able to initiate operations simultaneously
    -- NFR: handle at least 1,000 concurrent users without degradation
    all a: Actor | some op: REQ_CONTENT_PUB_01 | op.initiator = a
}

fact nfr_fact_usability_clear_errors {
    -- PROXY: limiting authenticated channels reduces complexity for user-friendly errors
    -- NFR: error messages should be clear && user-friendly
    all op: REQ_CONTENT_PUB_01 | #op.channel <= 2
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Authentication: At least one channel must be authenticated (weaker than all channels).
assert sr_assert_authentication {
  all op: REQ_CONTENT_PUB_01 | some c: op.channel | c.authenticated = True
}
check sr_assert_authentication for 5

-- Encryption-in-transit: At least one channel must be encrypted (weaker than all channels).
assert sr_assert_encryption {
  all op: REQ_CONTENT_PUB_01 | some c: op.channel | c.encrypted = True
}
check sr_assert_encryption for 5

-- Integrity: Only the resource owner or an Admin may perform a write operation on each resource.
assert sr_assert_integrity {
  all op: REQ_CONTENT_PUB_01 |
    (Write in op.initiator.mayPerform) =>
    (all r: op.target | op.initiator = r.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_integrity for 5

-- Privilege separation: No non-Admin actor may be both initiator and owner of a written resource.
assert sr_assert_privilege_separation {
  all op: REQ_CONTENT_PUB_01 |
    (Write in op.initiator.mayPerform) =>
    (all r: op.target | (r.owner = op.initiator) implies (Admin in op.initiator.mayPerform))
}
check sr_assert_privilege_separation for 5


