module REQ_MEM_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-MEM-01
 * Title       : Group Post Feed Filter
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Owner, Engineering_Team, UX_UI_Designer extends Actor {}
-- Product_Owner: represents stakeholder 'Product Owner'
-- Engineering_Team: represents stakeholder 'Engineering Team'
-- UX_UI_Designer: represents stakeholder 'UX/UI Designer'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Group_API, Post_Database extends Interface {}

fact interface_properties {
    Group_API.kind = API  -- The requirement interacts with this API to retrieve the list of groups a user belongs to.
    Post_Database.kind = Database  -- The requirement retrieves posts from this database, filtering them based on group membership.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where I am a group member logged into the system
-- Pre2: system is in state where I belong to multiple groups

-- Concrete post-states (one per distinct postcondition).
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_MEM_01
----------------------------------------------------------------------

sig REQ_MEM_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_MEM_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_MEM_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_MEM_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_MEM_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_MEM_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_MEM_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_MEM_01 {
    some op: REQ_MEM_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_MEM_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_MEM_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_MEM_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_MEM_01_well_formed {
    all op: REQ_MEM_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_MEM_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

--ac_reach_1: I see only posts from the groups I belong to
pred ac_reach_1 {
  some op: REQ_MEM_01 |
    all r: op.target |
      op.initiator in r.accessible
}
run ac_reach_1 for 5

-- ac_reach_2: I do NOT see posts from groups I am NOT a member of
pred ac_reach_2 {
  some op: REQ_MEM_01 |
    no r: Resource |
      r in op.target && op.initiator !in r.accessible
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: A user joining a new group after viewing the feed should NOT cause the operation to violate access control
assert ec_safe_1 {
    all op: REQ_MEM_01 |
        -- If the initiator has Read permission but NOT Admin permission,
        -- joining a new group (modeled as gaining new accessible resources)
        -- should NOT retroactively invalidate the operation's access
        (Read in op.initiator.mayPerform && Admin !in op.initiator.mayPerform) =>
            (op.initiator in op.target.accessible)
}
check ec_safe_1 for 5

-- Edge case 2: Large groups with high post volume should NOT cause resource access violations
-- Model a large group as a Resource with many accessible actors
assert ec_safe_2 {
    all op: REQ_MEM_01 |
        -- If a resource has many accessible actors (large group),
        -- the initiator must still be authorized for the target
        (#op.target.accessible > 2) =>
            (op.initiator in op.target.accessible)
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_mem_01_holds {
    some op: REQ_MEM_01 |
        op.pre = Pre1 && op.post = PostDone
}
run tc_mem_01_holds for 5

assert tc_mem_01_contract {
    all op: REQ_MEM_01 |
        op.pre = Pre1 => op.post = PostDone
}
check tc_mem_01_contract for 5

pred tc_mem_02_holds {
    some op: REQ_MEM_01 |
        op.pre = Pre2 && op.post = PostDone
}
run tc_mem_02_holds for 5

assert tc_mem_02_contract {
    all op: REQ_MEM_01 |
        op.pre = Pre2 => op.post = PostDone
}
check tc_mem_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- PROXY: Limiting the number of channels reduces communication overhead, proxying for a <2s response time.
fact nfr_fact_performance_load_time {
    all op: REQ_MEM_01 | #op.channel <= 2
}

-- PROXY: Requiring at least 2 channels ensures redundancy, proxying for 99.9% availability.
fact nfr_fact_availability_uptime {
    all op: REQ_MEM_01 | #op.channel >= 2
}

-- PROXY: Limiting the number of resources per operation ensures the system can handle up to 10,000 users.
fact nfr_fact_scalability_user_capacity {
    all op: REQ_MEM_01 | #op.target <= 5
}

-- PROXY: Every channel must be authenticated, preventing ambiguous error states && ensuring clear communication pathways.
fact nfr_fact_usability_clear_errors {
    all op: REQ_MEM_01 | all c: op.channel | c.authenticated = True
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

--Security properties for REQ_MEM_01

-- Authentication: every channel used in an operation must be authenticated
assert sr_assert_authentication_required {
    all op: REQ_MEM_01 | all c: op.channel | c.authenticated = True
}
check sr_assert_authentication_required for 5

-- Authorization (least privilege): the granted permission must be one the initiator may perform
assert sr_assert_authorization_least_privilege {
    all op: REQ_MEM_01 | op.grant in op.initiator.mayPerform
}
check sr_assert_authorization_least_privilege for 5

-- Confidentiality: initiator must be in the accessible set of each target resource
assert sr_assert_confidentiality {
    all op: REQ_MEM_01 | all r: op.target | op.initiator in r.accessible
}
check sr_assert_confidentiality for 5

-- Integrity: only owner || admin may perform a write operation
assert sr_assert_integrity {
    all op: REQ_MEM_01 |
        (Write in op.initiator.mayPerform) =>
        (op.initiator = op.target.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_integrity for 5

-- Non-repudiation: every operation has exactly one identified initiator (already enforced by sig, but asserted for clarity)
assert sr_assert_non_repudiation {
    all op: REQ_MEM_01 | one op.initiator
}
check sr_assert_non_repudiation for 5

-- Encryption-in-transit: all channels must be encrypted
assert sr_assert_encryption_in_transit {
    all op: REQ_MEM_01 | all c: op.channel | c.encrypted = True
}
check sr_assert_encryption_in_transit for 5

-- Privilege separation: no owner self-escalation for write without admin role
assert sr_assert_privilege_separation {
    all op: REQ_MEM_01 |
        (Write in op.initiator.mayPerform) =>
        (no r: op.target | r.owner = op.initiator && Admin !in op.initiator.mayPerform)
}
check sr_assert_privilege_separation for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed type errors in ac_reach_1 and ac_reach_2 (r.owner.accessible -> r.accessible)
-- Summary 2: Fixed syntax error: op.initiator ! in -> op.initiator !in
-- Summary 3: Removed type-incorrect fact sr_fact_group_access_control (Interface used as Actor)
-- Summary 4: Model still uses simple Actor/Resource abstraction for groups and membership
-- Assumption 1: Groups are represented as Actors (owners of resources), and membership as the accessible set of the resource.
-- Assumption 2: Performance, availability, and scalability are proxied by simple cardinality constraints (channels <=2, >=2, targets <=5).
-- Assumption 3: The system has only two interfaces: Group_API and Post_Database, both with default unset encrypted/authenticated.
-- Open issue 1: NFR proxies are coarse; actual timing, uptime, and user capacity are not directly modeled.
-- Open issue 2: Integrity assertion uses set equality (op.initiator = op.target.owner) which may not work for multi-resource operations.
-- Open issue 3: Security assertions assume all channels should be authenticated and encrypted; model may not enforce that for all instances.


