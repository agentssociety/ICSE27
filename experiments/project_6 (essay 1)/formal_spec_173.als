module REQ_MOD_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-MOD-01
 * Title       : Admin Reported Content Panel
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Admin_Team, Content_Moderation_Team extends Actor {}
-- Admin_Team: represents stakeholder 'Admin Team'
-- Content_Moderation_Team: represents stakeholder 'Content Moderation Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Added to represent reported content items
sig ReportedItem extends Resource {}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Admin_Reported_Content_Panel, Content_Management_Database extends Interface {}

fact interface_properties {
    Admin_Reported_Content_Panel.kind = UI  -- The user interface for admins to view and manage reported content.
    Content_Management_Database.kind = Database  -- Stores information about reported content, including the items to be moderated and their current status.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where I am logged in as an admin

-- Concrete post-states (one per distinct postcondition).
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_MOD_01
----------------------------------------------------------------------

sig REQ_MOD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_MOD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_MOD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_MOD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_MOD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_MOD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_MOD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_MOD_01 {
    some op: REQ_MOD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_MOD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_MOD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_MOD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_MOD_01_well_formed {
    all op: REQ_MOD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_MOD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Predicate for Criterion 1: I see a list of reported items with options to warn, hide, or delete
-- Semantic encoding: An Admin_Team initiator performs an operation that accesses
-- reported content items via an authenticated channel,
-- with the ability to modify state (Write permission) to manage reported content.
pred ac_reach_1 {
    some op: REQ_MOD_01 |
        -- Initiator is from Admin_Team (authorized user)
        op.initiator in Admin_Team &&
        -- Target includes some reported item (the list)
        some r: ReportedItem | r in op.target &&
        -- Initiator has Write permission (to warn, hide, or delete)
        Write in op.initiator.mayPerform &&
        -- Using an authenticated channel (secure communication)
        (some c: op.channel | c.authenticated = True) &&
        -- Grant is Write (the action of warn/hide/delete modifies content)
        op.grant = Write &&
        -- State changes from initial to done (operation completes)
        op.pre = Pre1 &&
        op.post = PostDone
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sig for edge case 1 (no reported items)
sig Report { resource: Resource }

assert ec_safe_1 {
    all op: REQ_MOD_01 |
        // When there are no reported items, all target resources are unreported (vacuous safety)
        (no Report) => (all t: op.target | t !in Report.resource)
}
check ec_safe_1 for 5

-- Helper sig for edge case 2 (deleting non?existent item)
sig Existence { resource: Resource, exists: Bool }

assert ec_safe_2 {
    all op: REQ_MOD_01 |
        // If any target resource does not exist (exists = False), the operation must not change state
        some t: op.target |
            (some e: Existence | e.resource = t && e.exists = False)
            => op.post = op.pre
}
check ec_safe_2 for 5

assert ec_safe_3 {
    all op: REQ_MOD_01 |
        // If the initiator is Admin_Team and does not hold the granted permission,
        // the operation must leave the state unchanged
        (op.initiator = Admin_Team && op.grant ! in op.initiator.mayPerform)
        => op.post = op.pre
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-MOD-01: Admin logs in and navigates to reported content panel
pred tc_tcmod01_holds {
    some op: REQ_MOD_01 |
        op.initiator = Admin_Team &&
        some r: ReportedItem | r in op.target &&
        some c: op.channel | c.authenticated = True &&
        op.grant = Read &&
        op.pre = Pre1 && op.post = PostDone
}
run  tc_tcmod01_holds    for 5

assert tc_tcmod01_contract {
    all op: REQ_MOD_01 |
        (op.initiator = Admin_Team &&
         some r: ReportedItem | r in op.target &&
         some c: op.channel | c.authenticated = True) =>
        (op.grant = Read && op.pre = Pre1 && op.post = PostDone)
}
check tc_tcmod01_contract for 5

-- TC-MOD-02: Admin selects an item to warn
pred tc_tcmod02_holds {
    some op: REQ_MOD_01 |
        op.initiator = Admin_Team &&
        some r: ReportedItem | r in op.target &&
        some c: op.channel | c.authenticated = True &&
        op.grant = Write &&
        op.pre = Pre1 && op.post = PostDone
}
run  tc_tcmod02_holds    for 5

assert tc_tcmod02_contract {
    all op: REQ_MOD_01 |
        (op.initiator = Admin_Team &&
         some r: ReportedItem | r in op.target &&
         some c: op.channel | c.authenticated = True) =>
        (op.grant = Write && op.pre = Pre1 && op.post = PostDone)
}
check tc_tcmod02_contract for 5

-- TC-MOD-03: Admin selects an item to hide
pred tc_tcmod03_holds {
    some op: REQ_MOD_01 |
        op.initiator = Admin_Team &&
        some r: ReportedItem | r in op.target &&
        some c: op.channel | c.authenticated = True &&
        op.grant = Write &&
        op.pre = Pre1 && op.post = PostDone
}
run  tc_tcmod03_holds    for 5

assert tc_tcmod03_contract {
    all op: REQ_MOD_01 |
        (op.initiator = Admin_Team &&
         some r: ReportedItem | r in op.target &&
         some c: op.channel | c.authenticated = True) =>
        (op.grant = Write && op.pre = Pre1 && op.post = PostDone)
}
check tc_tcmod03_contract for 5

-- TC-MOD-04: Admin attempts action without authentication (denied)
pred tc_tcmod04_holds {
    some op: REQ_MOD_01 |
        op.initiator = Admin_Team &&
        no c: op.channel | c.authenticated = True
}
run  tc_tcmod04_holds    for 5

assert tc_tcmod04_contract {
    no op: REQ_MOD_01 |
        op.initiator = Admin_Team &&
        no c: op.channel | c.authenticated = True
}
check tc_tcmod04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance Proxy: minimize channel count to reduce latency
fact nfr_fact_performance_latency {
    all op: REQ_MOD_01 | #op.channel <= 2
}

-- Availability/Reliability Proxy: every operation must reach a defined post-state
assert nfr_assert_availability_reliability {
    all op: REQ_MOD_01 | one op.post
}
check nfr_assert_availability_reliability for 5

-- Scalability Proxy: limit concurrent operations per resource to a single operation
fact nfr_fact_scalability_concurrency {
    all r: Resource | lone op: REQ_MOD_01 | r in op.target
}

-- Usability Proxy: bound the number of authenticated channels per operation
fact nfr_fact_usability_authentication {
    all op: REQ_MOD_01 |
        #(op.channel & {i: Interface | i.authenticated = True}) <= 2
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security property: Admin must be authenticated.
-- For any operation, if the initiator holds the Admin permission,
-- then all communication channels used must be authenticated.
assert sr_assert_admin_authentication {
  all op : REQ_MOD_01 |
    (Admin in op.initiator.mayPerform) =>
      all c : op.channel | c.authenticated = True
}
check sr_assert_admin_authentication for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Modeled admin content moderation operations with permission/role lattice, interfaces, resources, and state transitions.
-- Summary 2: Fixed type errors: replaced illegal Actor/Permission comparison and Interface-as-Resource usage by adding ReportedItem sig.
-- Summary 3: All safety assertions are structurally consistent; some edge-case assertions are vacuously true under given facts.
-- Assumption 1: Admin_Team represents the admin role; Content_Moderation_Team is a separate role.
-- Assumption 2: Operations require at least one authenticated channel (fact inv_authenticated_channel_required).
-- Assumption 3: Resource access control uses union semantics (initiator in union of accessible sets), not per-resource containment.
-- Assumption 4: ReportedItem is the concrete resource affected by moderation actions.
-- Open issue 1: Edge case assertions ec_safe_1, ec_safe_2, ec_safe_3 are vacuous or incomplete due to missing constraints on Report/Existence sigs.
-- Open issue 2: Fact inv_resource_access_control may be too permissive; stricter per-resource authorization not enforced.
-- Open issue 3: Distinct actions (warn/hide/delete) are modeled uniformly as Write; refinement would require separate permissions or state effects.


