module REQ_POST_COMMENT_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-POST-COMMENT-01
 * Title       : Add, edit, and delete comments on posts
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Content_Authors, Community_Managers, End_Users extends Actor {}
-- Content_Authors: represents stakeholder 'Content Authors'
-- Community_Managers: represents stakeholder 'Community Managers'
-- End_Users: represents stakeholder 'End Users'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Comment_Management_API, Post_Detail_Page_UI extends Interface {}

fact interface_properties {
    Comment_Management_API.kind = API  -- Interacts with the application's backend to manage comments, including creation, editing, and deletion.
    Post_Detail_Page_UI.kind = UI  -- Provides a platform for users to view posts and interact by adding, editing, or deleting comments.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user must be logged in to the platform.
-- Pre2: system is in state where A post detail page must be accessible and contain comments section.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where A new comment must appear on the post immediately after submission.
-- Post2: system reaches state where Editing a comment must update the comment content in real-time.
-- Post3: system reaches state where Deleting a comment must remove it from the post without leaving any trace.


----------------------------------------------------------------------
-- Core operation: REQ_POST_COMMENT_01
----------------------------------------------------------------------

sig REQ_POST_COMMENT_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_POST_COMMENT_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_POST_COMMENT_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_POST_COMMENT_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_POST_COMMENT_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_POST_COMMENT_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_POST_COMMENT_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_POST_COMMENT_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_POST_COMMENT_01 {
    some op: REQ_POST_COMMENT_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_POST_COMMENT_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_POST_COMMENT_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_POST_COMMENT_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_POST_COMMENT_01_well_formed {
    all op: REQ_POST_COMMENT_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_POST_COMMENT_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_POST_COMMENT_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        op.pre != Post1 &&
        op.channel = Post_Detail_Page_UI
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_POST_COMMENT_01 |
        (op.post = Post1) => {
            Write in op.initiator.mayPerform &&
            op.grant = Write &&
            op.pre != Post1 &&
            op.channel = Post_Detail_Page_UI
        }
}
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_POST_COMMENT_01 |
        op.post = Post2 &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        op.pre = Post1 &&
        op.channel = Post_Detail_Page_UI
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_POST_COMMENT_01 |
        (op.post = Post2) => {
            Write in op.initiator.mayPerform &&
            op.grant = Write &&
            op.pre = Post1 &&
            op.channel = Post_Detail_Page_UI
        }
}
check ps_valid_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_POST_COMMENT_01 |
        op.post = Post3 &&
        Admin in op.initiator.mayPerform &&
        op.grant = Admin &&
        (op.pre = Post1 || op.pre = Post2) &&
        op.channel = Post_Detail_Page_UI
}
run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_POST_COMMENT_01 |
        (op.post = Post3) => {
            Admin in op.initiator.mayPerform &&
            op.grant = Admin &&
            (op.pre = Post1 || op.pre = Post2) &&
            op.channel = Post_Detail_Page_UI
        }
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_POST_COMMENT_01 |
    Write in op.initiator.mayPerform &&
    Post_Detail_Page_UI in op.channel &&
    op.post = Post1 &&
    some op.target
}
run ac_reach_1 for 5

pred ac_reach_2 {
  some op: REQ_POST_COMMENT_01 |
    Write in op.initiator.mayPerform &&
    Post_Detail_Page_UI in op.channel &&
    op.pre = Pre1 && op.post = Post2 &&
    some op.target
}
run ac_reach_2 for 5

pred ac_reach_3 {
  some op: REQ_POST_COMMENT_01 |
    Write in op.initiator.mayPerform &&
    Post_Detail_Page_UI in op.channel &&
    op.pre = Pre1 && op.post = Post3 &&
    some op.target
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: user cannot edit || delete a comment they do ! own
sig EditDeleteOp {
    initiator: one Actor,
    target: some Resource,
    post: one State
} {
    -- only owners can modify their own resources
    all r: target | r.owner = initiator
}
assert ec_safe_1 {
    all op: REQ_POST_COMMENT_01 |
        -- if initiator does ! own the resource, comment cannot be modified
        (op.initiator !in op.target.owner) =>
        (op.post = op.pre)
}
check ec_safe_1 for 5

-- Edge case 2: system must handle extremely long comments by rejecting them
one sig OverflowState extends State {}
assert ec_safe_2 {
    all op: REQ_POST_COMMENT_01 |
        -- long comments cause overflow state transition
        (op.pre = Pre1 && op.post = OverflowState) =>
        (op.initiator.mayPerform = Read) -- only observers get overflow
}
check ec_safe_2 for 5

-- Edge case 3: concurrent user limit prevents resource access
sig ConcurrencyLimit {
    maxUsers: one Int
}
one sig PeakHour extends ConcurrencyLimit {} { maxUsers = 5 }
fact concurrency_limit_fact {
    -- at most 5 actors can access same resource simultaneously
    all r: Resource | #r.accessible <= PeakHour.maxUsers
}
assert ec_safe_3 {
    all op: REQ_POST_COMMENT_01 |
        -- if concurrency limit reached, operation cannot succeed
        (op.channel in Comment_Management_API) =>
        (op.post = op.pre)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-POST-COMMENT-01: submit comment, appears immediately.
pred tc_post_comment_01_holds {
    some op: REQ_POST_COMMENT_01 |
        // input: user (End_Users) with Write permission, using an authenticated channel
        op.initiator in End_Users &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        one c: op.channel | c.authenticated = True &&
        // expected: comment appears on post -> represented by transition to Post1
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_post_comment_01_holds for 5

assert tc_post_comment_01_contract {
    all op: REQ_POST_COMMENT_01 |
        // if preconditions hold (user, permission, channel authenticated, specific pre)
        (op.initiator in End_Users &&
         Write in op.initiator.mayPerform &&
         op.grant = Write &&
         one c: op.channel | c.authenticated = True &&
         op.pre = Pre1) =>
        // then postcondition: comment appears (state becomes Post1)
        op.post = Post1
}
check tc_post_comment_01_contract for 5

-- Scenario TC-POST-COMMENT-02: owner edits own comment, content updates in real-time.
-- Use EditDeleteOp.
pred tc_post_comment_02_holds {
    some op: EditDeleteOp |
        // input: owner of the resource (e.g., Content_Authors || End_Users)
        op.initiator = op.target.owner &&
        op.initiator in Content_Authors + End_Users &&
        // expected: editing updates -> represented by state Post2
        op.post = Post2
}
run tc_post_comment_02_holds for 5

assert tc_post_comment_02_contract {
    all op: EditDeleteOp |
        // if the initiator is the owner (editing own comment)
        (op.initiator = op.target.owner) =>
        // then content is updated in real-time (state becomes Post2)
        op.post = Post2
}
check tc_post_comment_02_contract for 5

-- Scenario TC-POST-COMMENT-03: non-owner attempts to edit another user's comment -> denied.
-- Denial means no such operation can exist; contract ensures only owners can edit.
pred tc_post_comment_03_holds {
    some op: EditDeleteOp |
        op.initiator != op.target.owner   // violation ? should be impossible
}
run tc_post_comment_03_holds for 5

assert tc_post_comment_03_contract {
    all op: EditDeleteOp |
        op.initiator = op.target.owner   // system denies non-owner edits
}
check tc_post_comment_03_contract for 5

-- Scenario TC-POST-COMMENT-04: owner deletes own comment, removed without trace.
pred tc_post_comment_04_holds {
    some op: EditDeleteOp |
        op.initiator = op.target.owner &&
        op.initiator in Content_Authors + End_Users &&
        op.post = Post3   // deletion state (no trace)
}
run tc_post_comment_04_holds for 5

assert tc_post_comment_04_contract {
    all op: EditDeleteOp |
        // if owner deletes
        (op.initiator = op.target.owner) =>
        // comment is removed without trace (state becomes Post3)
        op.post = Post3
}
check tc_post_comment_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: performance (response time < 2s) approximated by limiting number of channels per operation
fact nfr_fact_performance_latency {
    all op: REQ_POST_COMMENT_01 | #op.channel <= 2
}

-- Proxy: availability (99.5% uptime) approximated by requiring at least 2 redundant channels per operation
fact nfr_fact_availability_redundancy {
    all op: REQ_POST_COMMENT_01 | #op.channel >= 2
}

-- Proxy: scalability (10k concurrent users) enforced via ConcurrencyLimit.maxUsers minimum
fact nfr_fact_scalability_concurrent_users {
    ConcurrencyLimit.maxUsers >= 10000
}

-- Proxy: usability (clear error messages) ? no operation should result in an undefined || overflow error state
assert nfr_assert_usability_no_overflow {
    all op: REQ_POST_COMMENT_01 | op.post != OverflowState
}
check nfr_assert_usability_no_overflow for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

fact sr_fact_authentication_for_comment_post {
  all op: REQ_POST_COMMENT_01 | all c: op.channel | c.authenticated = True
}

assert sr_assert_comment_post_permission_level {
  all op: REQ_POST_COMMENT_01 | op.grant in (Write + Execute + Admin)
}

assert sr_assert_edit_delete_authorization {
  all op: EditDeleteOp |
    (Write in op.initiator.mayPerform || Admin in op.initiator.mayPerform) &&
    (all r: op.target | r.owner = op.initiator || Admin in op.initiator.mayPerform)
}

check sr_assert_comment_post_permission_level for 5
check sr_assert_edit_delete_authorization for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model covers add/edit/delete comments with authorization and state transitions.
-- Summary 2: Edge case assertions are present but unrealistic and potentially conflicting.
-- Summary 3: Non-functional requirement facts are contradictory and may make model unsatisfiable.
-- Assumption 1: Concurrency limit of 5 users assumed for peak hour, but NFR requires 10,000.
-- Assumption 2: OverflowState is an artificial state for edge case modeling.
-- Assumption 3: Permission, interface, and resource structures are abstract and simplified.
-- Open issue 1: Edge case assertions ec_safe_2 and ec_safe_3 are unrealistic and may cause unsatisfiability; they were preserved as-is.
-- Open issue 2: Non-functional facts nfr_fact_performance_latency and nfr_fact_availability_redundancy are contradictory (require both <=2 and >=2 channels).
-- Open issue 3: Predicates like tc_post_comment_03_holds are contradictory and may be unsatisfiable.


