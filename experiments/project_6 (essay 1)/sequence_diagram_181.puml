  Op --> API : Post2 (Error Logged)
  API --> Admin : 403 Forbidden { error: "Insufficient privileges" }
end if

deactivate Op
deactivate API

== Flow: Audit Log Review ==

AuditCommittee -> API : GET /audit/logs [TLS, authenticated]
activate API

API -> Perm : checkPermission(committee: AuditCommittee, requiredLevel: Permission) : Boolean
activate Perm

alt Permission sufficient (Read)
  Perm --> API : true
  deactivate Perm

  API -> DB : queryLogs(filters: Map) : List<AuditLog> [encrypted at rest]
  activate DB
  DB --> API : logs
  deactivate DB

  API --> AuditCommittee : 200 OK { logs: List<AuditLog> }
  
else Permission insufficient
  Perm --> API : false
  deactivate Perm
  
  API --> AuditCommittee : 403 Forbidden { error: "Insufficient privileges to view audit logs" }
end if

deactivate API

@enduml