module REQ_USER_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-USER-01
 * Title       : Create a User Profile
 * Type        : Functional
 * Priority    : Medium
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Manager, UX_UI_Designer, Backend_Developer, Frontend_Developer, QA_Engineer, Project_Manager extends Actor {}
-- Product_Manager: represents stakeholder 'Product Manager'
-- UX_UI_Designer: represents stakeholder 'UX/UI Designer'
-- Backend_Developer: represents stakeholder 'Backend Developer'
-- Frontend_Developer: represents stakeholder 'Frontend Developer'
-- QA_Engineer: represents stakeholder 'QA Engineer'
-- Project_Manager: represents stakeholder 'Project Manager'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Added concrete resource for the profile being created/displayed
one sig ProfileResource extends Resource {}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Account_Settings_Page extends Interface {}

fact interface_properties {
    Account_Settings_Page.kind = UI  -- The requirement interacts with the UI of the account settings page where users can upload photos and enter biographies.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where A new profile is created with the provided photo and biography
-- Post2: system reaches state where The profile is displayed on the user's account settings page


----------------------------------------------------------------------
-- Core operation: REQ_USER_01
----------------------------------------------------------------------

sig REQ_USER_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_USER_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_USER_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_USER_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_USER_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_USER_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_USER_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_USER_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_USER_01 {
    some op: REQ_USER_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_USER_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_USER_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_USER_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_USER_01_well_formed {
    all op: REQ_USER_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_USER_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates for post-states
pred ps_reach_Post1 {
    some op: REQ_USER_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        True in op.channel.authenticated &&
        op.pre = PreIdle && -- transition from idle to profile created
        some t: Resource | t in op.target && t.owner = op.initiator
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_USER_01 |
        op.post = Post2 &&
        Read in op.initiator.mayPerform &&
        UI in op.channel.kind &&
        True in op.channel.authenticated &&
        ProfileResource in op.target &&
        op.pre = Post1 -- transition from profile created to displayed on page
}
run ps_reach_Post2 for 5

-- Semantic validity assertions
assert ps_valid_Post1 {
    all op: REQ_USER_01 |
        (op.post = Post1) =>
            (Write in op.initiator.mayPerform &&
             True in op.channel.authenticated &&
             some t: Resource | t in op.target && t.owner = op.initiator &&
             op.pre != op.post)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_USER_01 |
        (op.post = Post2) =>
            (Read in op.initiator.mayPerform &&
             UI in op.channel.kind &&
             True in op.channel.authenticated &&
             ProfileResource in op.target &&
             op.pre != op.post)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: Registered user (initiator) performs profile creation operation
pred ac_reach_1 {
    some op: REQ_USER_01 |
        -- Initiator is a registered user (has some permission)
        some op.initiator.mayPerform &&
        -- Operation involves writing/creating data
        Write in op.initiator.mayPerform &&
        -- Target resource exists (profile being created)
        some op.target &&
        -- Channel is authenticated (user is logged in)
        (some c: op.channel | c.authenticated = True) &&
        -- State transitions from idle to post-creation
        op.pre = PreIdle &&
        op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: Valid photo upload && biography under 500 characters
pred ac_reach_2 {
    some op: REQ_USER_01 |
        -- Initiator has write permission (uploading photo)
        Write in op.initiator.mayPerform &&
        -- Target includes ProfileResource (the profile being created)
        ProfileResource in op.target &&
        -- Channel is encrypted (secure upload)
        (some c: op.channel | c.encrypted = True) &&
        -- Channel is authenticated
        (some c: op.channel | c.authenticated = True) &&
        -- State progresses to Post2 (biography validated)
        op.post = Post2
}
run ac_reach_2 for 5

-- Criterion 3: Profile is created && displayed successfully
pred ac_reach_3 {
    some op: REQ_USER_01 |
        -- Initiator has execute permission (displaying profile)
        Execute in op.initiator.mayPerform &&
        -- Target resource is accessible to initiator
        op.initiator in op.target.accessible &&
        -- Channel is authenticated (user session active)
        (some c: op.channel | c.authenticated = True) &&
        -- Final state is Post2 (profile displayed)
        op.post = Post2 &&
        -- Initiator is the owner of the target resource
        op.target.owner = op.initiator
}
run ac_reach_3 for 5

