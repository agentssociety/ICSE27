----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ============================================================
-- Scenario TC-01: Valid photo && short biography ? success
-- ============================================================
pred tc_01_holds {
    some op: REQ_USER_01 |
        op.initiator = Product_Manager
        && op.target = ProfileResource
        && op.grant = Write
        && all c: op.channel | c.encrypted = True && c.authenticated = True
        && op.pre = PreIdle
        && op.post = Post1
        && op.post != op.pre
}

assert tc_01_contract {
    all op: REQ_USER_01 |
        (op.initiator = Product_Manager
         && op.target = ProfileResource
         && op.grant = Write
         && all c: op.channel | c.encrypted = True && c.authenticated = True
         && op.pre = PreIdle)
        => (op.post = Post1 && op.post != op.pre)
}

run tc_01_holds for 5
check tc_01_contract for 5

-- ============================================================
-- Scenario TC-02: Photo > 2 MB ? error
-- ============================================================
pred tc_02_holds {
    some op: REQ_USER_01 |
        op.initiator = Product_Manager
        && op.target = ProfileResource
        && op.grant = Write
        && some c: op.channel | c.encrypted = False    -- e.g., unencrypted channel indicates failure
        && op.pre = PreIdle
        && op.post = Post2
        && op.post != op.pre
}

assert tc_02_contract {
    all op: REQ_USER_01 |
        (op.initiator = Product_Manager
         && op.target = ProfileResource
         && op.grant = Write
         && some c: op.channel | c.encrypted = False
         && op.pre = PreIdle)
        => (op.post = Post2 && op.post != op.pre)
}

run tc_02_holds for 5
check tc_02_contract for 5

-- ============================================================
-- Scenario TC-03: Biography > 500 chars ? error
-- ============================================================
pred tc_03_holds {
    some op: REQ_USER_01 |
        op.initiator = Product_Manager
        && op.target = ProfileResource
        && op.grant = Write
        && some c: op.channel | c.authenticated = False  -- unauthenticated channel represents error
        && op.pre = PreIdle
        && op.post = Post2
        && op.post != op.pre
}

assert tc_03_contract {
    all op: REQ_USER_01 |
        (op.initiator = Product_Manager
         && op.target = ProfileResource
         && op.grant = Write
         && some c: op.channel | c.authenticated = False
         && op.pre = PreIdle)
        => (op.post = Post2 && op.post != op.pre)
}

run tc_03_holds for 5
check tc_03_contract for 5

-- ============================================================
-- Scenario TC-04: Missing photo && biography ? prompt (no operation)
-- ============================================================
-- Since the system refuses the operation when inputs are missing,
-- no REQ_USER_01 exists with legitimate creation parameters.
-- We model this via a predicate that is unsatisfiable,
-- && an assertion that is vacuously true.
pred tc_04_holds {
    no op: REQ_USER_01 |
        op.initiator = Product_Manager
        && op.target = ProfileResource
        && op.grant = Write
        && op.pre = PreIdle
        && op.post != op.pre
}

assert tc_04_contract {
    all op: REQ_USER_01 |
        (op.initiator = Product_Manager
         && op.target = ProfileResource
         && op.grant = Write
         && op.pre = PreIdle
         && op.post != op.pre)
        => (op.post = Post2)  -- any error state; but condition never holds
}

run tc_04_holds for 5
check tc_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_channel_target_limit {
    -- Proxy: fewer channels && targets per operation reduces latency (performance NFR)
    -- Each operation uses at most 2 channels && 2 target resources
    all op: REQ_USER_01 | #op.channel <= 2 && #op.target <= 2
}

fact nfr_fact_availability_redundant_channels {
    -- Proxy: at least 2 channels per operation ensures redundancy (availability NFR)
    all op: REQ_USER_01 | #op.channel >= 2
}

fact nfr_fact_usability_authenticated_limit {
    -- Proxy: limiting authenticated channels per operation to at most 2 improves usability
    all op: REQ_USER_01 | #{ch: op.channel | ch.authenticated = True} <= 2
}

assert nfr_assert_scalability_operations_per_actor {
    -- Proxy: system can handle as many operations as actors (scalability NFR)
    #REQ_USER_01 >= #Actor
}
check nfr_assert_scalability_operations_per_actor for 5

