 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Management, Design_Team, Quality_Assurance extends Actor {}
-- Product_Management: represents stakeholder 'Product Management'
-- Design_Team: represents stakeholder 'Design Team'
-- Quality_Assurance: represents stakeholder 'Quality Assurance'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

one sig UserProfile extends Resource {}  -- represents a user's profile

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Profile_Settings_API, User_Profiles_Database extends Interface {}

fact interface_properties {
    Profile_Settings_API.kind = API  -- The system interacts with this API to retrieve and update profile settings.
    User_Profiles_Database.kind = Database  -- This database stores the visibility status of user profiles.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user must be logged in to their account.
-- Pre2: system is in state where The profile settings page must be accessible.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The user's profile visibility is updated to the selected state.
-- Post2: system reaches state where All users affected by the change (public to private) should no longer see the profile.


----------------------------------------------------------------------
-- Core operation: REQ_PROF_01
----------------------------------------------------------------------

sig REQ_PROF_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_PROF_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_PROF_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_PROF_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_PROF_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_PROF_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_PROF_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_PROF_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_PROF_01 {
    some op: REQ_PROF_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_PROF_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_PROF_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_PROF_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_PROF_01_well_formed {
    all op: REQ_PROF_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_PROF_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_PROF_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        Profile_Settings_API in op.channel &&
        UserProfile in op.target &&
        op.pre = Pre1 &&
        op.initiator = UserProfile.owner
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_PROF_01 |
        (op.post = Post1) => (
            Write in op.initiator.mayPerform &&
            Profile_Settings_API in op.channel &&
            UserProfile in op.target &&
            op.pre = Pre1 &&
            op.initiator = UserProfile.owner
        )
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_PROF_01 |
        op.post = Post2 &&
        Admin in op.initiator.mayPerform &&
        Profile_Settings_API in op.channel &&
        UserProfile in op.target &&
        op.pre = Pre1 &&
        op.initiator = UserProfile.owner
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_PROF_01 |
        (op.post = Post2) => (
            Admin in op.initiator.mayPerform &&
            Profile_Settings_API in op.channel &&
            UserProfile in op.target &&
            op.pre = Pre1 &&
            op.initiator = UserProfile.owner
        )
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Predicate for Criterion 1: user is on profile settings page
pred ac_reach_1 {
    some op: REQ_PROF_01 |
        op.pre = Pre1 &&
        some c: op.channel | c = Profile_Settings_API
}
run ac_reach_1 for 5

-- Predicate for Criterion 2: user toggles profile visibility
pred ac_reach_2 {
    some op: REQ_PROF_01 |
        op.grant = Write &&
        UserProfile in op.target &&
        Profile_Settings_API in op.channel
}
run ac_reach_2 for 5

-- Predicate for Criterion 3: profile visibility changes (post-state is Post2)
pred ac_reach_3 {
    some op: REQ_PROF_01 |
        op.grant = Write &&
        UserProfile in op.target &&
        op.post = Post2
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Toggle visibility to private, then logout/login ? state must persist
assert ec_safe_1 {
    all op: REQ_PROF_01 |
        -- If the operation writes to the user profile database, the post-state must be Post1 (private)
        (Write in op.grant && UserProfile in op.target) => (op.post = Post1)
}

check ec_safe_1 for 5

-- Edge case 2: Network issues during toggle ? all channels must be authenticated && encrypted
assert ec_safe_2 {
    all op: REQ_PROF_01 |
        all c: op.channel |
            c.authenticated = True && c.encrypted = True
}

check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? TC-PROF-01: Toggle profile visibility from private to public ????????
pred tc_PROF_01_holds {
    some op: REQ_PROF_01 |
        -- Input: initiator is an Admin
        Admin in op.initiator.mayPerform &&
        -- Input: grant is Write (toggle operation)
        op.grant = Write &&
        -- Input: target includes UserProfile
        UserProfile in op.target &&
        -- Input: pre-state is Pre1 (representing private state)
        op.pre = Pre1 &&
        -- Expected: post-state is Post1 (representing public state)
        op.post = Post1 &&
        -- Expected: target resource owner is the initiator
        UserProfile.owner = op.initiator &&
        -- Expected: all channels are authenticated && encrypted
        all c: op.channel | c.authenticated = True && c.encrypted = True
}
run tc_PROF_01_holds for 5

assert tc_PROF_01_contract {
    all op: REQ_PROF_01 |
        (op.pre = Pre1 && Admin in op.initiator.mayPerform && op.grant = Write && UserProfile in op.target) =>
        (op.post = Post1 && UserProfile.owner = op.initiator &&
         all c: op.channel | c.authenticated = True && c.encrypted = True)
}
check tc_PROF_01_contract for 5

-- ?? TC-PROF-02: Toggle profile visibility from public to private ????????
pred tc_PROF_02_holds {
    some op: REQ_PROF_01 |
        -- Input: initiator is an Admin
        Admin in op.initiator.mayPerform &&
        -- Input: grant is Write (toggle operation)
        op.grant = Write &&
        -- Input: target includes UserProfile
        UserProfile in op.target &&
        -- Input: pre-state is Post1 (representing public state)
        op.pre = Post1 &&
        -- Expected: post-state is Pre1 (representing private state)
        op.post = Pre1 &&
        -- Expected: target resource owner is the initiator
        UserProfile.owner = op.initiator &&
        -- Expected: all channels are authenticated && encrypted
        all c: op.channel | c.authenticated = True && c.encrypted = True
}
run tc_PROF_02_holds for 5

assert tc_PROF_02_contract {
    all op: REQ_PROF_01 |
        (op.pre = Post1 && Admin in op.initiator.mayPerform && op.grant = Write && UserProfile in op.target) =>
        (op.post = Pre1 && UserProfile.owner = op.initiator &&
         all c: op.channel | c.authenticated = True && c.encrypted = True)
}
check tc_PROF_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: minimize channels to reduce latency (proxy: fewer channels -> lower response time)
fact nfr_fact_response_time {
    all op: REQ_PROF_01 | #op.channel <= 2
}

-- Availability: require redundant channels to achieve 99.9% uptime (proxy: at least two channels per operation)
fact nfr_fact_high_availability {
    all op: REQ_PROF_01 | #op.channel >= 2
}

-- Scalability: every actor can initiate an operation, supporting many users (proxy: all actors are usable)
assert nfr_assert_scalability {
    all a: Actor | some op: REQ_PROF_01 | op.initiator = a
}
check nfr_assert_scalability for 5

-- Usability: operation affects exactly one resource, simplifying error messages (proxy: limited scope reduces confusion)
assert nfr_assert_usability {
    all op: REQ_PROF_01 | #op.target = 1
}
check nfr_assert_usability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

sig AuditEntry { operation: one REQ_PROF_01 }

fact sr_fact_auth_profile {
    all op: REQ_PROF_01 | all t: op.target |
        (t in UserProfile) =>
            (op.initiator = t.owner && (some c: op.channel | c.authenticated = True))
}

assert sr_assert_log_visibility {
    all op: REQ_PROF_01 |
        (some t: op.target | t in UserProfile) &&
        op.grant = Write =>
            one ae: AuditEntry | ae.operation = op
}

check sr_assert_log_visibility for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines structural invariants, state transitions, and permission-based authorization for toggling profile visibility.
-- Summary 2: Founded on a single abstract user profile resource (UserProfile) owned by an Actor, with operations using interfaces (Profile_Settings_API, User_Profiles_Database).
-- Summary 3: Includes safety assertions for unauthorized execution, resource access control, well-formedness, and post-state reachability.
-- Summary 4: Non-functional requirements encoded as constraints (e.g., exactly two channels per operation, single target resource).
-- Summary 5: Security properties enforce that profile operations require authenticated channels and are logged.
-- Assumption 1: Actors (Product_Management, Design_Team, Quality_Assurance) represent roles; any can be the user initiating the toggle.
-- Assumption 2: A single UserProfile resource abstracts all user profiles; owner assigned arbitrarily by solver.
-- Assumption 3: Pre/Post states (Pre1, Pre2, Post1, Post2) abstract the concrete conditions from the requirement.
-- Assumption 4: Permission 'Write' models the toggle action; 'Admin' used in test cases as a higher privilege is a modeling choice.
-- Assumption 5: Performance and availability constraints force exactly two channels per operation (from combined <=2 and >=2 facts).
-- Open issue 1: The model abstracts multiple users and profiles into a single resource, which may not capture real-world ownership and access control accurately.
-- Open issue 2: Use of 'Admin' permission in test predicates (tc_PROF_*) is not justified by the requirement; 'Write' would be more appropriate.
-- Open issue 3: The `stronger` fun is defined but never used; could be removed or utilized in authorization rules.
-- Open issue 4: The mapping between state changes and visibility toggles (public/private) is symbolic (Pre1/Post1 swapped in tc_PROF_02) and may not reflect the intended semantics exactly.


