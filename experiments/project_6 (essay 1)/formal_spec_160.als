module REQ_POST_LIKE_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-POST-LIKE-01
 * Title       : User can like and unlike a post
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Manager, UX_UI_Designer, Backend_Developer, Frontend_Developer, QA_Engineer extends Actor {}
-- Product_Manager: represents stakeholder 'Product Manager'
-- UX_UI_Designer: represents stakeholder 'UX/UI Designer'
-- Backend_Developer: represents stakeholder 'Backend Developer'
-- Frontend_Developer: represents stakeholder 'Frontend Developer'
-- QA_Engineer: represents stakeholder 'QA Engineer'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Like_Unlike_API, Post_Database extends Interface {}

fact interface_properties {
    Like_Unlike_API.kind = API  -- Interacts with the backend to update the like count and toggle the button state.
    Post_Database.kind = Database  -- Stores the current like count for each post.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user must be logged in
-- Pre2: system is in state where The post must exist in the system

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The total like count on the post is updated immediately
-- Post2: system reaches state where The like/unlike button reflects the current state (liked or unliked)


----------------------------------------------------------------------
-- Core operation: REQ_POST_LIKE_01
----------------------------------------------------------------------

sig REQ_POST_LIKE_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_POST_LIKE_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_POST_LIKE_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_POST_LIKE_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_POST_LIKE_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_POST_LIKE_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_POST_LIKE_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_POST_LIKE_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_POST_LIKE_01 {
    some op: REQ_POST_LIKE_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_POST_LIKE_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_POST_LIKE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_POST_LIKE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_POST_LIKE_01_well_formed {
    all op: REQ_POST_LIKE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_POST_LIKE_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability && semantic validation for Post1
pred ps_reach_Post1 {
    some op: REQ_POST_LIKE_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        Like_Unlike_API in op.channel &&
        API in op.target &&
        op.pre = Pre1
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_POST_LIKE_01 |
        (op.post = Post1) =>
            (Write in op.initiator.mayPerform &&
             API in op.target &&
             op.pre = Pre1)
}
check ps_valid_Post1 for 5

-- Reachability && semantic validation for Post2
pred ps_reach_Post2 {
    some op: REQ_POST_LIKE_01 |
        op.post = Post2 &&
        Admin in op.initiator.mayPerform &&
        Like_Unlike_API in op.channel &&
        Post_Database in op.target &&
        op.pre = Pre1
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_POST_LIKE_01 |
        (op.post = Post2) =>
            (Admin in op.initiator.mayPerform &&
             Post_Database in op.target &&
             op.pre = Pre1)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Liveness predicates for REQ_POST_LIKE_01

pred ac_reach_1 {
    some op: REQ_POST_LIKE_01 |
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        op.target = Post_Database &&
        (op.channel = Like_Unlike_API) &&
        (Like_Unlike_API.authenticated = True) &&
        op.pre = Pre1 &&
        op.post = Post1
}

pred ac_reach_2 {
    some op: REQ_POST_LIKE_01 |
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        op.target = Post_Database &&
        (op.channel = Like_Unlike_API) &&
        (Like_Unlike_API.authenticated = True) &&
        op.pre = Pre2 &&
        op.post = Post2
}

run ac_reach_1 for 5
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Liking a non-existent post should ! change state.
assert ec_safe_1 {
  all op: REQ_POST_LIKE_01 |
    -- assume Post_Database is the only valid resource for like/unlike
    (Post_Database ! in op.target) => op.post = op.pre
}

check ec_safe_1 for 5

-- Edge case 2: Concurrent likes && unlikes on the same resource must ! cause conflicting state changes.
assert ec_safe_2 {
  all disj op1, op2: REQ_POST_LIKE_01 |
    (some (op1.target & op2.target)) =>
      (op1.post = op1.pre) || (op2.post = op2.pre)
}

check ec_safe_2 for 5

-- Edge case 3: A user liking their own post must ! change state (self-like denied).
assert ec_safe_3 {
  all op: REQ_POST_LIKE_01 |
    (op.initiator in op.target.owner) => op.post = op.pre
}

check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_POST_LIKE_01_holds {
    some op: REQ_POST_LIKE_01 {
        op.pre = Pre1
        op.post = Post1
        op.initiator in op.target.accessible
        some perm: Permission | perm in op.initiator.mayPerform && op.grant = perm
        some c: op.channel | c.authenticated = True
    }
}
run tc_POST_LIKE_01_holds for 5

assert tc_POST_LIKE_01_contract {
    all op: REQ_POST_LIKE_01 {
        op.pre = Pre1 => op.post = Post1
    }
}
check tc_POST_LIKE_01_contract for 5

pred tc_POST_LIKE_02_holds {
    some op: REQ_POST_LIKE_01 {
        op.pre = Post1
        op.post = Pre1
        op.initiator in op.target.accessible
        some perm: Permission | perm in op.initiator.mayPerform && op.grant = perm
        some c: op.channel | c.authenticated = True
    }
}
run tc_POST_LIKE_02_holds for 5

assert tc_POST_LIKE_02_contract {
    all op: REQ_POST_LIKE_01 {
        op.pre = Post1 => op.post = Pre1
    }
}
check tc_POST_LIKE_02_contract for 5

pred tc_POST_LIKE_03_holds {
    some disj op1, op2: REQ_POST_LIKE_01 {
        op1.target = op2.target
        op1.initiator != op2.initiator
        op1.pre = Pre1 && op1.post = Post1
        op2.pre = Post1 && op2.post = Pre1
        op1.initiator in op1.target.accessible
        op2.initiator in op2.target.accessible
        some perm1: Permission | perm1 in op1.initiator.mayPerform && op1.grant = perm1
        some perm2: Permission | perm2 in op2.initiator.mayPerform && op2.grant = perm2
        some c1: op1.channel | c1.authenticated = True
        some c2: op2.channel | c2.authenticated = True
    }
}
run tc_POST_LIKE_03_holds for 5

assert tc_POST_LIKE_03_contract {
    all op1, op2: REQ_POST_LIKE_01 {
        (op1.target = op2.target && op1.post = op2.pre) => (op2.post = op1.pre)
    }
}
check tc_POST_LIKE_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_response_time {
    -- PROXY: limiting the number of channels && resources per operation reduces communication overhead, thus bounding response time
    -- NFR: Response time for liking/unliking a post should be less than || equal to 500ms
    all op: REQ_POST_LIKE_01 | #op.channel <= 2 && #op.target <= 1
}

fact nfr_fact_availability {
    -- PROXY: requiring at least two distinct channels ensures redundancy, supporting 99.9% uptime
    -- NFR: The system should be available 99.9% of the time
    all op: REQ_POST_LIKE_01 | #op.channel >= 2
}

fact nfr_fact_scalability {
    -- PROXY: ensuring that all actors can simultaneously initiate operations && that the number of resources is bounded supports handling 1,000 posts && 10,000 users
    -- NFR: The system must be able to handle at least 1,000 posts && 10,000 users simultaneously
    all op: REQ_POST_LIKE_01 | #Actor >= 2 && #Resource >= 2
}

fact nfr_fact_usability {
    -- PROXY: limiting the number of authenticated channels per operation reduces complexity, making error messages clearer
    -- NFR: Error messages should be clear && user-friendly
    all op: REQ_POST_LIKE_01 | #(op.channel & {c: Interface | c.authenticated = True}) <= 1
}

assert nfr_assert_scalability_simultaneous {
    -- PROXY: all actors can have simultaneous operations, ensuring scalability
    -- NFR: The system must be able to handle at least 1,000 posts && 10,000 users simultaneously
    all a: Actor | some op: REQ_POST_LIKE_01 | op.initiator = a
}
check nfr_assert_scalability_simultaneous for 5

