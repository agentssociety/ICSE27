module REQ_USER_FR_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-USER-FR-01
 * Title       : Send Friend Request
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig User_Interface_Team, Backend_Development_Team, Notification_System_Team extends Actor {}
-- User_Interface_Team: represents stakeholder 'User Interface Team'
-- Backend_Development_Team: represents stakeholder 'Backend Development Team'
-- Notification_System_Team: represents stakeholder 'Notification System Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Friendship_API, User_Database, Friend_Request_Notification extends Interface {}

fact interface_properties {
    Friendship_API.kind = API  -- Interface for sending, accepting, and rejecting friend requests.
    User_Database.kind = Database  -- Stores user information and friendship statuses.
    Friend_Request_Notification.kind = UI  -- Displays notifications to users about incoming friend requests.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user must be logged in to the system.
-- Pre2: system is in state where There should be another user available to send a friend request to.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where A new pending friend request is added to the recipient's list.
-- Post2: system reaches state where If accepted, a mutual friendship status is established between the sender and receiver.
-- Post3: system reaches state where If rejected, the request disappears from both users' lists of pending requests.


----------------------------------------------------------------------
-- Core operation: REQ_USER_FR_01
----------------------------------------------------------------------

sig REQ_USER_FR_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_USER_FR_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_USER_FR_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_USER_FR_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_USER_FR_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_USER_FR_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_USER_FR_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_USER_FR_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_USER_FR_01 {
    some op: REQ_USER_FR_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_USER_FR_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_USER_FR_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_USER_FR_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_USER_FR_01_well_formed {
    all op: REQ_USER_FR_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_USER_FR_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_USER_FR_01 |
        op.post = Post1 &&
        op.grant = Write &&
        op.channel.authenticated = True &&
        op.target.owner != op.initiator &&
        op.pre != op.post
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_USER_FR_01 |
        (op.post = Post1) =>
            (op.grant = Write &&
             op.channel.authenticated = True &&
             op.target.owner != op.initiator)
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_USER_FR_01 |
        op.post = Post2 &&
        op.grant = Execute &&
        op.channel.authenticated = True &&
        op.target.owner != op.initiator &&
        op.initiator in op.target.accessible &&
        op.pre != op.post
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_USER_FR_01 |
        (op.post = Post2) =>
            (op.grant = Execute &&
             op.channel.authenticated = True &&
             op.target.owner != op.initiator &&
             op.initiator in op.target.accessible)
}

check ps_valid_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_USER_FR_01 |
        op.post = Post3 &&
        op.grant = Write &&
        op.channel.authenticated = True &&
        op.target.owner != op.initiator &&
        op.initiator ! in op.target.accessible &&
        op.pre != op.post
}

run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_USER_FR_01 |
        (op.post = Post3) =>
            (op.grant = Write &&
             op.channel.authenticated = True &&
             op.target.owner != op.initiator &&
             op.initiator ! in op.target.accessible)
}

check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

// Criterion 1: The recipient receives a notification about the pending friend request.
pred ac_reach_1 {
    some op: REQ_USER_FR_01 |
        // The operation uses the Friendship_API interface
        some c: op.channel | c in Friendship_API &&
        // The operation targets User_Database resource
        User_Database in op.target &&
        // The initiator is User_Interface_Team
        op.initiator = User_Interface_Team &&
        // Post state Post1 is reached which includes notification sending
        op.post = Post1 &&
        // The operation uses a secure channel
        (some c: op.channel | c.encrypted = True) &&
        // The operation modifies the friend request notification resource
        Friend_Request_Notification in op.target
}
run ac_reach_1 for 5

// Criterion 2: When accepted, the sender && receiver are both marked as friends, && each gets a notification of this change.
pred ac_reach_2 {
    some op: REQ_USER_FR_01 |
        // The operation uses the Friendship_API interface
        some c: op.channel | c in Friendship_API &&
        // The initiator is a user (User_Interface_Team)
        op.initiator = User_Interface_Team &&
        // The operation targets both User_Database && Notification_System_Team resources
        User_Database in op.target &&
        Notification_System_Team in op.target &&
        // Post state Post2 is reached (friendship acceptance state)
        op.post = Post2 &&
        // The operation requires Write permission (to modify friendship status)
        Write in op.initiator.mayPerform &&
        // The operation uses an authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        // The resource is accessible to the initiator
        op.target.accessible = op.target.owner
}
run ac_reach_2 for 5

// Criterion 3: When rejected, the sender is notified that their request has been rejected.
pred ac_reach_3 {
    some op: REQ_USER_FR_01 |
        // The operation uses the Friendship_API interface
        some c: op.channel | c in Friendship_API &&
        // The initiator is User_Interface_Team
        op.initiator = User_Interface_Team &&
        // The operation targets the Notification_System_Team resource (to send rejection notification)
        Notification_System_Team in op.target &&
        // Post state Post3 is reached (rejection notification state)
        op.post = Post3 &&
        // The operation uses an encrypted channel
        (some c: op.channel | c.encrypted = True) &&
        // The operation requires Read permission (to read the request before rejecting)
        Read in op.initiator.mayPerform &&
        // The resource is accessible to the initiator
        op.target.accessible = op.target.owner
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

sig OnlineLink { actor: one Actor, online: one Bool }
sig FriendRequestRecord { from: one Actor, to: one Resource, pending: one Bool }
sig NetworkStatus { channel: one Interface, isFunctional: one Bool }

-- If the recipient (owner of a target resource) is offline, the operation must end in Post1 (error state).
assert ec_safe_1 {
  all op: REQ_USER_FR_01 |
    (some ln: OnlineLink, r: op.target | ln.actor = r.owner && ln.online = False) => op.post = Post1
}

-- If a duplicate friend request already exists (same initiator && target, pending), the operation must end in Post1.
assert ec_safe_2 {
  all op: REQ_USER_FR_01 |
    (some fr: FriendRequestRecord, r: op.target | fr.from = op.initiator && fr.to = r && fr.pending = True) => op.post = Post1
}

-- Self-request (initiator owns any target resource) is forbidden entirely.
assert ec_safe_3 {
  all op: REQ_USER_FR_01 |
    no r: op.target | r.owner = op.initiator
}

-- If any used channel is non?functional, the operation must end in Post1.
assert ec_safe_4 {
  all op: REQ_USER_FR_01 |
    (some ns: NetworkStatus, c: op.channel | ns.channel = c && ns.isFunctional = False) => op.post = Post1
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-FR-01: User sends a friend request to another user who is online
-- Input: initiator (! Admin), target is another user, channel is online/authenticated
-- Expected: recipient receives notification of pending request
pred tc_TC_FR_01_holds {
    some op: REQ_USER_FR_01 |
        -- initiator is a regular user (! Admin)
        Admin ! in op.initiator.mayPerform &&
        -- target resource is ! owned by initiator (different user)
        op.target.owner != op.initiator &&
        -- channel is authenticated && encrypted (online)
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        -- post-state reflects notification sent (Post1 represents notification sent state)
        op.post = Post1
}
run tc_TC_FR_01_holds for 5

assert tc_TC_FR_01_contract {
    all op: REQ_USER_FR_01 |
        -- Preconditions: initiator is ! Admin, target is different user, channel is authenticated
        (Admin ! in op.initiator.mayPerform &&
         op.target.owner != op.initiator &&
         all c: op.channel | c.authenticated = True && c.encrypted = True) =>
        -- Postcondition: notification is sent (Post1 state reached)
        op.post = Post1
}
check tc_TC_FR_01_contract for 5

-- Scenario TC-FR-02: User tries to send a friend request to themselves
-- Input: initiator targets their own resource
-- Expected: system rejects request, user notified with error (Post2 represents rejection/error state)
pred tc_TC_FR_02_holds {
    some op: REQ_USER_FR_01 |
        -- initiator targets their own resource (self-request)
        op.target.owner = op.initiator &&
        -- post-state reflects rejection/error
        op.post = Post2
}
run tc_TC_FR_02_holds for 5

assert tc_TC_FR_02_contract {
    all op: REQ_USER_FR_01 |
        -- Precondition: initiator targets their own resource
        (op.target.owner = op.initiator) =>
        -- Postcondition: system rejects request (Post2 state)
        op.post = Post2
}
check tc_TC_FR_02_contract for 5

-- Scenario TC-FR-03: User accepts a pending friend request from another user
-- Input: initiator accepts request (has permission), target is the request resource
-- Expected: both users marked as friends, each receives notification (Post3 represents friendship established state)
pred tc_TC_FR_03_holds {
    some op: REQ_USER_FR_01 |
        -- initiator has accept permission (Write || similar)
        Write in op.initiator.mayPerform &&
        -- target resource exists && is owned by another user
        some t: op.target | t.owner != op.initiator &&
        -- post-state reflects friendship established
        op.post = Post3
}
run tc_TC_FR_03_holds for 5

assert tc_TC_FR_03_contract {
    all op: REQ_USER_FR_01 |
        -- Preconditions: initiator has Write permission, target owned by different user
        (Write in op.initiator.mayPerform &&
         some t: op.target | t.owner != op.initiator) =>
        -- Postcondition: friendship established (Post3 state)
        op.post = Post3
}
check tc_TC_FR_03_contract for 5

-- Scenario TC-FR-04: User rejects a pending friend request from another user
-- Input: initiator rejects request (has permission), target is the request resource
-- Expected: request removed, sender notified of rejection (Post2 represents rejection/removal state)
pred tc_TC_FR_04_holds {
    some op: REQ_USER_FR_01 |
        -- initiator has reject permission (Write || similar)
        Write in op.initiator.mayPerform &&
        -- target resource exists && is owned by another user
        some t: op.target | t.owner != op.initiator &&
        -- post-state reflects rejection/removal
        op.post = Post2
}
run tc_TC_FR_04_holds for 5

assert tc_TC_FR_04_contract {
    all op: REQ_USER_FR_01 |
        -- Preconditions: initiator has Write permission, target owned by different user
        (Write in op.initiator.mayPerform &&
         some t: op.target | t.owner != op.initiator) =>
        -- Postcondition: request rejected/removed (Post2 state)
        op.post = Post2
}
check tc_TC_FR_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limit number of target resources && channels to reduce processing time.
fact nfr_fact_performance {
    all op: REQ_USER_FR_01 | #op.target = 1 && #op.channel <= 2
}

-- Availability proxy: at least two authenticated interfaces provide redundancy for high availability.
fact nfr_fact_availability {
    #{i: Interface | i.authenticated = True} >= 2
}

-- Scalability proxy: each resource is accessible by at least two actors to distribute load.
fact nfr_fact_scalability {
    all r: Resource | #r.accessible >= 2
}

-- Usability proxy: there exists an interface that is both encrypted && authenticated to ensure clear, secure feedback.
fact nfr_fact_usability {
    some i: Interface | i.encrypted = True && i.authenticated = True
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

assert sr_assert_authentication {
    all op: REQ_USER_FR_01 | all c: op.channel | c.authenticated = True
}
check sr_assert_authentication for 5

assert sr_assert_encryption {
    all op: REQ_USER_FR_01 | all c: op.channel | c.encrypted = True
}
check sr_assert_encryption for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model covers friend request lifecycle: send, accept, reject with notifications.
-- Summary 2: Safety assertions check authorization, resource access, and structural completeness.
-- Summary 3: Edge case assertions handle offline recipient, duplicate requests, self-requests, and network issues.
-- Summary 4: Test scenario predicates map to acceptance criteria and test cases.
-- Assumption 1: Actors represent teams, not individual users; individual user modeling is abstracted.
-- Assumption 2: Post-states (Post1, Post2, Post3) are symbolic and not fully linked to concrete system behavior.
-- Assumption 3: Non-functional requirements are approximated via structural constraints (e.g., number of channels).
-- Assumption 4: Security requirements are modeled as assertions that all channels must be authenticated and encrypted.
-- Open issue 1: Edge case assertions (ec_safe_1, ec_safe_2, ec_safe_4) may be unsatisfiable due to conflicting constraints (e.g., Post1 vs. inv_state_must_change).
-- Open issue 2: Test scenario contracts (tc_TC_FR_02_contract, tc_TC_FR_03_contract, tc_TC_FR_04_contract) may be vacuously true due to missing preconditions.
-- Open issue 3: Security assertions (sr_assert_authentication, sr_assert_encryption) conflict with inv_authenticated_channel_required and may be too strong.
-- Open issue 4: The model lacks explicit representation of friendship status and notification content.


