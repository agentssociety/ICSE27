module REQ_GROUP_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-GROUP-01
 * Title       : Create Group and Set Visibility
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Manager, Security_Team extends Actor {}
-- Product_Manager: represents stakeholder 'Product Manager'
-- Security_Team: represents stakeholder 'Security Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig GroupCreationAPI, GroupDB extends Interface {}

fact interface_properties {
    GroupCreationAPI.kind = API  -- Interface for creating a new group with specified visibility.
    GroupDB.kind = Database  -- Database where group details are stored, including visibility settings.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where A user is on the group creation page.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The system creates a new group with the selected visibility.
-- Post2: system reaches state where Public groups are visible and joinable by anyone.
-- Post3: system reaches state where Private groups require approval or invitation.


----------------------------------------------------------------------
-- Core operation: REQ_GROUP_01
----------------------------------------------------------------------

sig REQ_GROUP_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,       -- what data/objects are affected
    channel    : some Interface,      -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_GROUP_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_GROUP_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_GROUP_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_GROUP_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_GROUP_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_GROUP_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_GROUP_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_GROUP_01 {
    some op: REQ_GROUP_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_GROUP_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_GROUP_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_GROUP_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_GROUP_01_well_formed {
    all op: REQ_GROUP_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_GROUP_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates for each post-state
pred ps_reach_Post1 {
    some op: REQ_GROUP_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        op.initiator = Product_Manager &&
        Write in op.initiator.mayPerform &&
        GroupCreationAPI in op.channel
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_GROUP_01 |
        op.post = Post2 &&
        op.pre = Pre1 &&
        all r: op.target |
            all a: Actor | a in r.accessible
}
run ps_reach_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_GROUP_01 |
        op.post = Post3 &&
        op.pre = Pre1 &&
        all r: op.target |
            some a: Actor | a ! in r.accessible
}
run ps_reach_Post3 for 5

-- Semantic assertions for each post-state
assert ps_valid_Post1 {
    all op: REQ_GROUP_01 |
        op.post = Post1 =>
            op.initiator = Product_Manager &&
            GroupCreationAPI in op.channel
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_GROUP_01 |
        op.post = Post2 =>
            all r: op.target |
                all a: Actor | a in r.accessible
}
check ps_valid_Post2 for 5

assert ps_valid_Post3 {
    all op: REQ_GROUP_01 |
        op.post = Post3 =>
            all r: op.target |
                some a: Actor | a ! in r.accessible
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_GROUP_01 |
    op.initiator = Product_Manager &&
    GroupCreationAPI in op.channel &&
    GroupDB in op.channel &&
    some c: op.channel |
      c.kind = API &&
      c.encrypted = True &&
      c.authenticated = True &&
    op.grant = Admin &&
    (op.post = Post1 || op.post = Post2)
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

sig Visibility {}
one sig Public, Private extends Visibility {}

sig GroupName {}

sig Group {
    groupName: one GroupName,
    groupVisibility: one Visibility,
    groupResource: one Resource
}

-- Edge case 1: Every target resource of an operation must have a visibility selected (i.e., be associated with a Group).
assert ec_safe_1 {
    all op: REQ_GROUP_01 |
        all r: op.target |
            some g: Group |
                g.groupResource = r
}
check ec_safe_1 for 5

-- Edge case 2: No two groups may share the same name, i.e., duplicate group names are prohibited.
assert ec_safe_2 {
    all op: REQ_GROUP_01 |
        all r: op.target |
            all g: Group |
                g.groupResource = r =>
                    no g2: Group |
                        g2 != g && g2.groupName = g.groupName
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-GROUP-01: create public group
pred tc_GROUP01_holds {
    some op: REQ_GROUP_01 |
        op.post = Post1 &&
        some g: Group |
            g.groupVisibility = Public &&
            g.groupResource in op.target
}
run tc_GROUP01_holds for 5

assert tc_GROUP01_contract {
    all op: REQ_GROUP_01 |
        op.post = Post1 =>
        (some g: Group |
            g.groupVisibility = Public &&
            g.groupResource in op.target)
}
check tc_GROUP01_contract for 5

-- TC-GROUP-02: create private group
pred tc_GROUP02_holds {
    some op: REQ_GROUP_01 |
        op.post = Post2 &&
        some g: Group |
            g.groupVisibility = Private &&
            g.groupResource in op.target
}
run tc_GROUP02_holds for 5

assert tc_GROUP02_contract {
    all op: REQ_GROUP_01 |
        op.post = Post2 =>
        (some g: Group |
            g.groupVisibility = Private &&
            g.groupResource in op.target)
}
check tc_GROUP02_contract for 5

-- TC-GROUP-03: attempt without visibility ? error (no group created)
pred tc_GROUP03_holds {
    some op: REQ_GROUP_01 |
        op.post = Post3 &&
        no g: Group |
            g.groupResource in op.target
}
run tc_GROUP03_holds for 5

assert tc_GROUP03_contract {
    all op: REQ_GROUP_01 |
        op.post = Post3 =>
        no g: Group |
            g.groupResource in op.target
}
check tc_GROUP03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: minimizing channel count per operation reduces latency (performance)
fact nfr_fact_performance {
    all op: REQ_GROUP_01 | #op.channel <= 2
}

-- Proxy: requiring at least one authenticated channel per operation ensures reliability of communication (availability)
fact nfr_fact_availability {
    all op: REQ_GROUP_01 | some c: op.channel | c.authenticated = True
}

-- Proxy: limiting authenticated channels per operation reduces cognitive load (usability)
fact nfr_fact_usability {
    all op: REQ_GROUP_01 | #{c: op.channel | c.authenticated = True} <= 3
}

-- Proxy: every Actor can be an initiator of some operation (scalability)
assert nfr_assert_scalability {
    all a: Actor | some op: REQ_GROUP_01 | op.initiator = a
}
check nfr_assert_scalability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Non-repudiation: every operation has exactly one initiator (already structural, but asserted)
assert sr_assert_non_repudiation {
    all op: REQ_GROUP_01 | one op.initiator
}
check sr_assert_non_repudiation for 5

-- Encryption-in-transit: every channel used by the operation must be encrypted
assert sr_assert_encryption_in_transit {
    all op: REQ_GROUP_01 | all c: op.channel | c.encrypted = True
}
check sr_assert_encryption_in_transit for 5

-- Integrity: if the operation grants Write permission, the initiator must be the resource owner or have Admin permission
assert sr_assert_integrity {
    all op: REQ_GROUP_01 |
        (Write in op.initiator.mayPerform) =>
        (all r: op.target | r.owner = op.initiator || Admin in op.initiator.mayPerform)
}
check sr_assert_integrity for 5

-- Privilege separation: an initiator with Write but no Admin cannot be the owner of any target resource
assert sr_assert_privilege_separation {
    all op: REQ_GROUP_01 |
        (Write in op.initiator.mayPerform && Admin ! in op.initiator.mayPerform) =>
        all r: op.target | r.owner != op.initiator
}
check sr_assert_privilege_separation for 5

-- Group visibility access control:
-- If a target resource belongs to a group with Private visibility,
-- the initiator must be the resource owner or have Admin permission.
assert sr_assert_group_visibility_access_control {
    all op: REQ_GROUP_01 |
        all g: Group |
            (g.groupResource in op.target && g.groupVisibility = Private) =>
            (op.initiator = g.groupResource.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_group_visibility_access_control for 5


