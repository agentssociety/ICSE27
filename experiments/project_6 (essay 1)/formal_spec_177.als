module REQ_ADM_BADGE_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ADM-BADGE-01
 * Title       : Admin can grant verified badges on user profiles
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Admin_Team, User_Management_Interface_Developers, Security_Team extends Actor {}
-- Admin_Team: represents stakeholder 'Admin Team'
-- User_Management_Interface_Developers: represents stakeholder 'User Management Interface Developers'
-- Security_Team: represents stakeholder 'Security Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Admin_User_Management_Interface, User_Database, Audit_Logging_API extends Interface {}

fact interface_properties {
    Admin_User_Management_Interface.kind = UI  -- The interface through which admins can select a user profile and choose to grant or revoke verified badges.
    User_Database.kind = Database  -- The database where user profiles are stored, including the verified badge status.
    Audit_Logging_API.kind = API  -- API used to log actions related to granting and revoking badges for audit purposes.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system must be operational and accessible by authenticated admins with user management privileges.
-- Pre2: system is in state where The selected user profile must exist in the system.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The user's profile must reflect the change in verification status (granted or revoked badge).
-- Post2: system reaches state where Any relevant logs or audit trails must record the action taken by the admin.


----------------------------------------------------------------------
-- Core operation: REQ_ADM_BADGE_01
----------------------------------------------------------------------

sig REQ_ADM_BADGE_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ADM_BADGE_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ADM_BADGE_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ADM_BADGE_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ADM_BADGE_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ADM_BADGE_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ADM_BADGE_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ADM_BADGE_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ADM_BADGE_01 {
    some op: REQ_ADM_BADGE_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ADM_BADGE_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ADM_BADGE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ADM_BADGE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ADM_BADGE_01_well_formed {
    all op: REQ_ADM_BADGE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ADM_BADGE_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? POST-STATE REACHABILITY & SEMANTIC VERIFICATION ????????????

-- Post1: The user's profile must reflect the change in verification status
-- (granted || revoked badge).  This means the operation must involve a
-- permission grant (Admin-level) && the post-state must be distinct from pre.

pred ps_reach_Post1 {
    some op: REQ_ADM_BADGE_01 |
        op.post = Post1 &&
        op.pre != Post1 &&
        Admin in op.initiator.mayPerform &&
        op.grant in Read + Write + Execute &&
        some op.channel
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ADM_BADGE_01 |
        (op.post = Post1) =>
            (op.pre != Post1 &&
             Admin in op.initiator.mayPerform &&
             op.grant in Read + Write + Execute)
}

check ps_valid_Post1 for 5

-- Post2: Any relevant logs || audit trails must record the action taken by
-- the admin.  This => the operation uses an audit-capable channel
-- (e.g., Audit_Logging_API) && the post-state reflects that recording.

pred ps_reach_Post2 {
    some op: REQ_ADM_BADGE_01 |
        op.post = Post2 &&
        op.pre != Post2 &&
        Audit_Logging_API in op.channel.kind &&
        Admin in op.initiator.mayPerform &&
        op.grant in Read + Write + Execute
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_ADM_BADGE_01 |
        (op.post = Post2) =>
            (op.pre != Post2 &&
             Audit_Logging_API in op.channel.kind &&
             Admin in op.initiator.mayPerform)
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
   some op: REQ_ADM_BADGE_01 |
     op.initiator = Admin_Team &&
     Admin in op.initiator.mayPerform &&
     op.grant = Admin &&
     op.target = User_Database &&
     (some c: op.channel | c.authenticated = True) &&
     op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
   some op: REQ_ADM_BADGE_01 |
     op.initiator = Admin_Team &&
     Admin in op.initiator.mayPerform &&
     op.grant = Admin &&
     op.target = User_Database &&
     (some c: op.channel | c.authenticated = True) &&
     op.post = Post2
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge Case 1: Admin attempts to grant badge to non-existent user profile
sig UserProfile extends Resource {}
assert ec_safe_1 {
  all op: REQ_ADM_BADGE_01 |
    (some t: op.target | t ! in UserProfile) => op.post = op.pre
}
check ec_safe_1 for 5

-- Edge Case 2: Concurrent requests for granting badges by multiple admins
sig ConcurrentOp { ops: set REQ_ADM_BADGE_01 }
assert ec_safe_2 {
  all disj op1, op2: REQ_ADM_BADGE_01 |
    (op1.target & op2.target != none) && (op1.grant != op2.grant)
      => (op1.post = op1.pre || op2.post = op2.pre)
}
check ec_safe_2 for 5

-- Edge Case 3: Admin tries to revoke a badge that is ! currently assigned
-- (interpreted as granting a badge that is already assigned in pre-state)
assert ec_safe_3 {
  all op: REQ_ADM_BADGE_01 |
    (op.pre = Post1) => (op.post != Post1)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_ADM_BADGE_01_holds {
    some op: REQ_ADM_BADGE_01 |
        op.initiator = Admin_Team &&
        UserProfile in op.target &&
        op.grant = Admin &&
        op.post = Post1
}
run tc_ADM_BADGE_01_holds for 5

assert tc_ADM_BADGE_01_contract {
    all op: REQ_ADM_BADGE_01 |
        (op.initiator = Admin_Team && UserProfile in op.target && op.grant = Admin) =>
        op.post = Post1
}
check tc_ADM_BADGE_01_contract for 5

pred tc_ADM_BADGE_02_holds {
    some op: REQ_ADM_BADGE_01 |
        op.initiator = Admin_Team &&
        UserProfile in op.target &&
        op.grant = Admin &&
        op.pre = Post1 &&
        op.post = Post2
}
run tc_ADM_BADGE_02_holds for 5

assert tc_ADM_BADGE_02_contract {
    all op: REQ_ADM_BADGE_01 |
        (op.initiator = Admin_Team && UserProfile in op.target && op.grant = Admin && op.pre = Post1) =>
        op.post = Post2
}
check tc_ADM_BADGE_02_contract for 5

pred tc_ADM_BADGE_03_holds {
    some op: REQ_ADM_BADGE_01 |
        op.initiator = Admin_Team &&
        !(UserProfile in op.target) &&
        op.grant = Admin &&
        op.post != Post1
}
run tc_ADM_BADGE_03_holds for 5

assert tc_ADM_BADGE_03_contract {
    all op: REQ_ADM_BADGE_01 |
        (op.initiator = Admin_Team && !(UserProfile in op.target) && op.grant = Admin) =>
        op.post != Post1
}
check tc_ADM_BADGE_03_contract for 5

pred tc_ADM_BADGE_04_holds {
    some disj op1, op2: REQ_ADM_BADGE_01 |
        op1.initiator = Admin_Team &&
        op2.initiator = Security_Team &&
        op1.target = op2.target &&
        op1.target = UserProfile &&
        op1.grant = Admin &&
        op2.grant = Admin &&
        op1.pre = Pre1 &&
        op2.pre = Pre1 &&
        op1.post = Post1 &&
        op2.post = Post1
}
run tc_ADM_BADGE_04_holds for 5

assert tc_ADM_BADGE_04_contract {
    all disj op1, op2: REQ_ADM_BADGE_01 |
        (op1.initiator = Admin_Team && op2.initiator = Security_Team && op1.target = op2.target && op1.grant = Admin && op2.grant = Admin && op1.pre = Pre1 && op2.pre = Pre1) =>
        (op1.post = Post1 && op2.post = Post1)
}
check tc_ADM_BADGE_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting channel count proxies for response time <200ms
    all op: REQ_ADM_BADGE_01 | #op.channel <= 2
}

fact nfr_fact_availability {
    -- PROXY: requiring at least two communication channels per operation proxies for 99.9% availability via redundancy
    all op: REQ_ADM_BADGE_01 | #op.channel >= 2
}

fact nfr_fact_scalability_coverage {
    -- PROXY: every actor can initiate an operation, proxies for supporting up to 1000 concurrent users
    all a: Actor | some op: REQ_ADM_BADGE_01 | op.initiator = a
}

assert nfr_assert_usability {
    -- PROXY: limiting authenticated channels (to at most 3) reduces complexity, aiding usability
    #(Interface & {i: Interface | i.authenticated = True}) <= 3
}
check nfr_assert_usability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

sig AuditEntry {
    operation: one REQ_ADM_BADGE_01
}

fact sr_fact_audit_log {
    all op: REQ_ADM_BADGE_01 | some e: AuditEntry | e.operation = op
}

assert sr_assert_umi_access_restricted {
    all op: REQ_ADM_BADGE_01 |
        all c: op.channel |
            c.kind = Admin_User_Management_Interface =>
                (c.authenticated = True && Admin in op.initiator.mayPerform)
}

check sr_assert_umi_access_restricted for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model covers admin badge grant/revoke with permissions, actors, resources, interfaces, states, and operations.
-- Summary 2: Safety assertions check authorization, resource access, and structural well-formedness.
-- Summary 3: Reachability predicates verify post-state transitions for acceptance criteria.
-- Summary 4: Edge case assertions model non-existent user, concurrent requests, and duplicate badge grant.
-- Summary 5: Non-functional requirements are proxied via channel count and actor coverage facts.
-- Assumption 1: UserProfile is a subtype of Resource representing user profiles.
-- Assumption 2: Admin_Team and Security_Team are the primary actors for badge operations.
-- Assumption 3: Pre1 and Pre2 represent distinct preconditions; Post1 and Post2 represent distinct postconditions.
-- Assumption 4: Audit_Logging_API is the sole audit-capable channel.
-- Assumption 5: Concurrent operations are modeled via disj op1, op2 in assertions.
-- Open issue 1: Edge case assertions ec_safe_1, ec_safe_2, ec_safe_3 may be too restrictive or not fully capture intended behavior; they rely on specific interpretations of the requirement.
-- Open issue 2: Non-functional requirement facts (nfr_fact_performance, nfr_fact_availability) are contradictory (channel count <=2 and >=2) and may make the model unsatisfiable.
-- Open issue 3: The model does not explicitly represent badge state (granted/revoked) as a field; it is inferred from pre/post states.
-- Open issue 4: ConcurrentOp sig is declared but not used in any fact or assertion beyond ec_safe_2.


