module REQ_BOOKMARK_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BOOKMARK-01
 * Title       : User should be able to bookmark posts and view them later
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig End_users, Product_Manager, Design_Team extends Actor {}
-- End_users: represents stakeholder 'End-users'
-- Product_Manager: represents stakeholder 'Product Manager'
-- Design_Team: represents stakeholder 'Design Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig User_Interface, User_Database extends Interface {}

fact interface_properties {
    User_Interface.kind = UI  -- The requirement interacts with the user interface to allow users to mark posts as bookmarked and access their saved list.
    User_Database.kind = Database  -- The requirement interacts with a database to store and retrieve the list of bookmarked posts for each user.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where User is logged in

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where Post is added to the user's saved list


----------------------------------------------------------------------
-- Core operation: REQ_BOOKMARK_01
----------------------------------------------------------------------

sig REQ_BOOKMARK_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BOOKMARK_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BOOKMARK_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BOOKMARK_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BOOKMARK_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BOOKMARK_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BOOKMARK_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BOOKMARK_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BOOKMARK_01 {
    some op: REQ_BOOKMARK_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BOOKMARK_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BOOKMARK_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BOOKMARK_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BOOKMARK_01_well_formed {
    all op: REQ_BOOKMARK_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BOOKMARK_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_BOOKMARK_01 |
        op.post = Post1 &&
        op.initiator = End_users &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        some r: Resource | r in op.target &&
        op.pre = Pre1
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_BOOKMARK_01 |
        (op.post = Post1) => (op.initiator = End_users && op.grant = Write)
}
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

// Criterion 1-3: User bookmarks a post ? post added to saved list
// Maps to: authorized user with Write permission performs operation on a resource,
// affecting a UI component (like User_Database) && transitioning state
pred ac_reach_1 {
    some op: REQ_BOOKMARK_01 |
        // User is logged in (has Read permission at minimum)
        Read in op.initiator.mayPerform &&
        // User bookmarks (Write permission required for modification)
        Write in op.initiator.mayPerform &&
        // Post is a target resource
        some op.target &&
        // Resource accessible to initiator
        op.initiator in op.target.accessible &&
        // Using an authenticated interface
        (some c: op.channel | c.authenticated = True) &&
        // Post added to saved list (User_Database resource)
        op.target in User_Database &&
        // State transition occurs
        op.pre != op.post
}
run ac_reach_1 for 5

// Criterion 4-6: User navigates to saved list ? sees all bookmarked posts
// Maps to: authorized user with Read permission retrieves data from UI component
pred ac_reach_2 {
    some op: REQ_BOOKMARK_01 |
        // User has bookmarked posts (has Read permission for viewing)
        Read in op.initiator.mayPerform &&
        // Navigates to saved list (User_Interface resource)
        op.target in User_Interface &&
        // Interface is accessible
        op.initiator in op.target.accessible &&
        // Can see all bookmarks (requires access to User_Database)
        (some r: Resource | r in User_Database && op.initiator in r.accessible) &&
        // Using encrypted channel for security
        (some c: op.channel | c.encrypted = True) &&
        // State transitions to reflect data retrieval
        op.pre != op.post
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: User logs out while trying to bookmark a post
-- Safety: If the initiator is an End_users && the channel is ! authenticated,
-- the operation cannot succeed (post must remain unchanged from pre)
assert ec_safe_1 {
    all op: REQ_BOOKMARK_01 |
        (op.initiator in End_users && op.channel.authenticated = False) =>
            (op.post = op.pre)
}
check ec_safe_1 for 5

-- Edge case 2: Post is deleted after being bookmarked by the user
-- Safety: If the target resource is owned by an actor who is ! the initiator,
-- the operation must ! delete the target (target must remain accessible)
assert ec_safe_2 {
    all op: REQ_BOOKMARK_01 |
        some t: op.target |
            (t.owner != op.initiator && t in op.target) =>
                (t.owner in t.accessible)
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_bookmark01_holds {
    some op: REQ_BOOKMARK_01 |
        op.initiator = End_users &&
        some c: op.channel | c.authenticated = True &&
        all t: op.target | End_users in t.accessible
}

run  tc_bookmark01_holds    for 5

assert tc_bookmark01_contract {
    all op: REQ_BOOKMARK_01 |
        (op.initiator = End_users && some c: op.channel | c.authenticated = True) =>
        (all t: op.target | End_users in t.accessible)
}

check tc_bookmark01_contract   for 5

pred tc_bookmark02_holds {
    some r: Resource |
        some c: Interface |
            c.authenticated = False &&
            End_users ! in r.accessible &&
            no op: REQ_BOOKMARK_01 |
                op.initiator = End_users &&
                r in op.target &&
                c in op.channel
}

run  tc_bookmark02_holds    for 5

assert tc_bookmark02_contract {
    all op: REQ_BOOKMARK_01 |
        (op.initiator = End_users) =>
        (some c: op.channel | c.authenticated = True)
}

check tc_bookmark02_contract   for 5

pred tc_bookmark03_holds {
    some op: REQ_BOOKMARK_01 |
        op.initiator = End_users &&
        some c: op.channel | c.authenticated = True &&
        all t: op.target | End_users in t.accessible
}

run  tc_bookmark03_holds    for 5

assert tc_bookmark03_contract {
    all op: REQ_BOOKMARK_01 |
        (op.initiator = End_users && some c: op.channel | c.authenticated = True) =>
        (all t: op.target | End_users in t.accessible)
}

check tc_bookmark03_contract   for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- performance proxy: limit channel count to reduce latency
fact nfr_fact_performance {
    all op: REQ_BOOKMARK_01 | #op.channel <= 3
}

-- availability proxy: require at least two channels for redundancy
fact nfr_fact_availability {
    all op: REQ_BOOKMARK_01 | #op.channel >= 2
}

-- scalability proxy: bound resource usage per operation to support many concurrent operations
fact nfr_fact_scalability {
    all op: REQ_BOOKMARK_01 | #op.target <= 3
}

-- usability proxy: limit number of authenticated channels to reduce interface complexity
fact nfr_fact_usability {
    all op: REQ_BOOKMARK_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 2
}

-- cross-proxy invariant: channel count should ! exceed target count (balance)
assert nfr_assert_invariant_balance {
    all op: REQ_BOOKMARK_01 | #op.channel <= #op.target
}
check nfr_assert_invariant_balance for 5

