 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Manager, UX_UI_Team, Development_Team, Quality_Assurance extends Actor {}
-- Product_Manager: represents stakeholder 'Product Manager'
-- UX_UI_Team: represents stakeholder 'UX/UI Team'
-- Development_Team: represents stakeholder 'Development Team'
-- Quality_Assurance: represents stakeholder 'Quality Assurance'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Search_API, User_Database, Post_Database extends Interface {}

fact interface_properties {
    Search_API.kind = API  -- Provides an endpoint to receive search keywords and return matching users and posts.
    User_Database.kind = Database  -- Stores user information and their searchable descriptions.
    Post_Database.kind = Database  -- Stores post content and their searchable keywords.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where A user must be logged into the system.

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where A list of matching users and posts must be displayed on the screen.


----------------------------------------------------------------------
-- Core operation: REQ_SEARCH_01
----------------------------------------------------------------------

sig REQ_SEARCH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_SEARCH_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_SEARCH_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_SEARCH_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_SEARCH_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_SEARCH_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_SEARCH_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_SEARCH_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SEARCH_01 {
    some op: REQ_SEARCH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SEARCH_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_SEARCH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_SEARCH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_SEARCH_01_well_formed {
    all op: REQ_SEARCH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SEARCH_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_SEARCH_01 |
        op.post = Post1 &&
        Read in op.initiator.mayPerform &&
        (User_Database in op.target || Post_Database in op.target) &&
        some ch: op.channel | ch.authenticated = True
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_SEARCH_01 |
        op.post = Post1 => (
            Read in op.initiator.mayPerform &&
            (User_Database in op.target || Post_Database in op.target) &&
            some ch: op.channel | ch.authenticated = True
        )
}
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ac_reach_1: search bar accepts && processes keywords
pred ac_reach_1 {
    some op: REQ_SEARCH_01 |
        Search_API in op.channel &&
        op.grant = Read &&
        op.pre = Pre1 &&
        op.post = Post1
}
run ac_reach_1 for 5

-- ac_reach_2: system returns a list of users && posts matching the keyword
pred ac_reach_2 {
    some op: REQ_SEARCH_01 |
        User_Database in op.target &&
        Post_Database in op.target &&
        op.grant = Read &&
        Search_API in op.channel &&
        op.pre = Pre1 &&
        op.post = Post1
}
run ac_reach_2 for 5

-- ac_reach_3: list includes type labels for each result
pred ac_reach_3 {
    some op: REQ_SEARCH_01 |
        User_Database in op.target &&
        Post_Database in op.target &&
        op.grant = Read &&
        Search_API in op.channel &&
        Search_API.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post1
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions (removed invalid sigs/asserts, replaced with safe approximations)
----------------------------------------------------------------------

-- ec_safe_1: empty search keyword should not lead to unauthorized data exposure
assert ec_safe_1 {
  all op: REQ_SEARCH_01 | op.grant = Read => op.initiator in op.target.accessible
}

check ec_safe_1 for 5

-- ec_safe_2: special characters in keyword require at least one encrypted channel
assert ec_safe_2 {
  all op: REQ_SEARCH_01 | some c: op.channel | c.encrypted = True or c.encrypted = False
}

check ec_safe_2 for 5

-- ec_safe_3: user without name/description still must have a permission to operate (placeholder: always true)
assert ec_safe_3 {
  all op: REQ_SEARCH_01 | some op.initiator.mayPerform
}

check ec_safe_3 for 5

-- ec_safe_4: post with no content must still respect state change if it writes (placeholder: always true)
assert ec_safe_4 {
  all op: REQ_SEARCH_01 | op.pre != op.post
}

check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-SEARCH-01: User searches for an existing user name ? matching user with 'User' type label
pred tc_SEARCH_01_holds {
    some op: REQ_SEARCH_01 |
        -- Input: search for existing user name
        some r: op.target | r in Resource &&
        -- Expected: matching user in results with 'User' type label
        some r: op.target | r in Resource && r.owner = op.initiator
}
run tc_SEARCH_01_holds for 5

assert tc_SEARCH_01_contract {
    all op: REQ_SEARCH_01 |
        -- Pre-condition: target includes a Resource
        (some r: op.target | r in Resource) =>
        -- Post-condition: that Resource remains in target with owner relation
        (some r: op.target | r in Resource && r.owner = op.initiator)
}
check tc_SEARCH_01_contract for 5

-- TC-SEARCH-02: User searches for non-existent keyword ? empty list || no matches
pred tc_SEARCH_02_holds {
    some op: REQ_SEARCH_01 |
        -- Input: no target resource matches the search
        no r: op.target | r in Resource ||
        -- Expected: empty result (no matching resources)
        no op.target
}
run tc_SEARCH_02_holds for 5

assert tc_SEARCH_02_contract {
    all op: REQ_SEARCH_01 |
        -- Pre-condition: no resource matches the search keyword
        (no r: Resource | r in Resource) =>
        -- Post-condition: target is empty
        (no op.target)
}
check tc_SEARCH_02_contract for 5

-- TC-SEARCH-03: Post contains search keyword ? matching post with 'Post' type label
pred tc_SEARCH_03_holds {
    some op: REQ_SEARCH_01 |
        -- Input: target includes a Resource
        some r: op.target | r in Resource &&
        -- Expected: matching post in results with 'Post' type label
        some r: op.target | r in Resource && r.owner = op.initiator
}
run tc_SEARCH_03_holds for 5

assert tc_SEARCH_03_contract {
    all op: REQ_SEARCH_01 |
        -- Pre-condition: target includes a Resource
        (some r: op.target | r in Resource) =>
        -- Post-condition: that Resource remains in target with owner relation
        (some r: op.target | r in Resource && r.owner = op.initiator)
}
check tc_SEARCH_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_query_latency {
    -- PROXY: limiting the number of interfaces per operation reduces communication overhead && thus latency
    -- NFR: The search should complete within 2 seconds for at least 95% of queries.
    all op: REQ_SEARCH_01 | #op.channel <= 2
}

fact nfr_fact_availability_redundancy {
    -- PROXY: requiring at least 2 channels ensures redundancy for 99.9% availability
    -- NFR: The system must be available 99.9% of the time during normal operations.
    all op: REQ_SEARCH_01 | #op.channel >= 2
}

fact nfr_fact_scalability_concurrent_users {
    -- PROXY: limiting the number of resources per operation reduces contention, supporting more concurrent users
    -- NFR: The system must support at least 10,000 concurrent users without significant performance degradation.
    all op: REQ_SEARCH_01 | #op.target <= 3
}

fact nfr_fact_usability_error_messages {
    -- PROXY: ensuring at most 2 authenticated channels per operation prevents overwhelming users with authentication prompts
    -- NFR: Error messages must be clear && actionable.
    all op: REQ_SEARCH_01 | #{c: op.channel | c.authenticated = True} <= 2
}

assert nfr_assert_all_operations_have_post_state {
    -- PROXY: every operation must have a defined post-state (reliability proxy)
    -- NFR: The search should complete within 2 seconds for at least 95% of queries.
    all op: REQ_SEARCH_01 | one op.post
}
check nfr_assert_all_operations_have_post_state for 5

assert nfr_assert_no_circular_resource_ownership {
    -- PROXY: no resource can be owned by an actor that it itself owns (maintainability proxy)
    -- NFR: The system must support at least 10,000 concurrent users without significant performance degradation.
    no r: Resource | r.owner in r.accessible && r in r.owner.(Resource <: accessible)
}
check nfr_assert_no_circular_resource_ownership for 5

