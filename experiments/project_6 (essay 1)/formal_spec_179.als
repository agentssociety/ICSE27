module REQ_PAGIN_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-PAGIN-01
 * Title       : Implement paginated results for feeds and search results
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Owner, UX_UI_Designer, Frontend_Developer extends Actor {}
-- Product_Owner: represents stakeholder 'Product Owner'
-- UX_UI_Designer: represents stakeholder 'UX/UI Designer'
-- Frontend_Developer: represents stakeholder 'Frontend Developer'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

sig Page extends Resource {}              -- represents a page of results (feed or search)
sig InvalidPage extends Resource {}        -- represents a non-existent page


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Feed_and_Search_Result_Pages, Data_Fetching_API extends Interface {}

fact interface_properties {
    Feed_and_Search_Result_Pages.kind = UI  -- The requirement interacts with the UI components responsible for displaying the paginated results.
    Data_Fetching_API.kind = API  -- The requirement interacts with an API to fetch data for pagination. The API must support fetching a subset of items based on page number and item count.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where I am browsing a feed or viewing search results

-- Concrete post-states (one per distinct postcondition).
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_PAGIN_01
----------------------------------------------------------------------

sig REQ_PAGIN_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_PAGIN_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_PAGIN_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_PAGIN_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_PAGIN_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_PAGIN_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_PAGIN_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_PAGIN_01 {
    some op: REQ_PAGIN_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_PAGIN_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_PAGIN_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_PAGIN_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_PAGIN_01_well_formed {
    all op: REQ_PAGIN_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_PAGIN_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

// Liveness predicates for REQ_PAGIN_01 acceptance criteria

// Criterion 1: The system must be able to present a 'Load More' button || page navigation controls.
// This is encoded as the existence of an operation using a Feed_and_Search_Result_Pages interface,
// which is assumed to provide pagination controls.
pred ac_reach_1 {
    some op: REQ_PAGIN_01 |
        Feed_and_Search_Result_Pages in op.channel
}
run ac_reach_1 for 5

// Criterion 2: Only the first page of results is loaded initially.
// This is encoded as an operation that: grants Read permission,
// uses a Feed_and_Search_Result_Pages interface, starts from the initial state (Pre1),
// ends in the done state (PostDone), && targets exactly one resource (interpreted as the first page).
pred ac_reach_2 {
    some op: REQ_PAGIN_01 |
        op.grant = Read &&
        Read in op.initiator.mayPerform &&
        #op.target = 1 &&
        op.pre = Pre1 &&
        op.post = PostDone &&
        Feed_and_Search_Result_Pages in op.channel
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op : REQ_PAGIN_01 |
    all ch : op.channel | ch.authenticated = True
}
check ec_safe_1 for 5

assert ec_safe_2 {
  all op : REQ_PAGIN_01 |
    Feed_and_Search_Result_Pages in op.channel => op.grant = Read
}
check ec_safe_2 for 5

assert ec_safe_3 {
  all op : REQ_PAGIN_01 |
    InvalidPage !in op.target
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_PAGIN_01_holds {
    some op: REQ_PAGIN_01 |
        Page in op.target &&
        Feed_and_Search_Result_Pages in op.channel &&
        op.pre = Pre1 &&
        op.post != PostDone &&
        op.initiator.mayPerform in Read
}
run tc_PAGIN_01_holds for 5

assert tc_PAGIN_01_contract {
    all op: REQ_PAGIN_01 |
        (Page in op.target && Feed_and_Search_Result_Pages in op.channel && op.pre = Pre1) =>
        op.post != PostDone
}
check tc_PAGIN_01_contract for 5

pred tc_PAGIN_02_holds {
    some op: REQ_PAGIN_01 |
        Page in op.target &&
        Data_Fetching_API in op.channel &&
        op.pre = Pre1 &&
        op.post != PostDone &&
        op.grant = Read
}
run tc_PAGIN_02_holds for 5

assert tc_PAGIN_02_contract {
    all op: REQ_PAGIN_01 |
        (Page in op.target && Data_Fetching_API in op.channel && op.pre = Pre1) =>
        op.post != PostDone
}
check tc_PAGIN_02_contract for 5

pred tc_PAGIN_03_holds {
    some op: REQ_PAGIN_01 |
        Page in op.target &&
        Feed_and_Search_Result_Pages in op.channel &&
        op.pre = Pre1 &&
        op.post != Pre1 &&
        all c: op.channel | c.encrypted = True
}
run tc_PAGIN_03_holds for 5

assert tc_PAGIN_03_contract {
    all op: REQ_PAGIN_01 |
        (Page in op.target && Feed_and_Search_Result_Pages in op.channel && op.pre = Pre1) =>
        (op.post != Pre1 && some c: op.channel | c.encrypted = True)
}
check tc_PAGIN_03_contract for 5

pred tc_PAGIN_04_holds {
    some op: REQ_PAGIN_01 |
        Page in op.target &&
        Feed_and_Search_Result_Pages in op.channel &&
        UI in op.channel.kind &&
        op.pre = PostDone &&
        op.post = Pre1 &&
        op.initiator.mayPerform in Read
}
run tc_PAGIN_04_holds for 5

assert tc_PAGIN_04_contract {
    all op: REQ_PAGIN_01 |
        (Page in op.target && Feed_and_Search_Result_Pages in op.channel && op.pre = PostDone) =>
        op.post = Pre1
}
check tc_PAGIN_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Usability: Error handling for cases where there are no more pages to load
-- PROXY: ensure that when no resources are available (empty target set), the operation
-- still has a defined post-state && uses at most one channel (error response)
fact nfr_fact_empty_page_handling {
    all op: REQ_PAGIN_01 |
        (no op.target) => (#op.channel <= 1 && one op.post)
}

assert nfr_assert_usability_error_handling {
    -- Every operation must handle the empty-resource case gracefully
    all op: REQ_PAGIN_01 |
        (no op.target) => (#op.channel <= 1)
}
check nfr_assert_usability_error_handling for 5

