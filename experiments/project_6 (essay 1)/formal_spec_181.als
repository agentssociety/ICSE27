 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Admin_Team, Audit_Committee extends Actor {}
-- Admin_Team: represents stakeholder 'Admin Team'
-- Audit_Committee: represents stakeholder 'Audit Committee'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Admin_Action_API, Audit_Log_Database extends Interface {}

fact interface_properties {
    Admin_Action_API.kind = API  -- The system must provide an API for admin actions that will trigger the logging functionality.
    Audit_Log_Database.kind = Database  -- The audit log data should be stored in a persistent database accessible by authorized personnel.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where Admin must have sufficient privileges to perform actions

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Action must be recorded in the audit log
-- Post2: system reaches state where Log must include admin ID, action type, timestamp, and target user details


----------------------------------------------------------------------
-- Core operation: REQ_ADMIN_LOG_01
----------------------------------------------------------------------

sig REQ_ADMIN_LOG_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ADMIN_LOG_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ADMIN_LOG_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ADMIN_LOG_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ADMIN_LOG_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ADMIN_LOG_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ADMIN_LOG_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ADMIN_LOG_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ADMIN_LOG_01 {
    some op: REQ_ADMIN_LOG_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ADMIN_LOG_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ADMIN_LOG_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ADMIN_LOG_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ADMIN_LOG_01_well_formed {
    all op: REQ_ADMIN_LOG_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ADMIN_LOG_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates && semantic assertions for Post1 && Post2

pred ps_reach_Post1 {
    some op: REQ_ADMIN_LOG_01 |
        op.post = Post1 &&
        Audit_Log_Database in op.target &&
        Admin_Action_API in op.channel
}

assert ps_valid_Post1 {
    all op: REQ_ADMIN_LOG_01 |
        (op.post = Post1) => (Audit_Log_Database in op.target && Admin_Action_API in op.channel)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_ADMIN_LOG_01 |
        op.post = Post2 &&
        Audit_Log_Database in op.target &&
        Admin_Action_API in op.channel &&
        op.initiator in Admin_Team
}

assert ps_valid_Post2 {
    all op: REQ_ADMIN_LOG_01 |
        (op.post = Post2) => (Audit_Log_Database in op.target && Admin_Action_API in op.channel && op.initiator in Admin_Team)
}

run ps_reach_Post2 for 5
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Liveness predicates for acceptance criteria (REQ_ADMIN_LOG_01)

-- Criterion 1: An admin (Admin) performs an action (e.g., banning/warning).  
-- We require the initiator is Admin && the granted permission is Write (a typical action permission).
pred ac_reach_1 {
    some op: REQ_ADMIN_LOG_01 |
        op.initiator = Admin_Team &&
        Write in op.initiator.mayPerform
}
run ac_reach_1 for 5

-- Criterion 2: The action is completed.  
-- We require the operation's post-state is Post1 (assuming Post1 represents the completed/logged state)
-- && that at least one channel is authenticated (secure logging).
pred ac_reach_2 {
    some op: REQ_ADMIN_LOG_01 |
        op.initiator = Admin_Team &&
        op.post = Post1 &&
        some c: op.channel | c.authenticated = True
}
run ac_reach_2 for 5

-- Criterion 3: The action is recorded in the audit log with details (admin ID, action type, target user).  
-- We require the target includes the Audit_Log_Database resource, the channel includes the Admin_Action_API interface
-- (which is encrypted && authenticated), && the grant is Write (action type).
pred ac_reach_3 {
    some op: REQ_ADMIN_LOG_01 |
        op.initiator = Admin_Team &&
        op.grant = Write &&
        Audit_Log_Database in op.target &&
        Admin_Action_API in op.channel &&
        Admin_Action_API.encrypted = True &&
        Admin_Action_API.authenticated = True
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_ADMIN_LOG_01 |
    op.initiator in Admin_Team => op.grant in op.initiator.mayPerform
}
check ec_safe_1 for 5

assert ec_safe_2 {
  all disj op1, op2: REQ_ADMIN_LOG_01 |
    no (op1.target & op2.target) || op1.pre != op2.pre
}
check ec_safe_2 for 5

assert ec_safe_3 {
  all disj op1, op2: REQ_ADMIN_LOG_01 |
    op1.post != op2.post
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicate for TC-LOG-01: admin bans user && logs
pred tc_log01_holds {
    some op: REQ_ADMIN_LOG_01 |
        op.initiator = Admin_Team &&
        op.grant = Write &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_log01_holds for 5

-- Assertion for TC-LOG-01: if admin bans (as defined above) then post-state is Post1 (logged)
assert tc_log01_contract {
    all op: REQ_ADMIN_LOG_01 |
        (op.initiator = Admin_Team &&
         op.grant = Write &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
            op.post = Post1
}
check tc_log01_contract for 5

-- Predicate for TC-LOG-02: admin warns user && logs (single warning)
pred tc_log02_holds {
    some op: REQ_ADMIN_LOG_01 |
        op.initiator = Admin_Team &&
        op.grant = Write &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_log02_holds for 5

-- Assertion for TC-LOG-02: if admin warns (as above) then post-state is Post1 (logged)
assert tc_log02_contract {
    all op: REQ_ADMIN_LOG_01 |
        (op.initiator = Admin_Team &&
         op.grant = Write &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
            op.post = Post1
}
check tc_log02_contract for 5

-- Predicate for TC-LOG-03: admin performs action without sufficient privileges -> error logged
-- Note: inv_initiator_is_authorized forbids such operations; this shows the scenario is impossible.
pred tc_log03_holds {
    some op: REQ_ADMIN_LOG_01 |
        op.grant ! in op.initiator.mayPerform &&
        op.pre = Pre1 &&
        op.post = Post2
}
run tc_log03_holds for 5

-- Assertion for TC-LOG-03: if initiator lacks required permission then post-state is Post2 (error)
assert tc_log03_contract {
    all op: REQ_ADMIN_LOG_01 |
        (op.grant ! in op.initiator.mayPerform &&
         op.pre = Pre1) =>
            op.post = Post2
}
check tc_log03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance NFR: Latency proxy -> limit channel count per operation (fewer channels reduce communication overhead)
fact nfr_fact_performance_latency {
    all op: REQ_ADMIN_LOG_01 | #(op.channel) <= 2
}

-- Availability NFR: Uptime proxy -> require redundant channels per operation (failover support)
fact nfr_fact_availability_redundancy {
    all op: REQ_ADMIN_LOG_01 | #(op.channel) >= 2
}

-- Scalability NFR: Concurrent operations proxy -> existence of two operations with different initiators && disjoint targets (no resource contention)
assert nfr_assert_scalability_concurrency {
    some op1, op2: REQ_ADMIN_LOG_01 |
        op1 != op2 &&
        op1.initiator != op2.initiator &&
        no (op1.target & op2.target)
}
check nfr_assert_scalability_concurrency for 5

-- Usability NFR: Error clarity proxy -> limit the number of distinct interface kinds used across all operations (simpler interface landscape)
assert nfr_assert_usability_simplicity {
    let kinds = (REQ_ADMIN_LOG_01.channel).kind | #kinds <= 2
}
check nfr_assert_usability_simplicity for 5

