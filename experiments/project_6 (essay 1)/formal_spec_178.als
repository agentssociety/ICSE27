module REQ_USER_HIST_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-USER-HIST-01
 * Title       : View Post History
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Users, Product_Manager, Developer_Team extends Actor {}
-- Users: represents stakeholder 'Users'
-- Product_Manager: represents stakeholder 'Product Manager'
-- Developer_Team: represents stakeholder 'Developer Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig User_Profile_API, Post_History_Database extends Interface {}

fact interface_properties {
    User_Profile_API.kind = API  -- Provides endpoints for retrieving a user's post history and accessing account settings.
    Post_History_Database.kind = Database  -- Stores the user's posts along with timestamps.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The user must be logged in to access the profile page.
-- Pre2: system is in state where The system must have access to the user's post history data.
-- Pre3: system is in state where The system must be able to retrieve and display data from the database.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where Users shall see a list of their previous posts with timestamps on their profile page.
-- Post2: system reaches state where User password, email, or account deletion request shall be processed securely.
-- Post3: system reaches state where The user's account information shall be updated accordingly.


----------------------------------------------------------------------
-- Core operation: REQ_USER_HIST_01
----------------------------------------------------------------------

sig REQ_USER_HIST_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_USER_HIST_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_USER_HIST_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_USER_HIST_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_USER_HIST_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_USER_HIST_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_USER_HIST_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_USER_HIST_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_USER_HIST_01 {
    some op: REQ_USER_HIST_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_USER_HIST_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_USER_HIST_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_USER_HIST_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_USER_HIST_01_well_formed {
    all op: REQ_USER_HIST_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_USER_HIST_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_USER_HIST_01 |
        op.post = Post1 &&
        op.initiator = Users &&
        op.grant = Read &&
        Post_History_Database in op.target &&
        User_Profile_API in op.channel
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_USER_HIST_01 |
        op.post = Post1 =>
            (op.initiator = Users &&
             op.grant = Read &&
             Post_History_Database in op.target &&
             User_Profile_API in op.channel)
}
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_USER_HIST_01 |
        op.post = Post2 &&
        op.initiator = Users &&
        op.grant = Write &&
        API in op.target &&
        all c: op.channel | c.encrypted = True && c.authenticated = True
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_USER_HIST_01 |
        op.post = Post2 =>
            (op.initiator = Users &&
             op.grant = Write &&
             API in op.target &&
             all c: op.channel | c.encrypted = True && c.authenticated = True)
}
check ps_valid_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_USER_HIST_01 |
        op.post = Post3 &&
        op.initiator = Users &&
        op.grant = Write &&
        Database in op.target &&
        all c: op.channel | c.encrypted = True && c.authenticated = True
}
run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_USER_HIST_01 |
        op.post = Post3 =>
            (op.initiator = Users &&
             op.grant = Write &&
             Database in op.target &&
             all c: op.channel | c.encrypted = True && c.authenticated = True)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: The list of previous posts shall be displayed on the profile page.
pred ac_reach_1 {
    some op: REQ_USER_HIST_01 |
        Read in op.initiator.mayPerform &&
        User_Profile_API in op.target &&
        Users in op.initiator.accessible &&
        op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: Each post in the list shall include a timestamp.
pred ac_reach_2 {
    some op: REQ_USER_HIST_01 |
        Read in op.initiator.mayPerform &&
        Post_History_Database in op.target &&
        (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
        op.post = Post2
}
run ac_reach_2 for 5

-- Criterion 3: Users shall have access to account settings from their profile page.
pred ac_reach_3 {
    some op: REQ_USER_HIST_01 |
        Read in op.initiator.mayPerform &&
        User_Profile_API in op.target &&
        (some c: op.channel | c.authenticated = True) &&
        Users in op.initiator.accessible &&
        op.grant in op.initiator.mayPerform &&
        op.post = Post1
}
run ac_reach_3 for 5

-- Criterion 4: The change password option shall allow users to update their password securely.
pred ac_reach_4 {
    some op: REQ_USER_HIST_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
        op.post = Post2
}
run ac_reach_4 for 5

-- Criterion 5: The change email option shall allow users to update their email address && verify it.
pred ac_reach_5 {
    some op: REQ_USER_HIST_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
        op.post = Post3
}
run ac_reach_5 for 5

-- Criterion 6: The delete account option shall allow users to irreversible delete their account with a confirmation step.
pred ac_reach_6 {
    some op: REQ_USER_HIST_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        (some c: op.channel | c.authenticated = True) &&
        op.grant = Admin &&
        op.post = Post3
}
run ac_reach_6 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: deletion cancellation ? ensure that any operation that may delete a resource (i.e., changes state && has a non?read grant) is performed by the resource?s owner, so that the owner retains control to undo.
assert ec_safe_1 {
    all op: REQ_USER_HIST_01 |
        let modifying = Write + Execute + Admin {
            (op.grant in modifying && op.pre != op.post) =>
                op.initiator in op.target.owner
        }
}

check ec_safe_1 for 5

-- Edge case 2: concurrent updates ? ensure no two distinct operations that both hold a modifying permission share the same target resource, preventing write?write conflicts.
assert ec_safe_2 {
    all disj op1, op2: REQ_USER_HIST_01 |
        let modifying = Write + Execute + Admin {
            (op1.grant in modifying && op2.grant in modifying) =>
                no (op1.target & op2.target)
        }
}

check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario 1: user views post history
pred tc01_holds {
    some op: REQ_USER_HIST_01 |
        op.initiator = Users &&
        some r: op.target | r.owner = Users &&
        op.grant = Read &&
        all c: op.channel | c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.post != op.pre
}

assert tc01_contract {
    all op: REQ_USER_HIST_01 |
        (op.initiator = Users &&
         some r: op.target | r.owner = Users &&
         op.grant = Read &&
         all c: op.channel | c.authenticated = True) =>
        (op.post = Post1 && op.post != op.pre)
}

run tc01_holds for 5
check tc01_contract for 5

-- Scenario 2: user changes password
pred tc02_holds {
    some op: REQ_USER_HIST_01 |
        op.initiator = Users &&
        op.grant = Write &&
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        op.pre = Pre2 &&
        op.post = Post2 &&
        op.post != op.pre
}

assert tc02_contract {
    all op: REQ_USER_HIST_01 |
        (op.initiator = Users &&
         op.grant = Write &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         op.pre = Pre2) =>
        (op.post = Post2 && op.post != op.pre)
}

run tc02_holds for 5
check tc02_contract for 5

-- Scenario 3: account deletion with confirmation
pred tc03_holds {
    some op: REQ_USER_HIST_01 |
        op.initiator = Users &&
        op.grant = Admin &&
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        op.pre = Pre3 &&
        op.post = Post3 &&
        op.post != op.pre
}

assert tc03_contract {
    all op: REQ_USER_HIST_01 |
        (op.initiator = Users &&
         op.grant = Admin &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         op.pre = Pre3) =>
        (op.post = Post3 && op.post != op.pre)
}

run tc03_holds for 5
check tc03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: Limiting target resources per operation bounds response time for post history && account settings
fact nfr_fact_performance {
    all op: REQ_USER_HIST_01 | #op.target <= 2
}

-- Proxy: Requiring at least two channels per operation provides redundancy for 99.9% uptime
fact nfr_fact_availability {
    all op: REQ_USER_HIST_01 | #op.channel >= 2
}

-- Proxy: Every actor can initiate an operation, ensuring the system can support simultaneous users
fact nfr_fact_scalability {
    all actor: Actor | some op: REQ_USER_HIST_01 | op.initiator = actor
}

-- Proxy: Limiting channels per operation keeps the interface simple, aiding clear error messages
assert nfr_assert_usability {
    all op: REQ_USER_HIST_01 | #op.channel <= 3
}
check nfr_assert_usability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security property facts && assertions for REQ_USER_HIST_01

-- Encryption for password changes: if Database is involved, all channels must be encrypted
fact sr_fact_password_encryption {
    all op: REQ_USER_HIST_01 |
        (Database in op.target) => (all c: op.channel | c.encrypted = True)
}

-- Email verification: all operations must use authenticated channels (prevents unauthorized access)
assert sr_assert_email_verification {
    all op: REQ_USER_HIST_01 | all c: op.channel | c.authenticated = True
}

-- Account deletion confirmation: when initiator is owner of a target resource, at least two channels are required (second step)
assert sr_assert_account_deletion_confirmation {
    all op: REQ_USER_HIST_01 |
        (some r: op.target | r.owner = op.initiator) => (#op.channel >= 2)
}

-- Check commands for the new assertions
check sr_assert_email_verification for 5
check sr_assert_account_deletion_confirmation for 5


