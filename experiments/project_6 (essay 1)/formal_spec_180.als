----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Owner, Engineering_Team, Data_Protection_Officer extends Actor {}
-- Product_Owner: represents stakeholder 'Product Owner'
-- Engineering_Team: represents stakeholder 'Engineering Team'
-- Data_Protection_Officer: represents stakeholder 'Data Protection Officer'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Account_Management_API, User_Data_Database extends Interface {}

fact interface_properties {
    Account_Management_API.kind = API  -- The requirement interacts with this API to update account status and manage data retention.
    User_Data_Database.kind = Database  -- The requirement depends on this database to store and retrieve user data during the grace period.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where User has an active account

-- Concrete post-states (one per distinct postcondition).
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_ACC_01
----------------------------------------------------------------------

sig REQ_ACC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ACC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ACC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ACC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ACC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ACC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ACC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ACC_01 {
    some op: REQ_ACC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ACC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ACC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ACC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ACC_01_well_formed {
    all op: REQ_ACC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ACC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES for REQ_ACC_01 ??????????????????????????????

-- Criterion 1: Account is marked as deleted
-- The operation must result in the account being marked as deleted.
-- This is modeled by the post-state being PostDone && the operation
-- performing a Write permission (to mark the account).
pred ac_reach_1 {
    some op: REQ_ACC_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        op.post = PostDone &&
        (some c: op.channel | c.authenticated = True)
}
run ac_reach_1 for 5

-- Criterion 2: Data is preserved for a grace period
-- The operation must ensure that data is preserved (! permanently deleted)
-- by using a resource that remains accessible to the owner after the operation.
-- This is modeled by the target resource's owner retaining access post-operation.
pred ac_reach_2 {
    some op: REQ_ACC_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        (all r: op.target | r.owner in r.accessible) &&
        (some c: op.channel | c.encrypted = True)
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- helper sigs for edge cases
one sig GracePeriodState extends State {} -- represents the grace period state
one sig DeletedState extends State {}
one sig RecoveredState extends State {}

assert ec_safe_1 {
    all op: REQ_ACC_01 |
        (op.post = GracePeriodState && op.initiator = op.target.owner) =>
            op.pre != DeletedState
}

check ec_safe_1 for 5

assert ec_safe_2 {
    all op: REQ_ACC_01 |
        op.post = RecoveredState =>
            (all c: op.channel | c.authenticated = True && c.encrypted = True)
}

check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_ACC_01_holds {
    some op: REQ_ACC_01 |
        op.pre != GracePeriodState &&
        op.post = GracePeriodState &&
        Admin in op.initiator.mayPerform &&
        op.grant = Admin
}
run tc_ACC_01_holds for 5

assert tc_ACC_01_contract {
    all op: REQ_ACC_01 |
        (op.pre != GracePeriodState && Admin in op.initiator.mayPerform && op.grant = Admin) =>
        op.post = GracePeriodState
}
check tc_ACC_01_contract for 5

pred tc_ACC_02_holds {
    some op: REQ_ACC_01 |
        op.pre = GracePeriodState &&
        op.post = RecoveredState &&
        Admin in op.initiator.mayPerform &&
        op.grant = Admin
}
run tc_ACC_02_holds for 5

assert tc_ACC_02_contract {
    all op: REQ_ACC_01 |
        (op.pre = GracePeriodState && Admin in op.initiator.mayPerform && op.grant = Admin) =>
        op.post = RecoveredState
}
check tc_ACC_02_contract for 5

pred tc_ACC_03_holds {
    some op: REQ_ACC_01 |
        op.pre = GracePeriodState &&
        op.post = PostDone &&
        Admin in op.initiator.mayPerform &&
        op.grant = Admin
}
run tc_ACC_03_holds for 5

assert tc_ACC_03_contract {
    all op: REQ_ACC_01 |
        (op.pre = GracePeriodState && Admin in op.initiator.mayPerform && op.grant = Admin) =>
        op.post = PostDone
}
check tc_ACC_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_grace_period_availability {
    -- PROXY: Availability during grace period is modeled by requiring that
    -- when the pre-state is Pre1 (indicating account is active), if the
    -- post-state is GracePeriodState, then the account resource remains accessible
    -- to its owner (Product_Owner) during the transition.
    all op: REQ_ACC_01 {
        (op.pre = Pre1 && op.post = GracePeriodState) =>
            (op.target.owner = Product_Owner && 
             Product_Owner in op.target.accessible)
    }
}

fact nfr_fact_soft_delete_usability {
    -- PROXY: Usability for soft-delete is modeled by ensuring that when an
    -- account enters the DeletedState, there is at most one authenticated
    -- interface involved, to keep the recovery instruction path simple.
    all op: REQ_ACC_01 {
        op.post = DeletedState => #op.channel <= 1
    }
}

fact nfr_fact_recovery_usability {
    -- PROXY: Usability for recovery is modeled by ensuring that when an
    -- account transitions from DeletedState to RecoveredState, exactly one
    -- channel is used, providing a clear single path for recovery.
    all op: REQ_ACC_01 {
        (op.pre = DeletedState && op.post = RecoveredState) =>
            #op.channel = 1
    }
}

assert nfr_assert_grace_period_accessibility {
    -- PROXY: Availability assertion: during any grace period state,
    -- the Product_Owner must have access to the target resource.
    all op: REQ_ACC_01 {
        op.post = GracePeriodState =>
            Product_Owner in op.target.accessible
    }
}
check nfr_assert_grace_period_accessibility for 5

assert nfr_assert_soft_delete_ui_clarity {
    -- PROXY: Usability assertion: soft-deleted accounts should have
    -- limited interface complexity (max 1 interface) to ensure clear
    -- recovery/delete instructions.
    all op: REQ_ACC_01 {
        op.post = DeletedState => #op.channel <= 1
    }
}
check nfr_assert_soft_delete_ui_clarity for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security property: No access to deleted data by unauthorized users during grace period
assert sr_assert_no_unauthorized_access_grace_period {
    all op: REQ_ACC_01 |
        op.pre = GracePeriodState =>
            all r: op.target |
                (op.initiator = r.owner || Admin in op.initiator.mayPerform || op.initiator = Data_Protection_Officer)
}
check sr_assert_no_unauthorized_access_grace_period for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model represents soft delete with states Pre1, GracePeriodState, DeletedState, RecoveredState, PostDone
-- Summary 2: Safety assertions check authorization, resource access, well-formedness
-- Summary 3: Acceptance criteria reachable via predicates ac_reach_1 and ac_reach_2
-- Summary 4: Test cases modeled as predicates/assertions for soft delete, recovery, and permanent deletion
-- Summary 5: Security assertion restricts access during grace period to owner, Admin, or Data Protection Officer
-- Assumption 1: Grace period is represented as a distinct state GracePeriodState
-- Assumption 2: Product_Owner is the default resource owner for availability modeling
-- Assumption 3: Admin permission is required for initiating soft delete or recovery operations
-- Assumption 4: Recovery requires both authenticated and encrypted channels
-- Assumption 5: DeletedState and RecoveredState are distinct post-states for edge case modeling
-- Open issue 1: Edge case assertions ec_safe_1 and ec_safe_2 may be vacuously true due to lack of state transitions linking GracePeriodState and DeletedState
-- Open issue 2: The GracePeriod sig (originally with field resources) was removed; replaced by GracePeriodState but resource-level constraints are implicit
-- Open issue 3: NFR facts use proxy constraints that may not fully capture real-world availability or usability requirements
-- Open issue 4: The spec assumes a single resource per operation; requirement may involve multiple resources


