ReplyOp -> API : sendReply(reply: String) : Bool
API --> ReplyOp : success

ReplyOp -> State : setState(Post3)
State --> ReplyOp : state changed

ReplyOp --> Controller : 201 Created
Controller -> Controller : return success response

@enduml