module REQ_USER_BLOCK_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-USER-BLOCK-01
 * Title       : User must be able to block another user to hide their posts and messages
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Management, Engineering_Team, UX_UI_Designers, Security_Team extends Actor {}
-- Product_Management: represents stakeholder 'Product Management'
-- Engineering_Team: represents stakeholder 'Engineering Team'
-- UX_UI_Designers: represents stakeholder 'UX/UI Designers'
-- Security_Team: represents stakeholder 'Security Team'

-- Concrete user for blocking scenarios
sig User extends Actor {}


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Concrete resources: posts and messages
sig Post extends Resource {}
sig Message extends Resource {}

-- Every resource is owned by a User
fact owner_is_user {
    all r: Resource | r.owner in User
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Real_time_Messaging_System, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig User_Profile_API, Posts_Database, Messages_Database, Notification_System extends Interface {}

fact interface_properties {
    User_Profile_API.kind = API  -- Provides access to user profiles and allows updating the block status.
    Posts_Database.kind = Database  -- Stores and retrieves posts, which need to be filtered based on the blocking status.
    Messages_Database.kind = Database  -- Stores and retrieves messages, which need to be filtered based on the blocking status.
    Notification_System.kind = Real_time_Messaging_System  -- Handles sending notifications when a user is blocked or unblocked.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where I am a logged-in user
-- Pre2: system is in state where I have a list of posts and messages from user 'Alice'

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where All existing and future posts and messages from 'Alice' are hidden
-- Post2: system reaches state where I no longer receive new messages or see new posts from 'Alice'


----------------------------------------------------------------------
-- Core operation: REQ_USER_BLOCK_01
----------------------------------------------------------------------

sig REQ_USER_BLOCK_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}

-- Initiator must be a User
fact initiator_is_user {
    all op: REQ_USER_BLOCK_01 | op.initiator in User
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_USER_BLOCK_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_USER_BLOCK_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_USER_BLOCK_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_USER_BLOCK_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_USER_BLOCK_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_USER_BLOCK_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_USER_BLOCK_01 | op.post in Post1 + Post2
}


----------------------------------------------------------------------
-- Additional constraints for blocking semantics
----------------------------------------------------------------------

-- For a blocking operation targeting all resources of a blocked user,
-- the post-state Post1 indicates that the initiator cannot access those resources.
fact post_hides_resources {
    all op: REQ_USER_BLOCK_01 |
        op.post = Post1 implies
            (all r: op.target | op.initiator not in r.accessible)
}

-- For an unblocking operation (going from blocked to visible), the post-state Post2 indicates
-- that the initiator regains access. To avoid contradiction, we model only one direction.
-- Here we assume Post2 is an error state (e.g., attempt to block non-existent user).
fact post_error_state {
    all op: REQ_USER_BLOCK_01 |
        op.post = Post2 implies
            (some r: op.target | r.owner not in User)  -- non-existent user
}


----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_USER_BLOCK_01 {
    some op: REQ_USER_BLOCK_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_USER_BLOCK_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_USER_BLOCK_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_USER_BLOCK_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_USER_BLOCK_01_well_formed {
    all op: REQ_USER_BLOCK_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_USER_BLOCK_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability for Post1: blocking a user's resources
pred ps_reach_Post1 {
    some op: REQ_USER_BLOCK_01 |
        op.post = Post1 &&
        op.grant = Admin &&
        Admin in op.initiator.mayPerform &&
        some r: Resource | r in op.target && r.owner != op.initiator &&
        (all r2: Resource | r.owner = r2.owner implies r2 in op.target) &&
        op.channel.authenticated = True
}

assert ps_valid_Post1 {
    all op: REQ_USER_BLOCK_01 |
        (op.post = Post1) =>
            (op.grant = Admin &&
             Admin in op.initiator.mayPerform &&
             some r: Resource | r in op.target && r.owner != op.initiator)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

-- Reachability for Post2: error state (e.g., blocking non-existent user)
pred ps_reach_Post2 {
    some op: REQ_USER_BLOCK_01 |
        op.post = Post2 &&
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        some r: Resource | r in op.target && r.owner not in User &&
        op.channel.authenticated = True
}

assert ps_valid_Post2 {
    all op: REQ_USER_BLOCK_01 |
        (op.post = Post2) =>
            (op.grant = Write &&
             Write in op.initiator.mayPerform &&
             some r: Resource | r in op.target && r.owner not in User)
}

run ps_reach_Post2 for 5
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Predicate for acceptance criterion 1: All posts and messages from 'Alice' are hidden from my view
pred ac_reach_1 {
  some op: REQ_USER_BLOCK_01 |
    some alice: User |
      alice != op.initiator &&
      op.target = {r: Resource | r.owner = alice} &&
      op.grant in op.initiator.mayPerform &&
      op.post = Post1
}
run ac_reach_1 for 5

-- Predicate for acceptance criterion 2: I no longer receive new messages or see new posts from 'Alice'
pred ac_reach_2 {
  some op: REQ_USER_BLOCK_01 |
    some alice: User |
      alice != op.initiator &&
      op.target = {r: Resource | r.owner = alice} &&
      op.grant in op.initiator.mayPerform &&
      op.post = Post1
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helpers for edge cases
one sig Existence { existingUsers: set User }
one sig BlockRecord { blockedUsers: set User }

fact define_existing_users {
    Existence.existingUsers = User
}

fact define_blocked_users {
    BlockRecord.blockedUsers = { u: User | some op: REQ_USER_BLOCK_01 | 
        op.initiator != u and all r: op.target | r.owner = u }
}

assert ec_safe_1 {
  all op: REQ_USER_BLOCK_01 |
    (some t: op.target | t.owner !in Existence.existingUsers) => (op.post = op.pre)
}

assert ec_safe_2 {
  all op: REQ_USER_BLOCK_01 |
    (some t: op.target | t.owner = op.initiator) => (op.post = op.pre && op.post = Post2)
}

assert ec_safe_3 {
  all op: REQ_USER_BLOCK_01 |
    (some t: op.target | t.owner in BlockRecord.blockedUsers) => (op.post = Pre1)
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-01: Blocking a non-existing user  
-- Input: pre-state = Pre2 (non-existing), expected post-state = Post2 (error)  
pred tc_01_holds {
    some op: REQ_USER_BLOCK_01 |
        op.pre = Pre2 &&
        op.post = Post2 &&
        op.grant = Admin &&
        op.grant in op.initiator.mayPerform &&
        some c: op.channel | c.authenticated = True &&
        all r: op.target | op.initiator in r.accessible
}
run tc_01_holds for 5

assert tc_01_contract {
    all op: REQ_USER_BLOCK_01 |
        (op.pre = Pre2 &&
         op.grant = Admin &&
         op.grant in op.initiator.mayPerform &&
         some c: op.channel | c.authenticated = True &&
         all r: op.target | op.initiator in r.accessible) =>
        op.post = Post2
}
check tc_01_contract for 5

-- Scenario TC-02: Attempting to block oneself  
-- Input: target includes a resource owned by the initiator, pre=Pre1, expected post=Post2 (error)  
pred tc_02_holds {
    some op: REQ_USER_BLOCK_01 |
        op.pre = Pre1 &&
        op.post = Post2 &&
        some r: op.target | r.owner = op.initiator &&
        op.grant = Admin &&
        op.grant in op.initiator.mayPerform &&
        some c: op.channel | c.authenticated = True &&
        all r: op.target | op.initiator in r.accessible
}
run tc_02_holds for 5

assert tc_02_contract {
    all op: REQ_USER_BLOCK_01 |
        (op.pre = Pre1 &&
         some r: op.target | r.owner = op.initiator &&
         op.grant = Admin &&
         op.grant in op.initiator.mayPerform &&
         some c: op.channel | c.authenticated = True &&
         all r: op.target | op.initiator in r.accessible) =>
        op.post = Post2
}
check tc_02_contract for 5

-- Scenario TC-03: Unblocking a previously blocked user  
-- Input: pre=Post1 (blocked), expected post=Pre1 (unblocked), content reappears  
pred tc_03_holds {
    some op: REQ_USER_BLOCK_01 |
        op.pre = Post1 &&
        op.post = Pre1 &&
        op.grant = Admin &&
        op.grant in op.initiator.mayPerform &&
        some c: op.channel | c.authenticated = True &&
        all r: op.target | op.initiator in r.accessible
}
run tc_03_holds for 5

assert tc_03_contract {
    all op: REQ_USER_BLOCK_01 |
        (op.pre = Post1 &&
         op.grant = Admin &&
         op.grant in op.initiator.mayPerform &&
         some c: op.channel | c.authenticated = True &&
         all r: op.target | op.initiator in r.accessible) =>
        op.post = Pre1
}
check tc_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limiting number of resources && channels per operation reduces processing time
fact nfr_fact_performance_limit_channels_resources {
    all op: REQ_USER_BLOCK_01 {
        #op.target <= 2
        #op.channel <= 2
    }
}

-- Availability proxy: at least two channels per operation ensures channel redundancy && continuous service
fact nfr_fact_availability_min_channels {
    all op: REQ_USER_BLOCK_01 {
        #op.channel >= 2
    }
}

-- Scalability proxy: every actor must be able to initiate a block operation, ensuring the model
-- can handle many simultaneous requests
assert nfr_assert_scalability_all_actors_can_initiate {
    all a: Actor | some op: REQ_USER_BLOCK_01 | op.initiator = a
}
check nfr_assert_scalability_all_actors_can_initiate for 5

-- Usability proxy: bounding authenticated channels per operation keeps the interface simple,
-- leading to clearer error messages
fact nfr_fact_usability_max_authenticated_channels {
    all op: REQ_USER_BLOCK_01 {
        #{i: op.channel | i.authenticated = True} <= 1
    }
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

assert sr_assert_all_channels_authenticated {
    all op: REQ_USER_BLOCK_01 | all c: op.channel | c.authenticated = True
}
check sr_assert_all_channels_authenticated for 5

assert sr_assert_all_channels_encrypted {
    all op: REQ_USER_BLOCK_01 | all c: op.channel | c.encrypted = True
}
check sr_assert_all_channels_encrypted for 5

assert sr_assert_integrity_owner_or_admin {
    all op: REQ_USER_BLOCK_01 |
        (op.grant in Write + Execute + Admin) =>
        (all r: op.target | r.owner = op.initiator || Admin in op.initiator.mayPerform)
}
check sr_assert_integrity_owner_or_admin for 5

assert sr_assert_no_self_escalation {
    all op: REQ_USER_BLOCK_01 |
        (Write in op.initiator.mayPerform) =>
        (no r: op.target | r.owner = op.initiator && Admin ! in op.initiator.mayPerform)
}
check sr_assert_no_self_escalation for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Added concrete Resource sigs (Post, Message) to provide instances for operations
-- Summary 2: Added User sig extending Actor to represent end users
-- Summary 3: Fixed type mismatches: replaced references to IfaceKind/Interface with Resource in target fields
-- Summary 4: Added facts to ensure Resource ownership by Users and post-state semantics (Post1 hides resources)
-- Summary 5: Updated edge case helpers (Existence, BlockRecord) with coherent definitions
-- Summary 6: Corrected acceptance criterion predicates to use set comprehension for resources of a blocked user
-- Summary 7: Preserved all original comments and structure; removed only contradictory/unfeasible constraints
-- Assumption 1: Blocking is modeled as making resources inaccessible to the initiator
-- Assumption 2: Only Users (not other Actors) can initiate and be targets of blocking operations
-- Assumption 3: Post2 represents an error state (e.g., attempt to block non-existing user or self-block)
-- Assumption 4: Unblocking is represented by transitioning from Post1 back to Pre1
-- Open issue 1: Security assertions (sr_assert_all_channels_authenticated/encrypted) are still very strong and likely false in a real system; they are kept for verification but may require weakening
-- Open issue 2: NFR scalability assertion (all actors can initiate) may be unreachable because Product_Management etc. are not Users and cannot initiate; this is a modeling choice to preserve original stakeholders


