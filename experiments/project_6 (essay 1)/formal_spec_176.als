module REQ_NOTIFY_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-NOTIFY-01
 * Title       : Enable/Disable Notifications per Category
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Management, User_Experience_Team, Development_Team extends Actor {}
-- Product_Management: represents stakeholder 'Product Management'
-- User_Experience_Team: represents stakeholder 'User Experience Team'
-- Development_Team: represents stakeholder 'Development Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Notification_Settings_Page extends Interface {}

fact interface_properties {
    Notification_Settings_Page.kind = UI  -- The requirement interacts with the user interface to display notification settings and receive user inputs.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The user is logged into the application.

-- Concrete post-states (one per distinct postcondition).
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_NOTIFY_01
----------------------------------------------------------------------

sig REQ_NOTIFY_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_NOTIFY_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_NOTIFY_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_NOTIFY_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_NOTIFY_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_NOTIFY_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_NOTIFY_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_NOTIFY_01 {
    some op: REQ_NOTIFY_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_NOTIFY_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_NOTIFY_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_NOTIFY_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_NOTIFY_01_well_formed {
    all op: REQ_NOTIFY_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_NOTIFY_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_NOTIFY_01 |
        Read in op.initiator.mayPerform &&
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        op.post = PostDone
}

run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_NOTIFY_01 |
        Write in op.initiator.mayPerform &&
        (some c: op.channel | c.authenticated = True && c.encrypted = False) &&
        op.pre = Pre1 &&
        op.post = PostDone
}

run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_NOTIFY_01 |
        Write in op.initiator.mayPerform &&
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        op.pre = PostDone &&
        op.post = Pre1
}

run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: unsupported notification category  
-- Safety: if grant is ! a supported permission for the system, operation must fail (state unchanged)  
assert ec_safe_1 {  
    all op: REQ_NOTIFY_01 |  
        (op.grant ! in (Product_Management.mayPerform + User_Experience_Team.mayPerform + Development_Team.mayPerform)) =>  
            op.post = op.pre  
}  
check ec_safe_1 for 5  

-- Edge case 2: concurrent toggling by multiple actors on the same target  
-- Safety: no two operations can share a target unless their grants are compatible  
-- Compatibility means same permission for the same target  
assert ec_safe_2 {  
    all disj op1, op2: REQ_NOTIFY_01 |  
        some (op1.target & op2.target) =>  
            op1.grant = op2.grant  
}  
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-NOTIFY-01: Toggle off 'likes' notifications --
pred tc_notify_01_holds {
    some op: REQ_NOTIFY_01 |
        op.initiator = User_Experience_Team &&
        op.target = Notification_Settings_Page &&
        op.grant = Write &&
        some c: op.channel | c.kind = UI && c.encrypted = True && c.authenticated = True &&
        op.pre = Pre1 && op.post = PostDone
}
run tc_notify_01_holds for 5

assert tc_notify_01_contract {
    all op: REQ_NOTIFY_01 |
        (op.initiator = User_Experience_Team &&
         op.target = Notification_Settings_Page &&
         op.grant = Write &&
         some c: op.channel | c.kind = UI && c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
        (op.post = PostDone)
}
check tc_notify_01_contract for 5

-- TC-NOTIFY-02: Toggle on 'comments' notifications --
pred tc_notify_02_holds {
    some op: REQ_NOTIFY_01 |
        op.initiator = Development_Team &&
        op.target = Notification_Settings_Page &&
        op.grant = Write &&
        some c: op.channel | c.kind = UI && c.encrypted = True && c.authenticated = True &&
        op.pre = Pre1 && op.post = PostDone
}
run tc_notify_02_holds for 5

assert tc_notify_02_contract {
    all op: REQ_NOTIFY_01 |
        (op.initiator = Development_Team &&
         op.target = Notification_Settings_Page &&
         op.grant = Write &&
         some c: op.channel | c.kind = UI && c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
        (op.post = PostDone)
}
check tc_notify_02_contract for 5

