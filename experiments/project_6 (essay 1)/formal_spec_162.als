module REQ_USERFEED_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-USERFEED-01
 * Title       : Display News Feed Sorted by Time
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, AdminPerm extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else AdminPerm
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Management, Development_Team, QA_Team, Admin extends Actor {}
-- Product_Management: represents stakeholder 'Product Management'
-- Development_Team: represents stakeholder 'Development Team'
-- QA_Team: represents stakeholder 'QA Team'
-- Admin: represents the logged-in user


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Friendship_API, Post_Database extends Interface {}

fact interface_properties {
    Friendship_API.kind = API  -- The requirement interacts with this API to retrieve the list of friends for the authenticated user.
    Post_Database.kind = Database  -- The requirement retrieves posts from this database, filtered by the authenticated user's friends and sorted by creation time.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition)
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user is logged in.
-- Pre2: system is in state where The user has friends with posts.

-- Concrete post-states (one per distinct postcondition)
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_USERFEED_01
----------------------------------------------------------------------

sig REQ_USERFEED_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_USERFEED_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_USERFEED_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_USERFEED_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_USERFEED_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_USERFEED_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_USERFEED_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_USERFEED_01 {
    some op: REQ_USERFEED_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_USERFEED_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_USERFEED_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_USERFEED_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_USERFEED_01_well_formed {
    all op: REQ_USERFEED_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_USERFEED_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_USERFEED_01 |
    op.grant = Read &&
    NewsFeed in op.target &&
    some c: op.channel | c.kind = Friendship_API
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: no friends with posts ? feed cannot contain posts from unrelated users
assert ec_safe_1 {
    all op: REQ_USERFEED_01 |
        -- if initiator has no friendship with any owner, then no target resource owned by non-friend
        (no f: Friendship_API | f in op.initiator.(~owner)) =>
            (all r: op.target | r.owner in op.initiator.(~owner))
}

check ec_safe_1 for 5

-- Edge case 2: newly added friend's posts must respect the authenticated channel requirement
assert ec_safe_2 {
    all op: REQ_USERFEED_01 |
        -- if a friend is added after pre-state, then post-state must use authenticated channel
        (some a: Actor | a ! in op.initiator.(~owner) && a in op.target.owner) =>
            (all c: op.channel | c.authenticated = True)
}

check ec_safe_2 for 5

-- Edge case 3: deletion of friend's post cannot leave dangling references in target
assert ec_safe_3 {
    all op: REQ_USERFEED_01 |
        -- if a post existed in pre-state but not in post-state, initiator must still hold appropriate permission
        (some r: Resource | r in op.target && (some a: Actor | a in r.owner)) =>
            (Read in op.initiator.mayPerform) && (Write in op.initiator.mayPerform)
}

check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-USERFEED-01: User with no friends sees empty feed
pred tc_USERFEED_01_holds {
    some op: REQ_USERFEED_01 |
        op.initiator = Admin
        && op.grant = Read
        && NewsFeed.owner = Admin
        && NewsFeed.accessible = Admin
        && op.target = NewsFeed
        && some c: op.channel | c.authenticated = True
        && some c2: op.channel | c2.encrypted = True
        && op.pre = Pre1
        && op.post = PostDone
}
run tc_USERFEED_01_holds for 5

assert tc_USERFEED_01_contract {
    all op: REQ_USERFEED_01 |
        (   op.initiator = Admin
            && op.grant = Read
            && NewsFeed.owner = Admin
            && NewsFeed.accessible = Admin
            && op.target = NewsFeed
            && some c: op.channel | c.authenticated = True
            && some c2: op.channel | c2.encrypted = True
        ) => (op.pre = Pre1 && op.post = PostDone)
}
check tc_USERFEED_01_contract for 5

-- TC-USERFEED-02: User with one friend && one post from that friend
pred tc_USERFEED_02_holds {
    some op: REQ_USERFEED_01 |
        op.initiator = Admin
        && op.grant = Read
        && some friend: Actor | friend = Product_Management
        && NewsFeed.accessible = Admin + Product_Management
        && NewsFeed.owner = Admin   // feed structure owned by user, but friend's post is represented by accessible
        && op.target = NewsFeed
        && some c: op.channel | c.authenticated = True
        && op.pre = Pre2          // Pre2 indicates a friend's post exists
        && op.post = PostDone
}
run tc_USERFEED_02_holds for 5

assert tc_USERFEED_02_contract {
    all op: REQ_USERFEED_01 |
        (   op.initiator = Admin
            && op.grant = Read
            && NewsFeed.accessible = Admin + Product_Management
            && NewsFeed.owner = Admin
            && op.target = NewsFeed
            && some c: op.channel | c.authenticated = True
            && op.pre = Pre2
        ) => op.post = PostDone
}
check tc_USERFEED_02_contract for 5

-- TC-USERFEED-03: User adds a new friend, who posts immediately after adding
pred tc_USERFEED_03_holds {
    some op: REQ_USERFEED_01 |
        op.initiator = Admin
        && op.grant = Read
        && some newFriend: Actor | newFriend = Development_Team
        && NewsFeed.accessible = Admin + Development_Team  // friend added in pre-state
        && NewsFeed.owner = Admin
        && op.target = NewsFeed
        && some c: op.channel | c.authenticated = True
        && op.pre = Pre2
        && op.post = PostDone
}
run tc_USERFEED_03_holds for 5

assert tc_USERFEED_03_contract {
    all op: REQ_USERFEED_01 |
        (   op.initiator = Admin
            && op.grant = Read
            && NewsFeed.accessible = Admin + Development_Team
            && NewsFeed.owner = Admin
            && op.target = NewsFeed
            && some c: op.channel | c.authenticated = True
            && op.pre = Pre2
        ) => op.post = PostDone
}
check tc_USERFEED_03_contract for 5

-- TC-USERFEED-04: User views feed while a friend's post is being deleted
pred tc_USERFEED_04_holds {
    some op: REQ_USERFEED_01 |
        op.initiator = Admin
        && op.grant = Read
        && some delFriend: Actor | delFriend = Product_Management
        && NewsFeed.accessible = Admin   // friend removed (post deleted) in pre-state
        && NewsFeed.owner = Admin
        && op.target = NewsFeed
        && some c: op.channel | c.authenticated = True
        && op.pre = Pre1   // no friend's post remains
        && op.post = PostDone
}
run tc_USERFEED_04_holds for 5

assert tc_USERFEED_04_contract {
    all op: REQ_USERFEED_01 |
        (   op.initiator = Admin
            && op.grant = Read
            && NewsFeed.accessible = Admin
            && NewsFeed.owner = Admin
            && op.target = NewsFeed
            && some c: op.channel | c.authenticated = True
            && op.pre = Pre1
        ) => op.post = PostDone
}
check tc_USERFEED_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: fewer interfaces per operation reduces latency
fact nfr_fact_performance_latency {
    -- NFR: response time < 200ms (proxy: max 3 channels per operation)
    all op: REQ_USERFEED_01 | #op.channel <= 3
}

-- Performance proxy: limiting target resources reduces processing overhead
fact nfr_fact_performance_throughput {
    -- NFR: throughput > 1000 ops/sec (proxy: max 5 resources per operation)
    all op: REQ_USERFEED_01 | #op.target <= 5
}

-- Availability proxy: require redundant channels for resilience
fact nfr_fact_availability_redundancy {
    -- NFR: 99.9% uptime (proxy: at least 2 channels per operation)
    all op: REQ_USERFEED_01 | #op.channel >= 2
}

-- Scalability proxy: all actors can initiate operations simultaneously
assert nfr_assert_scalability_concurrency {
    -- NFR: support 1000 concurrent users (proxy: some operation for each actor)
    all a: Actor | some op: REQ_USERFEED_01 | op.initiator = a
}
check nfr_assert_scalability_concurrency for 5

-- Usability proxy: limit number of authenticated channels to reduce complexity
fact nfr_fact_usability_simplicity {
    -- NFR: intuitive interface design (proxy: at most 2 authenticated channels per op)
    all op: REQ_USERFEED_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 2
}

-- Maintainability proxy: no circular resource ownership chains
assert nfr_assert_maintainability_acyclic {
    -- NFR: easily maintainable permission structure (proxy: no cycles in owner chain)
    no disj r1, r2: Resource | r1.owner in r2.accessible && r2.owner in r1.accessible
}
check nfr_assert_maintainability_acyclic for 5

-- Reliability proxy: every operation must have a state transition
assert nfr_assert_reliability_state_transition {
    -- NFR: guaranteed operation completion (proxy: pre && post states differ)
    all op: REQ_USERFEED_01 | op.pre != op.post
}
check nfr_assert_reliability_state_transition for 5

