module REQ_APC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-APC-01
 * Title       : Prioritize Arrivals Over Departures When Allocating Slots
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Airport_Slot_Coordinator_Team, Air_Traffic_Control_Department, Safety_Compliance_Officer, Operations_Management extends Actor {}
-- Airport_Slot_Coordinator_Team: represents stakeholder 'Airport Slot Coordinator Team'
-- Air_Traffic_Control_Department: represents stakeholder 'Air Traffic Control Department'
-- Safety_Compliance_Officer: represents stakeholder 'Safety Compliance Officer'
-- Operations_Management: represents stakeholder 'Operations Management'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Slot_Allocation_API, Slot_Request_Database extends Interface {}

fact interface_properties {
    Slot_Allocation_API.kind = API  -- Interface for the slot allocation process, where arrival slots are allocated before departure slots.
    Slot_Request_Database.kind = Database  -- Stores information about all incoming and outgoing flight requests.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where Arrival slots have been allocated before departure slots


----------------------------------------------------------------------
-- Core operation: REQ_APC_01
----------------------------------------------------------------------

sig REQ_APC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_APC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_APC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_APC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_APC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_APC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_APC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_APC_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_APC_01 {
    some op: REQ_APC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_APC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_APC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_APC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_APC_01_well_formed {
    all op: REQ_APC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_APC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- POST-STATE VERIFICATION: Post1
-- Description: Arrival slots have been allocated before departure slots

pred ps_reach_Post1 {
    some op: REQ_APC_01 |
        op.post = Post1 &&
        op.pre = PreIdle &&
        op.grant = Write &&
        op.initiator in Airport_Slot_Coordinator_Team &&
        some t: op.target | t in Slot_Allocation_API &&
        op.channel.encrypted = True &&
        op.channel.authenticated = True
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_APC_01 |
        (op.post = Post1) =>
            (op.pre = PreIdle &&
             op.grant = Write &&
             op.initiator in Airport_Slot_Coordinator_Team &&
             some t: op.target | t in Slot_Allocation_API &&
             op.channel.encrypted = True &&
             op.channel.authenticated = True)
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_APC_01 |
        #op.target > 1
}

pred ac_reach_2 {
    some op: REQ_APC_01 |
        Write in op.initiator.mayPerform &&
        some c: op.channel | c.authenticated = True && c.encrypted = True
}

pred ac_reach_3 {
    some op: REQ_APC_01 |
        op.post = Post1 &&
        op.pre = PreIdle &&
        Write in op.initiator.mayPerform &&
        #op.target > 1 &&
        Admin in op.initiator.mayPerform
}

run ac_reach_1 for 5
run ac_reach_2 for 5
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- In this model:
--   Write permission = arrival request
--   Read permission  = departure request
--   Resource = time period (target)

assert ec_safe_1 {
  // Safety: In any time period (pre state), if the number of arrival operations (Write) equals the number of departure operations (Read), then no resource is targeted by both an arrival and a departure operation to avoid double-booking.
  all s: State |
    ( #{op: REQ_APC_01 | op.pre = s && op.grant = Write}
      = #{op: REQ_APC_01 | op.pre = s && op.grant = Read} ) =>
    no disj op1, op2: REQ_APC_01 |
      op1.pre = s && op2.pre = s && op1.grant = Write && op2.grant = Read &&
      some op1.target & op2.target
}
check ec_safe_1 for 5

assert ec_safe_2 {
  // Safety: During a surge (multiple operations targeting the same resource at the same time period), all such operations must have the same grant to avoid conflicting allocation.
  all disj op1, op2: REQ_APC_01 |
    op1.pre = op2.pre && some (op1.target & op2.target) =>
    op1.grant = op2.grant
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-APC-01: arrival slot allocated before departure slot
-- Arrival = Write, Departure = Read
pred tc_apc_01_holds {
    some op_arr, op_dep: REQ_APC_01 |
        op_arr != op_dep &&
        op_arr.grant = Write && op_dep.grant = Read &&
        some (op_arr.target & op_dep.target) &&          -- same time period (shared resource)
        op_arr.post = op_dep.pre                           -- arrival precedes departure
}
run  tc_apc_01_holds  for 5

assert tc_apc_01_contract {
    all op_arr, op_dep: REQ_APC_01 |
        (op_arr.grant = Write && op_dep.grant = Read &&
         some t: Resource | t in op_arr.target && t in op_dep.target) =>
        op_arr.post = op_dep.pre
}
check tc_apc_01_contract  for 5

-- Scenario TC-APC-02: equal number of arrival/departure during peak hours; arrival first
pred tc_apc_02_holds {
    some op_arr, op_dep: REQ_APC_01 |
        op_arr != op_dep &&
        op_arr.initiator = Airport_Slot_Coordinator_Team &&
        op_dep.initiator = Airport_Slot_Coordinator_Team &&
        op_arr.grant = Write && op_dep.grant = Read &&
        Slot_Allocation_API in op_arr.target &&
        Slot_Allocation_API in op_dep.target &&
        op_arr.post = op_dep.pre
}
run  tc_apc_02_holds  for 5

assert tc_apc_02_contract {
    all op_arr, op_dep: REQ_APC_01 |
        (op_arr.initiator = Airport_Slot_Coordinator_Team &&
         op_dep.initiator = Airport_Slot_Coordinator_Team &&
         op_arr.grant = Write && op_dep.grant = Read &&
         Slot_Allocation_API in op_arr.target &&
         Slot_Allocation_API in op_dep.target) =>
        op_arr.post = op_dep.pre
}
check tc_apc_02_contract  for 5

