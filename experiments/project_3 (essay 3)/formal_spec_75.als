module REQ_SCHED_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-SCHED-01
 * Title       : Detect and Prevent Slot Overlaps
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Scheduler, Resource_Manager, Project_Team extends Actor {}
-- Scheduler: represents stakeholder 'Scheduler'
-- Resource_Manager: represents stakeholder 'Resource Manager'
-- Project_Team: represents stakeholder 'Project Team'

-- Assign base permissions to actors (model assumption)
fact role_permissions {
    Scheduler.mayPerform = Read + Write + Execute + Admin
    Resource_Manager.mayPerform = Read + Write
    Project_Team.mayPerform = Read
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource: the schedule database (stores slots)
one sig ScheduleData extends Resource {}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Schedule_Database, Scheduler_Interface extends Interface {}

fact interface_properties {
    Schedule_Database.kind = Database
    Scheduler_Interface.kind = UI
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where A valid schedule with existing slots is available in the system

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The attempt to create or modify a slot that overlaps with an existing slot is rejected
-- Post2: system reaches state where An error message indicating the overlap is displayed


----------------------------------------------------------------------
-- Core operation: REQ_SCHED_01
----------------------------------------------------------------------

sig REQ_SCHED_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_SCHED_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_SCHED_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_SCHED_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_SCHED_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_SCHED_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_SCHED_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_SCHED_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SCHED_01 {
    some op: REQ_SCHED_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SCHED_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_SCHED_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_SCHED_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_SCHED_01_well_formed {
    all op: REQ_SCHED_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SCHED_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_SCHED_01 |
        op.post = Post1 &&
        op.pre != Post1 &&
        Write in op.grant &&
        some r: op.target | r.owner != op.initiator
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_SCHED_01 |
        op.post = Post1 => (
            Write in op.grant &&
            op.pre != Post1 &&
            some r: op.target | r.owner != op.initiator
        )
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_SCHED_01 |
        op.post = Post2 &&
        op.pre != Post2 &&
        Write in op.grant &&
        some r: op.target | r.owner != op.initiator &&
        some i: op.channel | i.kind = UI
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_SCHED_01 |
        op.post = Post2 => (
            Write in op.grant &&
            op.pre != Post2 &&
            some r: op.target | r.owner != op.initiator &&
            some i: op.channel | i.kind = UI
        )
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

// Criterion 1: Given a schedule with existing slots
pred ac_reach_1 {
    some op: REQ_SCHED_01 |
        // The operation involves the ScheduleData resource which represents schedule slots
        ScheduleData in op.target &&
        // An authorized user initiates the operation (must have necessary permissions)
        (Read + Write) in op.initiator.mayPerform &&
        // The operation changes state, demonstrating existing slots context
        op.pre = Pre1 &&
        op.post = Post1 &&
        // Uses a secure channel that requires authentication
        some c: op.channel | c.authenticated = True &&
        // The initiator can access the schedule database
        op.initiator in ScheduleData.accessible
}

run ac_reach_1 for 5

// Criterion 2: When a user attempts to create || modify a slot that overlaps with an existing slot
pred ac_reach_2 {
    some op: REQ_SCHED_01 |
        // The operation targets the ScheduleData (where slots are stored)
        ScheduleData in op.target &&
        // User has write permission (creating || modifying)
        Write in op.initiator.mayPerform &&
        // Operation uses appropriate channel with authentication
        some c: op.channel | c.authenticated = True &&
        // Resource access control is respected
        op.initiator in ScheduleData.accessible &&
        // State transition indicates an attempted modification
        op.pre = Pre1 &&
        op.post = Post2 &&
        // The grant permission is Write, indicating modification attempt
        op.grant = Write
}

run ac_reach_2 for 5

// Criterion 3: Then the system rejects the action && displays an error message indicating the overlap
pred ac_reach_3 {
    some op: REQ_SCHED_01 |
        // Operation targets the schedule database
        ScheduleData in op.target &&
        // The operation is attempted but rejected - state doesn't change meaningfully
        op.pre = Pre1 &&
        // Post2 represents a rejection state (error displayed)
        op.post = Post2 &&
        // Channel must be authenticated (system communication)
        some c: op.channel | c.authenticated = True &&
        // The initiator has permissions but the overlap causes rejection
        Write in op.initiator.mayPerform &&
        // Resource access is valid
        op.initiator in ScheduleData.accessible &&
        // Use the Scheduler_Interface for displaying error
        Scheduler_Interface in op.channel
}

run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
    all op: REQ_SCHED_01 |
        (op.initiator !in op.target.owner) => (op.grant = Read)
}
check ec_safe_1 for 5

assert ec_safe_2 {
    all op: REQ_SCHED_01 |
        (some ch: op.channel | ch.authenticated = False) => (op.grant != Write)
}
check ec_safe_2 for 5

assert ec_safe_3 {
    all op: REQ_SCHED_01 |
        (op.pre = Pre1 && op.post = Post1) => (some ch: op.channel | ch.encrypted = True)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-SCHED-01: Overlap detection on creation
pred tc_sched_01_holds {
    some op: REQ_SCHED_01 |
        -- Input: admin user creates a new slot that overlaps with an existing slot
        Admin in op.initiator.mayPerform &&
        op.grant = Write &&
        some r: op.target | r.owner = op.initiator &&
        -- Expected: system rejects action && displays error (modeled as transition to Post2)
        op.post = Post2
}
run tc_sched_01_holds for 5

assert tc_sched_01_contract {
    all op: REQ_SCHED_01 |
        -- If admin creates a slot that overlaps (modeled as leading to rejection)
        (Admin in op.initiator.mayPerform && op.grant = Write &&
         some r: op.target | r.owner = op.initiator) =>
        -- Then the system rejects (transitions to Post2)
        op.post = Post2
}
check tc_sched_01_contract for 5

-- TC-SCHED-02: Overlap detection on modification
pred tc_sched_02_holds {
    some op: REQ_SCHED_01 |
        -- Input: admin modifies an existing slot to create overlap
        Admin in op.initiator.mayPerform &&
        op.grant = Write &&
        some r: op.target | r.owner = op.initiator &&
        -- Expected: system rejects modification (transitions to Post2)
        op.post = Post2
}
run tc_sched_02_holds for 5

assert tc_sched_02_contract {
    all op: REQ_SCHED_01 |
        -- If admin modifies a slot to create overlap (modeled as leading to rejection)
        (Admin in op.initiator.mayPerform && op.grant = Write &&
         some r: op.target | r.owner = op.initiator) =>
        -- Then system rejects (transitions to Post2)
        op.post = Post2
}
check tc_sched_02_contract for 5

-- TC-SCHED-03: Non-overlapping slot creation
pred tc_sched_03_holds {
    some op: REQ_SCHED_01 |
        -- Input: admin creates a slot that fits between existing slots (no overlap)
        Admin in op.initiator.mayPerform &&
        op.grant = Write &&
        some r: op.target | r.owner = op.initiator &&
        -- Expected: system allows creation (state changes to Post1)
        op.post = Post1
}
run tc_sched_03_holds for 5

assert tc_sched_03_contract {
    all op: REQ_SCHED_01 |
        -- If admin creates a non-overlapping slot
        (Admin in op.initiator.mayPerform && op.grant = Write &&
         some r: op.target | r.owner = op.initiator) =>
        -- Then system allows it (state changes to Post1)
        op.post = Post1
}
check tc_sched_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: minimize resource usage per operation to reduce latency
fact nfr_fact_performance {
    all op: REQ_SCHED_01 | #op.target <= 3
}

-- Availability: require at least one encrypted channel for reliable communication
fact nfr_fact_availability {
    all op: REQ_SCHED_01 | some c: op.channel | c.encrypted = True
}

-- Usability: limit number of channels per operation to one for simple interaction
fact nfr_fact_usability {
    all op: REQ_SCHED_01 | #op.channel = 1
}

-- Scalability: ensure the system can handle multiple operations per actor
assert nfr_assert_scalability {
    some disj op1, op2: REQ_SCHED_01 | op1.initiator = op2.initiator
}
check nfr_assert_scalability for 5

