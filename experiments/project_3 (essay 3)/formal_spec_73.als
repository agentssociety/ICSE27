module REQ_SCHED_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-SCHED-01
 * Title       : Allocate 5-minute slots with a 3-minute gap between successive slots
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Scheduler, Customer_Support, Operational_Team extends Actor {}
-- Scheduler: represents stakeholder 'Scheduler'
-- Customer_Support: represents stakeholder 'Customer Support'
-- Operational_Team: represents stakeholder 'Operational Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Scheduling_Database, Scheduling_API extends Interface {}

fact interface_properties {
    Scheduling_Database.kind = Database  -- The system interacts with a database to store and retrieve time slot information.
    Scheduling_API.kind = API  -- The requirement involves creating slots through an API that can be invoked by the scheduling application or other services.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Time slots are created with the specified duration and gap
-- Post2: system reaches state where The scheduling system operates without errors related to slot allocation


----------------------------------------------------------------------
-- Core operation: REQ_SCHED_01
----------------------------------------------------------------------

sig REQ_SCHED_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_SCHED_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_SCHED_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_SCHED_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_SCHED_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_SCHED_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_SCHED_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_SCHED_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SCHED_01 {
    some op: REQ_SCHED_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SCHED_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_SCHED_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_SCHED_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_SCHED_01_well_formed {
    all op: REQ_SCHED_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SCHED_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1: Time slots are created with the specified duration && gap
pred ps_reach_Post1 {
    some op: REQ_SCHED_01 |
        op.post = Post1 &&
        op.pre = PreIdle &&
        (Scheduling_Database in op.target) &&
        (Scheduling_API in op.channel) &&
        Write in op.initiator.mayPerform &&
        op.initiator in Scheduler
}

assert ps_valid_Post1 {
    all op: REQ_SCHED_01 |
        (op.post = Post1) =>
            (op.pre = PreIdle &&
             Scheduling_Database in op.target &&
             Scheduling_API in op.channel &&
             Write in op.initiator.mayPerform &&
             op.initiator in Scheduler)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

-- Post2: The scheduling system operates without errors related to slot allocation
pred ps_reach_Post2 {
    some op: REQ_SCHED_01 |
        op.post = Post2 &&
        op.pre != Post2 &&
        (Scheduling_Database in op.target) &&
        (Scheduling_API in op.channel) &&
        Read in op.initiator.mayPerform &&
        op.initiator in Scheduler
}

assert ps_valid_Post2 {
    all op: REQ_SCHED_01 |
        (op.post = Post2) =>
            (op.pre != Post2 &&
             Scheduling_Database in op.target &&
             Scheduling_API in op.channel &&
             Read in op.initiator.mayPerform &&
             op.initiator in Scheduler)
}

run ps_reach_Post2 for 5
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ac_reach_1: reachability of a scheduling slot from PreIdle to Post1, using Scheduler && Database as a representative scenario.
pred ac_reach_1 {
    some op: REQ_SCHED_01 |
        op.pre = PreIdle &&
        op.post = Post1 &&
        op.initiator = Scheduler &&
        op.grant = Write &&
        op.target = Database
}
run ac_reach_1 for 5

-- ac_reach_2: reachability of two consecutive slots with a gap (Post1 as the intermediate state).
pred ac_reach_2 {
    some disj op1, op2: REQ_SCHED_01 |
        op1.pre = PreIdle && op1.post = Post1 &&
        op2.pre = Post1 && op2.post = Post2 &&
        op1.initiator = Scheduler && op2.initiator = Scheduler
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: overlapping slots ? no two operations can create conflicting resource states
assert ec_safe_1 {
    all op1, op2: REQ_SCHED_01 |
        op1 != op2 &&
        some op1.target & op2.target &&
        op1.grant = op2.grant &&
        op1.initiator != op2.initiator
        =>
            op1.post != op2.pre
}
check ec_safe_1 for 5

-- Edge case 2: slot duration other than 5 minutes ? model must handle any duration via state change
assert ec_safe_2 {
    all op: REQ_SCHED_01 |
        -- if pre state is PreIdle, post must be Post1 || Post2 (no undefined states)
        op.pre = PreIdle =>
            (op.post = Post1 || op.post = Post2)
}
check ec_safe_2 for 5

-- Edge case 3: no available time slots between end of one && start of next
assert ec_safe_3 {
    all op: REQ_SCHED_01 |
        -- if no gap exists, operation must still produce a valid post state
        (op.pre = Post1 && op.post = Post2) ||
        (op.pre = Post2 && op.post = Post1) ||
        (op.pre = PreIdle && (op.post = Post1 || op.post = Post2))
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_sched01_holds {
  some op: REQ_SCHED_01 |
    op.initiator = Scheduler &&
    op.grant = Write &&
    Scheduling_Database in op.target &&
    op.pre = PreIdle &&
    op.post = Post1 &&
    Scheduling_API in op.channel
}
run tc_sched01_holds for 5

assert tc_sched01_contract {
  all op: REQ_SCHED_01 |
    (op.initiator = Scheduler &&
     op.grant = Write &&
     Scheduling_Database in op.target &&
     op.pre = PreIdle) =>
    op.post = Post1
}
check tc_sched01_contract for 5

pred tc_sched02_holds {
  some op: REQ_SCHED_01 |
    op.initiator = Scheduler &&
    op.grant = Write &&
    Scheduling_Database in op.target &&
    op.pre = Post1 &&
    op.post = Post2 &&
    Scheduling_API in op.channel
}
run tc_sched02_holds for 5

assert tc_sched02_contract {
  all op: REQ_SCHED_01 |
    (op.initiator = Scheduler &&
     op.grant = Write &&
     Scheduling_Database in op.target &&
     op.pre = Post1) =>
    op.post = Post2
}
check tc_sched02_contract for 5

pred tc_sched03_holds {
  no op: REQ_SCHED_01 |
    op.initiator = Scheduler &&
    op.grant = Write &&
    Scheduling_Database in op.target &&
    op.pre = PreIdle &&
    op.post = Post2 &&
    Scheduling_API in op.channel
}
run tc_sched03_holds for 5

assert tc_sched03_contract {
  all op: REQ_SCHED_01 |
    (op.initiator = Scheduler &&
     op.grant = Write &&
     Scheduling_Database in op.target &&
     op.pre = PreIdle) =>
    op.post != Post2
}
check tc_sched03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_valid_pre_state {
    // NFR usability proxy: error handling for invalid slot configurations ? only PreIdle is a valid pre-state
    all op: REQ_SCHED_01 | op.pre = PreIdle
}

assert nfr_assert_clear_channel_display {
    // NFR usability proxy: clear display of available slots ? limit channel count per operation for simpler UI
    all op: REQ_SCHED_01 | #op.channel <= 1
}
check nfr_assert_clear_channel_display for 5

