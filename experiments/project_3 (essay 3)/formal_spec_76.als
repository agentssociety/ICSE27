module REQ_OPM_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-OPM-01
 * Title       : Runway Closure and Flight Reassignment Management
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 * Revised to fix: added concrete resources, actor permissions, interface properties, and corrected set-level comparisons.
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Airport_Operations_Manager, Flight_Control_Center, Passenger_Services_Department extends Actor {}
-- Airport_Operations_Manager: represents stakeholder 'Airport Operations Manager'
-- Flight_Control_Center: represents stakeholder 'Flight Control Center'
-- Passenger_Services_Department: represents stakeholder 'Passenger Services Department'

-- Assign permissions to actors
fact actor_permissions {
    Airport_Operations_Manager.mayPerform = Read + Write + Execute + Admin
    Flight_Control_Center.mayPerform = Read + Write + Execute
    Passenger_Services_Department.mayPerform = Read + Write
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Concrete resources
one sig RunwayClosureRequest, FlightSchedule, DelayCalculation extends Resource {}

-- Assign ownership and accessibility
fact resource_properties {
    RunwayClosureRequest.owner = Airport_Operations_Manager
    RunwayClosureRequest.accessible = Airport_Operations_Manager + Flight_Control_Center
    FlightSchedule.owner = Flight_Control_Center
    FlightSchedule.accessible = Airport_Operations_Manager + Flight_Control_Center + Passenger_Services_Department
    DelayCalculation.owner = Flight_Control_Center
    DelayCalculation.accessible = Airport_Operations_Manager + Flight_Control_Center + Passenger_Services_Department
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Runway_Closure_API, Flight_Schedule_Database, Airport_Operations_Manager_Console extends Interface {}

fact interface_properties {
    Runway_Closure_API.kind = API
    Runway_Closure_API.encrypted = True
    Runway_Closure_API.authenticated = True
    Flight_Schedule_Database.kind = Database
    Flight_Schedule_Database.encrypted = True
    Flight_Schedule_Database.authenticated = True
    Airport_Operations_Manager_Console.kind = UI
    Airport_Operations_Manager_Console.encrypted = True
    Airport_Operations_Manager_Console.authenticated = True
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where Runway closure request is received by the airport operations manager.
-- Pre2: system is in state where There are available alternate runways and slots.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where Flights have been reassigned to other available runways.
-- Post2: system reaches state where The new delays for each flight have been calculated.
-- Post3: system reaches state where Flights with a delay exceeding 60 minutes have been explicitly marked as delayed in the system.


----------------------------------------------------------------------
-- Core operation: REQ_OPM_01
----------------------------------------------------------------------

sig REQ_OPM_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_OPM_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_OPM_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_OPM_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_OPM_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_OPM_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_OPM_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_OPM_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_OPM_01 {
    some op: REQ_OPM_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_OPM_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_OPM_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_OPM_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_OPM_01_well_formed {
    all op: REQ_OPM_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_OPM_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicate for Post1: flights reassigned to other runways
pred ps_reach_Post1 {
    some op: REQ_OPM_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        op.initiator in Airport_Operations_Manager &&
        Write in op.grant &&
        Flight_Schedule_Database in op.target &&
        (some ifc: op.channel | ifc = Airport_Operations_Manager_Console || ifc = API) &&
        (all c: op.channel | c.encrypted = True && c.authenticated = True)
}
run ps_reach_Post1 for 5

-- Semantic assertion for Post1
assert ps_valid_Post1 {
    all op: REQ_OPM_01 |
        (op.post = Post1) =>
            (op.initiator in Airport_Operations_Manager &&
             Write in op.grant &&
             Flight_Schedule_Database in op.target &&
             (some ifc: op.channel | ifc = Airport_Operations_Manager_Console || ifc = API) &&
             (all c: op.channel | c.encrypted = True && c.authenticated = True))
}
check ps_valid_Post1 for 5

-- Reachability predicate for Post2: new delays calculated
pred ps_reach_Post2 {
    some op: REQ_OPM_01 |
        op.post = Post2 &&
        op.pre = Pre1 &&
        op.initiator in Flight_Control_Center &&
        Execute in op.grant &&
        Flight_Schedule_Database in op.target &&
        (some ifc: op.channel | ifc = API) &&
        (all c: op.channel | c.encrypted = True && c.authenticated = True)
}
run ps_reach_Post2 for 5

-- Semantic assertion for Post2
assert ps_valid_Post2 {
    all op: REQ_OPM_01 |
        (op.post = Post2) =>
            (op.initiator in Flight_Control_Center &&
             Execute in op.grant &&
             Flight_Schedule_Database in op.target &&
             (some ifc: op.channel | ifc = API) &&
             (all c: op.channel | c.encrypted = True && c.authenticated = True))
}
check ps_valid_Post2 for 5

-- Reachability predicate for Post3: flights with >60 min delay marked as delayed
pred ps_reach_Post3 {
    some op: REQ_OPM_01 |
        op.post = Post3 &&
        op.pre = Pre1 &&
        op.initiator in Airport_Operations_Manager &&
        Write in op.grant &&
        Flight_Schedule_Database in op.target &&
        (some ifc: op.channel | ifc = Airport_Operations_Manager_Console) &&
        (all c: op.channel | c.encrypted = True && c.authenticated = True)
}
run ps_reach_Post3 for 5

-- Semantic assertion for Post3
assert ps_valid_Post3 {
    all op: REQ_OPM_01 |
        (op.post = Post3) =>
            (op.initiator in Airport_Operations_Manager &&
             Write in op.grant &&
             Flight_Schedule_Database in op.target &&
             (some ifc: op.channel | ifc = Airport_Operations_Manager_Console) &&
             (all c: op.channel | c.encrypted = True && c.authenticated = True))
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
	some op: REQ_OPM_01 |
		op.post = Post1 &&
		op.initiator = Airport_Operations_Manager &&
		Execute in op.initiator.mayPerform &&
		some r: op.target |
			r in Resource &&
			r.owner = op.initiator &&
			op.initiator in r.accessible
}

run ac_reach_1 for 5

pred ac_reach_2 {
	some op: REQ_OPM_01 |
		op.post = Post2 &&
		op.initiator = Flight_Control_Center &&
		Write in op.initiator.mayPerform &&
		some r: op.target |
			r in Resource &&
			r.owner = op.initiator &&
			op.initiator in r.accessible
}

run ac_reach_2 for 5

pred ac_reach_3 {
	some op: REQ_OPM_01 |
		op.post = Post3 &&
		op.initiator = Airport_Operations_Manager &&
		Admin in op.initiator.mayPerform &&
		some r: op.target |
			r in Resource &&
			r.owner = op.initiator &&
			op.initiator in r.accessible
}

run ac_reach_3 for 5

pred ac_reach_4 {
	some op: REQ_OPM_01 |
		op.post = Post3 &&
		op.initiator = Passenger_Services_Department &&
		Write in op.initiator.mayPerform &&
		some r: op.target |
			r in Resource &&
			r.owner = op.initiator &&
			op.initiator in r.accessible
}

run ac_reach_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_OPM_01 |
    (Runway_Closure_API in op.target && op.pre = Pre1) => op.post != Post1
}
check ec_safe_1 for 5

assert ec_safe_2 {
  all op: REQ_OPM_01 |
    (Flight_Schedule_Database in op.target && op.pre = Pre2) => op.post != Post2
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-OPM-01: Runway closure request processed successfully
pred tc_OPM01_holds {
    some op: REQ_OPM_01 |
        op.initiator = Airport_Operations_Manager &&
        Runway_Closure_API in op.target &&
        (all c: op.channel | c.encrypted = True && c.authenticated = True) &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.post != op.pre
}
run tc_OPM01_holds for 5

assert tc_OPM01_contract {
    all op: REQ_OPM_01 |
        (op.initiator = Airport_Operations_Manager &&
         Runway_Closure_API in op.target &&
         (all c: op.channel | c.encrypted = True && c.authenticated = True) &&
         op.pre = Pre1) =>
        (op.post = Post1 && op.post != op.pre)
}
check tc_OPM01_contract for 5

-- Scenario TC-OPM-02: Delay calculation for a flight with 61 minutes delay
pred tc_OPM02_holds {
    some op: REQ_OPM_01 |
        op.initiator = Flight_Control_Center &&
        Flight_Schedule_Database in op.target &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post2 &&
        op.post != op.pre
}
run tc_OPM02_holds for 5

assert tc_OPM02_contract {
    all op: REQ_OPM_01 |
        (op.initiator = Flight_Control_Center &&
         Flight_Schedule_Database in op.target &&
         op.grant = Write &&
         op.pre = Pre1) =>
        (op.post = Post2 && op.post != op.pre)
}
check tc_OPM02_contract for 5

-- Scenario TC-OPM-03: Error handling when no alternate runways available
pred tc_OPM03_holds {
    some op: REQ_OPM_01 |
        op.initiator = Airport_Operations_Manager &&
        Airport_Operations_Manager_Console in op.target &&
        op.grant = Write &&
        op.pre = Pre2 &&
        op.post = Post3 &&
        op.post != op.pre
}
run tc_OPM03_holds for 5

assert tc_OPM03_contract {
    all op: REQ_OPM_01 |
        (op.initiator = Airport_Operations_Manager &&
         Airport_Operations_Manager_Console in op.target &&
         op.grant = Write &&
         op.pre = Pre2) =>
        (op.post = Post3 && op.post != op.pre)
}
check tc_OPM03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limit number of channels && targets to reduce latency
assert nfr_assert_performance {
    all op: REQ_OPM_01 | #op.channel <= 2 && #op.target <= 2
}
check nfr_assert_performance for 5

-- Availability proxy: require at least two channels for redundancy to ensure uptime
assert nfr_assert_availability {
    all op: REQ_OPM_01 | #op.channel >= 2
}
check nfr_assert_availability for 5

-- Scalability proxy: ensure enough operations exist to handle all actors simultaneously
assert nfr_assert_scalability {
    #REQ_OPM_01 >= #Actor
}
check nfr_assert_scalability for 5

-- Usability proxy: restrict channel kinds to standard interfaces (UI || API) for intuitive design
assert nfr_assert_usability {
    all op: REQ_OPM_01 | op.channel.kind in (UI + API)
}
check nfr_assert_usability for 5

