              endTime=datetime(2025, 6, 15, 10, 11, 0),                                                                                                                                
          )                                                                                                                                                                            
          with pytest.raises(ValueError, match="Adjacent gap of at least 3 minutes"):                                                                                                  
              self.service.allocate_slot(data2)                                                                                                                                        
                                                                                                                                                                                       
      def test_get_slot_found(self) -> None:                                                                                                                                           
          data = SlotCreateRequest(                                                                                                                                                    
