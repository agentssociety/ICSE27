          alt_runways = []                                                                                                                                                                      
          for alt_id in alternative_runway_ids:                                                                                                                                                 
              alt = self._repository.get_by_id(alt_id)                                                                                                                                          
              if alt is not None:                                                                                                                                                               
                  alt_runways.append(alt)                                                                                                                                                       
                                                                                                                                                                                                
