module REQ_CTR_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-CTR-01
 * Title       : Runway Slot Timetable View
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Controllers, Operations_Management_Team, Emergency_Services extends Actor {}
-- Air_Traffic_Controllers: represents stakeholder 'Air Traffic Controllers'
-- Operations_Management_Team: represents stakeholder 'Operations Management Team'
-- Emergency_Services: represents stakeholder 'Emergency Services'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- The runway schedule database is the primary resource for slot timetable.
one sig RunwayScheduleDB extends Resource {}

fact RunwayScheduleDB_access {
    RunwayScheduleDB.owner = Air_Traffic_Controllers
    RunwayScheduleDB.accessible = Air_Traffic_Controllers + Operations_Management_Team
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Information_API, Runway_Schedule_Database extends Interface {}

fact interface_properties {
    Flight_Information_API.kind = API  -- The requirement interacts with an external system to retrieve real-time flight data, including delays and emergency statuses.
    Runway_Schedule_Database.kind = Database  -- The requirement accesses a database to fetch the current schedule of runway slots and update their statuses in real-time.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The runway slot timetable view is accessible to authorized air traffic controllers

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The selected runway's slot timetable is displayed
-- Post2: system reaches state where Each slot's status is accurately updated based on real-time data


----------------------------------------------------------------------
-- Core operation: REQ_CTR_01
----------------------------------------------------------------------

sig REQ_CTR_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_CTR_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_CTR_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_CTR_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_CTR_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
-- Note: This fact is removed to avoid conflict with edge case assertions that allow no state change.

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_CTR_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_CTR_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_CTR_01 {
    some op: REQ_CTR_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_CTR_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_CTR_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_CTR_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_CTR_01_well_formed {
    all op: REQ_CTR_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_CTR_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_CTR_01 |
        op.post = Post1 &&
        (op.initiator in Resource.owner) &&
        (Read in op.initiator.mayPerform) &&
        (RunwayScheduleDB in op.target) &&
        (Flight_Information_API in op.channel)
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_CTR_01 |
        (op.post = Post1) =>
            (Read in op.initiator.mayPerform &&
             RunwayScheduleDB in op.target &&
             Flight_Information_API in op.channel)
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_CTR_01 |
        op.post = Post2 &&
        (Write in op.initiator.mayPerform) &&
        (RunwayScheduleDB in op.target) &&
        (op.pre != Post2) &&
        (Air_Traffic_Controllers in op.initiator) &&
        (API in op.channel)
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_CTR_01 |
        (op.post = Post2) =>
            (Write in op.initiator.mayPerform &&
             RunwayScheduleDB in op.target &&
             op.channel in Interface - Flight_Information_API &&
             op.pre != Post2)
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_CTR_01 |
        op.initiator = Air_Traffic_Controllers &&
        Read in op.initiator.mayPerform &&
        RunwayScheduleDB in op.target &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_CTR_01 |
        op.initiator = Air_Traffic_Controllers &&
        one op.target &&
        op.target = RunwayScheduleDB &&
        Read in op.grant
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_CTR_01 |
        op.initiator = Air_Traffic_Controllers &&
        RunwayScheduleDB in op.target &&
        op.initiator in RunwayScheduleDB.accessible &&
        op.post = Post1
}
run ac_reach_3 for 5

pred ac_reach_4 {
    some op: REQ_CTR_01 |
        op.initiator = Air_Traffic_Controllers &&
        RunwayScheduleDB in op.target &&
        Flight_Information_API in op.channel &&
        op.post = Post1
}
run ac_reach_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sigs for edge case safety invariants
sig SlotAvailability {
    resource: one Resource,
    hasSlots: one Bool
}
sig OperatingHoursStatus {
    resource: one Resource,
    isOpen: one Bool
}
sig EmergencyStatus {
    active: one Bool
}

-- Edge case 1: No scheduled slots ? operation must not change state
assert ec_safe_1 {
    all op: REQ_CTR_01 |
        (some s: SlotAvailability | s.resource in op.target && s.hasSlots = False) =>
        op.post = op.pre
}
check ec_safe_1 for 5

-- Edge case 2: Delay beyond operating hours ? operation must not change state
assert ec_safe_2 {
    all op: REQ_CTR_01 |
        (some h: OperatingHoursStatus | h.resource in op.target && h.isOpen = False) =>
        op.post = op.pre
}
check ec_safe_2 for 5

-- Edge case 3: Emergency flight active ? only emergency services or admin may perform operation
assert ec_safe_3 {
    all op: REQ_CTR_01 |
        (some em: EmergencyStatus | em.active = True) =>
        (op.initiator = Emergency_Services || op.grant = Admin)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-CTR-01: display scheduled slots
pred tc_ctr_01_holds {
    some op: REQ_CTR_01 |
        op.initiator in Air_Traffic_Controllers &&
        RunwayScheduleDB in op.target &&
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        some sa: SlotAvailability | sa.resource in op.target && sa.hasSlots = True &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_ctr_01_holds for 5

assert tc_ctr_01_contract {
    all op: REQ_CTR_01 |
        (op.initiator in Air_Traffic_Controllers &&
         RunwayScheduleDB in op.target &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         some sa: SlotAvailability | sa.resource in op.target && sa.hasSlots = True) =>
        (op.grant = Read && op.post != op.pre)
}
check tc_ctr_01_contract for 5

-- TC-CTR-02: update delay in slot timetable
pred tc_ctr_02_holds {
    some op: REQ_CTR_01 |
        op.initiator in Operations_Management_Team &&
        RunwayScheduleDB in op.target &&
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        some sa: SlotAvailability | sa.resource in op.target && sa.hasSlots = True &&
        op.grant = Write &&
        op.post != op.pre
}
run tc_ctr_02_holds for 5

assert tc_ctr_02_contract {
    all op: REQ_CTR_01 |
        (op.initiator in Operations_Management_Team &&
         RunwayScheduleDB in op.target &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         some sa: SlotAvailability | sa.resource in op.target && sa.hasSlots = True) =>
        (op.grant = Write && op.post != op.pre)
}
check tc_ctr_02_contract for 5

-- TC-CTR-03: mark emergency flight
pred tc_ctr_03_holds {
    some op: REQ_CTR_01 |
        op.initiator in Emergency_Services &&
        RunwayScheduleDB in op.target &&
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        some em: EmergencyStatus | em.active = True &&
        op.grant = Execute &&
        op.post != op.pre
}
run tc_ctr_03_holds for 5

assert tc_ctr_03_contract {
    all op: REQ_CTR_01 |
        (op.initiator in Emergency_Services &&
         RunwayScheduleDB in op.target &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         some em: EmergencyStatus | em.active = True) =>
        (op.grant = Execute && op.post != op.pre)
}
check tc_ctr_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limiting channels per operation reduces communication latency (NFR: response < 2s)
fact nfr_fact_performance {
    all op: REQ_CTR_01 | #op.channel <= 2
}

-- Availability proxy: requiring at least two channels per operation ensures redundancy (NFR: 99.9% uptime)
fact nfr_fact_availability {
    all op: REQ_CTR_01 | #op.channel >= 2
}

-- Scalability proxy: each resource must be capable of handling concurrent operations (NFR: 10,000 slots per minute)
assert nfr_assert_scalability {
    all r: Resource | some disj op1, op2: REQ_CTR_01 | r in op1.target && r in op2.target
}
check nfr_assert_scalability for 5

-- Usability proxy: limiting the number of authenticated interfaces simplifies the user interface (NFR: clear, intuitive)
assert nfr_assert_usability {
    #{i: Interface | i.authenticated = True} <= 2
}
check nfr_assert_usability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security property: Access to runway slot timetable view restricted to authorized personnel only.
-- Authorized personnel are defined as Air_Traffic_Controllers && Operations_Management_Team.
-- Already enforced via RunwayScheduleDB.accessible fact above.

assert sr_assert_runway_access_restricted {
    all op: REQ_CTR_01 |
        RunwayScheduleDB in op.target =>
            op.initiator in RunwayScheduleDB.accessible
}

check sr_assert_runway_access_restricted for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Added Resource sig RunwayScheduleDB to represent runway schedule database, fixing type errors where Interface was used as target.
-- Summary 2: Removed contradictory invariant inv_state_must_change to allow edge case assertions ec_safe_1 and ec_safe_2 (no state change when no slots or hours closed).
-- Summary 3: Corrected all references to Runway_Schedule_Database as target to use RunwayScheduleDB.
-- Summary 4: Fixed sr_fact_runway_access_control to set accessible on RunwayScheduleDB resource, not Interface.
-- Summary 5: Preserved module name and overall structure with minimal changes for coherence.
-- Assumption 1: Runway schedule database is a single Resource owned by Air_Traffic_Controllers, accessible to Air_Traffic_Controllers and Operations_Management_Team.
-- Assumption 2: Permissions Read, Write, Execute, Admin are sufficient for required operations.
-- Assumption 3: Edge case assertions (ec_safe_1, ec_safe_2) assume no state change when no slots or beyond hours, consistent with requirement exploration.
-- Assumption 4: EmergencyStatus.active is a global flag; its semantics per runway are not modeled.
-- Open issue 1: ec_safe_3 restricts all operations to Emergency_Services or Admin when any emergency is active, which may be too broad; requirement only mentions emergency flight addition.
-- Open issue 2: nfr_fact_performance and nfr_fact_availability force exactly two channels per operation, which may be unrealistic for simple read operations.
-- Open issue 3: The scalabaility assertion nfr_assert_scalability may fail for resources with only one operation; it is kept as a check but may be too strong.
-- Open issue 4: The 'stronger' permission function is defined but unused; could be removed or utilized in future refinements.


