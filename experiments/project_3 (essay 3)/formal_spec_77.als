module REQ_ATC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-01
 * Title       : Prioritize Emergency Flights and Re-queue Non-Emergency Flights
 * Type        : Functional
 * Priority    : Critical
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Control_Team, Flight_Operations_Department, Safety_Compliance_Office extends Actor {}
-- Air_Traffic_Control_Team: represents stakeholder 'Air Traffic Control Team'
-- Flight_Operations_Department: represents stakeholder 'Flight Operations Department'
-- Safety_Compliance_Office: represents stakeholder 'Safety Compliance Office'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Information_API, Scheduling_Database, Air_Traffic_Control_Interface extends Interface {}

fact interface_properties {
    Flight_Information_API.kind = API  -- The system will interact with the Flight Information API to detect and retrieve flight information, including priority status.
    Scheduling_Database.kind = Database  -- The system will use the Scheduling Database to store and update flight slot assignments.
    Air_Traffic_Control_Interface.kind = UI  -- The requirement interacts with the Air Traffic Control interface to display updated slot assignments.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where An emergency flight is detected.

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where Emergency flights are prioritized without disrupting overall scheduling.


----------------------------------------------------------------------
-- Core operation: REQ_ATC_01
----------------------------------------------------------------------

sig REQ_ATC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_01 {
    some op: REQ_ATC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_01_well_formed {
    all op: REQ_ATC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Predicate: ps_reach_Post1
-- Verifies that Post1 is reachable via some REQ_ATC_01 operation,
-- where the operation involves scheduling-related permissions,
-- targets a scheduling resource, && uses an authenticated channel.
pred ps_reach_Post1 {
    some op: REQ_ATC_01 |
        op.post = Post1 &&
        -- The initiator must have a permission relevant to scheduling/prioritization
        (Write in op.initiator.mayPerform) &&
        -- The target resource must be the Scheduling_Database, which is the scheduling resource
        (Scheduling_Database in op.target) &&
        -- At least one channel must be authenticated (as required by INV-6)
        (some ch: op.channel | ch.authenticated = True) &&
        -- State must change (consistent with inv_state_must_change)
        op.pre != Post1
}

run ps_reach_Post1 for 5

-- Assertion: ps_valid_Post1
-- Verifies that whenever an operation reaches Post1,
-- the operation involves scheduling permissions, targets a scheduling resource,
-- && uses an authenticated channel (semantic meaning: emergency flights prioritized without disrupting overall scheduling).
assert ps_valid_Post1 {
    all op: REQ_ATC_01 |
        (op.post = Post1) =>
            (Write in op.initiator.mayPerform) &&
            (Scheduling_Database in op.target) &&
            (some ch: op.channel | ch.authenticated = True) &&
            op.pre != Post1
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: Emergency flight moved to front of queue
pred ac_reach_1 {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        op.grant = Write &&
        Scheduling_Database in op.target &&
        some c: op.channel | c.authenticated = True &&
        op.pre = Pre1 && op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: All other flights re-queued in original order (represented by multiple targets, state change)
pred ac_reach_2 {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        op.grant = Write &&
        #op.target > 1 &&
        Scheduling_Database in op.target &&
        some r: op.target | r != Scheduling_Database &&
        some c: op.channel | c.authenticated = True &&
        op.pre = Pre1 && op.post = Post1
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: No non-emergency flights in queue
-- Safety: If there are no non-emergency flights, the system must still handle emergency flights correctly
-- We model this by checking that when all flights are emergency, the operation still works
assert ec_safe_1 {
    all op: REQ_ATC_01 |
        -- If initiator is Air_Traffic_Control_Team && no non-emergency flights exist
        -- (modeled as: all resources are owned by Air_Traffic_Control_Team)
        (op.initiator = Air_Traffic_Control_Team && 
         all r: Resource | r.owner = Air_Traffic_Control_Team) =>
        -- Then the operation must still complete (post state exists)
        op.post != op.pre
}

check ec_safe_1 for 5

-- Edge case 2: Multiple emergency flights detected simultaneously
-- Safety: Concurrent emergency handling must ! cause conflicts
-- We model this by checking that no two operations on the same target have conflicting grants
assert ec_safe_2 {
    all disj op1, op2: REQ_ATC_01 |
        -- If both operations target the same resource
        (some r: Resource | r in op1.target && r in op2.target) =>
        -- They must have compatible grants (both can access the resource)
        (op1.grant = op2.grant || 
         (op1.grant in op1.initiator.mayPerform && op2.grant in op2.initiator.mayPerform))
}

check ec_safe_2 for 5

-- Edge case 3: Flight flagged as both emergency && non-emergency
-- Safety: Ambiguous classification must ! lead to unauthorized access
-- We model this by checking that if a resource has conflicting ownership claims,
-- the operation still respects access control
assert ec_safe_3 {
    all op: REQ_ATC_01 |
        -- If any target resource has multiple owners (ambiguous classification)
        (some r: op.target | #r.owner > 1) =>
        -- The initiator must have explicit permission for that resource
        (all r: op.target | op.initiator in r.accessible)
}

check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_ATC_01_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        Database in op.target &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_ATC_01_holds for 5

assert tc_ATC_01_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control_Team &&
         Database in op.target &&
         op.grant = Read) =>
        op.post != op.pre
}
check tc_ATC_01_contract for 5

pred tc_ATC_02_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        Database in op.target &&
        UI in op.target &&
        API in op.target &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_ATC_02_holds for 5

assert tc_ATC_02_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control_Team &&
         Database in op.target &&
         UI in op.target &&
         API in op.target &&
         op.grant = Read) =>
        op.post != op.pre
}
check tc_ATC_02_contract for 5

pred tc_ATC_03_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        Database in op.target &&
        no r: Resource | r != Database && r in op.target &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_ATC_03_holds for 5

assert tc_ATC_03_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control_Team &&
         Database in op.target &&
         no r: Resource | r != Database && r in op.target &&
         op.grant = Read) =>
        op.post != op.pre
}
check tc_ATC_03_contract for 5

pred tc_ATC_04_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        Database in op.target &&
        UI in op.target &&
        API ! in op.target &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_ATC_04_holds for 5

assert tc_ATC_04_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control_Team &&
         Database in op.target &&
         UI in op.target &&
         API ! in op.target &&
         op.grant = Read) =>
        op.post != op.pre
}
check tc_ATC_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting the number of resources per operation reduces processing latency
    -- NFR: response time < 200ms
    all op: REQ_ATC_01 | #op.target <= 2
}

fact nfr_fact_availability {
    -- PROXY: at least two channels per operation ensures redundancy for higher uptime
    -- NFR: availability 99.9%
    all op: REQ_ATC_01 | #op.channel >= 2
}

assert nfr_assert_scalability {
    -- PROXY: every actor can be the initiator of some operation ? system scales to handle all actors
    -- NFR: support up to 1000 concurrent actors
    all a: Actor | some op: REQ_ATC_01 | op.initiator = a
}
check nfr_assert_scalability for 5

fact nfr_fact_usability {
    -- PROXY: limiting authenticated channels per operation reduces authentication burden
    -- NFR: user must ! re?authenticate more than once per workflow
    all op: REQ_ATC_01 | lone c: op.channel | c.authenticated = True
}

