 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Flight_Dispatchers, Airline_Operations_Team, Scheduling_Department extends Actor {}
-- Flight_Dispatchers: represents stakeholder 'Flight Dispatchers'
-- Airline_Operations_Team: represents stakeholder 'Airline Operations Team'
-- Scheduling_Department: represents stakeholder 'Scheduling Department'

-- Assign permissions to actors (minimal for registration)
fact actor_permissions {
    Flight_Dispatchers.mayPerform = Read + Write + Admin
    Airline_Operations_Team.mayPerform = Read + Write + Execute + Admin
    Scheduling_Department.mayPerform = Read + Write
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Concrete resource representing the flight database / flight records
one sig FlightDB_Resource extends Resource {}

-- Set owner and accessibility for the flight database resource
fact flight_db_properties {
    FlightDB_Resource.owner = Airline_Operations_Team
    FlightDB_Resource.accessible = Flight_Dispatchers + Airline_Operations_Team + Scheduling_Department
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Database, Dispatcher_Interface extends Interface {}

fact interface_properties {
    Flight_Database.kind = Database  -- The requirement interacts with the Flight Database to store flight information.
    Dispatcher_Interface.kind = UI  -- The requirement interacts with the Dispatcher UI for inputting flight details.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where I am a logged-in flight dispatcher.

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The system contains the newly registered flight with accurate estimated departure time.


----------------------------------------------------------------------
-- Core operation: REQ_FLIGHT_DISPATCHER_01
----------------------------------------------------------------------

sig REQ_FLIGHT_DISPATCHER_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_FLIGHT_DISPATCHER_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_FLIGHT_DISPATCHER_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_FLIGHT_DISPATCHER_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_FLIGHT_DISPATCHER_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_FLIGHT_DISPATCHER_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_FLIGHT_DISPATCHER_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_FLIGHT_DISPATCHER_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_FLIGHT_DISPATCHER_01 {
    some op: REQ_FLIGHT_DISPATCHER_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_FLIGHT_DISPATCHER_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_FLIGHT_DISPATCHER_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_FLIGHT_DISPATCHER_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_FLIGHT_DISPATCHER_01_well_formed {
    all op: REQ_FLIGHT_DISPATCHER_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_FLIGHT_DISPATCHER_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? Post-state verification for Post1 ????????????????????????????????
pred ps_reach_Post1 {
    some op: REQ_FLIGHT_DISPATCHER_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        op.pre = Pre1 &&
        FlightDB_Resource in op.target &&
        some c: op.channel | c.authenticated = True &&
        op.grant = Write
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_FLIGHT_DISPATCHER_01 |
        (op.post = Post1) =>
            (Write in op.initiator.mayPerform &&
             op.pre = Pre1 &&
             FlightDB_Resource in op.target &&
             some c: op.channel | c.authenticated = True &&
             op.grant = Write)
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_FLIGHT_DISPATCHER_01 |
        op.initiator = Flight_Dispatchers &&
        FlightDB_Resource in op.target &&
        op.grant = Write &&
        op.post = Post1
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Flight number already exists in the system
-- Safety: No two Write operations may target the same Resource (each Resource is a unique flight)
assert ec_safe_1 {
  all op1, op2: REQ_FLIGHT_DISPATCHER_01 |
    (op1 != op2 && op1.grant = Write && op2.grant = Write) =>
      no r: Resource | r in op1.target && r in op2.target
}
check ec_safe_1 for 5

-- Edge case 2: Incorrect origin || destination codes
-- Safety: Only authorized operational teams may modify flight resources
assert ec_safe_2 {
  all op: REQ_FLIGHT_DISPATCHER_01 |
    (some r: Resource | r in op.target && r.owner = Airline_Operations_Team) =>
      op.initiator in (Airline_Operations_Team + Scheduling_Department)
}
check ec_safe_2 for 5

-- Edge case 3: Non-standard time formats (e.g., HHMM instead of HH:MM)
-- Safety: All channels used for flight database operations must be authenticated
assert ec_safe_3 {
  all op: REQ_FLIGHT_DISPATCHER_01 |
    (some r: Resource | r in op.target && r.owner = Airline_Operations_Team) =>
      all iface: op.channel | iface.authenticated = True
}
check ec_safe_3 for 5

-- Edge case 4: Dispatcher without proper authorization
-- Safety: The Flight_Dispatchers actor must hold the required permission for any operation it initiates
assert ec_safe_4 {
  all op: REQ_FLIGHT_DISPATCHER_01 |
    (op.initiator = Flight_Dispatchers) => (op.grant in Flight_Dispatchers.mayPerform)
}
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-FLIGHT-DISPATCHER-01: Register a new flight with valid details.
pred tc_tc_flight_dispatcher_01_holds {
    some op: REQ_FLIGHT_DISPATCHER_01 |
        op.initiator = Flight_Dispatchers &&
        op.grant = Admin &&
        some c: op.channel | c.encrypted = True && c.authenticated = True &&
        FlightDB_Resource in op.target &&
        op.post != op.pre
}
run tc_tc_flight_dispatcher_01_holds for 5

assert tc_tc_flight_dispatcher_01_contract {
    all op: REQ_FLIGHT_DISPATCHER_01 |
        (op.initiator = Flight_Dispatchers &&
         op.grant = Admin &&
         some c: op.channel | c.encrypted = True && c.authenticated = True &&
         FlightDB_Resource in op.target) => op.post != op.pre
}
check tc_tc_flight_dispatcher_01_contract for 5

-- TC-FLIGHT-DISPATCHER-02: Attempt to register a flight with an already existing number.
-- Expected: system prevents duplicate (no effect on resource; error logged via state change).
-- We model duplicate as: the target resource is already present (FlightDB_Resource always exists)
-- && the operation is attempted but results in a state change (error flag).
-- Preconditions: same valid credentials, but channel is insecure (unencrypted || unauthenticated)
-- to represent invalid attempt. Postcondition: state changes (error logged).
pred tc_tc_flight_dispatcher_02_holds {
    some op: REQ_FLIGHT_DISPATCHER_01 |
        op.initiator = Flight_Dispatchers &&
        op.grant = Admin &&
        some c: op.channel | (c.encrypted = True && c.authenticated = False) &&
        FlightDB_Resource in op.target &&
        op.post != op.pre
}
run tc_tc_flight_dispatcher_02_holds for 5

assert tc_tc_flight_dispatcher_02_contract {
    all op: REQ_FLIGHT_DISPATCHER_01 |
        (op.initiator = Flight_Dispatchers &&
         op.grant = Admin &&
         some c: op.channel | (c.encrypted = True && c.authenticated = False) &&
         FlightDB_Resource in op.target) => op.post != op.pre
}
check tc_tc_flight_dispatcher_02_contract for 5

-- TC-FLIGHT-DISPATCHER-03: Input incorrect origin || destination codes.
-- Expected: system rejects input && prompts for correct codes.
-- Model: operation fails validation; state changes (error message recorded).
-- Pre: correct credentials, but grant is a wrong permission (e.g., Read instead of Admin)
-- && channel is secure. Post: state change.
pred tc_tc_flight_dispatcher_03_holds {
    some op: REQ_FLIGHT_DISPATCHER_01 |
        op.initiator = Flight_Dispatchers &&
        op.grant = Read &&
        some c: op.channel | c.encrypted = True && c.authenticated = True &&
        FlightDB_Resource in op.target &&
        op.post != op.pre
}
run tc_tc_flight_dispatcher_03_holds for 5

assert tc_tc_flight_dispatcher_03_contract {
    all op: REQ_FLIGHT_DISPATCHER_01 |
        (op.initiator = Flight_Dispatchers &&
         op.grant = Read &&
         some c: op.channel | c.encrypted = True && c.authenticated = True &&
         FlightDB_Resource in op.target) => op.post != op.pre
}
check tc_tc_flight_dispatcher_03_contract for 5

-- TC-FLIGHT-DISPATCHER-04: Use non-standard time format.
-- Expected: system converts time to standard format before registration.
-- Model: conversion is a state change; operation succeeds.
-- Pre: valid credentials, secure channel, correct grant (Admin).
-- Post: state change.
pred tc_tc_flight_dispatcher_04_holds {
    some op: REQ_FLIGHT_DISPATCHER_01 |
        op.initiator = Flight_Dispatchers &&
        op.grant = Admin &&
        some c: op.channel | c.encrypted = True && c.authenticated = True &&
        Dispatcher_Interface in op.channel &&  -- specific interface for time conversion
        FlightDB_Resource in op.target &&
        op.post != op.pre
}
run tc_tc_flight_dispatcher_04_holds for 5

assert tc_tc_flight_dispatcher_04_contract {
    all op: REQ_FLIGHT_DISPATCHER_01 |
        (op.initiator = Flight_Dispatchers &&
         op.grant = Admin &&
         some c: op.channel | c.encrypted = True && c.authenticated = True &&
         Dispatcher_Interface in op.channel &&
         FlightDB_Resource in op.target) => op.post != op.pre
}
check tc_tc_flight_dispatcher_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_min_channels {
    -- PROXY: limiting channel count per operation reduces latency (performance)
    -- NFR: response time < 200ms
    all op: REQ_FLIGHT_DISPATCHER_01 | #op.channel <= 2
}

fact nfr_fact_redundant_channels {
    -- PROXY: requiring redundant channels ensures availability
    -- NFR: uptime >= 99.9%
    some c1, c2: Interface | c1 != c2 && 
        all op: REQ_FLIGHT_DISPATCHER_01 | c1 in op.channel && c2 in op.channel
}

fact nfr_fact_simultaneous_ops {
    -- PROXY: all actors can initiate at least one operation (scalability)
    -- NFR: support 1000 concurrent users
    all a: Actor | some op: REQ_FLIGHT_DISPATCHER_01 | op.initiator = a
}

fact nfr_fact_defined_poststate {
    -- PROXY: every operation reaches a defined post-state (reliability)
    -- NFR: 100% success rate
    all op: REQ_FLIGHT_DISPATCHER_01 | one op.post
}

fact nfr_fact_auth_channel_limit {
    -- PROXY: bounded authenticated channels reduces complexity (usability)
    -- NFR: at most 3 authentication steps
    all op: REQ_FLIGHT_DISPATCHER_01 | #{c: op.channel | c.authenticated = True} <= 3
}

fact nfr_fact_no_circular_ownership {
    -- PROXY: no resource owned by itself prevents maintenance deadlocks (maintainability)
    -- NFR: no circular dependencies
    no r: Resource | r.owner = r.owner
}

assert nfr_assert_resource_limit {
    -- PROXY: limiting target resources per operation improves performance
    -- NFR: process at most 10 resources per request
    all op: REQ_FLIGHT_DISPATCHER_01 | #op.target <= 10
}
check nfr_assert_resource_limit for 5

assert nfr_assert_actor_coverage {
    -- PROXY: every actor type can initiate operations (scalability)
    -- NFR: support all roles concurrently
    all a: Actor | some op: REQ_FLIGHT_DISPATCHER_01 | op.initiator = a
}
check nfr_assert_actor_coverage for 5

assert nfr_assert_min_actors {
    -- PROXY: minimum actor count ensures team coverage (availability)
    -- NFR: at least 3 dispatchers on shift
    #{a: Actor | a in Flight_Dispatchers} >= 3
}
check nfr_assert_min_actors for 5

