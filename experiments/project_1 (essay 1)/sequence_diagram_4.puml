== ERROR: Database Connection Failure ==

COORDINATOR -> API_REG : POST /patients [TLS]

API_REG -> SVC : registerPatient(patientData: PatientDTO) : QueueDTO

SVC -> ACTOR : checkPermission(role: String, permission: Permission) : boolean

alt Permission granted
    SVC -> RESOURCE : checkAccess(actor: Actor, resource: Resource) : boolean
    
    alt Access granted
        SVC -> DB : beginTransaction() [TLS]
        
        alt Database connection failed
            SVC --> API_REG : return 503 Service Unavailable
            API_REG --> COORDINATOR : 503 Service Unavailable
        else Database timeout
            SVC --> API_REG : return 504 Gateway Timeout
            API_REG --> COORDINATOR : 504 Gateway Timeout
        end
    end
end

== ERROR: Unauthenticated Request ==

actor "Unauthenticated User" as UNAUTH

UNAUTH -> API_REG : POST /patients [No TLS]

API_REG --> UNAUTH : 401 Unauthorized
note right: Missing authentication channel

@enduml