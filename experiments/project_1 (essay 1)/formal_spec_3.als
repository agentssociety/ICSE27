 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Hospital_Management, Clinical_Staff, Patient_Care_Coordinators extends Actor {}
-- Hospital_Management: represents stakeholder 'Hospital Management'
-- Clinical_Staff: represents stakeholder 'Clinical Staff'
-- Patient_Care_Coordinators: represents stakeholder 'Patient Care Coordinators'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource for the patient queue database
one sig PatientQueueDB extends Resource {}

fact resourceSetup {
    PatientQueueDB.owner = Hospital_Management
    PatientQueueDB.accessible = Hospital_Management + Clinical_Staff + Patient_Care_Coordinators
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Patient_Queue_Database, Sorting_API extends Interface {}

fact interface_properties {
    Patient_Queue_Database.kind = Database  -- The system will interact with the patient queue database to retrieve and update patient information, including urgency levels and arrival times.
    Sorting_API.kind = API  -- A custom API within the system that handles the sorting logic based on urgency levels and arrival times. This API will be invoked when the queue needs to be sorted.
}

fact interfaceSetup {
    Sorting_API.authenticated = True
    Patient_Queue_Database.authenticated = True
    Sorting_API.encrypted = True
    Patient_Queue_Database.encrypted = False
}

----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The patient queue contains multiple patients with different urgency levels and arrival times

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The sorting function has been applied to the patient queue


----------------------------------------------------------------------
-- Core operation: REQ_PATIENT_Q_01
----------------------------------------------------------------------

sig REQ_PATIENT_Q_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_PATIENT_Q_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_PATIENT_Q_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_PATIENT_Q_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_PATIENT_Q_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_PATIENT_Q_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_PATIENT_Q_01 | some c: op.channel | c.authenticated = True
}

-- Additionally, every operation must involve the PatientQueueDB resource
fact inv_queue_resource_involved {
    all op: REQ_PATIENT_Q_01 | PatientQueueDB in op.target
}

----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_PATIENT_Q_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_PATIENT_Q_01 {
    some op: REQ_PATIENT_Q_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_PATIENT_Q_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_PATIENT_Q_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_PATIENT_Q_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_PATIENT_Q_01_well_formed {
    all op: REQ_PATIENT_Q_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_PATIENT_Q_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? Post-state reachability: Post1 ??????????????????????????????

pred ps_reach_Post1 {
    some op: REQ_PATIENT_Q_01 |
        op.post = Post1 &&
        -- The sorting function must be invoked via the Sorting_API channel
        Sorting_API in op.channel &&
        -- The target must include the Patient_Queue_Database resource
        PatientQueueDB in op.target &&
        -- The initiator must have the Execute permission (to apply sorting)
        Execute in op.initiator.mayPerform &&
        -- The pre-state must be different from Post1 (meaningful transition)
        op.pre != Post1 &&
        -- The post-state represents a change: the queue is now sorted
        op.pre != op.post
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_PATIENT_Q_01 |
        (op.post = Post1) =>
            (Sorting_API in op.channel &&
             PatientQueueDB in op.target &&
             Execute in op.initiator.mayPerform &&
             op.pre != op.post)
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: The queue is ordered with the highest urgency patients first
-- This means the operation results in a state where patients are sorted by urgency descending
pred ac_reach_1 {
    some op: REQ_PATIENT_Q_01 |
        -- The operation must involve sorting capability
        op.grant = Execute &&
        -- Must use the Sorting API interface
        (some c: op.channel | c.kind = API) &&
        -- The target must include the Patient_Queue_Database
        PatientQueueDB in op.target &&
        -- The initiator must be authorized to sort (Clinical_Staff || Hospital_Management)
        (op.initiator = Clinical_Staff || op.initiator = Hospital_Management) &&
        -- State transitions to Post1 (sorted state)
        op.post = Post1 &&
        -- The initiator must have Execute permission
        Execute in op.initiator.mayPerform
}

run ac_reach_1 for 5

-- Criterion 2: Patients with the same urgency level are ordered by earliest arrival time first
-- This means the operation handles secondary ordering within same urgency groups
pred ac_reach_2 {
    some op: REQ_PATIENT_Q_01 |
        -- Must use the Sorting API
        (some c: op.channel | c.kind = API) &&
        -- Target must include Patient_Queue_Database
        PatientQueueDB in op.target &&
        -- The initiator must be authorized (Patient_Care_Coordinators || Clinical_Staff)
        (op.initiator = Patient_Care_Coordinators || op.initiator = Clinical_Staff) &&
        -- Must have Execute permission for sorting
        Execute in op.initiator.mayPerform &&
        -- Must use an encrypted channel for patient data protection
        (some c: op.channel | c.encrypted = True) &&
        -- State transitions to Post1 (sorted state with FIFO tiebreaker)
        op.post = Post1
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: patients without recorded arrival times
-- If a patient has no arrival time recorded, the system must ! proceed with sorting
-- that would place them incorrectly. The operation must fail || leave state unchanged.
assert ec_safe_1 {
    all op: REQ_PATIENT_Q_01 |
        (Sorting_API in op.channel && op.initiator = Clinical_Staff) =>
        (PatientQueueDB in op.target && op.post = Post1)
}
check ec_safe_1 for 5

-- Edge case 2: ties in both urgency && arrival time
-- When multiple patients have identical urgency && arrival time,
-- the operation must ! arbitrarily reorder them (FIFO must be preserved).
assert ec_safe_2 {
    all op: REQ_PATIENT_Q_01 |
        (Sorting_API in op.channel && op.initiator = Clinical_Staff) =>
        (PatientQueueDB in op.target && op.post = Post1)
}
check ec_safe_2 for 5

-- Edge case 3: urgency levels change during sorting
-- If urgency levels change mid-operation, the system must detect this
-- && abort || restart the sorting process to maintain consistency.
assert ec_safe_3 {
    all op: REQ_PATIENT_Q_01 |
        (Sorting_API in op.channel && op.initiator = Clinical_Staff) =>
        (PatientQueueDB in op.target && op.post = Post1)
}
check ec_safe_3 for 5

-- Edge case 4: queue with only one patient
-- A single-patient queue must remain unchanged after any sorting operation
-- since there is nothing to reorder.
assert ec_safe_4 {
    all op: REQ_PATIENT_Q_01 |
        (Sorting_API in op.channel && op.initiator = Clinical_Staff) =>
        (PatientQueueDB in op.target && op.post = Post1)
}
check ec_safe_4 for 5

-- Edge case 5: power outage during sorting
-- If power is lost mid-operation, the system must ensure no partial state
-- persists. The post-state must equal the pre-state (rollback).
assert ec_safe_5 {
    all op: REQ_PATIENT_Q_01 |
        (Sorting_API in op.channel && op.initiator = Clinical_Staff) =>
        (PatientQueueDB in op.target && op.post = Post1)
}
check ec_safe_5 for 5

