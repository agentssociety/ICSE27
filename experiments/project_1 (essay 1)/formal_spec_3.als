-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting target resources to one reduces overhead, approximating sorting performance within 5s for 100 patients
    all op: REQ_PATIENT_Q_01 | #op.target = 1
}

fact nfr_fact_availability {
    -- PROXY: requiring at least two channels per operation provides redundancy to achieve 99.9% uptime
    all op: REQ_PATIENT_Q_01 | #op.channel >= 2
}

fact nfr_fact_scalability {
    -- PROXY: every actor able to initiate a sorting operation indicates horizontal scalability
    all a: Actor | some op: REQ_PATIENT_Q_01 | op.initiator = a
}

