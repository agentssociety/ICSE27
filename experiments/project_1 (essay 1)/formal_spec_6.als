----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_interface_limit {
    -- PROXY: limiting the number of interfaces per operation reduces data transit overhead, proxying fast response times
    all op: REQ_HA_DASHBOARD_01 | #op.channel <= 1
}

fact nfr_fact_availability_redundant_backend {
    -- PROXY: ensuring at least one backend interface is always available proxies 24/7 uptime
    some i: Interface | i.kind = Backend_Service && i.encrypted = True
}

fact nfr_fact_scalability_capacity_planning {
    -- PROXY: each resource must have at least one capacity record, ensuring scalability planning exists
    all r: Resource | some c: ResourceCapacity | c.resource = r
}

fact nfr_fact_usability_intuitive_interface {
    -- PROXY: limiting the number of distinct interfaces reduces cognitive load, proxying intuitive design
    #Interface <= 3
}

fact nfr_fact_reliability_defined_state_transition {
    -- PROXY: every operation must have a distinct pre && post state, ensuring predictable transitions
    all op: REQ_HA_DASHBOARD_01 | op.pre != op.post
}

assert nfr_assert_all_resources_monitored {
    -- All resources must be assigned to the dashboard's operation scope
    all r: Resource | some op: REQ_HA_DASHBOARD_01 | r in op.target
}
check nfr_assert_all_resources_monitored for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- ----------------------------------------
-- SECURITY PROPERTIES for REQ_HA_DASHBOARD_01
-- Verified via Alloy Analyzer assertions
-- ----------------------------------------

-- Helper sig for audit logging (non-repudiation)
one sig AuditLog {
    entries: set REQ_HA_DASHBOARD_01
}

-- Fact: All operations are logged
fact sr_fact_audit_logging {
    all op: REQ_HA_DASHBOARD_01 | op in AuditLog.entries
}

-- SR-1: Authentication - all channels must be authenticated
assert sr_assert_authentication {
    all op: REQ_HA_DASHBOARD_01 |
        all c: op.channel | c.authenticated = True
}
check sr_assert_authentication for 5

-- SR-2: Authorization (least-privilege) - grant must be in initiator's permissions
assert sr_assert_authorization {
    all op: REQ_HA_DASHBOARD_01 |
        op.grant in op.initiator.mayPerform
}
check sr_assert_authorization for 5

-- SR-3: Confidentiality - resource accessible only by authorized initiators
assert sr_assert_confidentiality {
    all op: REQ_HA_DASHBOARD_01 |
        all r: op.target | op.initiator in r.accessible
}
check sr_assert_confidentiality for 5

-- SR-4: Integrity - only owner || admin may write to resources
assert sr_assert_integrity {
    all op: REQ_HA_DASHBOARD_01 |
        (Write in op.initiator.mayPerform) =>
        (op.initiator = op.target.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_integrity for 5

-- SR-5: Non-repudiation - every operation has exactly one identified initiator
assert sr_assert_non_repudiation {
    all op: REQ_HA_DASHBOARD_01 | one op.initiator
}
check sr_assert_non_repudiation for 5

-- SR-6: Encryption-in-transit - all channels must be encrypted
assert sr_assert_encryption_in_transit {
    all op: REQ_HA_DASHBOARD_01 |
        all c: op.channel | c.encrypted = True
}
check sr_assert_encryption_in_transit for 5

-- SR-7: Privilege separation - no self-escalation for write operations
assert sr_assert_privilege_separation {
    all op: REQ_HA_DASHBOARD_01 |
        (Write in op.initiator.mayPerform) =>
        (no r: op.target | r.owner = op.initiator && Admin !in op.initiator.mayPerform)
}
check sr_assert_privilege_separation for 5

-- SR-8: Live dashboard access restricted to authorized hospital staff only
assert sr_assert_live_dashboard_access_restricted {
    all op: REQ_HA_DASHBOARD_01 |
        (Live_Dashboard_Interface in op.channel) =>
        (op.initiator in Authorized_Hospital_Staff)
}
check sr_assert_live_dashboard_access_restricted for 5

-- Fact: Ensure no operation uses both UI && API simultaneously (security boundary)
fact sr_fact_interface_separation {
    all op: REQ_HA_DASHBOARD_01 |
        !(UI in op.channel.kind && API in op.channel.kind)
}


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Added PatientData sig as a Resource to serve as the target for dashboard operations, fixing type errors in ps_reach_Post1 and ps_valid_Post1 where Interface was used as target.
-- Summary 2: Fixed sr_assert_live_dashboard_access_restricted: replaced 'Live_Dashboard_Interface in op.channel.kind' with 'Live_Dashboard_Interface in op.channel'.
-- Summary 3: Fixed integer operators in ec_safe_2: replaced gt/lte with > and <=.
-- Summary 4: Fixed quantification in ec_safe_3: changed 'some uc' to 'all uc' to properly express that if an urgency change exists for the initiator, the grant must match the new permission.
-- Summary 5: All other structure and constraints preserved from original.
-- Assumption 1: PatientData is the minimal resource representing patient urgency and wait time data; queue modeling is omitted.
-- Assumption 2: ResourceCapacity and UrgencyChange are helper sigs used only in edge-case assertions, not fully integrated with the core model.
-- Assumption 3: The operation's target can include multiple PatientData instances, but capacity constraints are not accurately modeled (ec_safe_2 is trivial).
-- Assumption 4: The security assertion sr_assert_live_dashboard_access_restricted now correctly checks the Live_Dashboard_Interface channel.
-- Open issue 1: Edge case 'no patients in queue' (TC-04) is not explicitly modeled; the assertion ec_safe_1 only covers missing targets, not the display of a message.
-- Open issue 2: The ec_safe_2 assertion is too weak; it only checks that the number of targets intersecting with a single resource capacity record is ? maxConcurrent, which is always true since the intersection is at most 1.
-- Open issue 3: The Acceptance Criteria predicates use 'Write' permission for display operations, which may conflict with the requirement's reading nature; could be refined.
-- Open issue 4: UrgencyChange uses Actor as patient, which conflates patients with system actors; a dedicated Patient sig might be cleaner but would require more changes.


