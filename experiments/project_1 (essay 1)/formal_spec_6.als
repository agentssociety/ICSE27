 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Hospital_Administrator, Authorized_Hospital_Staff extends Actor {}
-- Hospital_Administrator: represents stakeholder 'Hospital Administrator'
-- Authorized_Hospital_Staff: represents stakeholder 'Authorized Hospital Staff'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Minimal resource for patient data (urgency levels, wait times)
sig PatientData extends Resource {}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI, Backend_Service extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Live_Dashboard_Interface, Patient_Management_API, Wait_Time_Estimation_Service extends Interface {}

fact interface_properties {
    Live_Dashboard_Interface.kind = UI  -- The user interface for displaying each patient's urgency level and estimated wait time in real-time.
    Patient_Management_API.kind = API  -- An API to fetch current patient status and resource availability data from the hospital's patient management system.
    Wait_Time_Estimation_Service.kind = Backend_Service  -- A backend service responsible for calculating estimated wait times based on the current queue and resource availability.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The hospital administrator has a valid login credentials

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The live dashboard is displayed with up-to-date information on patients' urgency levels and estimated wait times


----------------------------------------------------------------------
-- Core operation: REQ_HA_DASHBOARD_01
----------------------------------------------------------------------

sig REQ_HA_DASHBOARD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_HA_DASHBOARD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_HA_DASHBOARD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_HA_DASHBOARD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_HA_DASHBOARD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_HA_DASHBOARD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_HA_DASHBOARD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_HA_DASHBOARD_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_HA_DASHBOARD_01 {
    some op: REQ_HA_DASHBOARD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_HA_DASHBOARD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_HA_DASHBOARD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_HA_DASHBOARD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_HA_DASHBOARD_01_well_formed {
    all op: REQ_HA_DASHBOARD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_HA_DASHBOARD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_HA_DASHBOARD_01 |
        op.post = Post1 &&
        op.channel = Live_Dashboard_Interface &&
        Read in op.initiator.mayPerform &&
        PatientData in op.target &&
        op.pre != Post1
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_HA_DASHBOARD_01 |
        (op.post = Post1) =>
            (op.channel = Live_Dashboard_Interface &&
             Read in op.initiator.mayPerform &&
             PatientData in op.target)
}
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_HA_DASHBOARD_01 |
    op.initiator = Hospital_Administrator &&
    some c: op.channel | c.kind = UI &&
    Write in op.initiator.mayPerform &&
    some op.target &&
    (some c2: op.channel | c2.authenticated = True)
}
run ac_reach_1 for 5

pred ac_reach_2 {
  some op: REQ_HA_DASHBOARD_01 |
    op.initiator = Hospital_Administrator &&
    some c: op.channel | c.kind = UI &&
    Write in op.initiator.mayPerform &&
    some op.target &&
    (some c2: op.channel | c2.encrypted = True) &&
    (some c3: op.channel | c3.authenticated = True)
}
run ac_reach_2 for 5

pred ac_reach_3 {
  some op: REQ_HA_DASHBOARD_01 |
    op.initiator = Hospital_Administrator &&
    some c: op.channel | c.kind = UI &&
    Write in op.initiator.mayPerform &&
    some op.target &&
    (some c2: op.channel | c2.encrypted = True) &&
    (some c3: op.channel | c3.authenticated = True) &&
    op.post = Post1
}
run ac_reach_3 for 5

pred ac_reach_4 {
  some op: REQ_HA_DASHBOARD_01 |
    op.initiator = Hospital_Administrator &&
    some c: op.channel | c.kind = UI &&
    Write in op.initiator.mayPerform &&
    some op.target &&
    (some c2: op.channel | c2.encrypted = True) &&
    (some c3: op.channel | c3.authenticated = True) &&
    op.post = Post1 &&
    op.pre != op.post
}
run ac_reach_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: No patients in the queue ? operation must ! proceed without a valid target
assert ec_safe_1 {
    all op: REQ_HA_DASHBOARD_01 |
        -- if target set is empty (no resources affected), operation is invalid
        no op.target => op.post = op.pre
}
check ec_safe_1 for 5

-- Edge case 2: Sudden spike in patient arrivals ? capacity constraints (modeled via ResourceCapacity)
sig ResourceCapacity {
    resource: one Resource,
    maxConcurrent: one Int
}
fact capacity_constraints {
    all rc: ResourceCapacity | rc.maxConcurrent > 0
}
assert ec_safe_2 {
    all op: REQ_HA_DASHBOARD_01 |
        some t: op.target |
            some rc: ResourceCapacity |
                rc.resource = t &&
                #(op.target & rc.resource) <= rc.maxConcurrent
}
check ec_safe_2 for 5

-- Edge case 3: Patient urgency level changes during wait ? operation must respect updated permissions
sig UrgencyChange {
    patient: one Actor,
    oldPermission: one Permission,
    newPermission: one Permission
}
fact urgency_consistency {
    all uc: UrgencyChange |
        uc.oldPermission != uc.newPermission
}
assert ec_safe_3 {
    all op: REQ_HA_DASHBOARD_01 |
        all uc: UrgencyChange |
            uc.patient = op.initiator =>
                op.grant = uc.newPermission
}
check ec_safe_3 for 5

