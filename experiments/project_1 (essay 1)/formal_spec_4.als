module REQ_SYS_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-SYS-01
 * Title       : Automated Queue Re-sorting upon Patient Registration or Urgency Update
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Healthcare_Professionals, Patient_Care_Coordinators, System_Administrators extends Actor {}
-- Healthcare_Professionals: represents stakeholder 'Healthcare Professionals'
-- Patient_Care_Coordinators: represents stakeholder 'Patient Care Coordinators'
-- System_Administrators: represents stakeholder 'System Administrators'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Patient_Registration_API, Re_Triage_API, Patient_Queue_Database extends Interface {}

fact interface_properties {
    Patient_Registration_API.kind = API  -- Interacts with the patient registration system to trigger re-sorting when a new patient is registered.
    Re_Triage_API.kind = API  -- Interacts with the re-triage system to update patient urgency levels and trigger re-sorting.
    Patient_Queue_Database.kind = Database  -- Stores patient information and urgency levels, which is used to determine the queue order.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The system maintains a queue of patients
-- Pre2: system is in state where New patients can be registered at any time
-- Pre3: system is in state where Existing patients' urgency levels can be updated (re-triage)

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The queue is automatically re-sorted immediately upon the triggering event
-- Post2: system reaches state where The queue reflects current priorities based on urgency


----------------------------------------------------------------------
-- Core operation: REQ_SYS_01
----------------------------------------------------------------------

sig REQ_SYS_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_SYS_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_SYS_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_SYS_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_SYS_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_SYS_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_SYS_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_SYS_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SYS_01 {
    some op: REQ_SYS_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SYS_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_SYS_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_SYS_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_SYS_01_well_formed {
    all op: REQ_SYS_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SYS_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? POST-STATE REACHABILITY VERIFICATION ??????????????????????????????

-- Post1: The queue is automatically re-sorted immediately upon the triggering event
pred ps_reach_Post1 {
    some op: REQ_SYS_01 |
        op.post = Post1 &&
        op.pre != Post1 &&
        -- Requires a write permission to modify the queue
        Write in op.initiator.mayPerform &&
        -- Must involve the Patient_Queue_Database resource
        Patient_Queue_Database in op.target &&
        -- Must use an authenticated channel
        some ch: op.channel | ch.authenticated = True &&
        -- The initiator must be authorized for the resource
        op.initiator in Patient_Queue_Database.accessible
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_SYS_01 |
        (op.post = Post1) =>
            (op.pre != Post1 &&
             Write in op.initiator.mayPerform &&
             Patient_Queue_Database in op.target &&
             some ch: op.channel | ch.authenticated = True)
}

check ps_valid_Post1 for 5

-- Post2: The queue reflects current priorities based on urgency
pred ps_reach_Post2 {
    some op: REQ_SYS_01 |
        op.post = Post2 &&
        op.pre != Post2 &&
        -- Requires a write permission to update priorities
        Write in op.initiator.mayPerform &&
        -- Must involve the Patient_Queue_Database resource
        Patient_Queue_Database in op.target &&
        -- Must use an authenticated channel
        some ch: op.channel | ch.authenticated = True &&
        -- The initiator must be authorized for the resource
        op.initiator in Patient_Queue_Database.accessible &&
        -- Must involve Healthcare_Professionals as initiator (they determine urgency)
        op.initiator in Healthcare_Professionals
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_SYS_01 |
        (op.post = Post2) =>
            (op.pre != Post2 &&
             Write in op.initiator.mayPerform &&
             Patient_Queue_Database in op.target &&
             some ch: op.channel | ch.authenticated = True &&
             op.initiator in Healthcare_Professionals)
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_SYS_01 |
        Write in op.initiator.mayPerform &&
        Patient_Queue_Database in op.target &&
        Patient_Registration_API in op.channel &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_SYS_01 |
        Write in op.initiator.mayPerform &&
        Patient_Queue_Database in op.target &&
        Re_Triage_API in op.channel &&
        op.grant = Write &&
        op.pre = Pre2 &&
        op.post = Post2
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Concurrent multiple registrations must ! use conflicting grants on shared resources
assert ec_safe_1 {
  all disj op1, op2 : REQ_SYS_01 |
    some (op1.target & op2.target) => op1.grant = op2.grant
}
check ec_safe_1 for 5

-- Edge case 2: Only Healthcare_Professionals may access resources that are exclusively accessible to them
assert ec_safe_2 {
  all op : REQ_SYS_01 |
    some r : Resource |
      (r in op.target) &&
      (Healthcare_Professionals in r.accessible) &&
      (Patient_Care_Coordinators ! in r.accessible) =>
        op.initiator = Healthcare_Professionals
}
check ec_safe_2 for 5

-- Edge case 3: Transition to the empty?queue state (Post2) from a non?empty pre?state (Pre1) requires the Write permission
assert ec_safe_3 {
  all op : REQ_SYS_01 |
    (op.pre = Pre1 && op.post = Post2) => op.grant = Write
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-SYS-01: New patient registration triggers queue re-sorting
pred tc_sys_01_holds {
    some op: REQ_SYS_01 |
        op.initiator = Patient_Care_Coordinators &&
        op.target = Patient_Queue_Database &&
        op.channel = Patient_Registration_API &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_sys_01_holds for 5

assert tc_sys_01_contract {
    all op: REQ_SYS_01 |
        (op.initiator = Patient_Care_Coordinators &&
         op.target = Patient_Queue_Database &&
         op.channel = Patient_Registration_API &&
         op.grant = Write &&
         op.pre = Pre1) =>
        op.post = Post1
}
check tc_sys_01_contract for 5

-- Scenario TC-SYS-02: Urgency level update triggers queue re-sorting
pred tc_sys_02_holds {
    some op: REQ_SYS_01 |
        op.initiator = Healthcare_Professionals &&
        op.target = Patient_Queue_Database &&
        op.channel = Re_Triage_API &&
        op.grant = Write &&
        op.pre = Pre2 &&
        op.post = Post2
}
run tc_sys_02_holds for 5

assert tc_sys_02_contract {
    all op: REQ_SYS_01 |
        (op.initiator = Healthcare_Professionals &&
         op.target = Patient_Queue_Database &&
         op.channel = Re_Triage_API &&
         op.grant = Write &&
         op.pre = Pre2) =>
        op.post = Post2
}
check tc_sys_02_contract for 5

-- Scenario TC-SYS-03: Multiple patients registered simultaneously triggers re-sorting
pred tc_sys_03_holds {
    some op: REQ_SYS_01 |
        op.initiator = Patient_Care_Coordinators &&
        op.target = Patient_Queue_Database &&
        op.channel = Patient_Registration_API &&
        op.grant = Write &&
        op.pre = Pre3 &&
        op.post = Post1
}
run tc_sys_03_holds for 5

assert tc_sys_03_contract {
    all op: REQ_SYS_01 |
        (op.initiator = Patient_Care_Coordinators &&
         op.target = Patient_Queue_Database &&
         op.channel = Patient_Registration_API &&
         op.grant = Write &&
         op.pre = Pre3) =>
        op.post = Post1
}
check tc_sys_03_contract for 5

-- Scenario TC-SYS-04: Urgency level updated from very low to very high triggers re-sorting
pred tc_sys_04_holds {
    some op: REQ_SYS_01 |
        op.initiator = Healthcare_Professionals &&
        op.target = Patient_Queue_Database &&
        op.channel = Re_Triage_API &&
        op.grant = Write &&
        op.pre = Pre2 &&
        op.post = Post1
}
run tc_sys_04_holds for 5

assert tc_sys_04_contract {
    all op: REQ_SYS_01 |
        (op.initiator = Healthcare_Professionals &&
         op.target = Patient_Queue_Database &&
         op.channel = Re_Triage_API &&
         op.grant = Write &&
         op.pre = Pre2) =>
        op.post = Post1
}
check tc_sys_04_contract for 5

-- Scenario TC-SYS-05: Queue becomes empty after all patients are treated
pred tc_sys_05_holds {
    some op: REQ_SYS_01 |
        op.initiator = Healthcare_Professionals &&
        op.target = Patient_Queue_Database &&
        op.channel = Re_Triage_API &&
        op.grant = Admin &&
        op.pre = Pre3 &&
        op.post = Post2
}
run tc_sys_05_holds for 5

assert tc_sys_05_contract {
    all op: REQ_SYS_01 |
        (op.initiator = Healthcare_Professionals &&
         op.target = Patient_Queue_Database &&
         op.channel = Re_Triage_API &&
         op.grant = Admin &&
         op.pre = Pre3) =>
        op.post = Post2
}
check tc_sys_05_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    // proxy: minimize number of channels && targets per operation to reduce latency
    all op: REQ_SYS_01 | #op.channel <= 2 && #op.target <= 3
}

fact nfr_fact_availability {
    // proxy: at least two interfaces ensure redundancy for 99.9% uptime
    #Interface >= 2
}

assert nfr_assert_scalability {
    // proxy: each resource can be targeted by some operation to show horizontal scaling
    all r: Resource | some op: REQ_SYS_01 | r in op.target
}
check nfr_assert_scalability for 5

fact nfr_fact_usability_error_handling {
    // proxy: all channels used in operations are authenticated for reliable communication
    all op: REQ_SYS_01 | all c: op.channel | c.authenticated = True
}

