module REQ_TN_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-TN-01
 * Title       : Assign urgency level to patients based on symptoms
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Triage_Nurse, Medical_Staff, Healthcare_Facility_Management, Patient_Care_Team extends Actor {}
-- Triage_Nurse: represents stakeholder 'Triage Nurse'
-- Medical_Staff: represents stakeholder 'Medical Staff'
-- Healthcare_Facility_Management: represents stakeholder 'Healthcare Facility Management'
-- Patient_Care_Team: represents stakeholder 'Patient Care Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource representing patient records
one sig PatientRecord extends Resource {}

-- Set access control for patient records
fact patient_record_access {
    PatientRecord.accessible in Triage_Nurse + Medical_Staff + Patient_Care_Team
}

-- Owner of patient record is the triage nurse (who creates/updates it)
fact patient_record_owner {
    PatientRecord.owner = Triage_Nurse
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Triage_Nurse_Interface, Patient_Information_Database extends Interface {}

fact interface_properties {
    Triage_Nurse_Interface.kind = UI  -- The triage nurse uses this interface to input patient symptoms and assign urgency levels.
    Patient_Information_Database.kind = Database  -- Stores patient data, including symptoms and assigned urgency levels.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where A patient is present in the triage area with identifiable symptoms
-- Pre2: system is in state where The triage nurse has access to the system for inputting patient information and assigning urgency levels

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The system displays the assigned urgency level for the patient
-- Post2: system reaches state where The patient's record indicates they are marked as highest priority
-- Post3: system reaches state where Medical staff are notified of the high priority status of the patient


----------------------------------------------------------------------
-- Core operation: REQ_TN_01
----------------------------------------------------------------------

sig REQ_TN_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_TN_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_TN_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_TN_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_TN_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_TN_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_TN_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_TN_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_TN_01 {
    some op: REQ_TN_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_TN_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_TN_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_TN_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_TN_01_well_formed {
    all op: REQ_TN_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_TN_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post-state reachability && semantic verification for REQ_TN_01

pred ps_reach_Post1 {
    some op: REQ_TN_01 |
        op.post = Post1 &&
        op.initiator in Triage_Nurse &&
        Read in op.initiator.mayPerform &&
        op.target in PatientRecord &&
        op.channel in Triage_Nurse_Interface &&
        op.grant = Read
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_TN_01 |
        (op.post = Post1) =>
            (op.initiator in Triage_Nurse &&
             Read in op.initiator.mayPerform &&
             op.target in PatientRecord &&
             op.channel in Triage_Nurse_Interface &&
             op.grant = Read)
}
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_TN_01 |
        op.post = Post2 &&
        op.initiator in Triage_Nurse &&
        Write in op.initiator.mayPerform &&
        op.target in PatientRecord &&
        op.channel in Triage_Nurse_Interface &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post != op.pre
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_TN_01 |
        (op.post = Post2) =>
            (op.initiator in Triage_Nurse &&
             Write in op.initiator.mayPerform &&
             op.target in PatientRecord &&
             op.channel in Triage_Nurse_Interface &&
             op.grant = Write &&
             op.pre != op.post)
}
check ps_valid_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_TN_01 |
        op.post = Post3 &&
        op.initiator in Triage_Nurse &&
        Write in op.initiator.mayPerform &&
        op.target in PatientRecord &&
        op.channel in Triage_Nurse_Interface &&
        op.grant = Write &&
        op.pre != Post3
}
run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_TN_01 |
        (op.post = Post3) =>
            (op.initiator in Triage_Nurse &&
             Write in op.initiator.mayPerform &&
             op.target in PatientRecord &&
             op.channel in Triage_Nurse_Interface &&
             op.grant = Write &&
             op.pre != op.post)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ac_reach_1: Patient with severe chest pain && shortness of breath (precondition)
pred ac_reach_1 {
    some op: REQ_TN_01 |
        op.pre = Pre1
        && op.initiator = Triage_Nurse
        && (some c: op.channel | c.kind = UI && c.encrypted = True && c.authenticated = True)
        && op.grant = Read
}

run ac_reach_1 for 5

-- ac_reach_2: Triage nurse evaluates symptoms (action)
pred ac_reach_2 {
    some op: REQ_TN_01 |
        op.initiator = Triage_Nurse
        && op.grant = Read
        && (some c: op.channel | c.kind = UI && c.encrypted = True && c.authenticated = True)
        && op.pre = Pre1
}

run ac_reach_2 for 5

-- ac_reach_3: Assigned urgency level is 1 (postcondition)
pred ac_reach_3 {
    some op: REQ_TN_01 |
        op.post = Post1
        && op.initiator = Triage_Nurse
        && op.grant = Read
        && (some c: op.channel | c.kind = UI && c.encrypted = True && c.authenticated = True)
        && op.pre = Pre1
}

run ac_reach_3 for 5

-- ac_reach_4: Patient is marked as highest priority (postcondition)
pred ac_reach_4 {
    some op: REQ_TN_01 |
        op.post = Post1
        && op.initiator = Triage_Nurse
        && op.grant = Read
        && (some c: op.channel | c.kind = UI && c.encrypted = True && c.authenticated = True)
        && op.pre = Pre1
}

run ac_reach_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Symptoms ! covered by standardized criteria should ! cause undefined behavior
-- Safety: When symptoms are outside criteria, the triage nurse must still produce a valid state transition
-- We model "uncovered symptoms" as a condition where the pre-state cannot be mapped to any valid post-state
-- Assertion: For any operation where the pre-state is Pre1 (representing initial patient presentation),
-- the post-state must be one of the defined post-states (Post1, Post2, || Post3)
assert ec_safe_1 {
    all op: REQ_TN_01 |
        (op.pre = Pre1 && op.initiator = Triage_Nurse) =>
        (op.post = Post1 || op.post = Post2 || op.post = Post3)
}
check ec_safe_1 for 5

-- Edge case 2: Triage nurse fails to input any symptoms (empty input)
-- Safety: If no symptoms are input, the operation must ! result in a state change
-- We model "no input" as the operation having no target resources (empty target set)
-- Note: REQ_TN_01.target is declared as "some Resource", so we use a different approach
-- Safety: When the nurse initiates but no symptoms are recorded, the state must remain unchanged
assert ec_safe_2 {
    all op: REQ_TN_01 |
        (op.initiator = Triage_Nurse && op.target = op.target) =>  -- always true, but structure preserved
        (op.pre = op.post => op.grant = Read)  -- if no state change, only read permission needed
}
check ec_safe_2 for 5

-- Edge case 3: System malfunction causes incorrect urgency level
-- Safety: The urgency level (modeled as post-state) must be consistent with the pre-state && permissions
-- We define a helper predicate to check consistency
pred urgency_consistent[op: REQ_TN_01] {
    -- If pre-state is Pre1 (initial assessment), post-state must be one of the defined outcomes
    (op.pre = Pre1) => (op.post = Post1 || op.post = Post2 || op.post = Post3)
}

assert ec_safe_3 {
    all op: REQ_TN_01 |
        urgency_consistent[op] &&
        -- The triage nurse must have appropriate permissions for the assigned urgency
        (op.initiator = Triage_Nurse && op.grant = Write) =>
        (op.post != op.pre)  -- writing changes state
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-TN-01: severe chest pain && shortness of breath ? urgency 1, highest priority
pred tc_TN_01_holds {
    some op: REQ_TN_01 |
        op.initiator = Triage_Nurse &&
        op.grant = Read &&
        some r: op.target | r.owner = Triage_Nurse &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_TN_01_holds for 5

assert tc_TN_01_contract {
    all op: REQ_TN_01 |
        (op.initiator = Triage_Nurse && op.grant = Read && some r: op.target | r.owner = Triage_Nurse && op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_TN_01_contract for 5

-- TC-TN-02: mild cough ? urgency 5, lowest priority
pred tc_TN_02_holds {
    some op: REQ_TN_01 |
        op.initiator = Triage_Nurse &&
        op.grant = Read &&
        some r: op.target | r.owner = Triage_Nurse &&
        op.pre = Pre2 &&
        op.post = Post2
}
run tc_TN_02_holds for 5

assert tc_TN_02_contract {
    all op: REQ_TN_01 |
        (op.initiator = Triage_Nurse && op.grant = Read && some r: op.target | r.owner = Triage_Nurse && op.pre = Pre2) =>
        (op.post = Post2)
}
check tc_TN_02_contract for 5

-- TC-TN-03: symptoms ! covered ? prompt for info || default urgency
pred tc_TN_03_holds {
    some op: REQ_TN_01 |
        op.initiator = Triage_Nurse &&
        op.grant = Read &&
        some r: op.target | r.owner = Triage_Nurse &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_TN_03_holds for 5

assert tc_TN_03_contract {
    all op: REQ_TN_01 |
        (op.initiator = Triage_Nurse && op.grant = Read && some r: op.target | r.owner = Triage_Nurse && op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_TN_03_contract for 5

-- TC-TN-04: no symptoms input ? alert to enter valid symptoms
pred tc_TN_04_holds {
    some op: REQ_TN_01 |
        op.initiator = Triage_Nurse &&
        op.grant = Read &&
        some r: op.target | r.owner = Triage_Nurse &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_TN_04_holds for 5

assert tc_TN_04_contract {
    all op: REQ_TN_01 |
        (op.initiator = Triage_Nurse && op.grant = Read && some r: op.target | r.owner = Triage_Nurse && op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_TN_04_contract for 5

-- TC-TN-05: system malfunction ? reset, nurse can manually correct
pred tc_TN_05_holds {
    some op: REQ_TN_01 |
        op.initiator = Triage_Nurse &&
        op.grant = Read &&
        some r: op.target | r.owner = Triage_Nurse &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_TN_05_holds for 5

assert tc_TN_05_contract {
    all op: REQ_TN_01 |
        (op.initiator = Triage_Nurse && op.grant = Read && some r: op.target | r.owner = Triage_Nurse && op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_TN_05_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: minimize channels && targets to reduce latency
fact nfr_fact_performance {
    all op: REQ_TN_01 | #op.target = 1 && #op.channel = 1
}

-- Availability: require interface to be both encrypted && authenticated for reliability
assert nfr_assert_availability {
    all i: Interface | i.encrypted = True && i.authenticated = True
}
check nfr_assert_availability for 5

-- Scalability: allow concurrent access to resources (at least two operations per resource)
fact nfr_fact_scalability {
    all r: Resource | some op1, op2: REQ_TN_01 | op1 != op2 && r in op1.target && r in op2.target
}

-- Usability: use minimal permissions for simplicity (only Read permission)
-- Removed because it conflicts with the need to write urgency level.

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Access control for patient records is already set in fact patient_record_access.

assert sr_assert_all_channels_authenticated {
    all op: REQ_TN_01 | all c: op.channel | c.authenticated = True
}
check sr_assert_all_channels_authenticated for 5

assert sr_assert_all_channels_encrypted {
    all op: REQ_TN_01 | all c: op.channel | c.encrypted = True
}
check sr_assert_all_channels_encrypted for 5

assert sr_assert_integrity_write {
    all op: REQ_TN_01 |
        (op.grant = Write) =>
            (all r: op.target | op.initiator = r.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_integrity_write for 5

assert sr_assert_non_repudiation {
    all op: REQ_TN_01 | one op.initiator
}
check sr_assert_non_repudiation for 5

assert sr_assert_privilege_separation {
    all op: REQ_TN_01 |
        (op.grant = Write) =>
            no r: op.target | r.owner = op.initiator && Admin ! in op.initiator.mayPerform
}
check sr_assert_privilege_separation for 5

assert sr_assert_patient_data_authorization {
    all op: REQ_TN_01 |
        (PatientRecord in op.target) =>
            op.initiator in (Triage_Nurse + Medical_Staff + Patient_Care_Team)
}
check sr_assert_patient_data_authorization for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Added concrete Resource PatientRecord to fix unsatisfiable model
-- Summary 2: Fixed type errors in ps_reach_Post3, ac_reach predicates, and security assertions
-- Summary 3: Removed conflicting nfr_fact_usability that forced Read-only permissions
-- Summary 4: Corrected sr_fact_patient_database_access to apply to Resource instead of Interface
-- Summary 5: Adjusted sr_assert_integrity_write and sr_assert_privilege_separation to use op.grant = Write
-- Summary 6: Preserved all original structure and module name
-- Assumption 1: PatientRecord is the only concrete resource representing patient data
-- Assumption 2: Owner of PatientRecord is Triage_Nurse (the one who creates/updates it)
-- Assumption 3: Access to PatientRecord is restricted to Triage_Nurse, Medical_Staff, and Patient_Care_Team
-- Assumption 4: Triage_Nurse_Interface is a UI interface; Patient_Information_Database is a Database interface
-- Assumption 5: All interfaces are assumed to be encrypted and authenticated for availability assertion
-- Open issue 1: Test case predicates (tc_TN_01_holds through tc_TN_05_holds) are nearly identical and do not differentiate between scenarios; proper symptom-to-urgency mapping is not modeled
-- Open issue 2: Edge case assertion ec_safe_2 is trivial and does not meaningfully capture 'no symptoms input'
-- Open issue 3: The model does not represent urgency levels numerically (e.g., 1-5) or symptoms; post-states are abstract
-- Open issue 4: Non-functional requirement 'handle up to 100 patients concurrently' is not explicitly modeled beyond scalability fact requiring at least two operations per resource


