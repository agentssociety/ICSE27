      \"\"\"Given mixed urgency and arrival times, sorting respects both criteria.\"\"\"                                                                                                  
      queue = PatientQueue(queueId=uuid4())                                                                                                                                               
      now = datetime.now()                                                                                                                                                                
                                                                                                                                                                                          
      # p1: urgency 0 (critical), earliest                                                                                                                                                
