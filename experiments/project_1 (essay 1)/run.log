enum RecordState {\n    PENDING_TRIAGE\n    IN_CONSULTATION\n    COMPLETED\n    ARCHIVED\n  + setState(RecordState.ACTIVE) : void\n  }\n\n  enum Permission {\n    READ\n    WRITE\n    EXECUTE\n 
}\n\n  enum Role {\n    TRIAGE_NURSE_TEAM\n    MEDICAL_STAFF\n    PATIENT_CARE_COORDINATION_TEAM\n  }\n\n  abstract class SymptomResource {\n    - resourceId: UUID\n    - description: String\n  
}\n\n  class Patient {\n    - patientId: UUID\n    - symptoms: SymptomResource[]\n    - state: RecordState\n  + createPatient(name: String, symptoms: List<String>) : Patient\n  + 
createPatient(name: String, symptoms: []) : Patient\n  }\n\n  note top of Patient : Invariant: Record must be\\ncreated with or without symptoms\n\n  class PatientQueue {\n    - queueId: UUID\n 
- patientId: UUID\n    - position: Integer\n    - severity: SeverityLevel\n  + addToQueue(patient: Patient, severity: SeverityLevel) : int\n  + calculatePosition(severity: SeverityLevel) : int\n
+ addToQueue(patient: Patient, severity: SeverityLevel.LOW) : int\n  + calculatePosition(SeverityLevel.LOW) : int\n  }\n\n  note top of PatientQueue : Invariant: Queue position is\\nbased on 
symptom severity\n\n  Patient --> "0..*" SymptomResource : aggregates >\n  Patient --> PatientQueue : dependency >\n}\n\npackage "DTOs" <<Rectangle>> {\n  class PatientRegistrationDto <<dto>> 
