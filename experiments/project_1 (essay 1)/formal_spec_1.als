module REQ_TRIAGE_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-TRIAGE-01
 * Title       : Register New Patient with Symptoms
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Triage_Nurse_Team, Medical_Staff, Patient_Care_Coordination_Team extends Actor {}
-- Triage_Nurse_Team: represents stakeholder 'Triage Nurse Team'
-- Medical_Staff: represents stakeholder 'Medical Staff'
-- Patient_Care_Coordination_Team: represents stakeholder 'Patient Care Coordination Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Triage_Nurse_Registration_Form, Patient_Database, Medical_Attention_Queue_API extends Interface {}

fact interface_properties {
    Triage_Nurse_Registration_Form.kind = UI  -- The user interface where triage nurses input patient information and symptoms.
    Patient_Database.kind = Database  -- Stores new patient records with their symptoms for medical attention.
    Medical_Attention_Queue_API.kind = API  -- Integrates the registration process with the queue management system, placing patients based on symptom severity.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The triage nurse is logged into the system.
-- Pre2: system is in state where The system is operational and accessible to the nurse.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The new patient record is visible to medical staff.
-- Post2: system reaches state where The patient's queue position is updated appropriately based on symptom severity.
-- Post3: system reaches state where Notification is sent to relevant medical staff if action is required immediately.


----------------------------------------------------------------------
-- Core operation: REQ_TRIAGE_01
----------------------------------------------------------------------

sig REQ_TRIAGE_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_TRIAGE_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_TRIAGE_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_TRIAGE_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_TRIAGE_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_TRIAGE_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_TRIAGE_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_TRIAGE_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_TRIAGE_01 {
    some op: REQ_TRIAGE_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_TRIAGE_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_TRIAGE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_TRIAGE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_TRIAGE_01_well_formed {
    all op: REQ_TRIAGE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_TRIAGE_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates for each post-state
pred ps_reach_Post1 {
    some op: REQ_TRIAGE_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        op.initiator = Triage_Nurse_Team &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        Triage_Nurse_Registration_Form in op.target &&
        Medical_Staff in Triage_Nurse_Registration_Form.accessible
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_TRIAGE_01 |
        op.post = Post2 &&
        op.pre = Pre2 &&
        op.initiator = Triage_Nurse_Team &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        Medical_Attention_Queue_API in op.target &&
        op.channel.kind = API
}
run ps_reach_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_TRIAGE_01 |
        op.post = Post3 &&
        op.pre = Pre2 &&
        op.initiator = Triage_Nurse_Team &&
        Execute in op.initiator.mayPerform &&
        op.grant = Execute &&
        Patient_Database in op.target &&
        op.channel.encrypted = True &&
        op.channel.authenticated = True
}
run ps_reach_Post3 for 5

-- Semantic verification assertions for each post-state
assert ps_valid_Post1 {
    all op: REQ_TRIAGE_01 |
        (op.post = Post1) =>
            (Medical_Staff in Triage_Nurse_Registration_Form.accessible &&
             Triage_Nurse_Registration_Form in op.target)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_TRIAGE_01 |
        (op.post = Post2) =>
            (Medical_Attention_Queue_API in op.target &&
             op.grant = Write)
}
check ps_valid_Post2 for 5

assert ps_valid_Post3 {
    all op: REQ_TRIAGE_01 |
        (op.post = Post3) =>
            (op.grant = Execute &&
             op.channel.encrypted = True &&
             op.channel.authenticated = True &&
             Patient_Database in op.target)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: A new patient record is created in the system.
pred ac_reach_1 {
    some op: REQ_TRIAGE_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: The patient's symptoms are recorded accurately.
pred ac_reach_2 {
    some op: REQ_TRIAGE_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        op.post = Post2
}
run ac_reach_2 for 5

-- Criterion 3: The patient is placed in a queue based on the severity of their symptoms.
pred ac_reach_3 {
    some op: REQ_TRIAGE_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        op.post = Post3
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Patient provides no symptoms.
-- The safety invariant: no operation can have an empty target set (which would represent no symptoms)
-- Since target is declared as "some Resource", the Alloy type system already ensures non-emptiness.
-- However, we interpret "no symptoms" as: the operation's pre-state is Pre1 (initial registration)
-- && the target does ! include any resource that represents symptom information.
-- We define a helper sig to represent symptom-bearing resources.
sig SymptomResource in Resource {}
assert ec_safe_1 {
    all op: REQ_TRIAGE_01 |
        (op.pre = Pre1 && no op.target & SymptomResource) =>
        op.post != Post2  -- cannot transition to a triage-complete state without symptom data
}
check ec_safe_1 for 5

-- Edge case 2: Symptoms are entered incorrectly || ambiguously.
-- The safety invariant: if the initiator is ! a medical professional (i.e., ! in Medical_Staff),
-- then any operation that modifies a resource with symptom data must result in a post-state
-- that is ! Post3 (which represents a finalized triage decision).
-- This prevents incorrect/ambiguous entries from being treated as final.
assert ec_safe_2 {
    all op: REQ_TRIAGE_01 |
        (op.initiator ! in Medical_Staff &&
         op.target in SymptomResource &&
         op.grant = Write) =>
        op.post != Post3
}
check ec_safe_2 for 5

-- Edge case 3: System fails to process registration within the expected time frame.
-- The safety invariant: if the operation's pre-state is Pre1 (initial registration)
-- && the post-state is still Pre1 (no progress), then the operation must have
-- encountered a channel that is ! authenticated, representing a system failure.
-- We interpret "expected time frame" as: the operation must make state progress.
assert ec_safe_3 {
    all op: REQ_TRIAGE_01 |
        (op.pre = Pre1 && op.post = Pre1) =>
        some c: op.channel | c.authenticated = False
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? Scenario TC-TRIAGE-01: Registering a patient with no symptoms ??????
pred tc_triage01_holds {
    some op: REQ_TRIAGE_01 |
        -- Input: Triage_Nurse_Team initiates registration
        op.initiator = Triage_Nurse_Team &&
        -- Input: Target is a new patient record (SymptomResource)
        some r: op.target | r in SymptomResource &&
        -- Input: No symptoms recorded (SymptomResource has no symptom field, but we model as no symptom-related state)
        -- Expected: Patient record created (post != pre)
        op.post != op.pre &&
        -- Expected: Patient placed at end of queue (modeled as resource accessible to queue API)
        some r: op.target | r.owner = Triage_Nurse_Team &&
        -- Expected: Channel used is Triage_Nurse_Registration_Form (authenticated)
        all c: op.channel | c in Triage_Nurse_Registration_Form && c.authenticated = True
}
run  tc_triage01_holds    for 5

assert tc_triage01_contract {
    all op: REQ_TRIAGE_01 |
        -- Precondition: Nurse team initiates with no symptoms
        (op.initiator = Triage_Nurse_Team &&
         some r: op.target | r in SymptomResource) =>
        -- Postcondition: Record created, patient queued
        (op.post != op.pre &&
         some r: op.target | r.owner = Triage_Nurse_Team &&
         all c: op.channel | c in Triage_Nurse_Registration_Form && c.authenticated = True)
}
check tc_triage01_contract for 5

-- ?? Scenario TC-TRIAGE-02: Incorrectly entered symptoms ???????????????
pred tc_triage02_holds {
    some op: REQ_TRIAGE_01 |
        -- Input: Nurse team initiates
        op.initiator = Triage_Nurse_Team &&
        -- Input: Target SymptomResource has incorrect data (modeled as pre != post with error state)
        op.pre = Pre1 && op.post = Post1 &&  -- Error state reached
        -- Expected: System records input errors (modeled as state transition to error state)
        op.post != op.pre &&
        -- Expected: Prompts correction (modeled as resource still accessible for correction)
        some r: op.target | r.owner = Triage_Nurse_Team
}
run  tc_triage02_holds    for 5

assert tc_triage02_contract {
    all op: REQ_TRIAGE_01 |
        -- Precondition: Nurse enters incorrect symptoms
        (op.initiator = Triage_Nurse_Team &&
         op.pre = Pre1) =>
        -- Postcondition: Error recorded, correction prompted
        (op.post = Post1 &&
         op.post != op.pre &&
         some r: op.target | r.owner = Triage_Nurse_Team)
}
check tc_triage02_contract for 5

-- ?? Scenario TC-TRIAGE-03: System failure during registration ????????
pred tc_triage03_holds {
    some op: REQ_TRIAGE_01 |
        -- Input: Any initiator (system failure is independent of actor)
        op.initiator = Triage_Nurse_Team &&
        -- Input: Failure occurs (modeled as no state change || error state)
        op.pre = Pre2 && op.post = Post2 &&  -- Failure state
        -- Expected: Registration fails (no new resource created)
        no r: op.target | r.owner = op.initiator &&
        -- Expected: Error message displayed (modeled as channel failure)
        some c: op.channel | c.encrypted = False  -- Channel compromised
}
run  tc_triage03_holds    for 5

assert tc_triage03_contract {
    all op: REQ_TRIAGE_01 |
        -- Precondition: System failure occurs during registration
        (op.pre = Pre2) =>
        -- Postcondition: Registration fails, error displayed
        (op.post = Post2 &&
         no r: op.target | r.owner = op.initiator &&
         some c: op.channel | c.encrypted = False)
}
check tc_triage03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: Limiting channel count per operation reduces processing complexity, proxying latency < 30s.
assert nfr_assert_performance {
    all op: REQ_TRIAGE_01 | #op.channel <= 2
}
check nfr_assert_performance for 5

-- Proxy: Requiring at least two redundant channels per operation ensures 99.9% uptime.
assert nfr_assert_availability {
    all op: REQ_TRIAGE_01 | #op.channel >= 2
}
check nfr_assert_availability for 5

-- Proxy: Each triage nurse must be the initiator of some operation, proxying support for 50 concurrent users.
assert nfr_assert_scalability {
    all t: Triage_Nurse_Team | some op: REQ_TRIAGE_01 | op.initiator = t
}
check nfr_assert_scalability for 5

-- Proxy: Limiting the variety of interface kinds per operation reduces cognitive load, proxying clear && actionable errors.
assert nfr_assert_usability {
    all op: REQ_TRIAGE_01 | #(op.channel.kind) <= 1
}
check nfr_assert_usability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security requirement 1: All patient data must be encrypted both at rest && in transit.
-- Encryption in transit: every channel used by the operation must be encrypted.
assert sr_assert_encrypt_in_transit {
    all op: REQ_TRIAGE_01 | all c: op.channel | c.encrypted = True
}
check sr_assert_encrypt_in_transit for 5

-- Encryption at rest: every resource that is a patient data resource must be owned by an actor that requires encryption.
-- We model this by requiring that any resource accessible to Triage_Nurse_Team (the only actor handling patient data) 
-- must have its owner enforce encryption. Since we have no field for encryption at rest on Resource, 
-- we enforce that the owner of any resource that is a target of an operation must be authorized to handle encrypted data.
-- This is a minimal model: we require that if a resource is targeted, its owner must have Admin permission (which => encryption responsibility).
assert sr_assert_encrypt_at_rest {
    all op: REQ_TRIAGE_01 | all r: op.target | 
        (Admin in r.owner.mayPerform) || (r.owner in Triage_Nurse_Team)
}
check sr_assert_encrypt_at_rest for 5

-- Security requirement 2: Access to the registration functionality is restricted to authorized triage nurses only.
-- The registration functionality is modeled by the Triage_Nurse_Registration_Form resource.
-- Only Triage_Nurse_Team actors may initiate operations that target this resource.
assert sr_assert_registration_access_restricted {
    all op: REQ_TRIAGE_01 |
        (Triage_Nurse_Registration_Form in op.target) =>
        (op.initiator in Triage_Nurse_Team)
}
check sr_assert_registration_access_restricted for 5

-- Additionally, ensure that only triage nurses can perform operations on the registration form.
-- This is a stronger version: the initiator must be part of Triage_Nurse_Team when targeting registration.
fact sr_fact_registration_authorization {
    all op: REQ_TRIAGE_01 |
        (Triage_Nurse_Registration_Form in op.target) =>
        (op.initiator in Triage_Nurse_Team)
}


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines actors, resources, interfaces, states, and operations for patient registration.
-- Summary 2: Structural invariants ensure well-formed operations with authorization and state change.
-- Summary 3: Safety assertions check unauthorized execution, resource access, and well-formedness.
-- Summary 4: Post-state reachability predicates verify each postcondition is achievable.
-- Summary 5: Edge case assertions model no symptoms, incorrect symptoms, and system failure.
-- Summary 6: Test scenario predicates and contracts cover the three test cases.
-- Summary 7: Non-functional requirement proxies use channel count and actor constraints.
-- Summary 8: Security properties enforce encryption and restricted access to registration.
-- Assumption 1: SymptomResource is a subset of Resource representing symptom-bearing data.
-- Assumption 2: State transitions Pre1/Pre2 to Post1/Post2/Post3 model specific pre/postconditions.
-- Assumption 3: Channel count proxies for performance and availability requirements.
-- Assumption 4: Admin permission implies encryption responsibility for at-rest data.
-- Assumption 5: Triage_Nurse_Team is a singleton representing the entire team.
-- Open issue 1: The nfr_assert_performance and nfr_assert_availability assertions are contradictory (channels <=2 vs >=2).
-- Open issue 2: The sr_assert_encrypt_at_rest assertion uses a weak condition (Admin or Triage_Nurse_Team) that may not fully capture encryption at rest.
-- Open issue 3: The tc_triage03_contract assertion uses op.pre = Pre2 but the precondition for system failure is not clearly defined in the requirements.


