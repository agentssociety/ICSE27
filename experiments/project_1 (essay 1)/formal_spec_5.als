module REQ_PAT_DEQ_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-PAT-DEQ-01
 * Title       : Dequeue Next Highest-Priority Patient
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig physicians, hospital_administration, patient_care_team extends Actor {}
-- physicians: represents stakeholder 'physicians'
-- hospital_administration: represents stakeholder 'hospital administration'
-- patient_care_team: represents stakeholder 'patient care team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Patient_Queue_Dequeue_API, Patient_Queue_Database, Physician_Interface extends Interface {}

fact interface_properties {
    Patient_Queue_Dequeue_API.kind = API  -- Provides an endpoint for physicians to request the next highest-priority patient from the queue.
    Patient_Queue_Database.kind = Database  -- Stores and manages the list of patients with their respective priorities. The system interacts with this database to retrieve and update patient information during the dequeue process.
    Physician_Interface.kind = UI  -- The physician interface allows physicians to initiate a dequeue request. It displays the details of the dequeued patient once the request is processed.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where there is a queue of patients with different priorities

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where the physician has been presented with the details of the next highest-priority patient
-- Post2: system reaches state where the patient is no longer in the queue


----------------------------------------------------------------------
-- Core operation: REQ_PAT_DEQ_01
----------------------------------------------------------------------

sig REQ_PAT_DEQ_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_PAT_DEQ_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_PAT_DEQ_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_PAT_DEQ_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_PAT_DEQ_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_PAT_DEQ_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_PAT_DEQ_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_PAT_DEQ_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_PAT_DEQ_01 {
    some op: REQ_PAT_DEQ_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_PAT_DEQ_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_PAT_DEQ_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_PAT_DEQ_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_PAT_DEQ_01_well_formed {
    all op: REQ_PAT_DEQ_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_PAT_DEQ_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates for Post1 && Post2
pred ps_reach_Post1 {
    some op: REQ_PAT_DEQ_01 |
        op.post = Post1 &&
        op.initiator = physicians &&
        some t: op.target | t = Patient_Queue_Database &&
        some c: op.channel | c = Physician_Interface &&
        Read in op.initiator.mayPerform &&
        op.pre = Pre1
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_PAT_DEQ_01 |
        op.post = Post2 &&
        op.initiator = physicians &&
        some t: op.target | t = Patient_Queue_Database &&
        some c: op.channel | c = Patient_Queue_Dequeue_API &&
        Write in op.initiator.mayPerform &&
        op.pre = Pre1
}
run ps_reach_Post2 for 5

-- Semantic validation assertions for each post-state
assert ps_valid_Post1 {
    all op: REQ_PAT_DEQ_01 |
        (op.post = Post1) =>
            (op.initiator = physicians &&
             some t: op.target | t = Patient_Queue_Database &&
             some c: op.channel | c = Physician_Interface &&
             Read in op.initiator.mayPerform)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_PAT_DEQ_01 |
        (op.post = Post2) =>
            (op.initiator = physicians &&
             some t: op.target | t = Patient_Queue_Database &&
             some c: op.channel | c = Patient_Queue_Dequeue_API &&
             Write in op.initiator.mayPerform)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: the system returns the patient with the highest priority
pred ac_reach_1 {
    some op: REQ_PAT_DEQ_01 |
        -- The operation involves reading || modifying patient data
        Read in op.initiator.mayPerform &&
        -- The target includes a patient queue resource
        some t: op.target | t in Patient_Queue_Database &&
        -- The channel used is authenticated && encrypted (secure medical system)
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        -- The operation results in Post1 state (patient returned)
        op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: that patient is removed from the queue
pred ac_reach_2 {
    some op: REQ_PAT_DEQ_01 |
        -- The operation requires write permission (to remove from queue)
        Write in op.initiator.mayPerform &&
        -- The target includes a patient queue database resource
        some t: op.target | t in Patient_Queue_Database &&
        -- The channel used is authenticated (secure medical system)
        (some c: op.channel | c.authenticated = True) &&
        -- The operation results in Post2 state (patient removed)
        op.post = Post2
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Empty queue ? if the patient queue is empty, no dequeue operation should succeed
assert ec_safe_1 {
    all op: REQ_PAT_DEQ_01 |
        -- Assume Pre1 represents an empty queue state; no operation from Pre1 should reach Post2 (a success state)
        (op.pre = Pre1) => (op.post != Post2)
}
check ec_safe_1 for 5

-- Edge case 2: Multiple patients with same highest priority ? introduce a helper sig to model priority ties
sig PriorityTie {}
-- A single atom to represent the tie scenario

-- Assertion: In a tie scenario (represented by Pre1), the dequeue must ! nondeterministically skip patients
assert ec_safe_2 {
    all op: REQ_PAT_DEQ_01 |
        (op.pre = Pre1) => (
            -- The operation must deterministically select one patient; we model this by requiring the post-state to be consistent
            -- For simplicity, require that if the queue has ties, the operation still produces a valid post-state
            op.post in Post1 + Post2
        )
}
check ec_safe_2 for 5

-- Edge case 3: Network failure ? if a channel fails, the operation must ! reach a success state
-- Introduce a helper sig to represent network failure scenarios
sig NetworkFailure {}
-- A single atom to represent the failure

assert ec_safe_3 {
    all op: REQ_PAT_DEQ_01 |
        -- If any channel used is ! authenticated (simulating failure), the operation must ! succeed
        (some c: op.channel | c.authenticated = False) => (op.post != Post2)
}
check ec_safe_3 for 5

-- Edge case 4: Concurrent dequeue requests ? no two operations can dequeue the same patient from the same queue
-- Introduce a helper sig to model concurrent operations
sig ConcurrentOp {
    op1, op2: REQ_PAT_DEQ_01
}
assert ec_safe_4 {
    all co: ConcurrentOp |
        -- If two operations share the same target resource && the same pre-state,
        -- they must ! both succeed (Post2) if the resource is consumed
        (co.op1.target = co.op2.target && co.op1.pre = co.op2.pre) =>
            !(co.op1.post = Post2 && co.op2.post = Post2)
}
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicate for TC-PAT-DEQ-01: Dequeue from empty queue ? error state
pred tc_pat_deq_01_holds {
    some op: REQ_PAT_DEQ_01 |
        op.pre = Pre1 &&
        op.post = Post1 &&
        no PriorityTie &&
        no NetworkFailure &&
        #REQ_PAT_DEQ_01 = 1
}
run tc_pat_deq_01_holds for 5

assert tc_pat_deq_01_contract {
    all op: REQ_PAT_DEQ_01 |
        (op.pre = Pre1 && no PriorityTie && no NetworkFailure) =>
        (op.post = Post1)
}
check tc_pat_deq_01_contract for 5

-- Predicate for TC-PAT-DEQ-02: Dequeue with priority tie ? success state
pred tc_pat_deq_02_holds {
    some op: REQ_PAT_DEQ_01 |
        op.initiator = physicians &&
        op.pre = Pre1 &&
        op.post = Post2 &&
        some PriorityTie &&
        no NetworkFailure &&
        #REQ_PAT_DEQ_01 = 1
}
run tc_pat_deq_02_holds for 5

assert tc_pat_deq_02_contract {
    all op: REQ_PAT_DEQ_01 |
        (op.pre = Pre1 && op.initiator = physicians && some PriorityTie && no NetworkFailure) =>
        (op.post = Post2)
}
check tc_pat_deq_02_contract for 5

-- Predicate for TC-PAT-DEQ-03: Dequeue during network failure ? error state
pred tc_pat_deq_03_holds {
    some op: REQ_PAT_DEQ_01 |
        op.pre = Pre1 &&
        op.post = Post1 &&
        some NetworkFailure
}
run tc_pat_deq_03_holds for 5

assert tc_pat_deq_03_contract {
    all op: REQ_PAT_DEQ_01 |
        (op.pre = Pre1 && some NetworkFailure) =>
        (op.post = Post1)
}
check tc_pat_deq_03_contract for 5

-- Predicate for TC-PAT-DEQ-04: Simultaneous dequeue requests from different physicians ? both succeed
pred tc_pat_deq_04_holds {
    some disj op1, op2: REQ_PAT_DEQ_01 |
        op1.initiator = physicians &&
        op2.initiator = hospital_administration &&
        op1.pre = Pre1 && op1.post = Post2 &&
        op2.pre = Pre1 && op2.post = Post2 &&
        no NetworkFailure
}
run tc_pat_deq_04_holds for 5

assert tc_pat_deq_04_contract {
    all op: REQ_PAT_DEQ_01 |
        (op.pre = Pre1 && no NetworkFailure &&
         some op2: REQ_PAT_DEQ_01 - op | op.initiator != op2.initiator) =>
        op.post = Post2
}
check tc_pat_deq_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- Proxy: Minimizing channel count reduces communication overhead,
    -- which helps achieve <5 second response time.
    all op: REQ_PAT_DEQ_01 | #op.channel <= 2
}

fact nfr_fact_availability {
    -- Proxy: At least two channels per operation provide redundancy,
    -- supporting 99.9% uptime even if one fails.
    all op: REQ_PAT_DEQ_01 | #op.channel >= 2
}

fact nfr_fact_scalability {
    -- Proxy: Every physician can initiate an operation, demonstrating
    -- the system can support many concurrent users.
    all p: physicians | some op: REQ_PAT_DEQ_01 | op.initiator = p
}

fact nfr_fact_usability {
    -- Proxy: Physician initiators must use the Physicians Interface,
    -- which is designed to deliver clear && concise error messages.
    all op: REQ_PAT_DEQ_01 |
        op.initiator in physicians => some (op.channel & Physician_Interface)
}

