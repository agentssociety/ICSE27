module REQ_ATC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-01
 * Title       : Flight Registration
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Controllers, Flight_Operations_Team extends Actor {}
-- Air_Traffic_Controllers: represents stakeholder 'Air Traffic Controllers'
-- Flight_Operations_Team: represents stakeholder 'Flight Operations Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Registration_API, Flight_Data_Store, Flight_Management_Dashboard extends Interface {}

fact interface_properties {
    Flight_Registration_API.kind = API  -- The system should provide an API to register, edit, and cancel flights.
    Flight_Data_Store.kind = Database  -- The system should interact with a database to store flight registration data, including updates and deletions.
    Flight_Management_Dashboard.kind = UI  -- The requirement interacts with the user interface where air traffic controllers can perform flight registration operations.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The air traffic controller is on the flight management dashboard

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The new flight is added to the system database
-- Post2: system reaches state where Existing flight data is updated if edited
-- Post3: system reaches state where Flight registration history is maintained for future reference


----------------------------------------------------------------------
-- Core operation: REQ_ATC_01
----------------------------------------------------------------------

sig REQ_ATC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_01 {
    some op: REQ_ATC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_01_well_formed {
    all op: REQ_ATC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_ATC_01 |
        op.post = Post1 &&
        op.grant = Write &&
        Database in op.target &&
        op.channel.authenticated = True &&
        op.pre = Pre1
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ATC_01 |
        (op.post = Post1) =>
            (op.grant = Write && Database in op.target)
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_ATC_01 |
        op.post = Post2 &&
        op.grant = Write &&
        Flight_Data_Store in op.target &&
        op.channel.encrypted = True &&
        op.pre = Pre1
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_ATC_01 |
        (op.post = Post2) =>
            (op.grant = Write && Flight_Data_Store in op.target)
}

check ps_valid_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_ATC_01 |
        op.post = Post3 &&
        op.grant = Read &&
        Flight_Management_Dashboard in op.target &&
        op.channel.authenticated = True &&
        op.pre = Pre1
}

run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_ATC_01 |
        (op.post = Post3) =>
            (op.grant = Read && Flight_Management_Dashboard in op.target)
}

check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_ATC_01 |
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        Flight_Registration_API in op.target &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_ATC_01 |
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        Flight_Data_Store in op.target &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post2
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_ATC_01 |
        op.grant = Read &&
        Read in op.initiator.mayPerform &&
        Flight_Management_Dashboard in op.target &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post3
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: If a flight number is already registered, the system must ! create a duplicate registration.
-- Model this by ensuring that no operation on a resource that already has an owner creates a new binding.
assert ec_safe_1 {
    all op: REQ_ATC_01 |
        -- If the target resource already has an owner different from the initiator,
        -- && the operation grants Write permission, then the post-state must reflect
        -- that the resource remains owned by its original owner (no overwrite).
        (some t: op.target | t.owner != op.initiator) && (Write in op.grant) =>
            (all t: op.target | t.owner != op.initiator => t.owner = t.owner)
}
check ec_safe_1 for 5

-- Edge case 2: Time zone differences must ! cause the system to schedule operations in the past.
-- Model this by ensuring that post-states always occur after pre-states in a global ordering.
-- Since we have no explicit time field, we use a fact that Post states are reachable only after Pre.
assert ec_safe_2 {
    all op: REQ_ATC_01 |
        -- The operation's post state must be distinct from its pre state (already in inv_state_must_change)
        -- Additionally, no operation can have a post state that is chronologically before its pre state.
        -- We model this by requiring that post states cannot be Pre1 (the initial state marker)
        op.post != Pre1
}
check ec_safe_2 for 5

-- Edge case 3: Attempting to edit || cancel a non-existent flight must be prevented.
-- Model this by ensuring that if a target resource does ! exist in the pre-state,
-- the operation cannot proceed to a post-state.
assert ec_safe_3 {
    all op: REQ_ATC_01 |
        -- If the target resource has no owner in the pre-state (i.e., it's ! registered),
        -- then the post-state must be identical to the pre-state (no change).
        (some t: op.target | no t.owner) => op.post = op.pre
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_ATC_01_holds {
    some op: REQ_ATC_01 |
        -- Input: Air_Traffic_Controllers initiate registration of a new arrival flight
        op.initiator = Air_Traffic_Controllers &&
        -- Input: Using Flight_Registration_API as channel, Database as target
        Flight_Registration_API in op.channel &&
        Database in op.target &&
        -- Expected: A new flight record is created (state changes) && marked as arrival
        op.pre = Pre1 &&
        op.post = Post1 &&
        Post1 != Pre1
}

run tc_ATC_01_holds for 5

assert tc_ATC_01_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Controllers &&
         Flight_Registration_API in op.channel &&
         Database in op.target &&
         op.pre = Pre1) =>
        (op.post = Post1 && Post1 != Pre1)
}

check tc_ATC_01_contract for 5

pred tc_ATC_02_holds {
    some op: REQ_ATC_01 |
        -- Input: Air_Traffic_Controllers edit an existing departure flight's scheduled time
        op.initiator = Air_Traffic_Controllers &&
        Database in op.target &&
        -- Expected: The specified departure flight's scheduled time is updated (state changes)
        op.pre = Pre1 &&
        op.post = Post2 &&
        Post2 != Pre1
}

run tc_ATC_02_holds for 5

assert tc_ATC_02_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Controllers &&
         Database in op.target &&
         op.pre = Pre1) =>
        (op.post = Post2 && Post2 != Pre1)
}

check tc_ATC_02_contract for 5

pred tc_ATC_03_holds {
    some op: REQ_ATC_01 |
        -- Input: Cancel a registered incoming flight
        op.initiator = Air_Traffic_Controllers &&
        Database in op.target &&
        -- Expected: Flight record marked as cancelled (state changes)
        op.pre = Pre1 &&
        op.post = Post3 &&
        Post3 != Pre1
}

run tc_ATC_03_holds for 5

assert tc_ATC_03_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Controllers &&
         Database in op.target &&
         op.pre = Pre1) =>
        (op.post = Post3 && Post3 != Pre1)
}

check tc_ATC_03_contract for 5

pred tc_ATC_04_holds {
    some op: REQ_ATC_01 |
        -- Input: Attempt to register a flight with incomplete details
        op.initiator = Air_Traffic_Controllers &&
        Flight_Registration_API in op.channel &&
        Database in op.target &&
        -- Expected: Error message displayed (state does ! change)
        op.pre = Pre1 &&
        op.post = Pre1
}

run tc_ATC_04_holds for 5

assert tc_ATC_04_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Controllers &&
         Flight_Registration_API in op.channel &&
         Database in op.target &&
         op.pre = Pre1) =>
        (op.post = Pre1)
}

check tc_ATC_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- PROXY: limiting channel count per operation reduces latency (performance)
fact nfr_fact_performance_concurrent {
    -- NFR: handle up to 100 concurrent flight registrations
    -- PROXY: each operation uses at most 2 channels to minimize overhead
    all op: REQ_ATC_01 | #op.channel <= 2
}

-- PROXY: requiring at least 2 redundant channels ensures availability
fact nfr_fact_availability_redundancy {
    -- NFR: system must be available 99.9% of the time
    -- PROXY: at least 2 channels exist so a backup is always available
    #Interface >= 2
}

-- PROXY: all actors can be initiators simultaneously, proving scalability
fact nfr_fact_scalability_capacity {
    -- NFR: support at least 5000 registered flights
    -- PROXY: every actor can initiate an operation concurrently
    all a: Actor | some op: REQ_ATC_01 | op.initiator = a
}

-- PROXY: limiting authenticated channels reduces complexity, improving usability
fact nfr_fact_usability_interface {
    -- NFR: intuitive interface for air traffic controllers
    -- PROXY: at most 3 authenticated channels to keep interface simple
    #{i: Interface | i.authenticated = True} <= 3
}

assert nfr_assert_performance_completes {
    -- All operations complete within bounded channel usage (performance proxy)
    all op: REQ_ATC_01 | #op.channel > 0 && #op.channel <= 2
}
check nfr_assert_performance_completes for 5

assert nfr_assert_availability_reachable {
    -- Every state is reachable by some operation (availability proxy)
    all s: State | some op: REQ_ATC_01 | op.post = s
}
check nfr_assert_availability_reachable for 5

assert nfr_assert_scalability_resources {
    -- Each resource can be targeted by multiple operations (scalability proxy)
    all r: Resource | #{op: REQ_ATC_01 | r in op.target} >= 1
}
check nfr_assert_scalability_resources for 5

assert nfr_assert_usability_clear_errors {
    -- Error states (Pre1) lead to defined post-states (usability proxy)
    all op: REQ_ATC_01 | op.pre = Pre1 => op.post != Pre1
}
check nfr_assert_usability_clear_errors for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security requirement 1: Encryption in transit for all channels
assert sr_assert_encryption_in_transit {
    all op: REQ_ATC_01 |
        all c: op.channel |
            c.encrypted = True
}
check sr_assert_encryption_in_transit for 5

-- Security requirement 2: Role-based access control for flight registration
-- Only authorized personnel (Air_Traffic_Controllers || Flight_Operations_Team) can perform operations
-- that require Write || higher permissions on flight registration resources
assert sr_assert_role_based_access {
    all op: REQ_ATC_01 |
        (Write in op.grant) =>
            (op.initiator in Air_Traffic_Controllers + Flight_Operations_Team)
}
check sr_assert_role_based_access for 5

-- Additional security: Least privilege - initiator must have exactly the permission they are granted
assert sr_assert_least_privilege {
    all op: REQ_ATC_01 |
        op.grant in op.initiator.mayPerform
}
check sr_assert_least_privilege for 5

-- Additional security: No privilege escalation through resource ownership
assert sr_assert_no_privilege_escalation {
    all op: REQ_ATC_01 |
        (Admin in op.grant) =>
            (op.initiator in Air_Traffic_Controllers + Flight_Operations_Team)
}
check sr_assert_no_privilege_escalation for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines a permission lattice, actor roles, resources, interfaces, and states for flight registration operations.
-- Summary 2: Structural invariants ensure operations have channels, targets, authorization, and state changes.
-- Summary 3: Safety assertions check unauthorized execution, resource access, and well-formedness.
-- Summary 4: Post-state reachability predicates verify that each postcondition can be achieved.
-- Summary 5: Edge case assertions model duplicate registration prevention, time zone safety, and non-existent flight handling.
-- Summary 6: Test case predicates and contracts specify expected behavior for registration, edit, cancel, and incomplete details.
-- Summary 7: Non-functional requirement proxies bound channel usage, ensure interface count, and enforce actor participation.
-- Summary 8: Security assertions require encryption, role-based access, least privilege, and no privilege escalation.
-- Assumption 1: Resources have a single owner and an accessible set that includes the owner.
-- Assumption 2: Interfaces have a kind (Database, UI, API) and boolean flags for encryption and authentication.
-- Assumption 3: States are abstract and only Pre1, Post1, Post2, Post3 are defined.
-- Assumption 4: Operations must change state (pre != post) and reach a defined post-state.
-- Assumption 5: At least one channel per operation must be authenticated.
-- Assumption 6: Non-functional requirements are modeled via proxy constraints (e.g., channel count, interface count).
-- Open issue 1: Edge case assertions ec_safe_1 and ec_safe_3 may be vacuously true due to the model's abstraction; they rely on resource ownership which is static.
-- Open issue 2: The model does not represent flight numbers, time zones, or incomplete details explicitly; these are abstracted into states and permissions.
-- Open issue 3: The assertion nfr_assert_usability_clear_errors contradicts tc_ATC_04_contract which expects post = Pre1 for incomplete details.
-- Open issue 4: The assertion sr_assert_encryption_in_transit requires all channels to be encrypted, but the requirement only specifies data transmission between controller and system; other channels may not need encryption.


