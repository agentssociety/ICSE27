from __future__ import annotations

from datetime import datetime
from pydantic import BaseModel

from src.domain.flight.flight_type import FlightType

"""
Dto layer for the Flight domain class

Package: dto.flight
Layer: dto
Related tasks: #65, #66, #67, #68, #69, #70, #71
Requirement coverage:
- Flight Registration
- Allocate 5-minute time slots with mandatory 3-minute gaps between flights
- Prioritize Arrivals Over Departures During Slot Allocation
- Automated Detection of Overlapping Assignments and Scheduling Violations
- Automated Reassignment and Rescheduling on Runway Closure
"""

class FlightRegistrationRequest(BaseModel):
    flightNumber: str
    airline: str
    origin: str
    destination: str
    scheduledTime: datetime
    type: FlightType

class FlightUpdateRequest(BaseModel):
    flightNumber: str
    scheduledTime: datetime

