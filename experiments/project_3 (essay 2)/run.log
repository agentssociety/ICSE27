  features = [                                                                                                                                
      {                                                                                                                                       
          "title": "Flight Registration",                                                                                                     
          "description": "As an air traffic controller, I want to register incoming and outgoing flights so that all flight operations are    
  recorded and managed within the system.\n\n**Acceptance Criteria:**\n- Ability to add a new flight with flight number, airline,             
  origin/destination, scheduled time, and type (arrival/departure)\n- Edit or cancel a registered flight\n- View list of all registered       
  flights"                                                                                                                                    
      },                                                                                                                                      
      {                                                                                                                                       
          "title": "Slot Allocation with Gap",                                                                                                
          "description": "As an air traffic controller, I want the system to allocate 5-minute time slots for flights with a mandatory        
  3-minute gap between consecutive slots to ensure safe separation.\n\n**Acceptance Criteria:**\n- Each flight gets a 5-minute slot\n- There  
  is a 3-minute buffer/gap between end of one slot and start of next\n- Slots are automatically assigned based on scheduling rules"           
      },                                                                                                                                      
      {                                                                                                                                       
          "title": "Arrival Priority Over Departures",                                                                                        
          "description": "As an air traffic controller, I want arrivals to be prioritized over departures during slot allocation to reduce    
  holding patterns and improve landing efficiency.\n\n**Acceptance Criteria:**\n- In case of slot conflicts, arriving flights get             
  precedence\n- Departure slots are adjusted after arrivals are placed\n- Priority logic is clearly documented"                               
      },                                                                                                                                      
      {                                                                                                                                       
          "title": "Overlap and Gap Violation Detection",                                                                                     
          "description": "As a system monitor, I want the system to automatically detect overlapping assignments or violations of the         
  3-minute gap rule so that scheduling conflicts can be flagged.\n\n**Acceptance Criteria:**\n- Alerts triggered when two flights occupy      
  overlapping time windows\n- Alerts triggered when gap between slots is less than 3 minutes\n- Visual/notification indicator of violations"  
      },                                                                                                                                      
      {                                                                                                                                       
          "title": "Runway Closure Handling",                                                                                                 
          "description": "As an air traffic controller, I want to handle a runway closure by having the system automatically reassign         
  affected flights to alternative runways (if available) or reschedule them.\n\n**Acceptance Criteria:**\n- Ability to mark a runway as       
  closed\n- System auto-suggests/reassigns affected slots to other runways\n- If no alternative runway, flights are queued/rescheduled with   
  notification"                                                                                                                               
      },                                                                                                                                      
      {                                                                                                                                       
          "title": "Emergency Priority Slot",                                                                                                 
          "description": "As an air traffic controller, I want to declare an emergency for a flight and have the system assign an immediate   
  priority slot overriding normal scheduling rules.\n\n**Acceptance Criteria:**\n- Option to mark a flight as emergency\n- Emergency flight   
  gets priority slot immediately\n- Other slots adjust automatically to accommodate the emergency"                                            
      },                                                                                                                                      
      {                                                                                                                                       
          "title": "Runway Slot Timetable Display",                                                                                           
          "description": "As an air traffic controller, I want to view a runway slot timetable that shows all allocated slots with clear      
  indicators for delays and emergencies to maintain situational awareness.\n\n**Acceptance Criteria:**\n- Timetable shows all allocated       
  slots per runway\n- Delayed flights are highlighted with delay duration\n- Emergency flights are highlighted with special marker\n-         
  Timetable can be filtered by runway and time period"                                                                                        
      }                                                                                                                                       
  ]                                                                                                                                           
                                                                                                                                              
  # Create all 7 tasks                                                                                                                        
  task_ids = []                                                                                                                               
