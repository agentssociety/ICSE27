*/\n\n\n----------------------------------------------------------------------\n-- Permission 
lattice\n----------------------------------------------------------------------\n\nabstract sig Permission {}\none sig Read, Write, Execute, 
Admin extends Permission {}\n\n-- Partial order: a permission subsumes another if it grants strictly more.\n-- Used in authorization 
assertions (see security section).\nfun stronger [p: Permission] : set Permission {\n    (p = Read)    => Read\n    else (p = Write)   => 
(Read + Write)\n    else (p = Execute) => (Read + Execute)\n    else 
Admin\n}\n\n\n----------------------------------------------------------------------\n-- Actor / Role 
hierarchy\n----------------------------------------------------------------------\n\nabstract sig Actor {\n    mayPerform : set 
Permission\n}\n\none sig Air_Traffic_Controllers, Flight_Operations_Team extends Actor {}\n-- Air_Traffic_Controllers: represents stakeholder 
'Air Traffic Controllers'\n-- Flight_Operations_Team: represents stakeholder 'Flight Operations 
Team'\n\n\n----------------------------------------------------------------------\n-- Resources (data / objects under 
operation)\n----------------------------------------------------------------------\n\nabstract sig Resource {\n    owner      : one  Actor,\n 
accessible : set  Actor\n}\n\n-- Every resource is accessible AT MINIMUM by its owner.\nfact owner_always_accessible {\n    all r: Resource | 
r.owner in r.accessible\n}\n\n\n----------------------------------------------------------------------\n-- Interfaces (communication 
channels)\n----------------------------------------------------------------------\n\nabstract sig IfaceKind {}\none sig Database, UI, API 
extends IfaceKind {}\n\nabstract sig Bool {}\none sig True, False extends Bool {}\n\nabstract sig Interface {\n    kind          : one 
IfaceKind,\n    encrypted     : one Bool,      -- transport-layer security\n    authenticated : one Bool       -- requires caller 
identity\n}\n\none sig Flight_Registration_API, Flight_Data_Store, Flight_Management_Dashboard extends Interface {}\n\nfact 
interface_properties {\n    Flight_Registration_API.kind = API  -- The system should provide an API to register, edit, and cancel flights.\n  
Flight_Data_Store.kind = Database  -- The system should interact with a database to store flight registration data, including updates and 
deletions.\n    Flight_Management_Dashboard.kind = UI  -- The requirement interacts with the user interface where air traffic controllers can 
perform flight registration operations.\n}\n\n\n----------------------------------------------------------------------\n-- System states and 
transitions\n----------------------------------------------------------------------\n\nabstract sig State {}\n\n-- Concrete pre-states (one 
per distinct precondition).\none sig Pre1 extends State {}\n-- Pre1: system is in state where The air traffic controller is on the flight 
management dashboard\n\n-- Concrete post-states (one per distinct postcondition).\none sig Post1, Post2, Post3 extends State {}\n-- Post1: 
system reaches state where The new flight is added to the system database\n-- Post2: system reaches state where Existing flight data is 
updated if edited\n-- Post3: system reaches state where Flight registration history is maintained for future 
reference\n\n\n----------------------------------------------------------------------\n-- Core operation: 
REQ_ATC_01\n----------------------------------------------------------------------\n\nsig REQ_ATC_01 {\n    initiator  : one  Actor,          
-- who triggers the operation\n    target     : some Resource,        -- what data/objects are affected\n    channel    : some Interface,     
