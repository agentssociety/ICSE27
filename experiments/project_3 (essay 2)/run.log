              },                                                                                                                              
          )                                                                                                                                   
          flight_id = create_resp.json()["id"]                                                                                                
                                                                                                                                              
          delete_resp = client.delete(f"/flights/{flight_id}")                                                                                
          assert delete_resp.status_code == 204                                                                                               
                                                                                                                                              
          # Verify it's gone                                                                                                                  
          get_resp = client.get(f"/flights/{flight_id}")                                                                                      
          assert get_resp.status_code == 404                                                                                                  
