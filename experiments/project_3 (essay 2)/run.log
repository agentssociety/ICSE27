        flight = Flight(
            flightNumber="AA123",
            airline="AA",
            origin="JFK",
            destination="LAX",
            scheduledTime=datetime(2025, 6, 1, 10, 0, 0),
            type=FlightType.ARRIVAL,
        )
        flight.setType(FlightType.DEPARTURE)
