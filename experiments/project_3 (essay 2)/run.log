    def test_set_type_invalid(self) -> None:
        flight = Flight(
            flightNumber="AA123",
            airline="AA",
            origin="JFK",
            destination="LAX",
            scheduledTime=datetime(2025, 6, 1, 10, 0, 0),
            type=FlightType.ARRIVAL,
        )
        with pytest.raises(TypeError):
            flight.setType("invalid")  # type: ignore[arg-type]

