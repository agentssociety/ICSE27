      response = client.post(                                                                                                                 
          "/flights",                                                                                                                         
          json={                                                                                                                              
              "flightNumber": "AA100",                                                                                                        
              "airline": "American Airlines",                                                                                                 
              "origin": "JFK",                                                                                                                
