m defaultFontSize 12\nskinparam backgroundColor #FEFEFE\n\nbox "Controller" #LightBlue\n  actor "AirTrafficController" as ATC\nend box\n\nbox 
"Application" #LightGreen\n  participant "EmergencyOperationHandler" as EOH\n  participant "FlightDispatch" as FD\n  participant 
"SafetyManagement" as SM\nend box\n\nbox "Domain" #LightYellow\n  participant "Flight" as F\n  participant "Slot" as S\n  participant 
"EmergencyStateMarker" as ESM\n  participant "CriticalFlight" as CF\n  participant "Resource" as R\n  participant "Actor" as A\n  participant 
"Permission" as P\n  participant "State" as ST\nend box\n\nbox "Infrastructure" #LightCoral\n  participant "FlightManagementDatabase" as 
DB\nend box\n\n== Main Flow - Mark Emergency Success ==\n\nATC -> EOH : POST /emergency [TLS]\nactivate EOH\n\nEOH -> EOH : 
validateInput(flightId) : boolean\nalt Invalid identifier\n  EOH --> ATC : 400 Bad Request\n  note right: Clear feedback (usability)\nelse 
Valid identifier\n  EOH -> DB : fetchFlight(flightId) [encrypted at rest]\n  activate DB\n  DB --> EOH : Flight data\n  deactivate DB\n  alt 
Flight not found\n    EOH --> ATC : 404 Not Found\n  else Flight found\n    EOH -> F : checkState() : State\n    activate F\n    F --> EOH : 
NORMAL\n    deactivate F\n    EOH -> A : authenticate(credentials) : Actor\n    activate A\n    A --> EOH : actor object\n    deactivate A\n  
EOH -> A : getPermissions() : Set<Permission>\n    activate A\n    A --> EOH : {Execute, Admin}\n    deactivate A\n    alt Permission 
missing\n      EOH --> ATC : 403 Forbidden\n    else Permission present\n      EOH -> F : isAccessible(actor) : boolean\n      activate F\n   
F --> EOH : true\n      deactivate F\n      alt Not accessible\n        EOH --> ATC : 403 Forbidden\n      else Accessible\n        EOH -> EOH
: checkTargetSlots(slotIds)\n        alt slot belongs to CriticalFlight\n          EOH --> ATC : 409 Conflict\n          note right: ec_safe_3
– operation denied\n        else valid slot\n          EOH -> F : assignEmergencyState() : State\n          activate F\n          F -> ESM : 
addState(EMERGENCY)\n          activate ESM\n          ESM --> F : ok\n          deactivate ESM\n          F --> EOH : EMERGENCY\n          
note left: Pre1 → Post1\n          deactivate F\n          EOH -> F : getResources() : Set<Resource>\n          activate F\n          F --> 
EOH : resources\n          deactivate F\n          EOH -> S : assignPrioritySlot(flightId, resources)\n          activate S\n          S -> DB
: updateSlot(slotId, priority) [encrypted at rest]\n          deactivate S\n          EOH -> S : adjustOtherSlots(flightId)\n          
activate S\n          S -> DB : bulkUpdateOtherSlots() [encrypted at rest]\n          note right: Post2 – real-time adjustment\n          
deactivate S\n          EOH --> ATC : 200 OK\n        end\n      end\n    end\n  end\nend\ndeactivate EOH\n\n== Error Flow - Flight Already in
Emergency ==\n\nATC -> EOH : POST /emergency [TLS]\nactivate EOH\n\nEOH -> DB : fetchFlight(flightId) [encrypted at rest]\nactivate DB\nDB -->
EOH : Flight data\ndeactivate DB\nEOH -> F : checkState() : State\nactivate F\nF --> EOH : EMERGENCY\ndeactivate F\nnote over EOH : ec_safe_1,
ec_safe_2 – no conflicting grants\nEOH --> ATC : 200 OK (already in emergency)\ndeactivate EOH\n\n== Error Flow - Attempt on CriticalFlight 
Resources ==\n\nATC -> EOH : POST /emergency (targeting critical slot)\nactivate EOH\n\nEOH -> DB : fetchFlight(flightId)\nactivate DB\nDB -->
EOH : Flight data\ndeactivate DB\nEOH -> F : isAccessible() : boolean\nactivate F\nF --> EOH : true\ndeactivate F\nEOH -> EOH : 
checkTargetSlots() -> includes critical slot\nEOH --> ATC : 409 Conflict\nnote right: ec_safe_3 – resources of CriticalFlight must not be 
touched\ndeactivate EOH\n\n== Edge Case - Simultaneous Declarations (No Conflict) ==\n\n|||\ngroup Handled independently per declaration\n  
ATC -> EOH : POST /emergency (flightA)\n  activate EOH\n  EOH -> DB : fetchFlight(flightA)\n  activate DB\n  DB --> EOH : Flight data\n  
deactivate DB\n  EOH -> F : lockResource(flightA)\n  activate F\n  F --> EOH : locked\n  deactivate F\n  EOH -> EOH : allocateSlot()\n  note 
right: ec_safe_2 – no overlapping targets\n  EOH --> ATC : 200 OK\n  deactivate EOH\nend\n|||\ngroup Simultaneous but different resources – no
conflict\n  ATC -> EOH : POST /emergency (flightB)\n  activate EOH\n  EOH -> DB : fetchFlight(flightB)\n  activate DB\n  DB --> EOH : Flight 
data\n  deactivate DB\n  EOH -> F : lockResource(flightB)\n  activate F\n  F --> EOH : locked\n  deactivate F\n  EOH --> ATC : 200 OK\n  
deactivate EOH\nend\n|||\n\n== Additional Flow - Unauthorized Actor (FlightDispatch) ==\n\nFD -> EOH : POST /emergency [TLS]\nactivate 
EOH\n\nEOH -> A : authenticate(credentials) : Actor\nactivate A\nA --> EOH : FlightDispatch actor\ndeactivate A\nEOH -> A : getPermissions() :
Set<Permission>\nactivate A\nA --> EOH : {}\ndeactivate A\nnote over EOH : No Execute/Admin permission\nEOH --> FD : 403 Forbidden\ndeactivate
