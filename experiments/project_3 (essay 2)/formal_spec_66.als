module REQ_ATC_TIME_SLOTS_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-TIME-SLOTS-01
 * Title       : Allocate 5-minute time slots with mandatory 3-minute gaps between flights
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Control_Team, Flight_Operations_Management, Safety_Compliance_Department extends Actor {}
-- Air_Traffic_Control_Team: represents stakeholder 'Air Traffic Control Team'
-- Flight_Operations_Management: represents stakeholder 'Flight Operations Management'
-- Safety_Compliance_Department: represents stakeholder 'Safety Compliance Department'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Information_API, Flight_Schedule_Database extends Interface {}

fact interface_properties {
    Flight_Information_API.kind = API  -- The system will use this API to retrieve flight schedule data and update slot allocations.
    Flight_Schedule_Database.kind = Database  -- Stores flight schedules, allocated time slots, and other relevant information.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Flights are scheduled with adequate time separation
-- Post2: system reaches state where Safety protocols are enforced during flight allocation


----------------------------------------------------------------------
-- Core operation: REQ_ATC_TIME_SLOTS_01
----------------------------------------------------------------------

sig REQ_ATC_TIME_SLOTS_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_TIME_SLOTS_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_TIME_SLOTS_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_TIME_SLOTS_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_TIME_SLOTS_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_TIME_SLOTS_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_TIME_SLOTS_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_TIME_SLOTS_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_TIME_SLOTS_01 {
    some op: REQ_ATC_TIME_SLOTS_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_TIME_SLOTS_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_TIME_SLOTS_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_TIME_SLOTS_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_TIME_SLOTS_01_well_formed {
    all op: REQ_ATC_TIME_SLOTS_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_TIME_SLOTS_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_ATC_TIME_SLOTS_01 |
        op.post = Post1 &&
        op.initiator = Flight_Operations_Management &&
        Flight_Schedule_Database in op.target &&
        op.grant = Write &&
        Flight_Information_API in op.channel &&
        op.pre != Post1
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_ATC_TIME_SLOTS_01 |
        op.post = Post2 &&
        op.initiator = Safety_Compliance_Department &&
        Flight_Schedule_Database in op.target &&
        op.grant = Admin &&
        Flight_Information_API in op.channel &&
        op.pre != Post2
}
run ps_reach_Post2 for 5

assert ps_valid_Post1 {
    all op: REQ_ATC_TIME_SLOTS_01 |
        (op.post = Post1) =>
            (op.initiator = Flight_Operations_Management &&
             Flight_Schedule_Database in op.target &&
             op.grant = Write &&
             Flight_Information_API in op.channel)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_ATC_TIME_SLOTS_01 |
        (op.post = Post2) =>
            (op.initiator = Safety_Compliance_Department &&
             Flight_Schedule_Database in op.target &&
             op.grant = Admin &&
             Flight_Information_API in op.channel)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Liveness predicates for REQ_ATC_TIME_SLOTS_01 criteria

pred ac_reach_1 {
    some op: REQ_ATC_TIME_SLOTS_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        (some r: op.target | r = Flight_Schedule_Database) &&
        (some c: op.channel | c.authenticated = True && c.encrypted = True)
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_ATC_TIME_SLOTS_01 |
        op.post = Post2 &&
        op.initiator = Safety_Compliance_Department &&
        (some r: op.target | r = Database) &&
        (some c: op.channel | c.authenticated = True)
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_ATC_TIME_SLOTS_01 |
        op.initiator = Air_Traffic_Control_Team &&
        op.grant = Execute &&
        op.post = Post1 &&
        (some r: op.target | r = Flight_Schedule_Database) &&
        (some c: op.channel | c.authenticated = True && c.encrypted = True)
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

one sig CanceledStatus { canceled: set Resource }
one sig DelayedStatus { delayed: set Resource }
one sig ConflictGroup { resources: set Resource }
fact { some ConflictGroup }

assert ec_safe_1 {
    all op: REQ_ATC_TIME_SLOTS_01 |
        (some r: op.target | r in CanceledStatus.canceled) => (op.post = op.pre)
}
check ec_safe_1 for 5

assert ec_safe_2 {
    all op: REQ_ATC_TIME_SLOTS_01 |
        (some r: op.target | r in DelayedStatus.delayed) => (Write in op.initiator.mayPerform)
}
check ec_safe_2 for 5

assert ec_safe_3 {
    all op: REQ_ATC_TIME_SLOTS_01 |
        no cg: ConflictGroup | #(op.target & cg.resources) > 1
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-01: Each flight receives a dedicated non-overlapping 5-minute slot
pred tc_01_holds {
    some op: REQ_ATC_TIME_SLOTS_01 |
        op.initiator in Air_Traffic_Control_Team &&
        all t: op.target | t.accessible in op.initiator &&
        all c: op.channel | c.authenticated = True &&
        op.pre != op.post
}
run tc_01_holds for 5

assert tc_01_contract {
    all op: REQ_ATC_TIME_SLOTS_01 |
        (op.initiator in Air_Traffic_Control_Team && all c: op.channel | c.authenticated = True) =>
        all t: op.target | t.accessible in op.initiator
}
check tc_01_contract for 5

-- TC-02: Mandatory 3-minute gap between consecutive time slots
pred tc_02_holds {
    some op: REQ_ATC_TIME_SLOTS_01 |
        op.pre = PreIdle &&
        op.post = Post2 &&
        all c: op.channel | c.encrypted = True
}
run tc_02_holds for 5

assert tc_02_contract {
    all op: REQ_ATC_TIME_SLOTS_01 |
        (op.pre = PreIdle && op.post = Post2) =>
        (all c: op.channel | c.encrypted = True)
}
check tc_02_contract for 5

-- TC-03: System performance under peak hour load
pred tc_03_holds {
    some op: REQ_ATC_TIME_SLOTS_01 |
        op.initiator = Flight_Operations_Management &&
        #op.target >= 3 &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.pre = PreIdle &&
        op.post = Post1
}
run tc_03_holds for 5

assert tc_03_contract {
    all op: REQ_ATC_TIME_SLOTS_01 |
        (op.initiator = Flight_Operations_Management && #op.target >= 3) =>
        (all c: op.channel | c.encrypted = True && c.authenticated = True)
}
check tc_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_slots {
  -- PROXY: limiting target resources && channels per operation reduces processing time
  -- NFR: complete slot allocation within 10 seconds per request
  all op: REQ_ATC_TIME_SLOTS_01 | #op.target <= 2 && #op.channel <= 2
}

fact nfr_fact_availability_redundancy {
  -- PROXY: requiring at least two channels ensures redundancy for 99.9% uptime
  -- NFR: 99.9% uptime during peak hours
  all op: REQ_ATC_TIME_SLOTS_01 | #op.channel >= 2
}

assert nfr_assert_scalability_concurrent {
  -- PROXY: any two distinct actors can each initiate a distinct operation (supports concurrency)
  -- NFR: must support up to 10,000 concurrent flight requests
  all a1, a2: Actor | a1 != a2 => some disj op1, op2: REQ_ATC_TIME_SLOTS_01 |
    op1.initiator = a1 && op2.initiator = a2
}
check nfr_assert_scalability_concurrent for 5

fact nfr_fact_usability_channel_limit {
  -- PROXY: limiting the number of channels per operation avoids overwhelming users with options
  -- NFR: error messages must be clear && actionable
  all op: REQ_ATC_TIME_SLOTS_01 | #op.channel <= 3
}

