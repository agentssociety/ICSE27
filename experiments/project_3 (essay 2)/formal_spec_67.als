module REQ_AC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-AC-01
 * Title       : Prioritize Arrivals Over Departures During Slot Allocation
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Controllers, Operations_Management, Flight_Service_Providers extends Actor {}
-- Air_Traffic_Controllers: represents stakeholder 'Air Traffic Controllers'
-- Operations_Management: represents stakeholder 'Operations Management'
-- Flight_Service_Providers: represents stakeholder 'Flight Service Providers'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Request_API, Slot_Allocation_Database extends Interface {}

fact interface_properties {
    Flight_Request_API.kind = API  -- The system will interact with this API to receive real-time flight request data and provide updated slot allocations.
    Slot_Allocation_Database.kind = Database  -- This database will store the current state of slot allocations, arrival/departure requests, and priority information.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where A set of arrival and departure requests for a given time window

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where All arrival slots are placed before any departure slots are adjusted


----------------------------------------------------------------------
-- Core operation: REQ_AC_01
----------------------------------------------------------------------

sig REQ_AC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_AC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_AC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_AC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_AC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_AC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_AC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_AC_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_AC_01 {
    some op: REQ_AC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_AC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_AC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_AC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_AC_01_well_formed {
    all op: REQ_AC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_AC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? Post1: All arrival slots are placed before any departure slots are adjusted ??

pred ps_reach_Post1 {
    some op: REQ_AC_01 |
        op.post = Post1 &&
        -- Meaningful transition: initiator has Admin permission, target includes at least one Resource,
        -- channel requires authentication, && the pre-state is ! Post1.
        Admin in op.initiator.mayPerform &&
        some op.target &&
        some op.channel &&
        True in op.channel.authenticated &&
        op.pre != Post1
}

run ps_reach_Post1 for 5


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ac_reach_1: slot conflict exists between arriving (Flight_Service_Providers) && departing (Operations_Management)
pred ac_reach_1 {
    some op: REQ_AC_01 |
        some r: op.target |
            Flight_Service_Providers in r.accessible &&
            Operations_Management in r.accessible
}
run ac_reach_1 for 5

-- ac_reach_2: slot allocation algorithm runs (initiator is Air_Traffic_Controllers, grant is Write)
pred ac_reach_2 {
    some op: REQ_AC_01 |
        op.initiator = Air_Traffic_Controllers &&
        op.grant = Write
}
run ac_reach_2 for 5

-- ac_reach_3: arriving flight is assigned the conflicting slot (the resource that is accessible to both is owned by arriving flight)
pred ac_reach_3 {
    some op: REQ_AC_01 |
        some r: op.target |
            Flight_Service_Providers in r.accessible &&
            Operations_Management in r.accessible &&
            r.owner = Flight_Service_Providers
}
run ac_reach_3 for 5

-- ac_reach_4: departing flight is assigned an alternative slot (there exists a resource owned by departing flight, && a different conflicting resource)
pred ac_reach_4 {
    some op: REQ_AC_01 |
        some r: Resource |
            r.owner = Operations_Management &&
            (some r2: Resource |
                r != r2 &&
                Flight_Service_Providers in r2.accessible &&
                Operations_Management in r2.accessible)
}
run ac_reach_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: conflicting slots for arrivals/departures
-- Safety: no two operations with conflicting grants (Write/Admin) on same resource
assert ec_safe_1 {
    all op1, op2: REQ_AC_01 |
        (op1 != op2) &&
        (some (op1.target & op2.target)) &&
        (op1.grant in Write + Admin) &&
        (op2.grant in Write + Admin) =>
        op1.initiator = op2.initiator
}
check ec_safe_1 for 5

-- Helper sig for capacity constraint (edge case 2)
one sig Capacity { max: Int }
fact capacity_limit { Capacity.max = 1 }

-- Edge case 2: surge in traffic exceeding capacity
-- Safety: no resource is targeted by more operations than allowed capacity
assert ec_safe_2 {
    all r: Resource |
        #{ op: REQ_AC_01 | r in op.target } <= Capacity.max
}
check ec_safe_2 for 5

-- Edge case 3: delayed flight during slot allocation
-- Safety: an operation cannot grant Write on a resource it does ! own
assert ec_safe_3 {
    no op: REQ_AC_01 |
        op.grant = Write &&
        some r: op.target |
            r.owner != op.initiator
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicate for TC-AC-01: single conflict, arrival prioritized
pred tc_ac01_holds {
    some op: REQ_AC_01 |
        -- Input: single conflict between arriving && departing flight
        one op.target &&                                 -- single resource affected
        some a: Actor | a in Air_Traffic_Controllers &&  -- initiator is ATC
        op.initiator = a &&
        -- Expected output: arriving flight gets slot, departing gets alternative
        op.post != op.pre &&                             -- state changes
        some r: op.target | r.owner = op.initiator       -- resource owned by initiator
}
run tc_ac01_holds for 5

-- Predicate for TC-AC-01 contract (not guaranteed, used for exploration)
pred tc_ac01_contract {
    all op: REQ_AC_01 |
        (one op.target && some op.initiator & Air_Traffic_Controllers) =>
        (op.post != op.pre && some r: op.target | r.owner = op.initiator)
}

-- Predicate for TC-AC-02: multiple conflicts, arrivals prioritized over departures
pred tc_ac02_holds {
    some op: REQ_AC_01 |
        -- Input: multiple conflicts
        #op.target > 1 &&                                -- multiple resources
        some a: Actor | a in Air_Traffic_Controllers &&
        op.initiator = a &&
        -- Expected: all arrivals placed before any departure adjustments
        all r: op.target | r.owner = op.initiator &&     -- all resources owned
        op.post != op.pre
}
run tc_ac02_holds for 5

-- Predicate for TC-AC-02 contract (not guaranteed, used for exploration)
pred tc_ac02_contract {
    all op: REQ_AC_01 |
        (#op.target > 1 && some op.initiator & Air_Traffic_Controllers) =>
        (all r: op.target | r.owner = op.initiator && op.post != op.pre)
}

-- Predicate for TC-AC-03: surge in arrivals exceeding available slots
pred tc_ac03_holds {
    some op: REQ_AC_01 |
        -- Input: arrival surge exceeds capacity
        #op.target > #Capacity &&                        -- more targets than capacity
        some a: Actor | a in Air_Traffic_Controllers &&
        op.initiator = a &&
        -- Expected: dynamic adjustment, arrivals prioritized
        some r: op.target | r.owner = op.initiator &&    -- at least one arrival gets slot
        op.post != op.pre
}
run tc_ac03_holds for 5

-- Predicate for TC-AC-03 contract (not guaranteed, used for exploration)
pred tc_ac03_contract {
    all op: REQ_AC_01 |
        (#op.target > #Capacity && some op.initiator & Air_Traffic_Controllers) =>
        (some r: op.target | r.owner = op.initiator && op.post != op.pre)
}

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_channel_limit {
    -- PROXY: minimizing channel count reduces latency
    -- NFR: response time < 200ms
    all op: REQ_AC_01 | #op.channel <= 2
}

fact nfr_fact_availability_redundancy {
    -- PROXY: at least two interfaces for redundancy to support 99.9% uptime
    -- NFR: availability
    #Interface >= 2
}

-- Predicate for scalability (not guaranteed, used for exploration)
pred nfr_pred_scalability_all_actors {
    -- PROXY: every actor can initiate an operation, showing system can handle all actors
    -- NFR: scalability
    all a: Actor | some op: REQ_AC_01 | op.initiator = a
}

fact nfr_fact_usability_bounded_auth {
    -- PROXY: number of authenticated channels is small to keep interface simple
    -- NFR: usability - clear error handling bounds authentication
    #({i: Interface | i.authenticated = True}) <= 2
}

