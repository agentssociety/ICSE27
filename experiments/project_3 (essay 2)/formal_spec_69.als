module REQ_ATC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-01
 * Title       : Automated Reassignment and Rescheduling on Runway Closure
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Control, Flight_Operations, Passengers extends Actor {}
-- Air_Traffic_Control: represents stakeholder 'Air Traffic Control'
-- Flight_Operations: represents stakeholder 'Flight Operations'
-- Passengers: represents stakeholder 'Passengers'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Scheduling_API, Runway_Status_Database, Air_Traffic_Control_Console extends Interface {}

fact interface_properties {
    Flight_Scheduling_API.kind = API  -- Interface for retrieving and updating flight schedules.
    Runway_Status_Database.kind = Database  -- Data source for runway closure status and alternative runway availability.
    Air_Traffic_Control_Console.kind = UI  -- Interface where air traffic controllers can review and approve reassignments.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where Runway closure has been officially marked in the system

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where All affected flights have either been reassigned to alternative runways or queued/rescheduled with updated times
-- Post2: system reaches state where Air traffic controller can review and approve or override the system's suggestions


----------------------------------------------------------------------
-- Core operation: REQ_ATC_01
----------------------------------------------------------------------

sig REQ_ATC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_01 {
    some op: REQ_ATC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_01_well_formed {
    all op: REQ_ATC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability && semantic verification for Post1
pred ps_reach_Post1 {
    some op: REQ_ATC_01 |
        op.post = Post1 &&
        -- Must involve flight scheduling || runway database (reassignment/rescheduling)
        (some c: op.channel | c.kind = Flight_Scheduling_API) &&
        -- Requires Write permission to modify schedules
        Write in op.initiator.mayPerform &&
        -- Target includes at least the Database (runway status) || API resource
        (Database in op.target || UI in op.target) &&
        -- Initiator is an actor that can affect flights (Air_Traffic_Control || Flight_Operations)
        (op.initiator = Air_Traffic_Control || op.initiator = Flight_Operations)
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ATC_01 |
        op.post = Post1 =>
            -- Operation uses a flight?related channel (scheduling || runway database)
            (some c: op.channel | c.kind = Flight_Scheduling_API) &&
            -- Write permission is used (to update flight data)
            Write in op.initiator.mayPerform &&
            -- At least one resource involved is the Database (runway status) || UI
            (Database in op.target || UI in op.target) &&
            -- Initiator is either air traffic control || flight operations
            (op.initiator = Air_Traffic_Control || op.initiator = Flight_Operations)
}
check ps_valid_Post1 for 5

-- Reachability && semantic verification for Post2
pred ps_reach_Post2 {
    some op: REQ_ATC_01 |
        op.post = Post2 &&
        -- Must involve the air traffic control console (review/approve)
        (some c: op.channel | c.kind = Air_Traffic_Control_Console) &&
        -- Requires Read permission (review) || possibly Execute/Admin for override
        (Read in op.initiator.mayPerform || Admin in op.initiator.mayPerform) &&
        -- Target includes UI (for display/approval) || API (for system suggestions)
        (UI in op.target || API in op.target) &&
        -- Initiator is the air traffic controller
        op.initiator = Air_Traffic_Control
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_ATC_01 |
        op.post = Post2 =>
            -- Channel is the air traffic control console
            (some c: op.channel | c.kind = Air_Traffic_Control_Console) &&
            -- Permission is Read (to review) &&/|| Admin (to override)
            (Read in op.initiator.mayPerform || Admin in op.initiator.mayPerform) &&
            -- Target includes UI || API (for displaying suggestions)
            (UI in op.target || API in op.target) &&
            -- Initiator is the air traffic controller
            op.initiator = Air_Traffic_Control
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Liveness predicates for REQ_ATC_01 acceptance criteria

pred ac_reach_1 {
  some op: REQ_ATC_01 |
    op.initiator = Air_Traffic_Control &&
    Runway_Status_Database in op.target &&
    Flight_Scheduling_API in op.target &&
    Admin in op.initiator.mayPerform &&
    (some c: op.channel | c.authenticated = True) &&
    op.pre = Pre1 &&
    op.post = Post1
}

run ac_reach_1 for 5

pred ac_reach_2 {
  some op: REQ_ATC_01 |
    op.initiator = Air_Traffic_Control &&
    Flight_Scheduling_API in op.target &&
    Database in op.target &&                -- alternative runway resource
    Write in op.initiator.mayPerform &&
    (some c: op.channel | c.authenticated = True) &&
    op.pre = Post1 &&
    op.post = Post2
}

run ac_reach_2 for 5

pred ac_reach_3 {
  some op: REQ_ATC_01 |
    op.initiator = Air_Traffic_Control &&
    Flight_Scheduling_API in op.target &&
    Runway_Status_Database in op.target &&  -- no alternative resource present
    Execute in op.initiator.mayPerform &&
    (some c: op.channel | c.authenticated = True) &&
    op.pre = Post2 &&
    op.post = Post2
}

run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: What happens if all alternative runways are also closed?
-- Safety invariant: If all resources that are an alternative to the target are also inaccessible,
-- the operation must ! proceed to a post-state where the target is modified.
assert ec_safe_1 {
    all op: REQ_ATC_01 |
        -- If there exists no accessible resource that could serve as alternative
        (no r: Resource | r != op.target && r in op.initiator.accessible) =>
            -- Then the operation must ! change the target's state
            (op.post = op.pre)
}
check ec_safe_1 for 5

-- Edge case 2: How does the system handle flights that cannot be reassigned due to operational constraints?
-- Safety invariant: If the initiator cannot reassign flights (no write permission || no accessible alternative resources),
-- the operation must ! result in a state where flights are left unassigned (represented by target resource being modified)
assert ec_safe_2 {
    all op: REQ_ATC_01 |
        -- If initiator lacks write permission || no alternative resources exist
        (Write !in op.initiator.mayPerform || no r: Resource | r != op.target && r in op.initiator.accessible) =>
            -- Then the operation must ! modify the target resource
            (op.post = op.pre)
}
check ec_safe_2 for 5

-- Edge case 3: What actions should the system take if there is a sudden change in runway status?
-- Safety invariant: The operation must only proceed if all channels used are authenticated
-- && the initiator has the required permission, ensuring no unauthorized changes occur during status updates
assert ec_safe_3 {
    all op: REQ_ATC_01 |
        -- If any channel is ! authenticated
        (some c: op.channel | c.authenticated = False) =>
            -- Then the operation must ! change state (no actions taken on unauthenticated channels)
            (op.post = op.pre)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? Scenario TC-01: Identify flights scheduled on a closed runway ??
-- Input: Air_Traffic_Control initiator, Database target (Runway_Status_Database),
--         Flight_Scheduling_API channel, Read permission
-- Expected: post-state includes a new Database resource (Runway_Status_Database)
--           that reflects the closed status; pre-state does ! have this.

pred tc_01_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control &&
        Runway_Status_Database in op.target &&
        Flight_Scheduling_API in op.channel.kind &&
        op.grant = Read &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_01_holds for 5

assert tc_01_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control &&
         Runway_Status_Database in op.target &&
         Flight_Scheduling_API in op.channel.kind &&
         op.grant = Read &&
         op.pre = Pre1) =>
        (op.post = Post1 && op.post != op.pre)
}
check tc_01_contract for 5

-- ?? Scenario TC-02: Suggest reassignments to alternative runways ??
-- Input: Air_Traffic_Control initiator, Flight_Operations resource,
--         UI channel, Admin permission
-- Expected: post-state shows reassignment suggestions (represented by
--           Post2 state) && the channel is encrypted && authenticated.

pred tc_02_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control &&
        Flight_Operations in op.target &&
        UI in op.channel.kind &&
        op.grant = Admin &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post2
}
run tc_02_holds for 5

assert tc_02_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control &&
         Flight_Operations in op.target &&
         UI in op.channel.kind &&
         op.grant = Admin &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
        (op.post = Post2 && op.post != op.pre)
}
check tc_02_contract for 5

-- ?? Scenario TC-03: Queue && reschedule flights when no alternatives ??
-- Input: Air_Traffic_Control initiator, Passengers resource,
--         API channel, Read permission
-- Expected: post-state represents queued/rescheduled flights (Post2);
--           channel is authenticated.

pred tc_03_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control &&
        Passengers in op.target &&
        API in op.channel.kind &&
        op.grant = Read &&
        all c: op.channel | c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post2
}
run tc_03_holds for 5

assert tc_03_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control &&
         Passengers in op.target &&
         API in op.channel.kind &&
         op.grant = Read &&
         all c: op.channel | c.authenticated = True &&
         op.pre = Pre1) =>
        (op.post = Post2 && op.post != op.pre)
}
check tc_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance NFR: Response time within 30 seconds ? proxy by limiting the number of resources && channels per operation to bound processing complexity.
fact nfr_fact_performance {
    all op: REQ_ATC_01 |
        #op.target <= 3 && #op.channel <= 2
}

-- Availability NFR: 99.9% uptime during runway closures ? proxy by requiring at least two channels per operation to enable failover.
fact nfr_fact_availability {
    all op: REQ_ATC_01 |
        #op.channel >= 2
}

-- Scalability NFR: System handles up to 1,000 flights simultaneously ? proxy by ensuring every actor can be the initiator of some operation, demonstrating per-actor capacity.
fact nfr_fact_scalability {
    all a: Actor |
        some op: REQ_ATC_01 | op.initiator = a
}

-- Usability NFR: Error messages should be clear && actionable ? proxy by requiring all channels to be authenticated, so errors are traceable to known identities.
assert nfr_assert_usability {
    all op: REQ_ATC_01 |
        all c: op.channel | c.authenticated = True
}
check nfr_assert_usability for 5

