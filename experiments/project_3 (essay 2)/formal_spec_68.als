module REQ_SYS_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-SYS-01
 * Title       : Automated Detection of Overlapping Assignments and Scheduling Violations
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Flight_Operations_Team, Safety_Compliance_Department extends Actor {}
-- Flight_Operations_Team: represents stakeholder 'Flight Operations Team'
-- Safety_Compliance_Department: represents stakeholder 'Safety Compliance Department'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Data_API, Scheduling_Database, Alert_UI extends Interface {}

fact interface_properties {
    Flight_Data_API.kind = API  -- Interface for receiving real-time flight assignment data from the flight management system.
    Scheduling_Database.kind = Database  -- Interface for accessing and updating the database of scheduled flight assignments.
    Alert_UI.kind = UI  -- Interface for displaying visual and auditory alerts to the system monitor.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system must be operational and running in real-time mode.
-- Pre2: system is in state where Flight assignments and time slots must be inputted into the system.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Alerts must be triggered for any detected overlapping assignments or scheduling violations.
-- Post2: system reaches state where A visual/notification indicator must be displayed to indicate a scheduling violation.


----------------------------------------------------------------------
-- Core operation: REQ_SYS_01
----------------------------------------------------------------------

sig REQ_SYS_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_SYS_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_SYS_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_SYS_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_SYS_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_SYS_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_SYS_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_SYS_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SYS_01 {
    some op: REQ_SYS_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SYS_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_SYS_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_SYS_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_SYS_01_well_formed {
    all op: REQ_SYS_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SYS_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post-state reachability && semantic verification for Post1 && Post2

pred ps_reach_Post1 {
    some op: REQ_SYS_01 |
        op.post = Post1 &&
        -- Must involve scheduling-related resources && permissions
        (Scheduling_Database in op.target || Alert_UI in op.target) &&
        -- Must have Read || Write permission on scheduling data
        (Read in op.initiator.mayPerform || Write in op.initiator.mayPerform) &&
        -- Initiator must be from a team that handles scheduling
        (op.initiator in Flight_Operations_Team || op.initiator in Safety_Compliance_Department) &&
        -- State must actually change
        op.pre != op.post
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_SYS_01 |
        (op.post = Post1) =>
            (some r: Resource | r in op.target && 
                (r = Scheduling_Database || r = Alert_UI) &&
                -- Alerts triggered means at least one channel communicates the alert
                some c: Interface | c in op.channel &&
                -- The operation must involve scheduling violation detection
                (Read in op.initiator.mayPerform || Write in op.initiator.mayPerform) &&
                -- Only authorized personnel can trigger alerts
                (op.initiator in Flight_Operations_Team || op.initiator in Safety_Compliance_Department))
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_SYS_01 |
        op.post = Post2 &&
        -- Must involve UI/visual notification resources
        (Alert_UI in op.target || UI in op.target) &&
        -- Must have permission to display notifications
        (Read in op.initiator.mayPerform || Write in op.initiator.mayPerform) &&
        -- Initiator must be from a team that manages scheduling
        (op.initiator in Flight_Operations_Team || op.initiator in Safety_Compliance_Department) &&
        -- State must actually change from previous state
        op.pre != op.post &&
        -- Notification display typically uses authenticated channels
        some c: Interface | c in op.channel && c.authenticated = True
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_SYS_01 |
        (op.post = Post2) =>
            (some r: Resource | r in op.target && 
                (r = Alert_UI || r = UI) &&
                -- Visual/notification indicator requires UI-related resources
                (Read in op.initiator.mayPerform || Write in op.initiator.mayPerform) &&
                -- Only authorized teams can display scheduling violations
                (op.initiator in Flight_Operations_Team || op.initiator in Safety_Compliance_Department) &&
                -- Must use authenticated channel for notification display
                some c: Interface | c in op.channel && c.authenticated = True)
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Reachability predicate for Criterion 1: Two flights overlap -> alerts triggered
pred ac_reach_1 {
    some op: REQ_SYS_01 |
        op.initiator = Flight_Operations_Team
        && op.grant = Read
        && #op.target >= 2
        && (some c: op.channel | c.kind = Alert_UI)
        && op.post = Post1
}
run ac_reach_1 for 5

-- Reachability predicate for Criterion 2: Gap < 3 min -> alerts triggered
pred ac_reach_2 {
    some op: REQ_SYS_01 |
        op.initiator = Flight_Operations_Team
        && op.grant = Read
        && Scheduling_Database in op.target
        && op.pre = Pre2
        && (some c: op.channel | c.kind = Alert_UI)
        && op.post = Post1
}
run ac_reach_2 for 5

-- Reachability predicate for Criterion 3: Violation detected -> visual/notification indicator shown
pred ac_reach_3 {
    some op: REQ_SYS_01 |
        op.initiator = Safety_Compliance_Department
        && op.grant = Write
        && Database in op.target
        && (some c: op.channel | c.kind = Alert_UI)
        && op.post = Post2
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Two flights with zero-minute gaps between their end && start times.
-- Safety: If two operations share the same target && same pre-state, they must agree on the post-state.
assert ec_safe_1 {
    all disj op1, op2: REQ_SYS_01 |
        (op1.target = op2.target && op1.pre = op2.pre) => op1.post = op2.post
}
check ec_safe_1 for 5

-- Edge case 2: Overlapping assignments that occur at the exact minute boundary.
-- Safety: No two operations may overlap on both target && channel (i.e., no concurrent use of same resource via same channel).
assert ec_safe_2 {
    no disj op1, op2: REQ_SYS_01 |
        (op1.target & op2.target != none) && (op1.channel & op2.channel != none)
}
check ec_safe_2 for 5

-- Edge case 3: Scheduling violations during a time zone change.
-- Safety: All channels used by any operation must be authenticated.
assert ec_safe_3 {
    all op: REQ_SYS_01 |
        all c: op.channel | c.authenticated = True
}
check ec_safe_3 for 5

-- Edge case 4: System performance under heavy load due to numerous simultaneous flight assignments.
-- Safety: No resource may be the target of more than three operations.
assert ec_safe_4 {
    all r: Resource | #{op: REQ_SYS_01 | r in op.target} <= 3
}
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-01: Two flights overlapping ? alert (modelled as two operations sharing a target)
pred tc_01_holds {
    some disj op1, op2: REQ_SYS_01 |
        op1.target & op2.target != none &&
        Alert_UI in op1.channel &&
        Alert_UI in op2.channel &&
        op1.post != op1.pre &&
        op2.post != op2.pre
}
run tc_01_holds for 5

assert tc_01_contract {
    all disj op1, op2: REQ_SYS_01 |
        (op1.target & op2.target != none) =>
            (Alert_UI in op1.channel && Alert_UI in op2.channel)
}
check tc_01_contract for 5

-- TC-02: Gap <3 min between slots ? alert (modelled via distinct pre?states)
pred tc_02_holds {
    some disj op1, op2: REQ_SYS_01 |
        op1.pre = Pre1 &&
        op2.pre = Pre2 &&
        Alert_UI in op1.channel &&
        Alert_UI in op2.channel &&
        op1.post != op1.pre &&
        op2.post != op2.pre
}
run tc_02_holds for 5

assert tc_02_contract {
    all disj op1, op2: REQ_SYS_01 |
        (op1.pre = Pre1 && op2.pre = Pre2) =>
            (Alert_UI in op1.channel && Alert_UI in op2.channel)
}
check tc_02_contract for 5

-- TC-03: Heavy load (many simultaneous assignments) ? system handles without data loss
pred tc_03_holds {
    // For bound 5, show that all 5 operation instances are feasible
    #REQ_SYS_01 = 5 &&
    all op: REQ_SYS_01 |
        op.post != op.pre
}
run tc_03_holds for 5

assert tc_03_contract {
    // Under any set of operations, every operation changes state (representing data integrity)
    all op: REQ_SYS_01 |
        op.post != op.pre
}
check tc_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy for performance: limit number of channels per operation to reduce latency
fact nfr_fact_performance {
    all op: REQ_SYS_01 | #op.channel <= 2
}

-- Proxy for availability: require at least two channels per operation for redundancy
fact nfr_fact_availability {
    all op: REQ_SYS_01 | #op.channel >= 2
}

-- Proxy for scalability: ensure no channel is shared between operations to avoid contention
fact nfr_fact_scalability {
    all disj op1, op2: REQ_SYS_01 | no op1.channel & op2.channel
}

-- Proxy for usability: all channels in an operation must have the same interface kind for consistency
fact nfr_fact_usability {
    all op: REQ_SYS_01 | one op.channel.kind
}

-- Additional assertion to verify all NFR proxies hold for all instances up to 5 atoms
assert nfr_assert_all_proxies_hold {
    all op: REQ_SYS_01 |
        #op.channel <= 2 &&
        #op.channel >= 2 &&
        all disj op1, op2: REQ_SYS_01 | no op1.channel & op2.channel &&
        one op.channel.kind
}
check nfr_assert_all_proxies_hold for 5

