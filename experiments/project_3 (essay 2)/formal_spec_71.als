assert no_unauthorized_execution {
    all op: REQ_ATC_TIMETABLE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

assert no_unauthorized_resource_access {
    all op: REQ_ATC_TIMETABLE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

assert REQ_ATC_TIMETABLE_01_well_formed {
    all op: REQ_ATC_TIMETABLE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_TIMETABLE_01_well_formed for 5


