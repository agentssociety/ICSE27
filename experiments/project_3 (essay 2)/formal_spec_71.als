        (some r: op.target | r in FlightData) &&
        op.initiator in op.target.accessible &&
        op.pre = Pre1 && op.post = Post2
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_ATC_TIMETABLE_01 |
        Execute in op.initiator.mayPerform &&
        op.grant = Execute &&
        (some r: op.target | r in RunwaySlotData) &&
        (some r: op.target | r in FlightData) &&
        op.initiator in op.target.accessible &&
        op.pre = Pre1 && op.post = Post3
}
run ac_reach_3 for 5

pred ac_reach_4 {
    some op: REQ_ATC_TIMETABLE_01 |
        Read in op.initiator.mayPerform && Execute in op.initiator.mayPerform &&
        op.grant = Read &&
        (some r: op.target | r in RunwaySlotData) &&
        op.initiator in op.target.accessible &&
        op.pre = Pre1 && op.post = Post4
}
run ac_reach_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
    all op: REQ_ATC_TIMETABLE_01 |
        (no RunwaySlotData) =>
            (op.post != Post4)
}
check ec_safe_1 for 5

assert ec_safe_2 {
    all op: REQ_ATC_TIMETABLE_01 |
        (Air_Traffic_Controllers in op.initiator) =>
            (some ch: op.channel | ch.authenticated = True)
}
check ec_safe_2 for 5

assert ec_safe_3 {
    all op: REQ_ATC_TIMETABLE_01 |
        (some r: op.target | no r.owner) =>
            (op.post != Post4)
}
check ec_safe_3 for 5

assert ec_safe_4 {
    all op: REQ_ATC_TIMETABLE_01 |
        (no op.target) =>
            (op.post = op.pre)
}
check ec_safe_4 for 5

