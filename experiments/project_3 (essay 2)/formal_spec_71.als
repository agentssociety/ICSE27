        op.initiator in (Air_Traffic_Controllers + Operations_Management) &&
        op.channel.authenticated = True &&
        op.pre != op.post
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ATC_TIMETABLE_01 |
