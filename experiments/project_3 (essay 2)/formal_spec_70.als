module REQ_ATC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-01
 * Title       : Assign Emergency Flight Priority Slot
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Control_Operations, Flight_Dispatch, Safety_Management extends Actor {}
-- Air_Traffic_Control_Operations: represents stakeholder 'Air Traffic Control Operations'
-- Flight_Dispatch: represents stakeholder 'Flight Dispatch'
-- Safety_Management: represents stakeholder 'Safety Management'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource types for flights and slots
sig Flight extends Resource {}
sig Slot extends Resource {}

fact some_flights_and_slots {
    some Flight
    some Slot
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Emergency_Declaration_API, Flight_Management_Database extends Interface {}

fact interface_properties {
    Emergency_Declaration_API.kind = API  -- Used by the air traffic controller to mark a flight as an emergency.
    Flight_Management_Database.kind = Database  -- Stores flight information and slot assignments.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where A flight is identified in the system with a valid identifier.
-- Pre2: system is in state where The air traffic controller has the necessary permissions to mark a flight as an emergency.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The emergency flight has been assigned a priority slot.
-- Post2: system reaches state where Other scheduled flights have been adjusted to accommodate the emergency flight.


----------------------------------------------------------------------
-- Core operation: REQ_ATC_01
----------------------------------------------------------------------

sig REQ_ATC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_01 {
    some op: REQ_ATC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_01_well_formed {
    all op: REQ_ATC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ps_reach_Post1: Post1 reachable via assignment of priority slot
pred ps_reach_Post1 {
    some op: REQ_ATC_01 |
        op.post = Post1 &&
        op.grant = Write &&
        Admin in op.initiator.mayPerform &&
        some r: Resource | r in op.target &&
        op.pre != Post1
}
run ps_reach_Post1 for 5

-- ps_valid_Post1: Whenever Post1 is reached, the emergency flight has a priority slot
assert ps_valid_Post1 {
    all op: REQ_ATC_01 |
        (op.post = Post1) =>
            (op.grant = Write &&
             Admin in op.initiator.mayPerform &&
             some r: Resource | r in op.target &&
             op.pre != Post1)
}
check ps_valid_Post1 for 5

-- ps_reach_Post2: Post2 reachable via adjustment of scheduled flights
pred ps_reach_Post2 {
    some op: REQ_ATC_01 |
        op.post = Post2 &&
        op.grant = Execute &&
        Write in op.initiator.mayPerform &&
        some r: Resource | r in op.target &&
        op.pre != Post2
}
run ps_reach_Post2 for 5

-- ps_valid_Post2: Whenever Post2 is reached, other scheduled flights are adjusted
assert ps_valid_Post2 {
    all op: REQ_ATC_01 |
        (op.post = Post2) =>
            (op.grant = Execute &&
             Write in op.initiator.mayPerform &&
             some r: Resource | r in op.target &&
             op.pre != Post2)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: The system assigns an immediate priority slot to a flight marked as an emergency.
pred ac_reach_1 {
    some op: REQ_ATC_01 |
        -- Emergency declaration involves the Emergency_Declaration_API
        Emergency_Declaration_API in op.channel &&
        -- The operation requires Admin permission (emergency handling)
        Admin in op.initiator.mayPerform &&
        -- The operation affects a Flight resource
        some t: op.target | t in Flight &&
        -- State transitions to Post1 (emergency slot assigned)
        op.post = Post1 &&
        -- Channel must be authenticated for emergency operations
        (some c: op.channel | c.authenticated = True)
}
run ac_reach_1 for 5

-- Criterion 2: Other scheduled slots are automatically adjusted to accommodate the emergency flight.
pred ac_reach_2 {
    some op: REQ_ATC_01 |
        -- Requires Admin permission for slot adjustment
        Admin in op.initiator.mayPerform &&
        -- Affects Slot resources (scheduling)
        some t: op.target | t in Slot &&
        -- State transitions to Post2 (slots adjusted)
        op.post = Post2 &&
        -- Uses encrypted channel for sensitive scheduling data
        (some c: op.channel | c.encrypted = True) &&
        -- The operation modifies scheduling data (Write permission)
        Write in op.initiator.mayPerform
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Already in emergency state ? must remain in emergency
one sig EmergencyStateMarker {
    states: set State
}
fact emergency_states_exist { some EmergencyStateMarker.states }

assert ec_safe_1 {
    all op: REQ_ATC_01 |
        (Emergency_Declaration_API in op.channel && op.pre in EmergencyStateMarker.states) =>
            op.post in EmergencyStateMarker.states
}
check ec_safe_1 for 5

-- Edge case 2: Simultaneous declarations ? no conflicting grants on same resource
assert ec_safe_2 {
    all disj op1, op2: REQ_ATC_01 |
        no (op1.target & op2.target) || op1.grant = op2.grant
}
check ec_safe_2 for 5

-- Edge case 3: Emergency slot must ! affect critical resources
one sig CriticalFlight {
    resources: set Resource
}
fact critical_resources_exist { some CriticalFlight.resources }

assert ec_safe_3 {
    all op: REQ_ATC_01 |
        Emergency_Declaration_API in op.channel =>
            no (op.target & CriticalFlight.resources)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-ATC-01: Marking a flight as an emergency when no other flights are scheduled.
pred tc_atc_01_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Operations &&
        op.grant = Execute &&  -- Execute permission relevant for emergency action
        some f: Flight | f in op.target &&
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        op.pre = Pre1 &&   -- Pre1: state with no emergency flights
        op.post = Post1    -- Post1: state with highest priority slot assigned
}
run tc_atc_01_holds for 5

assert tc_atc_01_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control_Operations &&
         some f: Flight | f in op.target &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_atc_01_contract for 5

-- Scenario TC-ATC-02: Handling multiple simultaneous emergency declarations.
pred tc_atc_02_holds {
    some disj op1, op2: REQ_ATC_01 |
        op1.initiator = Air_Traffic_Control_Operations &&
        op2.initiator = Air_Traffic_Control_Operations &&
        op1.grant = Execute && op2.grant = Execute &&
        some f1: Flight | f1 in op1.target &&
        some f2: Flight | f2 in op2.target &&
        all c: op1.channel | c.authenticated = True && c.encrypted = True &&
        all c: op2.channel | c.authenticated = True && c.encrypted = True &&
        op1.pre = Pre1 && op2.pre = Pre1 &&
        op1.post = Post1 && op2.post = Post1
}
run tc_atc_02_holds for 5

assert tc_atc_02_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Control_Operations &&
         some f: Flight | f in op.target &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_atc_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limit channels per operation to reduce latency (response time < 200ms)
fact nfr_fact_performance_latency {
    all op: REQ_ATC_01 | #op.channel <= 2
}

-- Availability proxy: require at least 2 channels per operation for redundancy (99.9% uptime)
fact nfr_fact_availability_redundancy {
    all op: REQ_ATC_01 | #op.channel >= 2
}

-- Scalability proxy: require at least 3 simultaneous emergency operations (support up to N flights)
fact nfr_fact_scalability {
    #REQ_ATC_01 >= 3
}

-- Usability proxy: limit target resources per operation to one (clear feedback for invalid IDs)
fact nfr_fact_usability_simplicity {
    all op: REQ_ATC_01 | #op.target <= 1
}

