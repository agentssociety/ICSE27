module REQ_ATC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-01
 * Title       : Register Incoming Flights
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Controller, System_Administrator extends Actor {}
-- Air_Traffic_Controller: represents stakeholder 'Air Traffic Controller'
-- System_Administrator: represents stakeholder 'System Administrator'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Aircraft_Movement_Log_Database, Flight_Registration_API extends Interface {}

fact interface_properties {
    Aircraft_Movement_Log_Database.kind = Database  -- The requirement interacts with this database to store and retrieve flight details.
    Flight_Registration_API.kind = API  -- The requirement utilizes this API to accept incoming flight registrations from the air traffic controller.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The system is ready to accept flight registrations

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The incoming flight has been stored in the system
-- Post2: system reaches state where The flight details (flight number, type, scheduled time) are accurately recorded
-- Post3: system reaches state where The aircraft movement log is updated with the new flight registration


----------------------------------------------------------------------
-- Core operation: REQ_ATC_01
----------------------------------------------------------------------

sig REQ_ATC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_01 {
    some op: REQ_ATC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_01_well_formed {
    all op: REQ_ATC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1 reachability: storage action (Write permission, target includes Database || Flight_Registration_API)
pred ps_reach_Post1 {
	some op: REQ_ATC_01 |
		op.post = Post1 &&
		Write in op.initiator.mayPerform &&
		(Database in op.target || Flight_Registration_API in op.target)
}
run ps_reach_Post1 for 5

-- Post1 semantic verification
assert ps_valid_Post1 {
	all op: REQ_ATC_01 |
		(op.post = Post1) =>
			(Write in op.initiator.mayPerform &&
			 (Database in op.target || Flight_Registration_API in op.target))
}
check ps_valid_Post1 for 5

-- Post2 reachability: accurate recording of flight details (Admin permission, target includes Flight_Registration_API)
pred ps_reach_Post2 {
	some op: REQ_ATC_01 |
		op.post = Post2 &&
		Admin in op.initiator.mayPerform &&
		Flight_Registration_API in op.target
}
run ps_reach_Post2 for 5

-- Post2 semantic verification
assert ps_valid_Post2 {
	all op: REQ_ATC_01 |
		(op.post = Post2) =>
			(Admin in op.initiator.mayPerform &&
			 Flight_Registration_API in op.target)
}
check ps_valid_Post2 for 5

-- Post3 reachability: aircraft movement log update (Write permission, target includes Aircraft_Movement_Log_Database)
pred ps_reach_Post3 {
	some op: REQ_ATC_01 |
		op.post = Post3 &&
		Write in op.initiator.mayPerform &&
		Aircraft_Movement_Log_Database in op.target
}
run ps_reach_Post3 for 5

-- Post3 semantic verification
assert ps_valid_Post3 {
	all op: REQ_ATC_01 |
		(op.post = Post3) =>
			(Write in op.initiator.mayPerform &&
			 Aircraft_Movement_Log_Database in op.target)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES for REQ_ATC_01 ??????????????????????????????

-- Criterion 1: The system records the incoming flight with flight number 'AA123',
-- type 'Boeing 737', && scheduled time '14:30'
-- This is represented by a state transition where the operation uses the
-- Flight_Registration_API && writes to the Aircraft_Movement_Log_Database
pred ac_reach_1 {
    some op: REQ_ATC_01 |
        -- The operation uses the Flight Registration API
        (some c: op.channel | c.kind = Flight_Registration_API) &&
        -- The operation targets the Aircraft Movement Log Database
        (Aircraft_Movement_Log_Database in op.target) &&
        -- The operation requires Write permission (recording data)
        (Write in op.initiator.mayPerform) &&
        -- The operation is performed by an Air Traffic Controller
        (op.initiator = Air_Traffic_Controller) &&
        -- The operation transitions from Pre1 to Post1 (recording state)
        (op.pre = Pre1 && op.post = Post1)
}

run ac_reach_1 for 5

-- Criterion 2: The flight appears in the aircraft movement log after registration
-- This means the operation results in the flight data being stored in the database
pred ac_reach_2 {
    some op: REQ_ATC_01 |
        -- The operation targets the Aircraft Movement Log Database
        (Aircraft_Movement_Log_Database in op.target) &&
        -- The operation uses the Flight Registration API
        (some c: op.channel | c.kind = Flight_Registration_API) &&
        -- The operation requires Write permission (to log the flight)
        (Write in op.initiator.mayPerform) &&
        -- The operation is performed by an Air Traffic Controller
        (op.initiator = Air_Traffic_Controller) &&
        -- The operation transitions to Post2 (logged state)
        (op.post = Post2) &&
        -- The channel must be authenticated (secure logging)
        (some c: op.channel | c.authenticated = True)
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: flight number already exists (interpreted as no two ops should target same resource with same grant)
assert ec_safe_1 {
    all op: REQ_ATC_01 |
        all op2: REQ_ATC_01 - op |
            (op.target & op2.target != none) => (op.grant != op2.grant)
}
check ec_safe_1 for 5

-- Edge case 2: empty/null input (interpreted as requiring at least one channel to be both encrypted && authenticated)
assert ec_safe_2 {
    all op: REQ_ATC_01 |
        some ch: op.channel | ch.encrypted = True && ch.authenticated = True
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicate for TC-ATC-01: Valid registration
pred tc_ATC_01_1_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Controller &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        Aircraft_Movement_Log_Database in op.target &&
        Flight_Registration_API in op.target &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_ATC_01_1_holds for 5

-- Contract for TC-ATC-01: Valid registration always leads to success
assert tc_ATC_01_1_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Controller &&
         Write in op.initiator.mayPerform &&
         op.grant = Write &&
         Aircraft_Movement_Log_Database in op.target &&
         Flight_Registration_API in op.target &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
        op.post = Post1
}
check tc_ATC_01_1_contract for 5

-- Predicate for TC-ATC-02: Empty flight number (failure)
pred tc_ATC_01_2_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Controller &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        Flight_Registration_API in op.target &&
        Aircraft_Movement_Log_Database ! in op.target &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post2
}
run tc_ATC_01_2_holds for 5

-- Contract for TC-ATC-02: Empty flight number always results in failure
assert tc_ATC_01_2_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Controller &&
         Write in op.initiator.mayPerform &&
         op.grant = Write &&
         Flight_Registration_API in op.target &&
         Aircraft_Movement_Log_Database ! in op.target &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
        op.post = Post2
}
check tc_ATC_01_2_contract for 5

-- Predicate for TC-ATC-03: Multiple successful registrations
pred tc_ATC_01_3_holds {
    some disj op1, op2: REQ_ATC_01 |
        op1.initiator = Air_Traffic_Controller &&
        Write in op1.initiator.mayPerform &&
        op1.grant = Write &&
        Aircraft_Movement_Log_Database in op1.target &&
        Flight_Registration_API in op1.target &&
        all c: op1.channel | c.encrypted = True && c.authenticated = True &&
        op1.pre = Pre1 &&
        op1.post = Post1 &&
        op2.initiator = Air_Traffic_Controller &&
        Write in op2.initiator.mayPerform &&
        op2.grant = Write &&
        Aircraft_Movement_Log_Database in op2.target &&
        Flight_Registration_API in op2.target &&
        all c: op2.channel | c.encrypted = True && c.authenticated = True &&
        op2.pre = Pre1 &&
        op2.post = Post1
}
run tc_ATC_01_3_holds for 5

-- Contract for TC-ATC-03: Multiple valid registrations all succeed
assert tc_ATC_01_3_contract {
    all op: REQ_ATC_01 |
        (op.initiator = Air_Traffic_Controller &&
         Write in op.initiator.mayPerform &&
         op.grant = Write &&
         Aircraft_Movement_Log_Database in op.target &&
         Flight_Registration_API in op.target &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
        op.post = Post1
}
check tc_ATC_01_3_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_robust_error_handling {
    -- PROXY: ensuring at least one channel is authenticated && encrypted provides clear feedback capability
    -- NFR: Error handling must be robust && interface should provide clear feedback for successful || failed registrations
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True && c.encrypted = True
}

fact nfr_fact_clear_feedback {
    -- PROXY: limiting the number of channels per operation ensures focused, clear communication paths
    -- NFR: Interface should provide clear feedback for successful || failed registrations
    all op: REQ_ATC_01 | #op.channel <= 2
}

assert nfr_assert_feedback_available {
    -- PROXY: every operation must have at least one authenticated channel for reliable feedback delivery
    -- NFR: Error handling must be robust && interface should provide clear feedback
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True
}
check nfr_assert_feedback_available for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Authentication: all channels must be authenticated
assert sr_assert_authentication {
    all op: REQ_ATC_01 | all c: op.channel | c.authenticated = True
}
check sr_assert_authentication for 5

-- Authorization: initiator must have the granted permission
assert sr_assert_authorization {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}
check sr_assert_authorization for 5

-- Confidentiality: initiator must be in accessible set of each target resource
assert sr_assert_confidentiality {
    all op: REQ_ATC_01 | all r: op.target | op.initiator in r.accessible
}
check sr_assert_confidentiality for 5

-- Integrity: only owner || admin may write
assert sr_assert_integrity {
    all op: REQ_ATC_01 |
        (Write in op.initiator.mayPerform) =>
        (op.initiator = op.target.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_integrity for 5

-- Non-repudiation: every operation has exactly one initiator
assert sr_assert_non_repudiation {
    all op: REQ_ATC_01 | one op.initiator
}
check sr_assert_non_repudiation for 5

-- Encryption-in-transit: all channels must be encrypted
assert sr_assert_encryption {
    all op: REQ_ATC_01 | all c: op.channel | c.encrypted = True
}
check sr_assert_encryption for 5

-- Privilege separation: no initiator who can write is also owner without admin
assert sr_assert_privilege_separation {
    all op: REQ_ATC_01 |
        (Write in op.initiator.mayPerform) =>
        (no r: op.target | r.owner = op.initiator && Admin !in op.initiator.mayPerform)
}
check sr_assert_privilege_separation for 5


