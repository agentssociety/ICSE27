module REQ_ATC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-01
 * Title       : Prevent Overlapping Flight Assignments
 * Type        : Functional
 * Priority    : Critical
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Controllers, Flight_Operations_Management, Safety_Compliance_Department extends Actor {}
-- Air_Traffic_Controllers: represents stakeholder 'Air Traffic Controllers'
-- Flight_Operations_Management: represents stakeholder 'Flight Operations Management'
-- Safety_Compliance_Department: represents stakeholder 'Safety Compliance Department'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Resources specific to the flight assignment domain
one sig FlightAssignmentAPIResource extends Resource {}
one sig FlightAssignmentDBResource extends Resource {}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Assignment_API, Flight_Assignment_Database extends Interface {}

fact interface_properties {
    Flight_Assignment_API.kind = API  -- The system will use this API to receive flight assignments and check for overlaps.
    Flight_Assignment_Database.kind = Database  -- The system will interact with this database to store and retrieve existing flight assignments.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The system monitors all flight assignments for slot and runway usage.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The system should reject the assignment.
-- Post2: system reaches state where The air traffic controller of the conflict should be notified.


----------------------------------------------------------------------
-- Core operation: REQ_ATC_01
----------------------------------------------------------------------

sig REQ_ATC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_01 {
    some op: REQ_ATC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_01_well_formed {
    all op: REQ_ATC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Predicate: Reachability of Post1 (reject assignment)
pred ps_reach_Post1 {
    some op: REQ_ATC_01 |
        op.post = Post1 &&
        -- initiator from Safety_Compliance_Department can reject an assignment
        op.initiator in Safety_Compliance_Department &&
        -- grant is Execute (acting on assignment data)
        Execute in op.grant &&
        -- target includes the flight assignment database (where assignment data resides)
        FlightAssignmentDBResource in op.target &&
        -- at least one channel is authenticated (required by inv_authenticated_channel_required)
        some ch: op.channel | ch.authenticated = True &&
        -- state must change: pre != post (already enforced by fact, but explicit here)
        op.pre != Post1 &&
        -- ensure the operation is meaningful: resource access control holds (fact ensures this)
        -- optionally require distinct resources (! necessary but adds specificity)
        #op.target = 1 -- only one resource involved in rejection
}

run ps_reach_Post1 for 5

-- Assertion: When Post1 is reached, the system rejects the assignment (initiator is Safety_Compliance, grant is Execute, target is flight assignment database)
assert ps_valid_Post1 {
    all op: REQ_ATC_01 |
        op.post = Post1 =>
            op.initiator in Safety_Compliance_Department &&
            Execute in op.grant &&
            FlightAssignmentDBResource in op.target
}

check ps_valid_Post1 for 5

-- Predicate: Reachability of Post2 (notify controller of conflict)
pred ps_reach_Post2 {
    some op: REQ_ATC_01 |
        op.post = Post2 &&
        -- initiator is Safety_Compliance_Department (they detect conflict)
        op.initiator in Safety_Compliance_Department &&
        -- grant is Read (to read conflict info) || Write (to write notification); choose Read for distinctness
        Read in op.grant &&
        -- target includes the flight assignment API (where conflict might be detected)
        FlightAssignmentAPIResource in op.target &&
        -- channel is authenticated (fact requires at least one, but we emphasize)
        some ch: op.channel | ch.authenticated = True &&
        -- state change
        op.pre != Post2 &&
        -- ensure that Post2 is ! same as Post1 (by semantic differences)
        !(op.initiator in Safety_Compliance_Department && Execute in op.grant && FlightAssignmentDBResource in op.target) -- avoid overlap with Post1
}

run ps_reach_Post2 for 5

-- Assertion: When Post2 is reached, the system notifies the controller of conflict (initiator is Safety_Compliance, grant is Read, target is flight assignment API)
assert ps_valid_Post2 {
    all op: REQ_ATC_01 |
        op.post = Post2 =>
            op.initiator in Safety_Compliance_Department &&
            Read in op.grant &&
            FlightAssignmentAPIResource in op.target
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: A flight assignment is being created || modified.
-- This means the operation involves Flight_Assignment_API && Flight_Assignment_Database,
-- with Write permission, && results in a state change.
pred ac_reach_1 {
    some op: REQ_ATC_01 |
        Write in op.initiator.mayPerform &&
        some op.target &
        (FlightAssignmentAPIResource + FlightAssignmentDBResource) &&
        op.post != op.pre
}
run ac_reach_1 for 5

-- Criterion 2: The assignment would result in two flights occupying the same slot || runway at the same time.
-- This is a safety violation that should never be reachable.
-- Therefore we emit an assertion that no operation can lead to this state.
assert ac_safety_2 {
    no op: REQ_ATC_01 |
        op.post = Post2 &&
        some op.target &
        FlightAssignmentDBResource
}
check ac_safety_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sigs for airspace && flight assignment concepts
sig Sector {}
sig FlightAssignment {
    resource : one Resource,
    finalized : one Bool,
    sector : one Sector
}

-- Edge case 1: No two non-finalized flight assignments may share the same resource
assert ec_safe_1 {
    no disj fa1, fa2 : FlightAssignment |
        fa1.finalized = False &&
        fa2.finalized = False &&
        fa1.resource = fa2.resource
}
check ec_safe_1 for 5

-- Edge case 2: Overlapping non-finalized assignments are allowed only if in different sectors
assert ec_safe_2 {
    all disj fa1, fa2 : FlightAssignment |
        (fa1.resource = fa2.resource &&
         fa1.finalized = False &&
         fa2.finalized = False) => fa1.sector != fa2.sector
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-ATC-01: Create new flight assignment that overlaps with existing one
pred tc_ATC_01_holds {
    some op: REQ_ATC_01 |
        -- Input: Air_Traffic_Controllers initiator
        op.initiator = Air_Traffic_Controllers &&
        -- Input: target is a FlightAssignment resource
        some fa: FlightAssignment | fa.resource in op.target &&
        -- Input: create new assignment that overlaps
        some existing: FlightAssignment | existing != fa &&
            existing.sector = fa.sector &&
            existing.finalized = False &&
            fa.finalized = False &&
        -- Expected: system rejects (pre-state differs from post-state)
        op.pre != op.post &&
        -- Expected: no new assignment created (target unchanged)
        no fa2: FlightAssignment | fa2 ! in op.target
}

run tc_ATC_01_holds for 5

assert tc_ATC_01_contract {
    all op: REQ_ATC_01 |
        -- Pre-condition: controller creating overlapping assignment
        (op.initiator = Air_Traffic_Controllers &&
         some fa: FlightAssignment | fa.resource in op.target &&
         some existing: FlightAssignment | existing != fa &&
             existing.sector = fa.sector &&
             existing.finalized = False &&
             fa.finalized = False) =>
        -- Post-condition: state changes (rejection)
        op.pre != op.post
}

check tc_ATC_01_contract for 5

-- TC-ATC-02: Modify existing flight assignment to create overlap
pred tc_ATC_02_holds {
    some op: REQ_ATC_01 |
        -- Input: Air_Traffic_Controllers initiator
        op.initiator = Air_Traffic_Controllers &&
        -- Input: modifying an existing flight assignment
        some fa: FlightAssignment | fa.resource in op.target &&
            fa.finalized = False &&
        -- Input: modification creates overlap with another assignment
        some other: FlightAssignment | other != fa &&
            other.sector != fa.sector &&  -- original sector different
            other.finalized = False &&
        -- Expected: system rejects modification
        op.pre != op.post
}

run tc_ATC_02_holds for 5

assert tc_ATC_02_contract {
    all op: REQ_ATC_01 |
        -- Pre-condition: controller modifying assignment to create overlap
        (op.initiator = Air_Traffic_Controllers &&
         some fa: FlightAssignment | fa.resource in op.target &&
             fa.finalized = False &&
         some other: FlightAssignment | other != fa &&
             other.finalized = False) =>
        -- Post-condition: state changes (rejection)
        op.pre != op.post
}

check tc_ATC_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: minimizing channel count reduces latency
fact nfr_fact_performance_channel_limit {
    all op: REQ_ATC_01 | #op.channel <= 2
}

-- Availability proxy: requiring at least two target resources per operation increases fault tolerance
-- Removed to avoid conflicts with predicates that assume a single target resource.
-- fact nfr_fact_availability_resource_redundancy {
--     all op: REQ_ATC_01 | #op.target >= 2
-- }

-- Scalability proxy: every actor type must be able to initiate an operation (system can handle all roles)
assert nfr_assert_scalability_all_actors {
    all a: Actor | some op: REQ_ATC_01 | op.initiator = a
}
check nfr_assert_scalability_all_actors for 5

-- Usability proxy: limit authenticated channels per operation to at most one (reduces authentication steps)
assert nfr_assert_usability_auth_limit {
    all op: REQ_ATC_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}
check nfr_assert_usability_auth_limit for 5

