  # Implement the EmergencyFlight domain model                                                                                                                                                  
  emergency_code = '''from __future__ import annotations                                                                                                                                        
                                                                                                                                                                                                
  from typing import Any, Optional, TYPE_CHECKING                                                                                                                                               
  from dataclasses import dataclass, field                                                                                                                                                      
  from enum import Enum                                                                                                                                                                         
  from datetime import datetime as DateTime                                                                                                                                                     
                                                                                                                                                                                                
  if TYPE_CHECKING:                                                                                                                                                                             
      from src.domain.flight.Flight import Flight                                                                                                                                               
      from src.domain.slot.Slot import Slot                                                                                                                                                     
                                                                                                                                                                                                
  """                                                                                                                                                                                           
  Domain layer for the EmergencyFlight domain class                                                                                                                                             
                                                                                                                                                                                                
  Package: domain.emergency_flight                                                                                                                                                              
  Layer: domain                                                                                                                                                                                 
  Related tasks: #51                                                                                                                                                                            
  """                                                                                                                                                                                           
                                                                                                                                                                                                
                                                                                                                                                                                                
  class FlightType(Enum):                                                                                                                                                                       
      EMERGENCY = "emergency"                                                                                                                                                                   
      NON_EMERGENCY = "non_emergency"                                                                                                                                                           
                                                                                                                                                                                                
                                                                                                                                                                                                
  class SlotStatus(Enum):                                                                                                                                                                       
      AVAILABLE = "available"                                                                                                                                                                   
      ALLOCATED = "allocated"                                                                                                                                                                   
                                                                                                                                                                                                
                                                                                                                                                                                                
  @dataclass                                                                                                                                                                                    
  class FlightQueue:                                                                                                                                                                            
      flights: list["Flight"] = field(default_factory=list)                                                                                                                                     
                                                                                                                                                                                                
      def insertEmergencyFlight(self, emergency: "EmergencyFlight", slot: "Slot") -> None:                                                                                                      
          """Insert an emergency flight at the front of the queue."""                                                                                                                           
          self.flights.insert(0, emergency.flight)                                                                                                                                              
          emergency.slot = slot                                                                                                                                                                 
                                                                                                                                                                                                
      def reQueueFlights(self, excludeEmergency: "Flight") -> list["Flight"]:                                                                                                                   
          """Re-queue all flights except the emergency flight, preserving order."""                                                                                                             
          return [f for f in self.flights if f.flightNumber != excludeEmergency.flightNumber]                                                                                                   
                                                                                                                                                                                                
      def reQueueAllNonEmergency(self) -> None:                                                                                                                                                 
          """Re-queue all non-emergency flights, preserving their original order."""                                                                                                            
          non_emergency = [f for f in self.flights                                                                                                                                              
                          if not hasattr(f, 'flightType') or f.flightType != FlightType.EMERGENCY]                                                                                              
          self.flights = non_emergency                                                                                                                                                          
                                                                                                                                                                                                
      def removeFlight(self, flight: "Flight") -> None:                                                                                                                                         
          """Remove a specific flight from the queue."""                                                                                                                                        
          self.flights = [f for f in self.flights if f.flightNumber != flight.flightNumber]                                                                                                     
                                                                                                                                                                                                
      def insertFlightAtPosition(self, flight: "Flight", position: int) -> None:                                                                                                                
          """Insert a flight at a specific position in the queue."""                                                                                                                            
          self.flights.insert(position, flight)                                                                                                                                                 
                                                                                                                                                                                                
                                                                                                                                                                                                
  @dataclass                                                                                                                                                                                    
  class EmergencyFlight:                                                                                                                                                                        
      id: str                                                                                                                                                                                   
      detectionTime: DateTime                                                                                                                                                                   
      flight: "Flight"                                                                                                                                                                          
      slot: Optional["Slot"] = None                                                                                                                                                             
                                                                                                                                                                                                
      def create(self, id: str, detectionTime: DateTime) -> "EmergencyFlight":                                                                                                                  
          """Create a new EmergencyFlight instance."""                                                                                                                                          
          return EmergencyFlight(                                                                                                                                                               
              id=id,                                                                                                                                                                            
              detectionTime=detectionTime,                                                                                                                                                      
              flight=self.flight,                                                                                                                                                               
          )                                                                                                                                                                                     
                                                                                                                                                                                                
                                                                                                                                                                                                
  @dataclass                                                                                                                                                                                    
  class EmergencyFlightId:                                                                                                                                                                      
      value: str                                                                                                                                                                                
                                                                                                                                                                                                
                                                                                                                                                                                                
  @dataclass                                                                                                                                                                                    
  class EmergencyFlightCreatedEvent:                                                                                                                                                            
      flight_id: str                                                                                                                                                                            
      detection_time: DateTime                                                                                                                                                                  
                                                                                                                                                                                                
                                                                                                                                                                                                
  @dataclass                                                                                                                                                                                    
  class EmergencyFlightUpdatedEvent:                                                                                                                                                            
      flight_id: str                                                                                                                                                                            
      slot_time: int                                                                                                                                                                            
  '''                                                                                                                                                                                           
  write_file(file_path="src/domain/emergency_flight/EmergencyFlight.py", content=emergency_code)                                                                                                
  print("EmergencyFlight domain implemented")                                                                                                                                                   
