  """                                                                                                                                                                                  
                                                                                                                                                                                       
  class FlightType(Enum):                                                                                                                                                              
      EMERGENCY = "emergency"                                                                                                                                                          
      NON_EMERGENCY = "non_emergency"                                                                                                                                                  
                                                                                                                                                                                       
