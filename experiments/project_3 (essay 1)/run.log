        setLoading(false);                                                                                                                                                             
      }                                                                                                                                                                                
    };                                                                                                                                                                                 
                                                                                                                                                                                       
    useEffect(() => { fetchFlights(); }, []);                                                                                                                                          
                                                                                                                                                                                       
    const handleCreate = async () => {                                                                                                                                                 
      if (!flightNumber || !aircraftType) return;                                                                                                                                      
