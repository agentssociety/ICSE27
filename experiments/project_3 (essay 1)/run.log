                      <td style={{ padding: '0.5rem' }}>{f.aircraftType}</td>                                                                                                          
                    </tr>                                                                                                                                                              
                  ))}                                                                                                                                                                  
                </tbody>                                                                                                                                                               
              </table>                                                                                                                                                                 
            )}                                                                                                                                                                         
          </div>                                                                                                                                                                       
        </div>                                                                                                                                                                         
      </div>                                                                                                                                                                           
    );                                                                                                                                                                                 
  }                                                                                                                                                                                    
