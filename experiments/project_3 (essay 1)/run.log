      Args:                                                                                                                                                                            
          existing_slots: List of existing allocated slots.                                                                                                                            
          reference_time: The reference time in minutes (0 = now).                                                                                                                     
          slot_duration: Duration of each slot in minutes (default 5).                                                                                                                 
