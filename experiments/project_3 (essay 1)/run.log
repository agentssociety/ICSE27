              isAvailable=True,                                                                                                                                                        
              time=100,                                                                                                                                                                
          )                                                                                                                                                                            
          db.add(slot)                                                                                                                                                                 
          db.flush()                                                                                                                                                                   
                                                                                                                                                                                       
          # Link slot to runway                                                                                                                                                        
          runway.slot_id = slot.id                                                                                                                                                     
          db.flush()                                                                                                                                                                   
                                                                                                                                                                                       
          # Create a flight                                                                                                                                                            
          flight = FlightORM(                                                                                                                                                          
              flightNumber="AA123",                                                                                                                                                    
              aircraftType="Boeing 737",                                                                                                                                               
          )                                                                                                                                                                            
          db.add(flight)                                                                                                                                                               
          db.commit()                                                                                                                                                                  
                                                                                                                                                                                       
          return runway.id, slot.id, flight.id                                                                                                                                         
                                                                                                                                                                                       
      def _get_db_session(self):                                                                                                                                                       
          """Get a test database session for seeding data."""                                                                                                                          
          db = TestSessionLocal()                                                                                                                                                      
          return db                                                                                                                                                                    
                                                                                                                                                                                       
      def test_get_timetable_success(self):                                                                                                                                            
          """Test that the timetable endpoint returns correct data."""                                                                                                                 
          db = self._get_db_session()                                                                                                                                                  
          runway_id, slot_id, flight_id = self._seed_data(db)                                                                                                                          
          db.close()                                                                                                                                                                   
                                                                                                                                                                                       
          response = client.get(f"/runways/{runway_id}/timetable")                                                                                                                     
          assert response.status_code == 200                                                                                                                                           
          data = response.json()                                                                                                                                                       
          assert data["runway_id"] == "RWY-01"                                                                                                                                         
          assert data["runway_status"] == "active"                                                                                                                                     
          assert len(data["entries"]) == 2  # 1 slot + 1 flight                                                                                                                        
                                                                                                                                                                                       
          # Check slot entry                                                                                                                                                           
          slot_entries = [e for e in data["entries"] if e.get("slot_id") is not None]                                                                                                  
          assert len(slot_entries) == 1                                                                                                                                                
          slot_entry = slot_entries[0]                                                                                                                                                 
          assert slot_entry["slot_time"] == 100                                                                                                                                        
          assert slot_entry["status"] == "allocated"                                                                                                                                   
                                                                                                                                                                                       
          # Check flight entry                                                                                                                                                         
          flight_entries = [e for e in data["entries"] if e.get("flight_id") is not None]                                                                                              
          assert len(flight_entries) == 1                                                                                                                                              
          flight_entry = flight_entries[0]                                                                                                                                             
          assert flight_entry["flight_number"] == "AA123"                                                                                                                              
          assert flight_entry["aircraft_type"] == "Boeing 737"                                                                                                                         
          assert flight_entry["status"] == "scheduled"                                                                                                                                 
                                                                                                                                                                                       
      def test_get_timetable_runway_not_found(self):                                                                                                                                   
          """Test that 404 is returned for a non-existent runway."""                                                                                                                   
          response = client.get("/runways/nonexistent/timetable")                                                                                                                      
          assert response.status_code == 404                                                                                                                                           
          assert "Runway not found" in response.json()["detail"]                                                                                                                       
                                                                                                                                                                                       
