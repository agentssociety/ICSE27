module REQ_ATC_EMLY_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-EMLY-01
 * Title       : Handle Emergency Flights
 * Type        : Functional
 * Priority    : Critical
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Controllers, Emergency_Services, Flight_Operators extends Actor {}
-- Air_Traffic_Controllers: represents stakeholder 'Air Traffic Controllers'
-- Emergency_Services: represents stakeholder 'Emergency Services'
-- Flight_Operators: represents stakeholder 'Flight Operators'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flight_Queue_API, Flight_Schedule_Database extends Interface {}

fact interface_properties {
    Flight_Queue_API.kind = API  -- The requirement interacts with the Flight Queue API to retrieve, update, and re-queue flight slots.
    Flight_Schedule_Database.kind = Database  -- The requirement uses the Flight Schedule Database to store and manage scheduled flights and their slots.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system has a queue of scheduled flights with assigned slots.
-- Pre2: system is in state where Emergency flights are flagged and prioritized above all others.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3, Post4 extends State {}
-- Post1: system reaches state where The emergency flight is handled immediately by allocating the next available slot.
-- Post2: system reaches state where All other previously queued flights are re-queued in order with adjusted slots.
-- Post3: system reaches state where No non-emergency flight loses its original order.
-- Post4: system reaches state where The emergency flight is placed at the front of the queue.


----------------------------------------------------------------------
-- Core operation: REQ_ATC_EMLY_01
----------------------------------------------------------------------

sig REQ_ATC_EMLY_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_EMLY_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_EMLY_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_EMLY_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_EMLY_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_EMLY_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_EMLY_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_EMLY_01 | op.post in Post1 + Post2 + Post3 + Post4
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_EMLY_01 {
    some op: REQ_ATC_EMLY_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_EMLY_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_EMLY_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_EMLY_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_EMLY_01_well_formed {
    all op: REQ_ATC_EMLY_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_EMLY_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates for each defined post-state
pred ps_reach_Post1 {
    some op: REQ_ATC_EMLY_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        op.initiator = Emergency_Services &&
        Flight_Queue_API in op.target &&
        op.channel.authenticated = True
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_ATC_EMLY_01 |
        op.post = Post2 &&
        op.pre = Pre1 &&
        op.initiator = Air_Traffic_Controllers &&
        Flight_Queue_API in op.target &&
        Flight_Schedule_Database in op.target &&
        op.channel.authenticated = True
}
run ps_reach_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_ATC_EMLY_01 |
        op.post = Post3 &&
        op.pre = Pre2 &&
        op.initiator = Flight_Operators &&
        Flight_Queue_API in op.target &&
        op.channel.authenticated = True
}
run ps_reach_Post3 for 5

pred ps_reach_Post4 {
    some op: REQ_ATC_EMLY_01 |
        op.post = Post4 &&
        op.pre = Pre2 &&
        op.initiator = Emergency_Services &&
        Flight_Queue_API in op.target &&
        op.channel.authenticated = True
}
run ps_reach_Post4 for 5

-- Semantic verification assertions linking post-state to its description
assert ps_valid_Post1 {
    all op: REQ_ATC_EMLY_01 |
        op.post = Post1 =>
            (op.pre = Pre1 &&
             op.initiator = Emergency_Services &&
             Flight_Queue_API in op.target &&
             op.channel.authenticated = True)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_ATC_EMLY_01 |
        op.post = Post2 =>
            (op.pre = Pre1 &&
             op.initiator = Air_Traffic_Controllers &&
             Flight_Queue_API in op.target &&
             Flight_Schedule_Database in op.target &&
             op.channel.authenticated = True)
}
check ps_valid_Post2 for 5

assert ps_valid_Post3 {
    all op: REQ_ATC_EMLY_01 |
        op.post = Post3 =>
            (op.pre = Pre2 &&
             op.initiator = Flight_Operators &&
             Flight_Queue_API in op.target &&
             op.channel.authenticated = True)
}
check ps_valid_Post3 for 5

assert ps_valid_Post4 {
    all op: REQ_ATC_EMLY_01 |
        op.post = Post4 =>
            (op.pre = Pre2 &&
             op.initiator = Emergency_Services &&
             Flight_Queue_API in op.target &&
             op.channel.authenticated = True)
}
check ps_valid_Post4 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ac_reach_1: An incoming emergency flight is detected.
pred ac_reach_1 {
    some op: REQ_ATC_EMLY_01 |
        Read in op.initiator.mayPerform &&
        Emergency_Services in op.initiator.mayPerform &&  -- Emergency actor can perform the operation
        some op.target &&
        (some c: op.channel | c.authenticated = True)
}

run ac_reach_1 for 5

-- ac_reach_2: The system allocates the next available slot.
pred ac_reach_2 {
    some op: REQ_ATC_EMLY_01 |
        Write in op.initiator.mayPerform &&
        op.grant = Write &&  -- Write permission to modify (allocate) slot
        op.post = Post1 &&   -- Allocation post-state
        some op.target &&
        (some c: op.channel | c.authenticated = True)
}

run ac_reach_2 for 5

-- ac_reach_3: The emergency flight is inserted into that slot.
pred ac_reach_3 {
    some op: REQ_ATC_EMLY_01 |
        Write in op.initiator.mayPerform &&
        op.initiator in Emergency_Services &&  -- Emergency actor performs insertion
        op.target = Flight_Queue_API &&        -- Target is the queue
        op.post = Post2 &&
        (some c: op.channel | c.authenticated = True)
}

run ac_reach_3 for 5

-- ac_reach_4: All other previously queued flights are re-queued in order with adjusted slots.
pred ac_reach_4 {
    some op: REQ_ATC_EMLY_01 |
        Write in op.initiator.mayPerform &&
        op.post = Post3 &&  -- Re-queuing post-state
        op.target = Flight_Queue_API &&
        op.initiator in Flight_Operators &&  -- Performed by operators
        some op.channel
}

run ac_reach_4 for 5

-- ac_reach_5: A queue of non-emergency flights exists.
pred ac_reach_5 {
    some op: REQ_ATC_EMLY_01 |
        op.pre = Pre1 &&  -- Initial state has queue
        Read in op.initiator.mayPerform &&
        op.target = Flight_Queue_API &&
        op.initiator in Air_Traffic_Controllers &&  -- ATC monitors the queue
        some op.channel
}

run ac_reach_5 for 5

-- ac_reach_6: An emergency flight is allocated a slot.
pred ac_reach_6 {
    some op: REQ_ATC_EMLY_01 |
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        op.initiator in Emergency_Services &&
        op.post = Post2 &&
        (some c: op.channel | c.encrypted = True)  -- Emergency channel is encrypted
}

run ac_reach_6 for 5

-- ac_reach_7: No non-emergency flight loses its original order.
pred ac_reach_7 {
    some op: REQ_ATC_EMLY_01 |
        op.post = Post3 &&
        op.pre = Pre1 &&
        op.initiator in Air_Traffic_Controllers &&
        op.target = Flight_Schedule_Database &&  -- Schedule database maintains order
        (some c: op.channel | c.authenticated = True)
}

run ac_reach_7 for 5

-- ac_reach_8: The emergency flight is placed at the front of the queue (in the next available slot).
pred ac_reach_8 {
    some op: REQ_ATC_EMLY_01 |
        Write in op.initiator.mayPerform &&
        op.post = Post4 &&  -- Emergency at front post-state
        op.initiator in Emergency_Services &&
        op.target = Flight_Queue_API &&
        (some c: op.channel | c.authenticated = True && c.encrypted = True)  -- Both authenticated && encrypted
}

run ac_reach_8 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: No available slots for emergency flights must never lead to a successful emergency insertion.
-- We assume Post1 represents the state after a successful emergency insertion (updateable if semantics change).
assert ec_safe_1 {
    all op: REQ_ATC_EMLY_01 |
        (op.initiator in Emergency_Services &&
         Flight_Queue_API in op.target) 
        => op.post != Post1
}
check ec_safe_1 for 5

-- Edge case 2: Multiple emergencies simultaneously must never cause conflicting write operations on the same queue.
assert ec_safe_2 {
    no disj op1, op2: REQ_ATC_EMLY_01 |
        op1.initiator in Emergency_Services &&
        op2.initiator in Emergency_Services &&
        Flight_Queue_API in op1.target &&
        Flight_Queue_API in op2.target &&
        op1.grant = Write && op2.grant = Write
}
check ec_safe_2 for 5

-- Edge case 3: A non?emergency re?queue must ! occur while an emergency flight is already scheduled (Post1 assumed as emergency scheduled).
assert ec_safe_3 {
    all op: REQ_ATC_EMLY_01 |
        (op.initiator in Flight_Operators &&
         op.grant = Write &&
         Flight_Queue_API in op.target)
        => op.pre != Post1
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-ATC-EMLY-01: Emergency flight gets next available slot
pred tc_ATC_EMLY_01_holds {
    some op: REQ_ATC_EMLY_01 |
        -- initiator is an Air Traffic Controller with Admin permission
        op.initiator in Air_Traffic_Controllers &&
        Admin in op.initiator.mayPerform &&
        -- target includes the flight queue API && schedule database
        Flight_Queue_API in op.target &&
        Flight_Schedule_Database in op.target &&
        -- grant permission is Write (to modify queue)
        op.grant = Write &&
        -- channel is authenticated && encrypted
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        -- pre-state is Pre1 (normal operations)
        op.pre = Pre1 &&
        -- post-state is Post1 (emergency inserted, others re-queued)
        op.post = Post1 &&
        -- state changes
        op.post != op.pre
}
run tc_ATC_EMLY_01_holds for 5

assert tc_ATC_EMLY_01_contract {
    all op: REQ_ATC_EMLY_01 |
        (op.initiator in Air_Traffic_Controllers &&
         Admin in op.initiator.mayPerform &&
         Flight_Queue_API in op.target &&
         Flight_Schedule_Database in op.target &&
         op.grant = Write &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         op.pre = Pre1) =>
        (op.post = Post1 && op.post != op.pre)
}
check tc_ATC_EMLY_01_contract for 5

-- Scenario TC-ATC-EMLY-02: Multiple simultaneous emergencies handled in order
pred tc_ATC_EMLY_02_holds {
    some op: REQ_ATC_EMLY_01 |
        -- initiator is an Air Traffic Controller with Admin permission
        op.initiator in Air_Traffic_Controllers &&
        Admin in op.initiator.mayPerform &&
        -- target includes the flight queue API && schedule database
        Flight_Queue_API in op.target &&
        Flight_Schedule_Database in op.target &&
        -- grant permission is Write (to modify queue)
        op.grant = Write &&
        -- channel is authenticated && encrypted
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        -- pre-state is Pre2 (multiple emergencies detected)
        op.pre = Pre2 &&
        -- post-state is Post2 (emergencies allocated slots in detection order)
        op.post = Post2 &&
        -- state changes
        op.post != op.pre
}
run tc_ATC_EMLY_02_holds for 5

assert tc_ATC_EMLY_02_contract {
    all op: REQ_ATC_EMLY_01 |
        (op.initiator in Air_Traffic_Controllers &&
         Admin in op.initiator.mayPerform &&
         Flight_Queue_API in op.target &&
         Flight_Schedule_Database in op.target &&
         op.grant = Write &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         op.pre = Pre2) =>
        (op.post = Post2 && op.post != op.pre)
}
check tc_ATC_EMLY_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_rapid_response {
    -- PROXY: minimizing the number of channels reduces communication overhead, improving response time
    -- NFR: performance - rapid response to critical situations
    all op: REQ_ATC_EMLY_01 | #op.channel <= 1
}

fact nfr_fact_channel_availability {
    -- PROXY: requiring at least one encrypted channel ensures communication availability even under adverse conditions
    -- NFR: availability
    all op: REQ_ATC_EMLY_01 | some ch: op.channel | ch.encrypted = True
}

fact nfr_fact_scalable_actors {
    -- PROXY: ensuring all actors can potentially initiate operations tests scalability
    -- NFR: scalability
    all a: Actor | some op: REQ_ATC_EMLY_01 | op.initiator = a
}

fact nfr_fact_usability_bounded_channels {
    -- PROXY: limiting the number of authenticated channels simplifies the user interface, improving usability
    -- NFR: usability
    all op: REQ_ATC_EMLY_01 | #op.channel <= 3
}

assert nfr_assert_performance_latency {
    -- PROXY: ensuring each operation uses at most one channel minimizes latency
    -- NFR: performance - rapid response to critical situations
    all op: REQ_ATC_EMLY_01 | #op.channel <= 1
}
check nfr_assert_performance_latency for 5

assert nfr_assert_availability_redundancy {
    -- PROXY: requiring at least one encrypted channel per operation ensures communication availability
    -- NFR: availability
    all op: REQ_ATC_EMLY_01 | some ch: op.channel | ch.encrypted = True
}
check nfr_assert_availability_redundancy for 5

assert nfr_assert_scalability_coverage {
    -- PROXY: ensuring every actor can initiate an operation tests system scalability
    -- NFR: scalability
    all a: Actor | some op: REQ_ATC_EMLY_01 | op.initiator = a
}
check nfr_assert_scalability_coverage for 5

assert nfr_assert_usability_simplicity {
    -- PROXY: limiting authenticated channels to a small number improves user experience
    -- NFR: usability
    all op: REQ_ATC_EMLY_01 | #op.channel <= 3
}
check nfr_assert_usability_simplicity for 5

