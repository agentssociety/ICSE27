----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: limit number of slots per operation to bound allocation time
fact nfr_fact_slot_limit {
    -- PROXY: fewer slots per operation => faster allocation
    all op: REQ_ATC_01 | #(OperationSlot <: slot).(op->Slot) <= 3
}

-- Availability: require at least two channels per operation for redundancy
fact nfr_fact_redundant_channels {
    -- PROXY: multiple channels ensure continuous operation if one fails
    all op: REQ_ATC_01 | #op.channel >= 2
}

-- Scalability: ensure all actors can initiate operations simultaneously
fact nfr_fact_actor_capacity {
    -- PROXY: all actors must be able to be initiators, supporting growth
    all a: Actor | some op: REQ_ATC_01 | op.initiator = a
}

-- Usability: limit authenticated channels to avoid overwhelming users
fact nfr_fact_auth_channel_limit {
    -- PROXY: fewer authenticated channels reduces complexity for user feedback
    all op: REQ_ATC_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

assert nfr_assert_no_circular_ownership {
    -- Maintainability: no resource is owned by an actor that accesses itself
    no r: Resource | r.owner in r.accessible
}
check nfr_assert_no_circular_ownership for 5

assert nfr_assert_all_ops_have_post {
    -- Reliability: every operation has a defined post-state
    all op: REQ_ATC_01 | one op.post
}
check nfr_assert_all_ops_have_post for 5

