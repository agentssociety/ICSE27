----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Controllers, Operations_Management, Flight_Schedule_Managers extends Actor {}
-- Air_Traffic_Controllers: represents stakeholder 'Air Traffic Controllers'
-- Operations_Management: represents stakeholder 'Operations Management'
-- Flight_Schedule_Managers: represents stakeholder 'Flight Schedule Managers'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete runway resources
sig Runway extends Resource {}
one sig Runway1, Runway2 extends Runway {}

fact resource_owners {
    Runway1.owner = Air_Traffic_Controllers
    Runway2.owner = Air_Traffic_Controllers
    Runway1.accessible = Air_Traffic_Controllers + Operations_Management
    Runway2.accessible = Air_Traffic_Controllers + Operations_Management
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Runway_API, Flight_Database, Runway_Timetable_UI extends Interface {}

fact interface_properties {
    Runway_API.kind = API  -- The requirement interacts with the Runway API to fetch runway data, including time slots, flight details, and statuses.
    Flight_Database.kind = Database  -- The system retrieves flight details from the Flight Database to populate the timetable.
    Runway_Timetable_UI.kind = UI  -- The requirement interacts with the Runway Timetable UI to display the slot timetable to air traffic controllers.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user must be logged into the runway management system.
-- Pre2: system is in state where The specific runway must have allocated time slots, flight details, and statuses to display.

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The user should see a slot timetable with all necessary information for the selected runway.


----------------------------------------------------------------------
-- Core operation: REQ_ATC_TIMETABLE_01
----------------------------------------------------------------------

sig REQ_ATC_TIMETABLE_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_TIMETABLE_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_TIMETABLE_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_TIMETABLE_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_TIMETABLE_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_TIMETABLE_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_TIMETABLE_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_TIMETABLE_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_TIMETABLE_01 {
    some op: REQ_ATC_TIMETABLE_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_TIMETABLE_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_TIMETABLE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_TIMETABLE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_TIMETABLE_01_well_formed {
    all op: REQ_ATC_TIMETABLE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_TIMETABLE_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? Post-state reachability && semantic verification ????????????????

pred ps_reach_Post1 {
    some op: REQ_ATC_TIMETABLE_01 |
        op.post = Post1 &&
        op.pre != Post1 &&
        Runway_Timetable_UI in op.channel &&
        Read in op.initiator.mayPerform &&
        some r: Runway | r in op.target &&
        op.grant = Read
}

assert ps_valid_Post1 {
    all op: REQ_ATC_TIMETABLE_01 |
        (op.post = Post1) =>
            (op.pre != Post1 &&
             Runway_Timetable_UI in op.channel &&
             Read in op.initiator.mayPerform &&
             some r: Runway | r in op.target &&
             op.grant = Read)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
   some op: REQ_ATC_TIMETABLE_01 |
       op.initiator = Air_Traffic_Controllers &&
       op.grant = Read &&
       Runway_Timetable_UI in op.channel &&
       some r: Runway | r in op.target &&
       Flight_Database in op.channel &&
       some c: op.channel | c.kind = UI && c.authenticated = True
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: No time slots allocated for a runway
-- Safety: If no Resource (runway) has any allocation in the operation's target, the operation must ! change state.
assert ec_safe_1 {
    all op: REQ_ATC_TIMETABLE_01 |
        -- If the target set contains only resources with no time slots (modeled as empty target being impossible due to INV-2),
        -- we check that if the operation's grant does ! include scheduling permissions, state remains unchanged.
        (op.grant ! in Air_Traffic_Controllers.mayPerform) => (op.post = op.pre)
}
check ec_safe_1 for 5

-- Edge case 2: Real-time data updates during flight operations
-- Safety: If the operation uses API channels, it must also use Database channels to ensure data persistence.
assert ec_safe_2 {
    all op: REQ_ATC_TIMETABLE_01 |
        -- If any channel is of kind API, then at least one channel must be of kind Database
        (some ch: op.channel | ch.kind = API) => (some ch: op.channel | ch.kind = Database)
}
check ec_safe_2 for 5

-- Edge case 3: Multiple runways with overlapping time slots
-- Safety: No two operations can target the same Resource with conflicting grants that might cause overlap.
-- We define overlapping as operations that share a target && have different grant permissions.
assert ec_safe_3 {
    all disj op1, op2: REQ_ATC_TIMETABLE_01 |
        (some (op1.target & op2.target)) => (op1.grant = op2.grant)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_01_holds {
    some op: REQ_ATC_TIMETABLE_01 |
        op.initiator in Air_Traffic_Controllers &&
        op.grant = Read &&
        Runway_Timetable_UI in op.channel &&
        some c: op.channel | c.kind = UI &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_01_holds for 5

assert tc_01_contract {
    all op: REQ_ATC_TIMETABLE_01 |
        (op.initiator in Air_Traffic_Controllers &&
         op.grant = Read &&
         Runway_Timetable_UI in op.channel &&
         some c: op.channel | c.kind = UI) =>
        op.post = Post1
}
check tc_01_contract for 5

pred tc_02_holds {
    some op: REQ_ATC_TIMETABLE_01 |
        op.initiator in Air_Traffic_Controllers &&
        op.grant = Read &&
        Runway_Timetable_UI in op.channel &&
        some c: op.channel | c.kind = UI &&
        op.pre = Pre2 &&
        op.post = Post1
}
run tc_02_holds for 5

assert tc_02_contract {
    all op: REQ_ATC_TIMETABLE_01 |
        (op.initiator in Air_Traffic_Controllers &&
         op.grant = Read &&
         Runway_Timetable_UI in op.channel &&
         some c: op.channel | c.kind = UI &&
         op.pre = Pre2) =>
        op.post = Post1
}
check tc_02_contract for 5

pred tc_03_holds {
    some op: REQ_ATC_TIMETABLE_01 |
        op.initiator in Operations_Management &&
        op.grant = Write &&
        Flight_Database in op.channel &&
        some c: op.channel | c.kind = API &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_03_holds for 5

assert tc_03_contract {
    all op: REQ_ATC_TIMETABLE_01 |
        (op.initiator in Operations_Management &&
         op.grant = Write &&
         Flight_Database in op.channel &&
         some c: op.channel | c.kind = API) =>
        op.post = Post1
}
check tc_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limit channels && targets to reduce latency (response time < 2s)
fact nfr_fact_performance {
    all op: REQ_ATC_TIMETABLE_01 | #op.channel <= 2 && #op.target <= 3
}

-- Availability proxy: require at least two redundant channels per operation (99.9% uptime)
fact nfr_fact_availability {
    all op: REQ_ATC_TIMETABLE_01 | #op.channel >= 2
}

-- Scalability proxy: ensure at least two resources exist to support multiple runways (up to 100)
fact nfr_fact_scalability {
    #Resource >= 2
}

-- Usability proxy: limit the number of authenticated channels per operation to at most one (clear, user?friendly)
fact nfr_fact_usability {
    all op: REQ_ATC_TIMETABLE_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

