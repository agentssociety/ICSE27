module REQ_ATC_PRI_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-PRI-01
 * Title       : Priority Slot Allocation for Arrival Flights
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Control_Team, Passengers, Aircraft_Operators extends Actor {}
-- Air_Traffic_Control_Team: represents stakeholder 'Air Traffic Control Team'
-- Passengers: represents stakeholder 'Passengers'
-- Aircraft_Operators: represents stakeholder 'Aircraft Operators'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Concrete resources for the slot allocation domain
one sig RunwaySlotResource extends Resource {}
one sig FlightScheduleResource extends Resource {}
one sig SafetyConstraintsResource extends Resource {}

fact resource_ownership {
    RunwaySlotResource.owner = Air_Traffic_Control_Team
    RunwaySlotResource.accessible = Actor
    FlightScheduleResource.owner = Air_Traffic_Control_Team
    FlightScheduleResource.accessible = Actor
    SafetyConstraintsResource.owner = Air_Traffic_Control_Team
    SafetyConstraintsResource.accessible = Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, External_System, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Runway_Slot_API, Flight_Schedule_Database, Safety_Constraints_Module extends Interface {}

fact interface_properties {
    Runway_Slot_API.kind = API  -- The system will interact with this API to request and allocate runway slots.
    Flight_Schedule_Database.kind = Database  -- This database will be used to retrieve current flight schedules and arrival/departure statuses.
    Safety_Constraints_Module.kind = External_System  -- The system will interface with this module to ensure all safety constraints are met during slot allocation.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where There is at least one runway slot available for allocation.
-- Pre2: system is in state where A set of both arrival flights and departure flights are competing for the same slot window.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where All arrival flights that requested slots have been allocated slots before any departure flights receive slots.
-- Post2: system reaches state where Any conflicts between arrival and departure flights have been resolved, with priority given to arrival flights.


----------------------------------------------------------------------
-- Core operation: REQ_ATC_PRI_01
----------------------------------------------------------------------

sig REQ_ATC_PRI_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_PRI_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_PRI_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_PRI_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_PRI_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_PRI_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_PRI_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_PRI_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_PRI_01 {
    some op: REQ_ATC_PRI_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_PRI_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_PRI_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_PRI_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_PRI_01_well_formed {
    all op: REQ_ATC_PRI_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_PRI_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? POST-STATE REACHABILITY VERIFICATION ??????????????????????????????

-- Post1: All arrival flights that requested slots have been allocated slots
-- before any departure flights receive slots.
pred ps_reach_Post1 {
    some op: REQ_ATC_PRI_01 |
        op.post = Post1 &&
        -- Initiator must be Air_Traffic_Control_Team (the authority for slot allocation)
        op.initiator = Air_Traffic_Control_Team &&
        -- Must use Runway_Slot_API as the channel (slot allocation interface)
        Runway_Slot_API in op.channel &&
        -- Must grant Execute permission (to execute slot allocation)
        Execute in op.grant &&
        -- Target must include RunwaySlotResource (the slot system)
        RunwaySlotResource in op.target &&
        -- Pre-state must be different from post-state (state change occurred)
        op.pre != op.post &&
        -- The channel must be authenticated (required for critical operations)
        op.channel.authenticated = True
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ATC_PRI_01 |
        (op.post = Post1) =>
            -- Only Air_Traffic_Control_Team can reach this state
            op.initiator = Air_Traffic_Control_Team &&
            -- Must use Runway_Slot_API channel
            Runway_Slot_API in op.channel &&
            -- Must grant Execute permission
            Execute in op.grant &&
            -- Must target RunwaySlotResource
            RunwaySlotResource in op.target &&
            -- State must have changed
            op.pre != op.post
}

check ps_valid_Post1 for 5

-- Post2: Any conflicts between arrival && departure flights have been resolved,
-- with priority given to arrival flights.
pred ps_reach_Post2 {
    some op: REQ_ATC_PRI_01 |
        op.post = Post2 &&
        -- Initiator must be Air_Traffic_Control_Team (conflict resolution authority)
        op.initiator = Air_Traffic_Control_Team &&
        -- Must use Safety_Constraints_Module as the channel (conflict resolution)
        Safety_Constraints_Module in op.channel &&
        -- Must grant Admin permission (to resolve conflicts with priority)
        Admin in op.grant &&
        -- Target must include FlightScheduleResource (where schedules are stored)
        FlightScheduleResource in op.target &&
        -- Pre-state must be different from post-state
        op.pre != op.post &&
        -- The channel must be authenticated && encrypted (safety-critical)
        op.channel.authenticated = True &&
        op.channel.encrypted = True
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_ATC_PRI_01 |
        (op.post = Post2) =>
            -- Only Air_Traffic_Control_Team can reach this state
            op.initiator = Air_Traffic_Control_Team &&
            -- Must use Safety_Constraints_Module channel
            Safety_Constraints_Module in op.channel &&
            -- Must grant Admin permission (priority resolution requires admin rights)
            Admin in op.grant &&
            -- Must target FlightScheduleResource
            FlightScheduleResource in op.target &&
            -- State must have changed
            op.pre != op.post &&
            -- Channel must be authenticated && encrypted
            op.channel.authenticated = True &&
            op.channel.encrypted = True
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: arrival slots allocated before departure slots considered
pred ac_reach_1 {
    some op: REQ_ATC_PRI_01 |
        op.initiator = Air_Traffic_Control_Team
        && Write in op.initiator.mayPerform
        && op.grant = Write
        && op.target = RunwaySlotResource
        && (some c: op.channel | c.encrypted = True && c.authenticated = True)
        && op.pre = Pre1
        && op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: arrival receives slot in conflict with departure
pred ac_reach_2 {
    some op: REQ_ATC_PRI_01 |
        op.initiator = Air_Traffic_Control_Team
        && Write in op.initiator.mayPerform
        && op.grant = Write
        && RunwaySlotResource in op.target
        && FlightScheduleResource in op.target
        && (some c: op.channel | c.encrypted = True && c.authenticated = True)
        && op.pre = Pre2
        && op.post = Post2
}
run ac_reach_2 for 5

-- Criterion 3: slot reallocated from departure to arrival
pred ac_reach_3 {
    some op: REQ_ATC_PRI_01 |
        op.initiator = Air_Traffic_Control_Team
        && Admin in op.initiator.mayPerform
        && op.grant = Admin
        && RunwaySlotResource in op.target
        && (some c: op.channel | c.encrypted = True && c.authenticated = True)
        && op.pre = Pre2
        && op.post = Post1
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: No available runway slots for arrival flights
-- Safety: If there are no available slots, the operation must ! grant a slot allocation
assert ec_safe_1 {
    all op: REQ_ATC_PRI_01 |
        -- If the operation targets RunwaySlotResource && no slots are available
        (RunwaySlotResource in op.target && no op.initiator.mayPerform & Read) =>
        -- Then the post state must equal the pre state (no change)
        op.post = op.pre
}
check ec_safe_1 for 5

-- Edge case 2: Multiple conflicting arrival && departure requests simultaneously
-- Safety: No two operations can grant conflicting permissions on the same target
assert ec_safe_2 {
    all disj op1, op2: REQ_ATC_PRI_01 |
        -- If they share a target resource
        some op1.target & op2.target =>
        -- They must ! have conflicting grants (Read vs Write on same resource)
        !(op1.grant = Read && op2.grant = Write) &&
        !(op1.grant = Write && op2.grant = Read)
}
check ec_safe_2 for 5

-- Edge case 3: Flight canceled || rescheduled mid-allocation
-- Safety: If a flight is canceled, the operation must ! proceed to completion
assert ec_safe_3 {
    all op: REQ_ATC_PRI_01 |
        -- If the operation involves a canceled flight (pre state indicates cancellation)
        (op.pre = Pre1 && op.initiator in Aircraft_Operators) =>
        -- Then the post state must reflect the cancellation (no new allocation)
        op.post = Pre1
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? SCENARIO TC-ATC-PRI-01 ??????????????????????????????????????????
pred tc_ATC_PRI_01_holds {
    some op: REQ_ATC_PRI_01 |
        -- Input: equal number of arrival && departure requests
        -- Represented by having at least one arrival (Pre1 state) && one departure
        op.pre = Pre1 &&
        -- Expected: all arrivals get slots (Pre1 represents arrival state)
        -- Departures on waiting list (Post1 represents waiting list state)
        op.post = Post1 &&
        op.post != op.pre
}
run tc_ATC_PRI_01_holds for 5

assert tc_ATC_PRI_01_contract {
    all op: REQ_ATC_PRI_01 |
        (op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_ATC_PRI_01_contract for 5

-- ?? SCENARIO TC-ATC-PRI-02 ??????????????????????????????????????????
pred tc_ATC_PRI_02_holds {
    some op: REQ_ATC_PRI_01 |
        -- Input: conflict between arrival && departure for same slot
        -- Pre2 represents conflict state
        op.pre = Pre2 &&
        -- Expected: arrival receives slot (Post1), departure on waiting list
        op.post = Post1 &&
        op.post != op.pre
}
run tc_ATC_PRI_02_holds for 5

assert tc_ATC_PRI_02_contract {
    all op: REQ_ATC_PRI_01 |
        (op.pre = Pre2) =>
        (op.post = Post1)
}
check tc_ATC_PRI_02_contract for 5

-- ?? SCENARIO TC-ATC-PRI-03 ??????????????????????????????????????????
pred tc_ATC_PRI_03_holds {
    some op: REQ_ATC_PRI_01 |
        -- Input: arrival requests slot already allocated to departure
        -- Pre2 represents this conflict state
        op.pre = Pre2 &&
        -- Expected: arrival gets slot, departure reassigned to next available
        -- Post2 represents reassignment state
        op.post = Post2 &&
        op.post != op.pre
}
run tc_ATC_PRI_03_holds for 5

assert tc_ATC_PRI_03_contract {
    all op: REQ_ATC_PRI_01 |
        (op.pre = Pre2) =>
        (op.post = Post2)
}
check tc_ATC_PRI_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limiting channel count reduces latency (NFR: response time)
fact nfr_fact_performance_limit_channels {
    all op: REQ_ATC_PRI_01 | #op.channel <= 2
}

-- Availability proxy: require at least 2 channels for redundancy (NFR: high uptime)
fact nfr_fact_availability_redundant_channels {
    all op: REQ_ATC_PRI_01 | #op.channel >= 2
}

-- Scalability proxy: every actor can be initiator of an operation (NFR: horizontal scaling)
assert nfr_assert_scalability_all_actors {
    all a: Actor | some op: REQ_ATC_PRI_01 | op.initiator = a
}
check nfr_assert_scalability_all_actors for 5

-- Usability proxy: limit number of authenticated interfaces to reduce complexity (NFR: graceful error handling)
assert nfr_assert_usability_bounded_auth {
    #{c: Interface | c.authenticated = True} <= 3
}
check nfr_assert_usability_bounded_auth for 5

