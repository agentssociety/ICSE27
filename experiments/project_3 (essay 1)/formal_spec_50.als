module REQ_ATC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ATC-01
 * Title       : Automatic Reassignment of Flights During Runway Closure
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Air_Traffic_Control_Team, Flight_Operations_Management, Safety_Compliance_Office extends Actor {}
-- Air_Traffic_Control_Team: represents stakeholder 'Air Traffic Control Team'
-- Flight_Operations_Management: represents stakeholder 'Flight Operations Management'
-- Safety_Compliance_Office: represents stakeholder 'Safety Compliance Office'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Runway_Status_API, Aircraft_and_Traffic_Database, Separation_Rules_Database extends Interface {}

fact interface_properties {
    Runway_Status_API.kind = API  -- The system interfaces with an external API to receive real-time runway closure information.
    Aircraft_and_Traffic_Database.kind = Database  -- The system queries this database to get the necessary aircraft type and traffic data for rerouting decisions.
    Separation_Rules_Database.kind = Database  -- This database is used to enforce separation rules during flight reassignment.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3, Pre4 extends State {}
-- Pre1: system is in state where runway closure has been declared for runway 27L
-- Pre2: system is in state where flight A123 is scheduled to depart from runway 27L
-- Pre3: system is in state where alternative runways have sufficient capacity and configuration for the aircraft types
-- Pre4: system is in state where real-time knowledge of runway closures and available alternative runways

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where flights are safely and efficiently rerouted
-- Post2: system reaches state where separation rules between all affected flights are maintained


----------------------------------------------------------------------
-- Core operation: REQ_ATC_01
----------------------------------------------------------------------

sig REQ_ATC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ATC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ATC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ATC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ATC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ATC_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ATC_01 {
    some op: REQ_ATC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ATC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ATC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ATC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ATC_01_well_formed {
    all op: REQ_ATC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ATC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? Post1: flights are safely && efficiently rerouted ??

pred ps_reach_Post1 {
    some op: REQ_ATC_01 |
        op.post = Post1 &&
        -- Initiator must be Air_Traffic_Control_Team (the team that reroutes flights)
        op.initiator = Air_Traffic_Control_Team &&
        -- Requires Execute permission (to execute rerouting)
        Execute in op.initiator.mayPerform &&
        -- Must use API as the communication channel
        API in op.channel.(kind) &&
        -- Target must include Aircraft_and_Traffic_Database (to access flight data)
        Aircraft_and_Traffic_Database in op.target &&
        -- The resource must be accessible to the initiator
        op.initiator in op.target.accessible &&
        -- State must actually change from pre to post
        op.pre != op.post &&
        -- At least one channel must be authenticated (per INV-6)
        some c: op.channel | c.authenticated = True
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ATC_01 |
        (op.post = Post1) =>
            -- The operation must involve the Air_Traffic_Control_Team
            op.initiator = Air_Traffic_Control_Team &&
            -- They must have Execute permission (to reroute)
            Execute in op.initiator.mayPerform &&
            -- They must access Aircraft_and_Traffic_Database (flight data for rerouting)
            Aircraft_and_Traffic_Database in op.target &&
            -- Resource must be accessible
            op.initiator in op.target.accessible &&
            -- State must have changed (transition into Post1)
            op.pre != op.post
}

check ps_valid_Post1 for 5

-- ?? Post2: separation rules between all affected flights are maintained ??

pred ps_reach_Post2 {
    some op: REQ_ATC_01 |
        op.post = Post2 &&
        -- Initiator must be Safety_Compliance_Office (responsible for separation rules)
        op.initiator = Safety_Compliance_Office &&
        -- Requires Read permission (to verify rules)
        Read in op.initiator.mayPerform &&
        -- Must use API as the communication channel
        API in op.channel.(kind) &&
        -- Target must include Separation_Rules_Database (to check/maintain rules)
        Separation_Rules_Database in op.target &&
        -- The resource must be accessible to the initiator
        op.initiator in op.target.accessible &&
        -- State must actually change from pre to post
        op.pre != op.post &&
        -- At least one channel must be authenticated (per INV-6)
        some c: op.channel | c.authenticated = True
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_ATC_01 |
        (op.post = Post2) =>
            -- The operation must involve the Safety_Compliance_Office
            op.initiator = Safety_Compliance_Office &&
            -- They must have Read permission (to verify separation rules)
            Read in op.initiator.mayPerform &&
            -- They must access Separation_Rules_Database (rules repository)
            Separation_Rules_Database in op.target &&
            -- Resource must be accessible
            op.initiator in op.target.accessible &&
            -- State must have changed (transition into Post2)
            op.pre != op.post
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ac_reach_1: flight A123 reassigned to alternative runway (modeled as update to Runway_Status_API)
pred ac_reach_1 {
  some op: REQ_ATC_01 |
    Write in op.initiator.mayPerform &&
    Runway_Status_API in op.target &&
    op.post = Post1
}
run ac_reach_1 for 5

-- ac_reach_2: departure time updated with delay (modeled as update to Aircraft_and_Traffic_Database)
pred ac_reach_2 {
  some op: REQ_ATC_01 |
    Write in op.initiator.mayPerform &&
    Aircraft_and_Traffic_Database in op.target &&
    op.post = Post2
}
run ac_reach_2 for 5

-- ac_reach_3: separation rules maintained (show a read-only operation on Separation_Rules_Database that still satisfies invariants)
pred ac_reach_3 {
  some op: REQ_ATC_01 |
    Read in op.initiator.mayPerform &&
    Separation_Rules_Database in op.target &&
    (some c: op.channel | c.authenticated = True) &&
    op.grant = Read
}
run ac_reach_3 for 5

-- ac_reach_4: each flight assigned suitable runway based on aircraft type && traffic (operation uses both Runway_Status_API && Aircraft_and_Traffic_Database with Admin permission)
pred ac_reach_4 {
  some op: REQ_ATC_01 |
    Admin in op.initiator.mayPerform &&
    Runway_Status_API in op.target &&
    Aircraft_and_Traffic_Database in op.target &&
    op.post = Post1
}
run ac_reach_4 for 5

-- ac_safety_5: no two flights assigned same runway within minimum separation time (safety: no two operations share the same runway resource)
assert ac_safety_5 {
  all op1, op2: REQ_ATC_01 |
    op1 != op2 =>
      no (op1.target & op2.target & Runway_Status_API)
}
check ac_safety_5 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_ATC_01 | (op.pre = Pre1) => (op.post = Post1)
}
check ec_safe_1 for 5

assert ec_safe_2 {
  all op: REQ_ATC_01 | (op.pre = Pre2) => (op.post = Post1)
}
check ec_safe_2 for 5

assert ec_safe_3 {
  all op: REQ_ATC_01 | (op.pre = Pre3) => (op.post = Post1)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-ATC-01: Runway closure for single flight
pred tc_ATC_01_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        Aircraft_and_Traffic_Database in op.target &&
        all c: op.channel | c.encrypted = True
}
run tc_ATC_01_holds for 5

assert tc_ATC_01_contract {
    all op: REQ_ATC_01 |
        (op.pre = Pre1) => (op.post = Post1)
}
check tc_ATC_01_contract for 5

-- Scenario TC-ATC-02: Multiple flights affected by a runway closure
pred tc_ATC_02_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        op.grant = Write &&
        op.pre = Pre2 &&
        op.post = Post2 &&
        #op.target > 1 &&
        all c: op.channel | c.encrypted = True
}
run tc_ATC_02_holds for 5

assert tc_ATC_02_contract {
    all op: REQ_ATC_01 |
        (op.pre = Pre2) => (op.post = Post2)
}
check tc_ATC_02_contract for 5

-- Scenario TC-ATC-03: No available alternative runways
pred tc_ATC_03_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        op.grant = Write &&
        op.pre = Pre3 &&
        op.post = Post1 &&
        Database in op.target &&
        all c: op.channel | c.encrypted = True
}
run tc_ATC_03_holds for 5

assert tc_ATC_03_contract {
    all op: REQ_ATC_01 |
        (op.pre = Pre3) => (op.post = Post1)
}
check tc_ATC_03_contract for 5

-- Scenario TC-ATC-04: Flight too large for any alternative runway
pred tc_ATC_04_holds {
    some op: REQ_ATC_01 |
        op.initiator = Air_Traffic_Control_Team &&
        op.grant = Write &&
        op.pre = Pre4 &&
        op.post = Post2 &&
        Runway_Status_API in op.target &&
        all c: op.channel | c.encrypted = True
}
run tc_ATC_04_holds for 5

assert tc_ATC_04_contract {
    all op: REQ_ATC_01 |
        (op.pre = Pre4) => (op.post = Post2)
}
check tc_ATC_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_latency {
    -- Proxy: limiting channel count per operation reduces latency && processing overhead
    all op: REQ_ATC_01 | #op.channel <= 2
}

fact nfr_fact_availability_redundancy {
    -- Proxy: requiring at least 2 channels per operation ensures a backup path, increasing uptime
    all op: REQ_ATC_01 | #op.channel >= 2
}

fact nfr_fact_usability_auth_count {
    -- Proxy: limiting authenticated channels per operation reduces operator cognitive load
    all op: REQ_ATC_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 2
}

assert nfr_assert_scalability_all_actors {
    -- Proxy: every actor must be able to initiate an operation, verifying the system can serve all roles
    all a: Actor | some op: REQ_ATC_01 | op.initiator = a
}
check nfr_assert_scalability_all_actors for 5

