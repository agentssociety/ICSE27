class NuggetConsumer(AsyncWebsocketConsumer):
    """
    Consumer that connects to a personal group (user_{user.id}) to receive
    nugget/streak animation updates after answer submissions.
    Also handles exam timer synchronization if needed.
    """

    async def connect(self):
        """Authenticate and join personal group."""
        if self.scope['user'].is_anonymous:
            await self.close(code=4001)
            return

        self.user = self.scope['user']
        # Personal group for nugget/streak pushes
        self.personal_group = f"user_{self.user.id}"
        await self.channel_layer.group_add(
            self.personal_group,
            self.channel_name
        )

        await self.accept()
        logger.info('NuggetConsumer connected: user=%s', self.user.username)

    async def disconnect(self, close_code):
        """Leave personal group."""
        if hasattr(self, 'personal_group'):
            await self.channel_layer.group_discard(
                self.personal_group,
                self.channel_name
            )
        logger.info('NuggetConsumer disconnected: user=%s', self.user.username)

    # ----------------
    # Message handlers (sent via channel layer from views)
    # ----------------
    async def nugget_update(self, event):
        """
        Handler for 'nugget_update' type messages.
        Sends JSON with animation data to WebSocket.
        """
        await self.send(text_data=json.dumps({
            'type': 'nugget_update',
            'nuggets_earned': event['nuggets_earned'],
            'new_balance': event['new_balance'],
            'current_streak': event['current_streak'],
        }))

    async def exam_timer(self, event):
        """
        Handler for 'exam_timer' type messages (server-sent countdown).
        Sends remaining seconds.
        """
        await self.send(text_data=json.dumps({
            'type': 'exam_timer',
            'remaining_seconds': event['remaining_seconds'],
        }))


