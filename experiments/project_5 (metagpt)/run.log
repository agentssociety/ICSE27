        """
        empty_cohort = Cohort.objects.create(
            creator=self.instructor,
            name='Empty Cohort'
        )
        # No students enrolled, so no attempts
        leaderboard = (
            ExamAttempt.objects
            .filter(
                student__cohort=empty_cohort,
                end_time__gte=timezone.now() - timedelta(days=30),
                end_time__isnull=False,
            )
            .values('student')
            .annotate(total_nuggets=Sum('total_nuggets_earned'))
            .order_by('-total_nuggets')
        )
        self.assertEqual(list(leaderboard), [])

