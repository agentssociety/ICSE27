        self.assertEqual(mastery_entries.count(), 2)
        for entry in mastery_entries:
            if entry.competency == self.comp1:
                self.assertEqual(entry.mastery_percentage, 100.0)
            else:
                self.assertEqual(entry.mastery_percentage, 0.0)

