# gamification/views.py
"""
Views for gamification features: nugget balance, leaderboard, badges, and WebSocket-triggered updates.
Handles student-facing endpoints and badge eligibility checks.
"""
import logging
from datetime import timedelta
from typing import Any, Dict, List, Optional

from django.contrib.auth.decorators import login_required
from django.contrib.auth.models import User
from django.core.exceptions import PermissionDenied
from django.db.models import Sum, Count
from django.http import HttpRequest, JsonResponse
from django.shortcuts import get_object_or_404
from django.utils import timezone
from django.views.decorators.http import require_http_methods

from accounts.models import StudentProfile
from exams.models import Cohort, ExamAttempt
from .models import Badge, StudentBadge, RewardItem

logger = logging.getLogger(__name__)


# ------------------------------------------------------------------
# Helper: Get current student profile (raises PermissionDenied if not student)
# ------------------------------------------------------------------
def _get_student_profile(user: User) -> StudentProfile:
    """Return StudentProfile for user; raises PermissionDenied if not student."""
    try:
        return user.student_profile
    except StudentProfile.DoesNotExist:
        raise PermissionDenied("User is not a student.")


# ------------------------------------------------------------------
# GET /api/gamification/nugget-balance
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def nugget_balance(request: HttpRequest) -> JsonResponse:
    """Return current nugget balance, streak, and max streak for the authenticated student."""
    student = _get_student_profile(request.user)
    return JsonResponse({
        'nugget_balance': student.nugget_balance,
        'current_streak': student.current_streak,
        'max_streak': student.max_streak,
        'last_activity_date': student.last_activity_date.isoformat() if student.last_activity_date else None,
    })


# ------------------------------------------------------------------
# GET /api/gamification/leaderboard?cohort_id=<int>&window_days=<int>
# Default: last 30 days, max 365. If no cohort_id, use all cohorts the student belongs to.
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def leaderboard(request: HttpRequest) -> JsonResponse:
    """Return top students by nuggets earned within a configurable time window.

    Avoids N+1 query by prefetching all StudentProfile objects in one query.
    """
    student = _get_student_profile(request.user)

    # Parse query parameters
    try:
        window_days = int(request.GET.get('window_days', 30))
    except (ValueError, TypeError):
        window_days = 30
    window_days = max(1, min(window_days, 365))

    cohort_id = request.GET.get('cohort_id', None)
    if cohort_id:
        cohort = get_object_or_404(Cohort, pk=cohort_id)
        # Ensure student is in this cohort
        if not cohort.students.filter(pk=student.pk).exists():
            return JsonResponse({'error': 'You are not enrolled in this cohort.'}, status=403)
        target_students = cohort.students.all()
    else:
        # Use all cohorts the student belongs to
        cohorts = Cohort.objects.filter(students=student)
        target_students = StudentProfile.objects.filter(
            cohort__in=cohorts
        ).distinct()

    # Calculate total nuggets earned in the window from exam attempts
    start_date = timezone.now() - timedelta(days=window_days)
    attempts_qs = ExamAttempt.objects.filter(
        student__in=target_students,
        end_time__gte=start_date,
        end_time__isnull=False,
    ).values('student').annotate(
        total_nuggets=Sum('total_nuggets_earned'),
        total_attempts=Count('id')
    ).order_by('-total_nuggets')

    # Prefetch all relevant student profiles in one query to avoid N+1
    student_ids = [entry['student'] for entry in attempts_qs]
    student_map = {
        s.id: s for s in StudentProfile.objects.filter(id__in=student_ids).select_related('user')
    }

    leaderboard_data = []
    for entry in attempts_qs:
        student_obj = student_map.get(entry['student'])
        if student_obj is None:
            continue
        leaderboard_data.append({
            'student_id': student_obj.id,
            'username': student_obj.user.username,
            'tot_nuggets': entry['total_nuggets'] or 0,
            'attempts': entry['total_attempts'],
        })

    return JsonResponse({
        'window_days': window_days,
        'cohort_id': cohort_id,
        'leaderboard': leaderboard_data,
    })


# ------------------------------------------------------------------
# GET /api/gamification/badges
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def badge_list(request: HttpRequest) -> JsonResponse:
    """Return all available badges with their criteria (public)."""
    badges = Badge.objects.all().values('id', 'name', 'description', 'icon_url', 'criteria')
    return JsonResponse({'badges': list(badges)})


# ------------------------------------------------------------------
# GET /api/gamification/student-badges
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def student_badges(request: HttpRequest) -> JsonResponse:
    """Return badges earned by the authenticated student with earned timestamps."""
    student = _get_student_profile(request.user)
    earned = StudentBadge.objects.filter(student=student).select_related('badge')
    data = [{
        'badge_id': sb.badge.id,
        'name': sb.badge.name,
        'description': sb.badge.description,
        'icon_url': sb.badge.icon_url,
        'earned_at': sb.earned_at.isoformat(),
    } for sb in earned]
    return JsonResponse({'student_badges': data})


# ------------------------------------------------------------------
# POST /api/gamification/check-badges
# (Called after exam submission or manually; checks all badges for current student)
# ------------------------------------------------------------------
@login_required
@require_http_methods(["POST"])
def check_badges(request: HttpRequest) -> JsonResponse:
    """Check all badges for eligibility and award any newly earned ones."""
    student = _get_student_profile(request.user)
    # Get all badges that the student does NOT already have
    earned_badge_ids = set(
        StudentBadge.objects.filter(student=student).values_list('badge_id', flat=True)
    )
    potential_badges = Badge.objects.exclude(id__in=earned_badge_ids)

    new_badges = []
    for badge in potential_badges:
        if badge.check_eligibility(student):
            StudentBadge.objects.create(student=student, badge=badge)
            new_badges.append({
                'badge_id': badge.id,
                'name': badge.name,
                'description': badge.description,
            })
            logger.info(
                'Badge awarded: student=%s, badge=%s',
                student.user.username,
                badge.name
            )

    return JsonResponse({
        'new_badges': new_badges,
        'total_earned': len(earned_badge_ids) + len(new_badges),
    })


# ------------------------------------------------------------------
# Helper: Used by views/exams to send nugget update via WebSocket
# (This will be called from exam submission view)
# ------------------------------------------------------------------
def notify_nugget_update(student: StudentProfile, nuggets_earned: int) -> None:
    """
    Send a message to the student's personal WebSocket group
    with new nugget animation data.
    """
    from channels.layers import get_channel_layer
    from asgiref.sync import async_to_sync

    channel_layer = get_channel_layer()
    group_name = f"user_{student.user.id}"
    async_to_sync(channel_layer.group_send)(
        group_name,
        {
            'type': 'nugget_update',
            'nuggets_earned': nuggets_earned,
            'new_balance': student.nugget_balance,
            'current_streak': student.current_streak,
        }
    )


