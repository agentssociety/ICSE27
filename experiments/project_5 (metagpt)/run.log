@login_required
@require_http_methods(["POST"])
def start_exam(request: HttpRequest, exam_id: int) -> HttpResponse:
    """
    Start a new exam attempt for the authenticated student.
    Returns the first question and timer information.
    """
    student = _get_student_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id)

    now = timezone.now()
    if exam.open_date > now or exam.close_date < now:
        return JsonResponse({'error': 'Exam is not currently active.'}, status=400)

    if not exam.cohorts.filter(students=student).exists():
        return JsonResponse({'error': 'You are not enrolled in this exam.'}, status=403)

    existing_attempt = ExamAttempt.objects.filter(
        student=student,
        exam=exam,
        end_time__isnull=True,
    ).first()
    if existing_attempt:
        return _prepare_attempt_response(existing_attempt)

    attempt = ExamAttempt.objects.create(
        student=student,
        exam=exam,
        start_time=now,
        responses={},
        results={},
        total_nuggets_earned=0,
        streak_multiplier=1.0,
    )
    _log_exam_action(
        actor=request.user,
        action='exam_started',
        exam_id=exam.id,
        details={'attempt_id': attempt.id},
    )
    return _prepare_attempt_response(attempt)


