@login_required
@require_http_methods(["POST"])
def start_exam(request: HttpRequest, exam_id: int) -> HttpResponse:
    """
    Start a new exam attempt for the authenticated student.
    Returns the first question and timer information.
    """
    student = _get_student_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id)

    # Check if the exam is currently active
    now = timezone.now()
    if exam.open_date > now or exam.close_date < now:
        return JsonResponse({'error': 'Exam is not currently active.'}, status=400)

    # Check if student is in a cohort assigned to this exam
    if not exam.cohorts.filter(students=student).exists():
        return JsonResponse({'error': 'You are not enrolled in this exam.'}, status=403)

    # Check if there's an existing incomplete attempt (allow resuming? For simplicity, create new)
    existing_attempt = ExamAttempt.objects.filter(
        student=student,
        exam=exam,
        end_time__isnull=True,
    ).first()
    if existing_attempt:
        # Resume existing attempt
        return _prepare_attempt_response(existing_attempt)

    # Create a new attempt
    attempt = ExamAttempt.objects.create(
        student=student,
        exam=exam,
        start_time=now,
        responses={},
        results={},
        total_nuggets_earned=0,
        streak_multiplier=1.0,
    )
    _log_exam_action(
        actor=request.user,
        action='exam_started',
        exam_id=exam.id,
        details={'attempt_id': attempt.id},
    )
    return _prepare_attempt_response(attempt)


def _prepare_attempt_response(attempt: ExamAttempt) -> JsonResponse:
    """
    Helper to build the response when starting or continuing an exam.
    Returns first unanswered question or completion signal.
    """
    exam = attempt.exam
    questions = exam.questions.all().order_by('order')
    answered_ids = set(int(k) for k in (attempt.responses or {}).keys())

    next_question = None
    for q in questions:
        if q.id not in answered_ids:
            next_question = q
            break

    response_data = {
        'attempt_id': attempt.id,
        'exam_title': exam.title,
        'time_limit_minutes': exam.time_limit_minutes,
        'start_time': attempt.start_time.isoformat(),
        'total_questions': questions.count(),
        'answered_count': len(answered_ids),
    }

    if next_question:
        response_data['question'] = _serialize_question(next_question)
        response_data['is_complete'] = False
    else:
        response_data['is_complete'] = True
        response_data['message'] = 'All questions answered. Submit your exam.'

    return JsonResponse(response_data)


def _serialize_question(question: Question) -> Dict[str, Any]:
    """
    Serialize a question for the API response.
    Handles different question types (MCQ, DRAG_DROP, CODE).
    """
    base = {
        'id': question.id,
        'question_type': question.question_type,
        'content': question.content,
        'difficulty': question.difficulty,
        'nugget_multiplier': question.nugget_multiplier,
    }

    # For MCQ, include the options
    if question.question_type == 'MCQ':
        options = question.content.get('options', [])
        base['options'] = options

    # For DRAG_DROP, include draggable items and drop zones
    elif question.question_type == 'DRAG_DROP':
        base['drag_items'] = question.content.get('drag_items', [])
        base['drop_zones'] = question.content.get('drop_zones', [])

    # For CODE, include starter code and language
    elif question.question_type == 'CODE':
        base['starter_code'] = question.content.get('starter_code', '')
        base['language'] = question.content.get('language', 'python')

    return base


