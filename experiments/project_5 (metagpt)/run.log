        self.assertEqual(self.student.max_streak, 1)

        # Add nuggets
        self.student.add_nuggets(10, 'correct answer')
        self.assertEqual(self.student.nugget_balance, 10)

        # Wrong answer resets streak
        self.student.update_streak(False)
        self.assertEqual(self.student.current_streak, 0)
        self.assertEqual(self.student.max_streak, 1)  # max unchanged

