# exams/views.py
"""
Views for exam management: creating, taking, submitting exams and questions.
Handles instructor exam builder and student exam interface.
"""
import json
import logging
from typing import Any, Dict, List, Optional, Tuple, Union
from datetime import datetime, timedelta

from django.contrib.auth.decorators import login_required, user_passes_test
from django.contrib.auth.models import User
from django.db import transaction
from django.db.models import Count, Q, Prefetch
from django.http import (
    HttpRequest,
    HttpResponse,
    JsonResponse,
    HttpResponseForbidden,
    HttpResponseNotFound,
    HttpResponseBadRequest,
)
from django.shortcuts import render, redirect, get_object_or_404
from django.utils import timezone
from django.views.decorators.http import require_http_methods
from django.views.decorators.csrf import csrf_exempt
from django.core.exceptions import ValidationError, PermissionDenied
from rest_framework.decorators import api_view, permission_classes
from rest_framework.permissions import IsAuthenticated, IsAdminUser
from rest_framework.response import Response
from rest_framework import status

# Local imports
from accounts.models import StudentProfile, InstructorProfile
from accounts.views import login_required as custom_login_required
from analytics.utils import update_competency_masteries, get_student_competency_breakdown
from audit.models import AuditLog
from .models import Exam, Question, Competency, Cohort, ExamAttempt
from .forms import ExamForm, QuestionForm, CompetencyForm
from gamification.models import Badge, StudentBadge


logger = logging.getLogger(__name__)


# ============================================================
# HELPER FUNCTIONS
# ============================================================

def _get_student_profile(user: User) -> StudentProfile:
    """
    Retrieve the StudentProfile for a user.
    Raises PermissionDenied if the user is not a student.
    """
    try:
        return user.student_profile
    except StudentProfile.DoesNotExist:
        raise PermissionDenied("User is not a student.")


def _get_instructor_profile(user: User) -> InstructorProfile:
    """
    Retrieve the InstructorProfile for a user.
    Raises PermissionDenied if the user is not an instructor.
    """
    try:
        return user.instructor_profile
    except InstructorProfile.DoesNotExist:
        raise PermissionDenied("User is not an instructor.")


def _log_exam_action(
    actor: User,
    action: str,
    exam_id: Optional[int] = None,
    details: Optional[Dict[str, Any]] = None,
) -> None:
    """
    Helper to log exam-related actions to the audit log.
    """
    AuditLog.log(
        action=action,
        actor=actor,
        resource_type='exam',
        resource_id=exam_id,
        details=details or {},
    )


def _calculate_streak_multiplier(student: StudentProfile) -> float:
    """
    Calculate the nugget multiplier based on current streak.
    Multiplier increases by 0.1 for each streak day, max 2.0x.
    """
    base_multiplier = 1.0
    max_multiplier = 2.0
    increment_per_streak = 0.1

    multiplier = base_multiplier + (student.current_streak * increment_per_streak)
    return min(multiplier, max_multiplier)


# ============================================================
# EXAM CRUD (Instructor)
# ============================================================

@login_required
@require_http_methods(["GET", "POST"])
def exam_list_create(request: HttpRequest) -> HttpResponse:
    """
    List all exams (instructor sees own, student sees available) or create a new exam.
    """
    user = request.user

    if request.method == "GET":
        if hasattr(user, 'instructor_profile'):
            exams = Exam.objects.filter(creator=user.instructor_profile).order_by('-created_at')
        elif hasattr(user, 'student_profile'):
            # Students see exams from cohorts they belong to
            student = user.student_profile
            cohorts = Cohort.objects.filter(students=student)
            exams = Exam.objects.filter(
                cohorts__in=cohorts,
                open_date__lte=timezone.now(),
                close_date__gte=timezone.now(),
            ).distinct().order_by('-open_date')
        else:
            exams = Exam.objects.none()

        return render(request, 'exams/exam_list.html', {'exams': exams})

    elif request.method == "POST":
        instructor = _get_instructor_profile(user)
        form = ExamForm(request.POST)
        if form.is_valid():
            exam = form.save(commit=False)
            exam.creator = instructor
            exam.save()
            form.save_m2m()  # Save many-to-many relationships (cohorts)
            _log_exam_action(
                actor=user,
                action='exam_created',
                exam_id=exam.id,
                details={'title': exam.title},
            )
            return JsonResponse({'id': exam.id, 'title': exam.title}, status=201)
        else:
            return JsonResponse({'errors': form.errors}, status=400)


@login_required
@require_http_methods(["GET", "PUT", "DELETE"])
def exam_detail(request: HttpRequest, exam_id: int) -> HttpResponse:
    """
    Retrieve, update, or delete an exam.
    Only the creator (instructor) can modify or delete.
    """
    instructor = _get_instructor_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id, creator=instructor)

    if request.method == "GET":
        return render(request, 'exams/exam_detail.html', {
            'exam': exam,
            'questions': exam.questions.all().order_by('order'),
            'competencies': Competency.objects.filter(question__exam=exam).distinct(),
        })

    elif request.method == "PUT":
        form = ExamForm(request.PUT, instance=exam)
        if form.is_valid():
            form.save()
            _log_exam_action(
                actor=request.user,
                action='exam_updated',
                exam_id=exam.id,
                details={'title': exam.title},
            )
            return JsonResponse({'id': exam.id, 'title': exam.title})
        else:
            return JsonResponse({'errors': form.errors}, status=400)

    elif request.method == "DELETE":
        exam.delete()
        _log_exam_action(
            actor=request.user,
            action='exam_deleted',
            exam_id=exam_id,
            details={},
        )
        return JsonResponse({'message': 'Exam deleted.'})


