@login_required
@require_http_methods(["POST"])
def cohort_enroll_student(request: HttpRequest, cohort_id: int) -> HttpResponse:
    """Enroll a student in a cohort. Expects JSON with 'student_id' or 'student_email'."""
    instructor = _get_instructor_profile(request.user)
    cohort = get_object_or_404(Cohort, pk=cohort_id, creator=instructor)

    try:
        data = json.loads(request.body)
    except json.JSONDecodeError:
        return JsonResponse({'error': 'Invalid JSON.'}, status=400)

    student_id = data.get('student_id')
    student_email = data.get('student_email')

    if student_id:
        student = get_object_or_404(StudentProfile, pk=student_id)
    elif student_email:
        try:
            user = User.objects.get(email=student_email)
            student = get_object_or_404(StudentProfile, user=user)
        except User.DoesNotExist:
            return JsonResponse({'error': 'User with this email does not exist.'}, status=404)
    else:
        return JsonResponse({'error': 'Provide student_id or student_email.'}, status=400)

    if student in cohort.students.all():
        return JsonResponse({'message': 'Student already enrolled.'}, status=200)

    cohort.students.add(student)
    _log_exam_action(
        actor=request.user,
        action='student_enrolled',
        details={
            'cohort_id': cohort_id,
            'student_id': student.id,
        },
    )
    return JsonResponse({'message': f'Student {student.user.username} enrolled in {cohort.name}.'}, status=200)


