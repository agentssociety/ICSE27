"""
Integration tests for the competency-based exam platform.
Covers full end-to-end flows: user registration, exam creation, exam taking,
gamification (nuggets, streaks, badges), store redemption, and analytics.
Uses Django's TestCase with in-memory channel layer for WebSocket simulation.
"""
import json
from datetime import timedelta
from unittest.mock import patch

from asgiref.sync import async_to_sync
from channels.layers import get_channel_layer
from channels.testing import ChannelsLiveServerTestCase
from django.conf import settings
from django.contrib.auth.models import User
from django.test import TestCase, override_settings
from django.utils import timezone

from accounts.models import StudentProfile, InstructorProfile
from analytics.models import CompetencyMastery
from analytics.utils import get_student_competency_breakdown
from audit.models import AuditLog
from exams.models import Exam, Question, Competency, Cohort, ExamAttempt
from gamification.models import Badge, StudentBadge, RewardItem
from store.models import Redemption


# Use in-memory channel layer for tests to avoid Redis dependency
@override_settings(CHANNEL_LAYERS={
    'default': {
        'BACKEND': 'channels.layers.InMemoryChannelLayer',
    },
})
class IntegrationTest(TestCase):
    """Integration tests covering core user stories."""

    def setUp(self):
        """Create test users, cohorts, exam, and initial data."""
        # Create instructor
        self.instructor_user = User.objects.create_user(
            username='instructor1',
            email='instructor@test.com',
            password='testpass123'
        )
        self.instructor = InstructorProfile.objects.create(
            user=self.instructor_user,
            department='Computer Science'
        )

        # Create student
        self.student_user = User.objects.create_user(
            username='student1',
            email='student@test.com',
            password='testpass123'
        )
        self.student = StudentProfile.objects.create(
            user=self.student_user,
            nugget_balance=0,
            current_streak=0,
            max_streak=0,
            last_activity_date=None,
        )

        # Create cohort and enroll student
        self.cohort = Cohort.objects.create(
            creator=self.instructor,
            name='Test Cohort'
        )
        self.cohort.students.add(self.student)

        # Create competencies
        self.comp1 = Competency.objects.create(
            name='Python Basics',
            description='Basic Python syntax and semantics',
            mastery_threshold=80
        )
        self.comp2 = Competency.objects.create(
            name='Data Structures',
            description='Lists, dicts, sets',
            mastery_threshold=70
        )

        # Create exam
        self.exam = Exam.objects.create(
            creator=self.instructor,
            title='Midterm Exam',
            description='Test your Python knowledge',
            open_date=timezone.now() - timedelta(days=1),
            close_date=timezone.now() + timedelta(days=7),
            time_limit_minutes=30,
        )
        self.exam.cohorts.add(self.cohort)

        # Create two questions (MCQ and Code)
        self.q1 = Question.objects.create(
            exam=self.exam,
            question_type='MCQ',
            content={
                'question_text': 'What is 2+2?',
                'options': ['3', '4', '5', '6'],
                'correct_option': 1,
                'explanation': 'Basic addition'
            },
            difficulty='BEGINNER',
            nugget_multiplier=1.0,
            order=1,
        )
        self.q1.competencies.add(self.comp1)

        self.q2 = Question.objects.create(
            exam=self.exam,
            question_type='CODE',
            content={
                'question_text': 'Write a function that returns the sum of two numbers.',
                'starter_code': 'def add(a, b):\n    pass',
                'solution': 'def add(a, b):\n    return a + b',
                'language': 'python',
                'test_cases': [
                    {'input': [1, 2], 'expected': 3},
                    {'input': [10, -5], 'expected': 5},
                ]
            },
            difficulty='INTERMEDIATE',
            nugget_multiplier=2.0,
            order=2,
        )
        self.q2.competencies.add(self.comp2)

        # Create a badge for earning nuggets
        self.badge = Badge.objects.create(
            name='First Nuggets',
            description='Earn your first 10 nuggets',
            criteria={
                'field': 'nugget_balance',
                'operator': '>=',
                'value': 10
            },
        )

        # Create a reward item
        self.reward = RewardItem.objects.create(
            name='Virtual Hat',
            description='A cool virtual hat for your avatar',
            nugget_cost=50,
            item_type='VIRTUAL',
            stock=10
        )

    # ------------------------------------------------------------------
    # Helper methods
    # ------------------------------------------------------------------
    def _login(self, user):
        """Log in a user via the test client."""
        self.client.login(username=user.username, password='testpass123')

    def _start_exam(self, student_user):
        """Start an exam and return the response."""
        self._login(student_user)
        return self.client.post(f'/api/exams/{self.exam.id}/start/')

    def _submit_answer(self, student_user, question_id, response):
        """Submit an answer for a question."""
        self._login(student_user)
        return self.client.post(
            f'/api/exams/{self.exam.id}/submit-answer/',
            data=json.dumps({
                'question_id': question_id,
                'response': response
            }),
            content_type='application/json'
        )

    def _submit_exam(self, student_user):
        """Finalize the exam attempt."""
        self._login(student_user)
        return self.client.post(f'/api/exams/{self.exam.id}/submit/')

    # ------------------------------------------------------------------
    # Integration tests
    # ------------------------------------------------------------------
    def test_full_student_exam_flow(self):
        """
        Complete student exam taking flow:
        - Register, login, start exam
        - Answer two questions (one correct, one incorrect)
        - Verify nugget and streak updates
        - Submit exam and check competency breakdown
        """
        # 1. Start exam
        response = self._start_exam(self.student_user)
        self.assertEqual(response.status_code, 200)
        data = response.json()
        self.assertIn('attempt_id', data)
        self.assertFalse(data['is_complete'])
        self.assertEqual(data['exam_title'], 'Midterm Exam')

        attempt_id = data['attempt_id']
        attempt = ExamAttempt.objects.get(pk=attempt_id)
        self.assertIsNotNone(attempt)
        self.assertIsNone(attempt.end_time)

        # 2. Answer first question correctly (MCQ)
        response = self._submit_answer(self.student_user, self.q1.id, 1)  # correct index 1 = '4'
        self.assertEqual(response.status_code, 200)
        result = response.json()
        self.assertTrue(result['correct'])
        self.assertGreater(result['nuggets_earned'], 0)
        # Nuggets should be baseline * multiplier (1.0 * 1.0 = 1) with streak 1 => 1.1
        # But streak update occurs inside submit_answer; we check later.
        self.assertEqual(result['current_streak'], 1)

        # Refresh student profile
        self.student.refresh_from_db()
        self.assertEqual(self.student.current_streak, 1)

        # 3. Answer second question incorrectly (CODE)
        # Send a wrong code (does not match solution)
        response = self._submit_answer(self.student_user, self.q2.id, 'def add(a,b): return a-b')
        self.assertEqual(response.status_code, 200)
        result2 = response.json()
        self.assertFalse(result2['correct'])
        self.assertEqual(result2['nuggets_earned'], 0)  # incorrect => 0 nuggets
        self.assertEqual(result2['current_streak'], 0)  # streak reset

        self.student.refresh_from_db()
        self.assertEqual(self.student.current_streak, 0)

        # 4. Submit exam
        response = self._submit_exam(self.student_user)
        self.assertEqual(response.status_code, 200)
        final_data = response.json()
        self.assertIn('competency_breakdown', final_data)
        self.assertIn('study_tips', final_data)

        breakdown = final_data['competency_breakdown']
        # Python Basics: 1 correct out of 1 = 100%
        self.assertIn('Python Basics', breakdown)
        self.assertEqual(breakdown['Python Basics'], 100.0)
        # Data Structures: 0 correct out of 1 = 0%
        self.assertIn('Data Structures', breakdown)
        self.assertEqual(breakdown['Data Structures'], 0.0)

        # Verify CompetencyMastery cache updated
        mastery = CompetencyMastery.objects.filter(
            student=self.student,
            exam=self.exam,
            competency=self.comp1
        ).first()
        self.assertIsNotNone(mastery)
        self.assertEqual(mastery.mastery_percentage, 100.0)

        # 5. Verify total nuggets earned (1 for correct answer with streak multiplier 1.0)
        attempt.refresh_from_db()
        expected_nuggets = 1.0  # baseline * multiplier * streak_multiplier (1.0*1.0*1.0=1)
        self.assertEqual(attempt.total_nuggets_earned, expected_nuggets)

    def test_badge_eligibility_after_exam(self):
        """
        After earning enough nuggets, student should be awarded the 'First Nuggets' badge.
        We'll manually add nuggets and check badge assignment.
        """
        # Manually set nugget balance to trigger badge
        self.student.nugget_balance = 15
        self.student.save(update_fields=['nugget_balance'])

        # Call check-badges endpoint
        self._login(self.student_user)
        response = self.client.post('/api/gamification/check-badges/')
        self.assertEqual(response.status_code, 200)
        data = response.json()
        self.assertGreater(len(data['new_badges']), 0)
        badge_names = [b['name'] for b in data['new_badges']]
        self.assertIn('First Nuggets', badge_names)

        # Verify StudentBadge created
        student_badge = StudentBadge.objects.filter(
            student=self.student,
            badge=self.badge
        ).first()
        self.assertIsNotNone(student_badge)

    def test_store_redemption_flow(self):
        """
        Student with enough nuggets can redeem an item.
        Test atomic deduction and redemption record creation.
        """
        # Give student enough nuggets
        self.student.nugget_balance = 100
        self.student.save(update_fields=['nugget_balance'])

        self._login(self.student_user)
        response = self.client.post(
            '/api/store/redeem/',
            data=json.dumps({'item_id': self.reward.id}),
            content_type='application/json'
        )
        self.assertEqual(response.status_code, 201)
        data = response.json()
        self.assertEqual(data['status'], 'COMPLETED')
        self.assertEqual(data['item_name'], 'Virtual Hat')
        self.assertIsNotNone(data['redemption_id'])

        # Check nugget deduction
        self.student.refresh_from_db()
        self.assertEqual(self.student.nugget_balance, 50)  # 100 - 50

        # Check stock decrement
        self.reward.refresh_from_db()
        self.assertEqual(self.reward.stock, 9)

        # Check redemption record
        redemption = Redemption.objects.get(pk=data['redemption_id'])
        self.assertEqual(redemption.student, self.student)
        self.assertEqual(redemption.reward_item, self.reward)
        self.assertEqual(redemption.status, 'COMPLETED')

    def test_analytics_endpoint(self):
        """
        Instructor can retrieve heatmap and radar data after students complete exams.
        """
        # Have student complete the exam
        self.test_full_student_exam_flow()

        # Instructor log in and request analytics
        self._login(self.instructor_user)
        response = self.client.get(f'/api/analytics/exam/{self.exam.id}/')
        self.assertEqual(response.status_code, 200)
        data = response.json()
        self.assertEqual(data['exam_title'], 'Midterm Exam')
        self.assertEqual(data['total_attempts'], 1)
        self.assertAlmostEqual(data['average_score'], 50.0)  # one correct out of two

        # Check heatmap
        heatmap = data['competency_heatmap']
        self.assertEqual(len(heatmap), 2)  # one student, two competencies
        # Find entries for our student
        student_entries = [h for h in heatmap if h['student_name'] == 'student1']
        self.assertEqual(len(student_entries), 2)

    def test_audit_log_creation(self):
        """Verify that audit logs are created for key actions (exam start, answer, submit)."""
        self._login(self.student_user)
        # Trigger exam start
        self._start_exam(self.student_user)

        # Check audit log exists for exam_started
        audit_logs = AuditLog.objects.filter(action='exam_started', actor=self.student_user)
