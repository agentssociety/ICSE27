"""
Models for gamification: Badges, StudentBadges, and RewardItems.
Manages achievements and virtual rewards within the exam platform.
"""
import operator
from typing import Any, Dict, Union
from django.db import models
from django.utils import timezone


# Define a mapping of string operators to Python operator functions
OPERATOR_MAP = {
    '>=': operator.ge,
    '<=': operator.le,
    '>': operator.gt,
    '<': operator.lt,
    '==': operator.eq,
    '!=': operator.ne,
}


class Badge(models.Model):
    """
    Represents an achievement badge that students can earn.
    The criteria field defines conditions for eligibility (JSON format).
    """
    name = models.CharField(
        max_length=200,
        unique=True,
        help_text='Display name of the badge.'
    )
    description = models.TextField(
        max_length=500,
        blank=True,
        default='',
        help_text='Detailed description of how to earn this badge.'
    )
    icon_url = models.URLField(
        max_length=500,
        blank=True,
        default='',
        help_text='URL to the badge icon image.'
    )
    criteria = models.JSONField(
        default=dict,
        blank=True,
        help_text='JSON object defining conditions for earning the badge. '
                  'Expected format: {"field": "<field_path>", "operator": "<op>", "value": <value>}. '
                  'Supported operators: >=, <=, >, <, ==, !=. '
                  'Field path can be dotted (e.g., "student_profile.nugget_balance").'
    )

    class Meta:
        app_label = 'gamification'
        verbose_name = 'Badge'
        verbose_name_plural = 'Badges'
        ordering = ['name']

    def __str__(self) -> str:
        return self.name

    def check_eligibility(self, student_profile: 'StudentProfile') -> bool:
        """
        Evaluate whether a student qualifies for this badge based on criteria.
        Performs a simple field comparison using the student's related data.

        Args:
            student_profile: The StudentProfile instance to check.

        Returns:
            True if the student meets all criteria defined in the badge.
            False if any condition fails or criteria is malformed.
        """
        if not self.criteria:
            return False  # No criteria means badge is not earnable

        # Support multiple conditions: if criteria is a list, all must be met
        conditions = self.criteria if isinstance(self.criteria, list) else [self.criteria]

        for condition in conditions:
            # Expected keys: "field", "operator", "value"
            field_path = condition.get('field')
            operator_str = condition.get('operator')
            target_value = condition.get('value')

            if not field_path or not operator_str or target_value is None:
                # Malformed condition; skip or fail
                return False

            # Resolve the field value using getattr with dotted path support
            value = self._resolve_field(student_profile, field_path)
            if value is None:
                return False  # Field does not exist or is inaccessible

            # Get the comparison operator
            op_func = OPERATOR_MAP.get(operator_str)
            if op_func is None:
                return False  # Unsupported operator

            # Attempt to compare; ensure type compatibility (e.g., convert to int if possible)
            try:
                if not isinstance(value, type(target_value)):
                    # Attempt conversion to the target type
                    target_type = type(target_value)
                    value = target_type(value)
                if not op_func(value, target_value):
                    return False
            except (TypeError, ValueError):
                return False

        return True

    def _resolve_field(self, instance: Any, dotted_path: str) -> Any:
        """
        Resolve a dotted attribute path on an object (e.g., 'user.username').
        Returns the attribute value or None if any part is missing.

        Args:
            instance: The starting object (StudentProfile).
            dotted_path: Dot-separated attribute names.

        Returns:
            The resolved attribute value, or None if not found.
        """
        parts = dotted_path.split('.')
        current = instance
        for part in parts:
            if not hasattr(current, part):
                return None
            current = getattr(current, part)
        return current


class StudentBadge(models.Model):
    """
    Records when a specific student earned a specific badge.
    Each student can earn a badge only once (unique constraint).
    """
    student = models.ForeignKey(
        'accounts.StudentProfile',
        on_delete=models.CASCADE,
        related_name='student_badges',
        help_text='The student who earned the badge.'
    )
    badge = models.ForeignKey(
        Badge,
        on_delete=models.CASCADE,
        related_name='earned_by',
        help_text='The badge that was earned.'
    )
    earned_at = models.DateTimeField(
        default=timezone.now,
        help_text='Timestamp when the badge was awarded.'
    )

    class Meta:
        app_label = 'gamification'
        verbose_name = 'Student Badge'
        verbose_name_plural = 'Student Badges'
        unique_together = ('student', 'badge')
        ordering = ['-earned_at']

    def __str__(self) -> str:
        return f"{self.student.user.username} earned '{self.badge.name}'"


class RewardItem(models.Model):
    """
    Represents a purchasable item in the nugget store.
    Can be virtual items or digital vouchers (perks).
    """
    ITEM_TYPE_CHOICES = [
        ('VIRTUAL', 'Virtual Good'),
        ('PERK', 'Digital Perk'),
    ]

    name = models.CharField(
        max_length=200,
        help_text='Display name of the reward item.'
    )
    description = models.TextField(
        max_length=500,
        blank=True,
        default='',
        help_text='Detailed description of the reward.'
    )
    nugget_cost = models.PositiveIntegerField(
        help_text='Number of nuggets required to redeem this item.'
    )
    item_type = models.CharField(
        max_length=20,
        choices=ITEM_TYPE_CHOICES,
        default='VIRTUAL',
        help_text='Type of reward: VIRTUAL (cosmetic) or PERK (redeemable code).'
    )
    stock = models.IntegerField(
        default=-1,
        help_text='Number of items available. -1 means unlimited.'
    )

    class Meta:
        app_label = 'gamification'
        verbose_name = 'Reward Item'
        verbose_name_plural = 'Reward Items'
        ordering = ['nugget_cost']

    def __str__(self) -> str:
        return f"{self.name} ({self.nugget_cost} nuggets)"

    def is_available(self) -> bool:
        """
        Check if the item is currently in stock (unlimited or count > 0).

        Returns:
            True if the item can be redeemed.
        """
        return self.stock == -1 or self.stock > 0

    def redeem(self, student_profile: 'StudentProfile') -> bool:
        """
        Attempt to redeem this reward item for a student.
        Checks stock and nugget balance, deducts nuggets, decrements stock.

        Args:
            student_profile: The student trying to redeem the item.

        Returns:
            True if redemption was successful, False otherwise.
        """
        if not self.is_available():
            return False

        # Check if student has enough nuggets
        if student_profile.nugget_balance < self.nugget_cost:
            return False

        # Atomic redemption: deduct nuggets and decrease stock
        from django.db import transaction

        with transaction.atomic():
            # Re-check conditions within the transaction
            student_ref = type(student_profile).objects.select_for_update().get(
                pk=student_profile.pk
            )
            if student_ref.nugget_balance < self.nugget_cost:
                return False

            self_ref = type(self).objects.select_for_update().get(pk=self.pk)
            if not self_ref.is_available():
                return False

            # Deduct nuggets
            student_ref.nugget_balance -= self.nugget_cost
            student_ref.save(update_fields=['nugget_balance'])

            # Decrement stock if not unlimited
            if self_ref.stock != -1:
                self_ref.stock -= 1
                self_ref.save(update_fields=['stock'])

        # TODO: For PERK items, generate or reserve a voucher code.
        # This placeholder logs a message; actual implementation depends on external system.
        if self.item_type == 'PERK':
            import logging
            logger = logging.getLogger(__name__)
            logger.info(
                'Perk redeemed: student=%s, item=%s. Voucher generation required.',
                student_profile.user.username,
                self.name
            )

        return True
