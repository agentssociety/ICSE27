@login_required
@require_http_methods(["GET", "POST"])
def question_list_create(request: HttpRequest, exam_id: int) -> HttpResponse:
    """
    List or create questions for a specific exam.
    """
    instructor = _get_instructor_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id, creator=instructor)

    if request.method == "GET":
        questions = exam.questions.all().order_by('order')
        return render(request, 'exams/question_list.html', {
            'exam': exam,
            'questions': questions,
        })

    elif request.method == "POST":
        form = QuestionForm(request.POST)
        if form.is_valid():
            question = form.save(commit=False)
            question.exam = exam
            if question.order is None:
                max_order = exam.questions.aggregate(Max('order'))['order__max'] or 0
                question.order = max_order + 1
            question.save()
            form.save_m2m()  # Save competencies
            _log_exam_action(
                actor=request.user,
                action='question_created',
                exam_id=exam.id,
                details={
                    'question_id': question.id,
                    'question_type': question.question_type,
                },
            )
            return JsonResponse({'id': question.id, 'content': question.content}, status=201)
        else:
            return JsonResponse({'errors': form.errors}, status=400)


