        # Check eligibility manually (as done by check_badges endpoint)
        self.assertTrue(self.badge.check_eligibility(self.student))

        # Award badge
        StudentBadge.objects.create(student=self.student, badge=self.badge)
        badges = StudentBadge.objects.filter(student=self.student)
        self.assertEqual(badges.count(), 1)

    def test_store_redemption_atomicity(self):
        """
        Test that redemption correctly deducts nuggets, decrements stock,
        and creates a Redemption record with atomicity.
        """
        self.student.nugget_balance = 100
        self.student.save()

        # Successful redemption
        redemption = Redemption.create_redemption(self.student, self.reward)
        self.assertIsNotNone(redemption)
        self.assertEqual(redemption.status, Redemption.Status.COMPLETED)
        self.student.refresh_from_db()
        self.assertEqual(self.student.nugget_balance, 50)  # 100 - 50
        self.reward.refresh_from_db()
        self.assertEqual(self.reward.stock, 9)

        # Insufficient nuggets (student has 50, item costs 50, but student still has 50 after first redemption)
        # Actually after first redemption, student has 50, so trying to redeem again (cost 50) should succeed
        # Let's adjust: use a second student with low balance
        student2_user = User.objects.create_user(
            username='student_low',
            email='low@test.com',
            password='testpass123'
        )
        student2 = StudentProfile.objects.create(
            user=student2_user,
            nugget_balance=10,
        )
        with self.assertRaises(ValueError):
            Redemption.create_redemption(student2, self.reward)

        # Out-of-stock scenario
        self.student.nugget_balance = 200
        self.student.save()
        self.reward.stock = 0
        self.reward.save()
        with self.assertRaises(ValueError):
            Redemption.create_redemption(self.student, self.reward)

        # Redemption cancellation
        self.reward.stock = 10
        self.reward.save()
        self.student.nugget_balance = 100
        self.student.save()
        redemption2 = Redemption.create_redemption(self.student, self.reward)
        self.student.refresh_from_db()
        balance_before_cancel = self.student.nugget_balance
        redemption2.cancel(reason='Testing cancellation')
        self.student.refresh_from_db()
        self.assertEqual(self.student.nugget_balance,
                         balance_before_cancel + self.reward.nugget_cost)
        self.reward.refresh_from_db()
        self.assertEqual(self.reward.stock, 10)  # restored to original (10)
        self.assertEqual(redemption2.status, Redemption.Status.CANCELLED)

    def test_gamification_reward_item_redeem_method(self):
        """
