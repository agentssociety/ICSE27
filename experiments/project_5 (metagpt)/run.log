@login_required
@require_http_methods(["GET", "POST"])
def cohort_list_create(request: HttpRequest) -> HttpResponse:
    """
    List or create cohorts for the instructor.
    """
    instructor = _get_instructor_profile(request.user)

    if request.method == "GET":
        cohorts = Cohort.objects.filter(creator=instructor).order_by('name')
        return render(request, 'exams/cohort_list.html', {'cohorts': cohorts})

    elif request.method == "POST":
        name = request.POST.get('name', '').strip()
