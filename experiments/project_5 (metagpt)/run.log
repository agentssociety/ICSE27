```html
<!-- templates/instructor/exam_builder.html -->
{% extends "base_instructor.html" %}
{% block title %}Exam Builder{% endblock %}

{% block content %}
<div class="exam-builder" x-data="examBuilder()">
    <h1>{% if exam %}Edit Exam{% else %}Create New Exam{% endif %}</h1>

    <form @submit.prevent="saveExam" class="exam-form">
        <div class="form-group">
            <label for="title">Exam Title</label>
            <input type="text" id="title" x-model="form.title" required class="form-control">
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" x-model="form.description" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="open_date">Open Date</label>
                <input type="datetime-local" id="open_date" x-model="form.open_date" required class="form-control">
            </div>
            <div class="form-group">
                <label for="close_date">Close Date</label>
                <input type="datetime-local" id="close_date" x-model="form.close_date" required class="form-control">
            </div>
        </div>

        <div class="form-group">
            <label for="time_limit">Time Limit (minutes)</label>
            <input type="number" id="time_limit" x-model="form.time_limit_minutes" min="1" class="form-control">
        </div>

        <div class="form-group">
            <label>Cohorts</label>
            <div class="cohort-checkboxes">
                <template x-for="cohort in cohorts" :key="cohort.id">
                    <label class="checkbox-label">
                        <input type="checkbox" :value="cohort.id" x-model="form.cohorts">
                        <span x-text="cohort.name"></span>
                    </label>
                </template>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" x-text="saving ? 'Saving...' : 'Save Exam'"></button>
    </form>

    <div class="questions-section" x-show="examId">
        <h2>Questions</h2>
        <div class="question-list">
            <template x-for="(question, index) in questions" :key="question.id">
                <div class="question-card">
                    <div class="question-header">
                        <span class="question-number" x-text="index + 1"></span>
                        <span class="question-type" x-text="question.question_type"></span>
                        <button @click="editQuestion(question.id)" class="btn btn-sm">Edit</button>
                        <button @click="deleteQuestion(question.id)" class="btn btn-sm btn-danger">Delete</button>
                    </div>
                    <div class="question-preview" x-text="question.content.text"></div>
                </div>
            </template>
        </div>
        <button @click="addQuestion()" class="btn btn-secondary">Add Question</button>
    </div>
</div>
{% endblock %}

{% block extra_scripts %}
<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('examBuilder', () => ({
            form: {
                title: '{{ exam.title|default:"" }}',
                description: '{{ exam.description|default:"" }}',
                open_date: '{{ exam.open_date|date:"Y-m-d\\TH:i"|default:"" }}',
                close_date: '{{ exam.close_date|date:"Y-m-d\\TH:i"|default:"" }}',
                time_limit_minutes: {{ exam.time_limit_minutes|default:"60" }},
                cohorts: []
            },
            examId: {{ exam.id|default:"null" }},
            cohorts: [],
            questions: [],
            saving: false,

            async init() {
                await this.loadCohorts();
                if (this.examId) {
                    await this.loadQuestions();
                }
            },

            async loadCohorts() {
                try {
                    const response = await fetch('/api/exams/cohorts/');
                    const data = await response.json();
                    this.cohorts = data.cohorts || [];
                } catch (error) {
                    console.error('Failed to load cohorts:', error);
                }
            },

            async loadQuestions() {
                try {
                    const response = await fetch(`/api/exams/${this.examId}/questions/`);
                    const data = await response.json();
                    this.questions = data.questions || [];
                } catch (error) {
                    console.error('Failed to load questions:', error);
                }
            },

            async saveExam() {
                this.saving = true;
                try {
                    const method = this.examId ? 'PUT' : 'POST';
                    const url = this.examId ? `/api/exams/${this.examId}/` : '/api/exams/';
                    const response = await fetch(url, {
                        method: method,
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify(this.form)
                    });
                    const data = await response.json();
                    if (response.ok) {
                        this.examId = data.id;
                        alert('Exam saved successfully!');
                    } else {
                        alert('Error: ' + JSON.stringify(data.errors));
                    }
                } catch (error) {
                    console.error('Failed to save exam:', error);
                    alert('Failed to save exam');
                } finally {
                    this.saving = false;
                }
            },

            addQuestion() {
                window.location.href = `/exams/${this.examId}/questions/new/`;
            },

            editQuestion(questionId) {
                window.location.href = `/exams/${this.examId}/questions/${questionId}/`;
            },

            async deleteQuestion(questionId) {
                if (!confirm('Are you sure you want to delete this question?')) return;
                try {
                    const response = await fetch(`/api/exams/${this.examId}/questions/${questionId}/`, {
                        method: 'DELETE'
                    });
                    if (response.ok) {
                        this.questions = this.questions.filter(q => q.id !== questionId);
                    }
                } catch (error) {
                    console.error('Failed to delete question:', error);
                }
            }
        }))
    })
</script>
{% endblock %}
```

