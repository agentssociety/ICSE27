            Newly created Redemption instance with status=COMPLETED.

        Raises:
            ValueError: If stock is empty or insufficient nuggets.
        """
        with transaction.atomic():
            # Lock the student and item rows to prevent race conditions
            student = type(student_profile).objects.select_for_update().get(
                pk=student_profile.pk
            )
            item = GamificationRewardItem.objects.select_for_update().get(
                pk=reward_item.pk
            )

            # Validate conditions
            if not item.is_available():
                raise ValueError(f'Item {item.name} is out of stock.')
            if student.nugget_balance < item.nugget_cost:
                raise ValueError(
                    f'Insufficient nuggets: have {student.nugget_balance}, need {item.nugget_cost}.'
                )

            # Deduct nuggets
            student.nugget_balance -= item.nugget_cost
            student.save(update_fields=['nugget_balance'])

            # Decrement stock if not unlimited
            if item.stock != -1:
                item.stock -= 1
                item.save(update_fields=['stock'])

            # Create redemption record
            redemption = cls(
                student=student,
                reward_item=item,
                status=cls.Status.COMPLETED,
                # For PERK items, generate a placeholder voucher (actual generation depends on external system)
                voucher_code='' if item.item_type != 'PERK' else f'PERK-{student.pk}-{timezone.now().timestamp()}'
            )
            redemption.save()

        return redemption

    def mark_as_used(self) -> None:
        """
        Mark this redemption as used (e.g., after the student claims a perk).
        Can only be called on completed redemptions.
        """
        if self.status != self.Status.COMPLETED:
            raise ValidationError('Only completed redemptions can be marked as used.')
        with transaction.atomic():
            # Lock the redemption row to prevent double-use
            redemption = type(self).objects.select_for_update().get(pk=self.pk)
            if redemption.status != self.Status.COMPLETED:
                raise ValidationError('Redemption status changed before processing (expected COMPLETED).')
            redemption.status = self.Status.USED
            redemption.save(update_fields=['status'])
            # Synchronize local instance with database
            self.status = redemption.status

    def cancel(self, reason: str = 'Cancelled by system') -> None:
        """
        Cancel the redemption and refund the nuggets.
        Only works for completed redemptions (not yet used).
        Refunding restores stock if applicable.

        Args:
            reason: A descriptive reason for the cancellation. Must be non-empty.
        """
        if not reason:
            raise ValueError('A reason must be provided for cancellation.')
        if self.status != self.Status.COMPLETED:
            raise ValidationError('Only completed redemptions can be cancelled.')

        with transaction.atomic():
            # Lock the redemption row to prevent double-cancel
            redemption = type(self).objects.select_for_update().get(pk=self.pk)
            if redemption.status != self.Status.COMPLETED:
                raise ValidationError('Redemption status changed before processing (expected COMPLETED).')

            student = type(self.student).objects.select_for_update().get(pk=self.student.pk)
            item = GamificationRewardItem.objects.select_for_update().get(pk=self.reward_item.pk)

            # Refund nuggets
            student.nugget_balance += item.nugget_cost
            student.save(update_fields=['nugget_balance'])

            # Restore stock if not unlimited
            if item.stock != -1:
                item.stock += 1
                item.save(update_fields=['stock'])

            redemption.status = self.Status.CANCELLED
            redemption.notes = reason
            redemption.save(update_fields=['status', 'notes'])
            # Synchronize local instance with database
            self.status = redemption.status
            self.notes = redemption.notes
