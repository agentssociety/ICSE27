@login_required
@require_http_methods(["GET", "POST"])
def exam_list_create(request: HttpRequest) -> HttpResponse:
    """
    List all exams (instructor sees own, student sees available) or create a new exam.
    """
    user = request.user

    if request.method == "GET":
        if hasattr(user, 'instructor_profile'):
            exams = Exam.objects.filter(creator=user.instructor_profile).order_by('-created_at')
        elif hasattr(user, 'student_profile'):
            # Students see exams from cohorts they belong to
            student = user.student_profile
            cohorts = Cohort.objects.filter(students=student)
            exams = Exam.objects.filter(
                cohorts__in=cohorts,
                open_date__lte=timezone.now(),
                close_date__gte=timezone.now(),
            ).distinct().order_by('-open_date')
        else:
            exams = Exam.objects.none()

        return render(request, 'exams/exam_list.html', {'exams': exams})

    elif request.method == "POST":
        instructor = _get_instructor_profile(user)
        form = ExamForm(request.POST)
        if form.is_valid():
            exam = form.save(commit=False)
            exam.creator = instructor
            exam.save()
            form.save_m2m()  # Save many-to-many relationships (cohorts)
            _log_exam_action(
                actor=user,
                action='exam_created',
                exam_id=exam.id,
                details={'title': exam.title},
            )
            return JsonResponse({'id': exam.id, 'title': exam.title}, status=201)
        else:
            return JsonResponse({'errors': form.errors}, status=400)


@login_required
@require_http_methods(["GET", "PUT", "DELETE"])
def exam_detail(request: HttpRequest, exam_id: int) -> HttpResponse:
    """
    Retrieve, update, or delete an exam.
    Only the creator (instructor) can modify or delete.
    """
    instructor = _get_instructor_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id, creator=instructor)

    if request.method == "GET":
        return render(request, 'exams/exam_detail.html', {
            'exam': exam,
            'questions': exam.questions.all().order_by('order'),
            'competencies': Competency.objects.filter(question__exam=exam).distinct(),
        })

    elif request.method == "PUT":
        form = ExamForm(request.PUT, instance=exam)
        if form.is_valid():
            form.save()
            _log_exam_action(
                actor=request.user,
                action='exam_updated',
                exam_id=exam.id,
                details={'title': exam.title},
            )
            return JsonResponse({'id': exam.id, 'title': exam.title})
        else:
            return JsonResponse({'errors': form.errors}, status=400)

    elif request.method == "DELETE":
        exam.delete()
        _log_exam_action(
            actor=request.user,
            action='exam_deleted',
            exam_id=exam_id,
            details={},
        )
        return JsonResponse({'message': 'Exam deleted.'})


