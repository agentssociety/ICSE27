</div>

<div class="dashboard-stats">
    <div class="stat-card">
        <h3>Total Exams</h3>
        <p class="stat-value">{{ exams|length }}</p>
    </div>
    <div class="stat-card">
        <h3>Active Exams</h3>
        <p class="stat-value">{{ active_exams_count }}</p>
    </div>
</div>

<div class="exam-list">
    <h2>Your Exams</h2>
    {% if exams %}
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Open Date</th>
                    <th>Close Date</th>
                    <th>Attempts</th>
                    <th>Avg Score</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for exam in exams %}
                <tr>
                    <td>{{ exam.title }}</td>
                    <td>{{ exam.open_date|date:"Y-m-d H:i" }}</td>
                    <td>{{ exam.close_date|date:"Y-m-d H:i" }}</td>
                    <td>{{ exam.total_attempts }}</td>
                    <td>{{ exam.average_score|floatformat:1 }}%</td>
                    <td>
                        <a href="{% url 'exam_detail' exam.id %}" class="btn btn-sm">View</a>
                        <a href="{% url 'instructor_exam_detail' exam.id %}" class="btn btn-sm btn-secondary">Analytics</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>No exams created yet. <a href="{% url 'exam_list_create' %}">Create your first exam</a></p>
    {% endif %}
</div>
{% endblock %}

{% block extra_scripts %}
<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('dashboardStats', () => ({
            init() {
                // Fetch real-time stats if needed
            }
        }))
    })
</script>
{% endblock %}
