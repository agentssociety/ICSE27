                'solution': 'def add(a, b):\n    return a + b',
                'language': 'python',
                'test_cases': [
                    {'input': [1, 2], 'expected': 3},
                    {'input': [10, -5], 'expected': 5},
                ]
            },
            difficulty='INTERMEDIATE',
            nugget_multiplier=2.0,
            order=2,
        )
        self.q2.competencies.add(self.comp2)

        # Create badge for earning nuggets
        self.badge = Badge.objects.create(
            name='First Nuggets',
            description='Earn your first 10 nuggets',
            criteria={
                'field': 'nugget_balance',
                'operator': '>=',
                'value': 10
            },
        )

        # Create a reward item
        self.reward = RewardItem.objects.create(
            name='Virtual Hat',
            description='A cool virtual hat for your avatar',
            nugget_cost=50,
            item_type='VIRTUAL',
            stock=10
        )

    # ------------------------------------------------------------------
    # Helper: Simulate a completed exam attempt (bypasses HTTP endpoints)
    # ------------------------------------------------------------------
    def _create_completed_attempt(self, student, responses_correctness):
        """
        Create and finalize an ExamAttempt with given responses.
        responses_correctness: list of tuples (question, response, is_correct)
        Returns the Attempt instance.
        """
        attempt = ExamAttempt.objects.create(
            student=student,
            exam=self.exam,
            start_time=timezone.now() - timedelta(minutes=10),
            responses={},
            results={},
            total_nuggets_earned=0,
            streak_multiplier=1.0,
        )

        total_nuggets = 0
        results = {}
        responses = {}
        current_streak = 0

        for question, response, is_correct in responses_correctness:
            question_id = question.id
            responses[str(question_id)] = response
            # Compute nuggets: base = nugget_multiplier * 1.0 (streak multiplier not applied here for simplicity)
            nuggets_earned = question.nugget_multiplier * 10.0 if is_correct else 0
            total_nuggets += nuggets_earned
            # Update streak locally (mirrors StudentProfile.update_streak)
            if is_correct:
                current_streak += 1
            else:
                current_streak = 0
            results[str(question_id)] = {
                'correct': is_correct,
                'nuggets': nuggets_earned,
                'time_spent': 30,
                'feedback': 'OK' if is_correct else 'Wrong'
            }

        attempt.responses = responses
        attempt.results = results
        attempt.total_nuggets_earned = total_nuggets
        attempt.streak_multiplier = 1.0 + current_streak * 0.1  # Simulate streak multiplier
        attempt.end_time = timezone.now()
        attempt.save()

        # Update student's nugget balance and streak (as would happen in the view)
        student.nugget_balance += total_nuggets
        for question, response, is_correct in responses_correctness:
            student.update_streak(is_correct)
        student.save()

        # Update competency masteries (normally called by view after submission)
        update_competency_masteries(attempt)

        return attempt

