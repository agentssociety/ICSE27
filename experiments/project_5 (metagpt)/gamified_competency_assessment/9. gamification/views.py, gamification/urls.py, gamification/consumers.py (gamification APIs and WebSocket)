# gamification/consumers.py
"""
WebSocket consumer for real-time gamification updates.
Handles live timer, nugget animations, and streak updates during exam taking.
"""
import json
import logging
from datetime import timedelta
from typing import Optional

from channels.generic.websocket import AsyncJsonWebsocketConsumer
from channels.db import database_sync_to_async
from django.urls import re_path
from django.utils import timezone

from accounts.models import StudentProfile
from exams.models import Exam, ExamAttempt

logger = logging.getLogger(__name__)


class ExamConsumer(AsyncJsonWebsocketConsumer):
    """
    WebSocket consumer that manages real-time exam sessions:
    - Server-side countdown timer
    - Pushes nugget and streak updates
    - Handles reconnection and session recovery
    """

    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.exam_id: Optional[int] = None
        self.student: Optional[StudentProfile] = None
        self.attempt: Optional[ExamAttempt] = None
        self.timer_task = None

    async def connect(self):
        """Authenticate and join exam group. Expects exam_id in URL."""
        user = self.scope['user']
        if user.is_anonymous:
            await self.close(code=4001)
            return

        self.student = await self._get_student_profile(user)
        if self.student is None:
            await self.close(code=4002)
            return

        # Extract exam_id from URL route
        self.exam_id = self.scope['url_route']['kwargs'].get('exam_id')
        if self.exam_id is None:
            await self.close(code=4003)
            return

        # Verify student has an active attempt for this exam
        self.attempt = await self._get_active_attempt(self.exam_id)
        if self.attempt is None:
            await self.close(code=4004)
            return

        # Join the exam group and a personal user group for targeted messages
        await self.channel_layer.group_add(
            f"exam_{self.exam_id}",
            self.channel_name
        )
        await self.channel_layer.group_add(
            f"user_{user.id}",
            self.channel_name
        )
        await self.accept()

        # Start the server-side timer and send initial state
        await self._send_timer_state()

    async def disconnect(self, close_code):
        """Leave groups and clean up timer task."""
        if self.exam_id is not None:
            await self.channel_layer.group_discard(
                f"exam_{self.exam_id}",
                self.channel_name
            )
        if self.student is not None:
            await self.channel_layer.group_discard(
                f"user_{self.student.user.id}",
                self.channel_name
            )

    async def receive_json(self, content: dict) -> None:
        """
        Handle incoming messages from WebSocket.
        Currently supports: 'ping' to keep alive, 'timer_sync' to request timer update.
        """
        msg_type = content.get('type')
        if msg_type == 'ping':
            await self.send_json({'type': 'pong'})
        elif msg_type == 'timer_sync':
            await self._send_timer_state()
        else:
            logger.warning('Unknown message type: %s', msg_type)

    async def _send_timer_state(self) -> None:
        """Send current timer state (remaining seconds) to the client."""
        if self.attempt is None or self.attempt.end_time is not None:
            await self.send_json({
                'type': 'timer_update',
                'remaining_seconds': 0,
                'status': 'over',
            })
            return

        exam = await database_sync_to_async(lambda: self.attempt.exam)()
        time_limit = exam.time_limit_minutes
        elapsed = (timezone.now() - self.attempt.start_time).total_seconds()
        remaining = max(0, (time_limit * 60) - elapsed) if time_limit else -1  # -1 means no limit

        await self.send_json({
            'type': 'timer_update',
            'remaining_seconds': int(remaining),
            'status': 'running' if remaining > 0 else 'over',
        })

        # If time expired, auto-submit the attempt
        if remaining == 0 and time_limit:
            await self._auto_submit()

    async def _auto_submit(self) -> None:
        """Auto-submit the exam when time expires."""
        if self.attempt and self.attempt.end_time is None:
            # Mark end_time and notify client
            self.attempt.end_time = timezone.now()
            await database_sync_to_async(self.attempt.save)(update_fields=['end_time'])
            await self.send_json({
                'type': 'exam_auto_submitted',
                'message': 'Time limit reached. Your exam has been submitted.'
            })
            # Note: Actual nugget/streak calculation should be performed by the server
            # when the exam is finalized (e.g., via a separate endpoint or async task).
            # For now, we simply record the end_time.

    # ------------------------------------------------------------------
    # Handlers for messages sent via group_send (from server)
    # ------------------------------------------------------------------
    async def nugget_update(self, event: dict) -> None:
        """Forward nugget and streak updates to the client."""
        await self.send_json({
            'type': 'nugget_update',
            'nuggets_earned': event.get('nuggets_earned', 0),
            'new_balance': event.get('new_balance', 0),
            'current_streak': event.get('current_streak', 0),
        })

    async def timer_sync(self, event: dict) -> None:
        """Handle forced timer sync from server."""
        await self._send_timer_state()

    # ------------------------------------------------------------------
    # Database helpers (async)
    # ------------------------------------------------------------------
    @database_sync_to_async
    def _get_student_profile(self, user) -> Optional[StudentProfile]:
        try:
            return user.student_profile
        except StudentProfile.DoesNotExist:
            return None

    @database_sync_to_async
    def _get_active_attempt(self, exam_id: int) -> Optional[ExamAttempt]:
        """Retrieve the active (unsubmitted) attempt for this student and exam."""
        if self.student is None:
            return None
        try:
            return ExamAttempt.objects.get(
                student=self.student,
                exam_id=exam_id,
                end_time__isnull=True
            )
        except ExamAttempt.DoesNotExist:
            return None


# WebSocket URL patterns for routing
websocket_urlpatterns = [
    re_path(r'ws/exam/(?P<exam_id>\d+)/$', ExamConsumer.as_asgi()),
]
