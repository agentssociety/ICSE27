"""
Admin configuration for accounts models.
"""
from django.contrib import admin
from django.contrib.auth.admin import UserAdmin as BaseUserAdmin
from django.contrib.auth.models import User
from .models import StudentProfile, InstructorProfile


class StudentProfileInline(admin.StackedInline):
    """Inline admin for StudentProfile."""
    model = StudentProfile
    can_delete = False
    verbose_name_plural = 'Student Profiles'


class InstructorProfileInline(admin.StackedInline):
    """Inline admin for InstructorProfile."""
    model = InstructorProfile
    can_delete = False
    verbose_name_plural = 'Instructor Profiles'


class UserAdmin(BaseUserAdmin):
    """Custom User admin with profile inlines."""
    inlines = (StudentProfileInline, InstructorProfileInline)


# Re-register UserAdmin
admin.site.unregister(User)
admin.site.register(User, UserAdmin)


@admin.register(StudentProfile)
class StudentProfileAdmin(admin.ModelAdmin):
    """Admin for StudentProfile."""
    list_display = ('user', 'nugget_balance', 'current_streak', 'max_streak')
    search_fields = ('user__username', 'user__email')
    list_filter = ('current_streak',)


@admin.register(InstructorProfile)
class InstructorProfileAdmin(admin.ModelAdmin):
    """Admin for InstructorProfile."""
    list_display = ('user', 'department')
    search_fields = ('user__username', 'department')
