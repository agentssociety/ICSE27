"""
Models for user profiles: StudentProfile and InstructorProfile.
Extends Django's built-in User model with one-to-one relationships.
"""
from django.contrib.auth.models import User
from django.db import models
from django.utils import timezone


class StudentProfile(models.Model):
    """Profile for student users, managing nuggets, streaks, and avatar."""
    user = models.OneToOneField(
        User, on_delete=models.CASCADE, related_name='student_profile'
    )
    avatar_url = models.URLField(max_length=500, blank=True, default='')
    nugget_balance = models.IntegerField(default=0)
    current_streak = models.IntegerField(default=0)
    max_streak = models.IntegerField(default=0)
    last_activity_date = models.DateField(null=True, blank=True)

    def add_nuggets(self, amount: int, reason: str) -> None:
        """Add nuggets to student's balance. Audit logging handled by middleware."""
        if amount <= 0:
            raise ValueError("Amount must be positive")
        self.nugget_balance += amount
        self.save(update_fields=['nugget_balance'])

    def deduct_nuggets(self, amount: int) -> bool:
        """Deduct nuggets if sufficient balance exists. Returns True if successful."""
        if amount <= 0:
            raise ValueError("Amount must be positive")
        if self.nugget_balance < amount:
            return False
        self.nugget_balance -= amount
        self.save(update_fields=['nugget_balance'])
        return True

    def update_streak(self, correct: bool) -> None:
        """Update streak based on answer correctness. Resets to 0 if incorrect."""
        today = timezone.now().date()
        if correct:
            if self.last_activity_date == today:
                # Already answered correctly today, streak unchanged
                return
            if self.last_activity_date is None or self.last_activity_date != today - timezone.timedelta(days=1):
                self.current_streak = 1
            else:
                self.current_streak += 1
            if self.current_streak > self.max_streak:
                self.max_streak = self.current_streak
        else:
            self.current_streak = 0
        self.last_activity_date = today
        self.save(update_fields=['current_streak', 'max_streak', 'last_activity_date'])

    def __str__(self) -> str:
        return f"StudentProfile(user={self.user.username}, nuggets={self.nugget_balance})"


class InstructorProfile(models.Model):
    """Profile for instructor users, managing exams and cohorts."""
    user = models.OneToOneField(
        User, on_delete=models.CASCADE, related_name='instructor_profile'
    )
    department = models.CharField(max_length=200, blank=True, default='')

    def create_exam(self, exam_data: dict) -> 'Exam':
        """Create a new exam with validated fields (lazy import to avoid circular)."""
        from exams.models import Exam
        valid_fields = {
            k: v for k, v in exam_data.items()
            if k in [f.name for f in Exam._meta.get_fields()]
        }
        exam = Exam.objects.create(creator=self, **valid_fields)
        return exam

    def view_analytics(self, exam_id: int) -> dict:
        """Retrieve analytics for a given exam (lazy import)."""
        from analytics.utils import get_exam_analytics
        return get_exam_analytics(exam_id)

    def __str__(self) -> str:
        return f"InstructorProfile(user={self.user.username}, dept={self.department})"


# accounts/forms.py
"""
Forms for user registration, login, and profile editing.
"""
from django import forms
from django.contrib.auth.models import User
from django.contrib.auth.forms import UserCreationForm, AuthenticationForm
from .models import StudentProfile, InstructorProfile


class UserRegistrationForm(UserCreationForm):
    """Form for registering a new user with role selection."""
    ROLE_CHOICES = [
        ('student', 'Student'),
        ('instructor', 'Instructor'),
    ]
    email = forms.EmailField(required=True)
    role = forms.ChoiceField(choices=ROLE_CHOICES, required=True)

    class Meta:
        model = User
        fields = ('username', 'email', 'password1', 'password2', 'role')

    def save(self, commit: bool = True) -> User:
        """Save user and create corresponding profile based on role."""
        user = super().save(commit=False)
        user.email = self.cleaned_data['email']
        if commit:
            user.save()
            role = self.cleaned_data['role']
            if role == 'student':
                StudentProfile.objects.create(user=user)
            elif role == 'instructor':
                InstructorProfile.objects.create(user=user)
        return user


class UserLoginForm(AuthenticationForm):
    """Form for user login (uses Django's built-in authentication)."""
    username = forms.CharField(max_length=150)
    password = forms.CharField(widget=forms.PasswordInput)


class StudentProfileForm(forms.ModelForm):
    """Form for editing student profile (avatar, etc.)."""
    class Meta:
        model = StudentProfile
        fields = ('avatar_url',)


class InstructorProfileForm(forms.ModelForm):
    """Form for editing instructor profile."""
    class Meta:
        model = InstructorProfile
        fields = ('department',)


