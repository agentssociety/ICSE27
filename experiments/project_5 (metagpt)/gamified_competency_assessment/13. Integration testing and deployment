    def test_competency_breakdown_calculation(self):
        """
        Verify that get_student_competency_breakdown returns correct percentages.
        """
        attempt = self._create_completed_attempt(
            self.student,
            [
                (self.q1, 1, True),   # correct -> Python Basics 100%
                (self.q2, 'def add(a,b): return a+b', True),  # correct -> Data Structures 100%
            ]
        )

        breakdown = get_student_competency_breakdown(attempt)
        self.assertAlmostEqual(breakdown['Python Basics'], 100.0)
        self.assertAlmostEqual(breakdown['Data Structures'], 100.0)

        # Test with both incorrect
        attempt2 = self._create_completed_attempt(
            self.student,
            [
                (self.q1, 2, False),  # incorrect
                (self.q2, 'def add(a,b): return a-b', False),  # incorrect
            ]
        )
        breakdown2 = get_student_competency_breakdown(attempt2)
        self.assertAlmostEqual(breakdown2['Python Basics'], 0.0)
        self.assertAlmostEqual(breakdown2['Data Structures'], 0.0)

