    def test_leaderboard_logic(self):
        """
        Test leaderboard calculation using model methods (without HTTP).
        """
        # Student 2
        student2_user = User.objects.create_user(
            username='student2',
            email='student2@test.com',
            password='testpass123'
        )
        student2 = StudentProfile.objects.create(
            user=student2_user,
            nugget_balance=0,
            current_streak=0,
            max_streak=0,
        )
        self.cohort.students.add(student2)

        # Student 1 gets 1 correct (+10 nuggets), student2 gets both correct (+30 nuggets)
        self._create_completed_attempt(
            self.student,
            [(self.q1, 1, True), (self.q2, 'wrong', False)]
        )
        self._create_completed_attempt(
            student2,
            [(self.q1, 2, True), (self.q2, 'def add(a,b): return a+b', True)]
        )

        # Query leaderboard directly: aggregated nuggets by student
        leaderboard = (
            ExamAttempt.objects
            .filter(
                student__cohort=self.cohort,
                end_time__gte=timezone.now() - timedelta(days=30),
                end_time__isnull=False,
            )
            .values('student')
            .annotate(total_nuggets=Sum('total_nuggets_earned'))
            .order_by('-total_nuggets')
        )
        # student2 should have more nuggets (30 vs 10)
        student1_entry = [l for l in leaderboard if l['student'] == self.student.id][0]
        student2_entry = [l for l in leaderboard if l['student'] == student2.id][0]
        self.assertGreater(student2_entry['total_nuggets'], student1_entry['total_nuggets'])

