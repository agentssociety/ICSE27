        self.assertEqual(self.student.nugget_balance, 50)
        self.reward.refresh_from_db()
        self.assertEqual(self.reward.stock, 9)

        # Insufficient nuggets
        result = self.reward.redeem(self.student)  # student now has 50, item costs 50
        self.assertTrue(result)  # should succeed
        self.student.refresh_from_db()
        self.assertEqual(self.student.nugget_balance, 0)
        self.reward.refresh_from_db()
        self.assertEqual(self.reward.stock, 8)

        # Out of stock
        self.reward.stock = 0
        self.reward.save()
        self.student.nugget_balance = 200
        self.student.save()
        result = self.reward.redeem(self.student)
        self.assertFalse(result)

