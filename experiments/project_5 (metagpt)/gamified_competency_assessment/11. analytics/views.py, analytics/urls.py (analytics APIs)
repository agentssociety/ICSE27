    heatmap_data = get_heatmap_data(exam)
    return JsonResponse({'heatmap': heatmap_data})


# ------------------------------------------------------------------
# GET /api/analytics/exam/{exam_id}/radar  (Instructor only)
# Returns per-student competency breakdown for radar chart.
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def exam_radar_data(request: HttpRequest, exam_id: int) -> JsonResponse:
    """
    Return data for radar charts: for each student who attempted the exam,
    provide their mastery percentages across all competencies.
    """
    instructor = _get_instructor_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id, creator=instructor)

    # Get all attempts for this exam
    attempts = ExamAttempt.objects.filter(exam=exam).select_related('student__user')
    competencies = list(Competency.objects.filter(question__exam=exam).distinct().values('id', 'name'))

    radar_data = []
    for attempt in attempts:
        student = attempt.student
        breakdown = get_student_competency_breakdown(attempt)
        # Build a list of mastery values in the same order as competencies
        mastery_values = [breakdown.get(comp['name'], 0.0) for comp in competencies]
        radar_data.append({
            'student_id': student.id,
            'username': student.user.username,
            'competencies': [c['name'] for c in competencies],
            'mastery_values': mastery_values,
        })

    return JsonResponse({
        'competencies': [c['name'] for c in competencies],
        'students': radar_data,
    })


# ------------------------------------------------------------------
# GET /api/analytics/student/{student_id}/exam/{exam_id}  (Instructor only)
# Returns a specific student's competency breakdown for a given exam.
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def student_exam_breakdown(request: HttpRequest, student_id: int, exam_id: int) -> JsonResponse:
    """
    Retrieve a specific student's competency breakdown for an exam.
    Only the exam creator (instructor) can access this.
    """
    instructor = _get_instructor_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id, creator=instructor)
    student = get_object_or_404(StudentProfile, pk=student_id)

    # Get the student's most recent completed attempt for this exam
    attempt = ExamAttempt.objects.filter(
        student=student,
        exam=exam,
        end_time__isnull=False
    ).order_by('-end_time').first()

    if not attempt:
        return JsonResponse({'error': 'No completed attempt found for this student.'}, status=404)

    breakdown = get_student_competency_breakdown(attempt)
    return JsonResponse({
        'student_id': student.id,
        'username': student.user.username,
        'exam_title': exam.title,
        'competency_breakdown': breakdown,
        'total_nuggets_earned': attempt.total_nuggets_earned,
        'streak_multiplier': attempt.streak_multiplier,
    })


# ------------------------------------------------------------------
# GET /api/analytics/my-competency?exam_id=...  (Student only)
# Returns the authenticated student's own competency breakdown for a given exam.
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def my_competency_breakdown(request: HttpRequest) -> JsonResponse:
    """
    Return the current student's competency breakdown for a specific exam.
    Query parameter: exam_id (required).
    """
    student = _get_student_profile(request.user)
    exam_id = request.GET.get('exam_id')
    if not exam_id:
        return JsonResponse({'error': 'exam_id query parameter is required.'}, status=400)

    exam = get_object_or_404(Exam, pk=exam_id)
    # Ensure the student is enrolled in a cohort that has access to this exam
    if not exam.cohorts.filter(students=student).exists():
        return JsonResponse({'error': 'You are not enrolled in this exam.'}, status=403)

    attempt = ExamAttempt.objects.filter(
        student=student,
        exam=exam,
        end_time__isnull=False
    ).order_by('-end_time').first()

    if not attempt:
        return JsonResponse({'error': 'No completed attempt found for this exam.'}, status=404)

    breakdown = get_student_competency_breakdown(attempt)
    return JsonResponse({
        'exam_title': exam.title,
        'competency_breakdown': breakdown,
        'total_nuggets_earned': attempt.total_nuggets_earned,
        'streak_multiplier': attempt.streak_multiplier,
    })


# ------------------------------------------------------------------
# GET /analytics/instructor/dashboard/  (Instructor HTML view)
# Renders the instructor analytics dashboard with Plotly charts.
# ------------------------------------------------------------------
@login_required
def instructor_dashboard(request: HttpRequest):
    """
    Render the instructor analytics dashboard page.
    This view returns an HTML page with exam summaries and links to detailed views.
    """
    instructor = _get_instructor_profile(request.user)
    exams = Exam.objects.filter(creator=instructor).order_by('-created_at')

    exam_list = []
    for exam in exams:
        attempts = ExamAttempt.objects.filter(exam=exam, end_time__isnull=False)
        total_attempts = attempts.count()
        average_score = _calculate_average_score(attempts)

        exam_list.append({
            'id': exam.id,
            'title': exam.title,
            'total_attempts': total_attempts,
            'average_score': average_score,
            'open_date': exam.open_date,
            'close_date': exam.close_date,
        })

    context = {
        'instructor': instructor,
        'exams': exam_list,
    }
    return render(request, 'analytics/instructor_dashboard.html', context)


# ------------------------------------------------------------------
# GET /analytics/instructor/exam/{exam_id}/  (Instructor HTML view)
# Renders the detailed analytics page for a specific exam.
# ------------------------------------------------------------------
@login_required
def instructor_exam_detail(request: HttpRequest, exam_id: int):
    """
    Render the detailed analytics page for a specific exam.
    Context includes exam info, heatmap data, radar chart data.
    """
    instructor = _get_instructor_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id, creator=instructor)

    # Get basic stats
    attempts = ExamAttempt.objects.filter(exam=exam, end_time__isnull=False)
    total_attempts = attempts.count()
    average_score = _calculate_average_score(attempts)

    # Get heatmap data
    heatmap_data = get_heatmap_data(exam)

    # Get radar data
    competencies = list(Competency.objects.filter(question__exam=exam).distinct().values('id', 'name'))
    radar_data = []
    for attempt in attempts.select_related('student__user'):
        student = attempt.student
        breakdown = get_student_competency_breakdown(attempt)
        mastery_values = [breakdown.get(c['name'], 0.0) for c in competencies]
        radar_data.append({
            'student_id': student.id,
            'username': student.user.username,
            'mastery_values': mastery_values,
        })

    context = {
        'exam': exam,
        'total_attempts': total_attempts,
        'average_score': average_score,
        'competencies': [c['name'] for c in competencies],
        'heatmap': heatmap_data,
        'radar': radar_data,
    }
    return render(request, 'analytics/instructor_exam_detail.html', context)


