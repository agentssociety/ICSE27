# ------------------------------------------------------------------
# Helper: Get instructor profile (raises PermissionDenied if not instructor)
# ------------------------------------------------------------------
def _get_instructor_profile(user: User) -> InstructorProfile:
    """Return InstructorProfile for user; raises PermissionDenied if not instructor."""
    try:
        return user.instructor_profile
    except InstructorProfile.DoesNotExist:
        raise PermissionDenied("User is not an instructor.")


# ------------------------------------------------------------------
# Helper: Get student profile (raises PermissionDenied if not student)
# ------------------------------------------------------------------
def _get_student_profile(user: User) -> StudentProfile:
    """Return StudentProfile for user; raises PermissionDenied if not student."""
    try:
        return user.student_profile
    except StudentProfile.DoesNotExist:
        raise PermissionDenied("User is not a student.")


# ------------------------------------------------------------------
# Helper: calculate average score (percentage correct) across attempts.
# ------------------------------------------------------------------
def _calculate_average_score(attempts) -> float:
    """Compute the average percentage of correct answers across completed attempts."""
    total_correct = 0
    total_questions = 0
    for attempt in attempts:
        results = attempt.results or {}
        for result in results.values():
            total_questions += 1
            if result.get('correct', False):
                total_correct += 1
    if total_questions == 0:
        return 0.0
    return round((total_correct / total_questions) * 100.0, 2)


# ------------------------------------------------------------------
# GET /api/analytics/exam/{id}  (Instructor only)
# Returns aggregated exam analytics including heatmap and cohort performance.
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def exam_analytics(request: HttpRequest, exam_id: int) -> JsonResponse:
    """
    Retrieve comprehensive analytics for a given exam.
    Only the exam creator (instructor) can access this data.

    Returns JSON with:
        - exam_title
        - total_attempts
        - average_score (percentage of correct answers)
        - competency_heatmap (list of per-student per-competency mastery)
        - cohort_performance (list of per-student scores)
    """
    instructor = _get_instructor_profile(request.user)
    exam = get_object_or_404(Exam, pk=exam_id, creator=instructor)

    attempts = ExamAttempt.objects.filter(exam=exam, end_time__isnull=False)
    total_attempts = attempts.count()
    average_score = _calculate_average_score(attempts)

    # Get heatmap and cohort performance (reusing utility functions)
    heatmap = get_heatmap_data(exam)
    cohort_performance = []
    for attempt in attempts.select_related('student__user').iterator():
        student = attempt.student
        results = attempt.results or {}
        correct_count = sum(1 for r in results.values() if r.get('correct', False))
        total_q = len(results)
        score_pct = (correct_count / total_q * 100) if total_q > 0 else 0.0
        cohort_performance.append({
            'student_id': student.id,
            'username': student.user.username,
            'score_percentage': round(score_pct, 2),
            'nuggets_earned': attempt.total_nuggets_earned,
            'streak_multiplier': attempt.streak_multiplier,
        })

    return JsonResponse({
        'exam_title': exam.title,
        'total_attempts': total_attempts,
        'average_score': average_score,
        'competency_heatmap': heatmap,
        'cohort_performance': cohort_performance,
    })


# ------------------------------------------------------------------
# GET /api/analytics/exam/{exam_id}/heatmap  (Instructor only)
# Returns raw heatmap data for Plotly rendering.
# ------------------------------------------------------------------
@login_required
@require_http_methods(["GET"])
def exam_heatmap(request: HttpRequest, exam_id: int) -> JsonResponse:
    """
    Return heatmap data (student vs competency mastery percentages) for an exam.
    Used by the frontend to render a Plotly heatmap.
    """
    instructor = _get_instructor_profile(request.user)
