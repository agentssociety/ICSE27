def _get_student_profile(user: User) -> StudentProfile:
    """Retrieve the StudentProfile for a user. Raises PermissionDenied if not a student."""
    try:
        return user.student_profile
    except StudentProfile.DoesNotExist:
        raise PermissionDenied("User is not a student.")


def _get_instructor_profile(user: User) -> InstructorProfile:
    """Retrieve the InstructorProfile for a user. Raises PermissionDenied if not an instructor."""
    try:
        return user.instructor_profile
    except InstructorProfile.DoesNotExist:
        raise PermissionDenied("User is not an instructor.")


def _log_exam_action(
    actor: User,
    action: str,
    exam_id: Optional[int] = None,
    details: Optional[Dict[str, Any]] = None,
) -> None:
    """Helper to log exam-related actions to the audit log."""
    AuditLog.log(
        action=action,
        actor=actor,
        resource_type='exam',
        resource_id=exam_id,
        details=details or {},
    )


def _calculate_streak_multiplier(student: StudentProfile) -> float:
    """Calculate nugget multiplier based on current streak (0.1 per day, max 2.0x)."""
    base_multiplier = 1.0
    max_multiplier = 2.0
    increment_per_streak = 0.1
    multiplier = base_multiplier + (student.current_streak * increment_per_streak)
    return min(multiplier, max_multiplier)


def _serialize_question(question: Question) -> Dict[str, Any]:
    """Serialize a question for the API response, handling different types."""
    base = {
        'id': question.id,
        'question_type': question.question_type,
        'content': question.content,
        'difficulty': question.difficulty,
        'nugget_multiplier': question.nugget_multiplier,
    }
    if question.question_type == 'MCQ':
        base['options'] = question.content.get('options', [])
    elif question.question_type == 'DRAG_DROP':
        base['drag_items'] = question.content.get('drag_items', [])
        base['drop_zones'] = question.content.get('drop_zones', [])
    elif question.question_type == 'CODE':
        base['starter_code'] = question.content.get('starter_code', '')
        base['language'] = question.content.get('language', 'python')
    return base


def _prepare_attempt_response(attempt: ExamAttempt) -> JsonResponse:
    """Build response for starting or continuing an exam. Returns next question or completion signal."""
    exam = attempt.exam
    questions = exam.questions.all().order_by('order')
    answered_ids = set(int(k) for k in (attempt.responses or {}).keys())

    next_question = None
    for q in questions:
        if q.id not in answered_ids:
            next_question = q
            break

    response_data = {
        'attempt_id': attempt.id,
        'exam_title': exam.title,
        'time_limit_minutes': exam.time_limit_minutes,
        'start_time': attempt.start_time.isoformat(),
        'total_questions': questions.count(),
        'answered_count': len(answered_ids),
    }

    if next_question:
        response_data['question'] = _serialize_question(next_question)
        response_data['is_complete'] = False
    else:
        response_data['is_complete'] = True
        response_data['message'] = 'All questions answered. Submit your exam.'

    return JsonResponse(response_data)


def _check_exam_time_limit(attempt: ExamAttempt) -> bool:
    """Check if the attempt has exceeded the time limit. If so, auto-submit."""
    if attempt.end_time:
        return True  # Already finalized
    exam = attempt.exam
    if exam.time_limit_minutes:
        deadline = attempt.start_time + timedelta(minutes=exam.time_limit_minutes)
        if timezone.now() >= deadline:
            # Auto-finalize attempt
            attempt.end_time = timezone.now()
            attempt.save(update_fields=['end_time'])
            return True
    return False


