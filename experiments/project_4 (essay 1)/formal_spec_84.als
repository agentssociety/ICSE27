module REQ_ADMIN_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ADMIN-01
 * Title       : Admin Flagged Transaction Review and Action
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Admin_Team, Security_Team, Finance_Team, IT_Support extends Actor {}
-- Admin_Team: represents stakeholder 'Admin Team'
-- Security_Team: represents stakeholder 'Security Team'
-- Finance_Team: represents stakeholder 'Finance Team'
-- IT_Support: represents stakeholder 'IT Support'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Transaction_Review_Interface, Flagged_Transactions_API extends Interface {}

fact interface_properties {
    Transaction_Review_Interface.kind = UI  -- The user interface where admins can view flagged transactions and select actions.
    Flagged_Transactions_API.kind = API  -- API to retrieve flagged transactions and update their status based on admin actions.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where I am logged in as an admin
-- Pre2: system is in state where A list of suspicious transactions is available

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The selected action (approve, reject, or escalate) has been applied to the transaction
-- Post2: system reaches state where The transaction status has been updated in the system
-- Post3: system reaches state where The action has been logged for audit purposes


----------------------------------------------------------------------
-- Core operation: REQ_ADMIN_01
----------------------------------------------------------------------

sig REQ_ADMIN_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ADMIN_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ADMIN_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ADMIN_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ADMIN_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ADMIN_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ADMIN_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ADMIN_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ADMIN_01 {
    some op: REQ_ADMIN_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ADMIN_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ADMIN_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ADMIN_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ADMIN_01_well_formed {
    all op: REQ_ADMIN_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ADMIN_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1: action applied (approve/reject/escalate)
pred ps_reach_Post1 {
    some op: REQ_ADMIN_01 |
        op.post = Post1 &&
        op.grant in Write &&
        op.initiator in Admin_Team &&
        Transaction_Review_Interface in op.channel &&
        op.pre != Post1
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ADMIN_01 |
        (op.post = Post1) =>
            (op.grant in Write &&
             op.initiator in Admin_Team &&
             Transaction_Review_Interface in op.channel)
}
check ps_valid_Post1 for 5

-- Post2: transaction status updated
pred ps_reach_Post2 {
    some op: REQ_ADMIN_01 |
        op.post = Post2 &&
        op.grant in Execute &&
        op.initiator in Admin_Team &&
        op.pre != Post2 &&
        op.pre != op.post
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_ADMIN_01 |
        (op.post = Post2) =>
            (op.grant in Execute &&
             op.initiator in Admin_Team &&
             op.pre != op.post)
}
check ps_valid_Post2 for 5

-- Post3: action logged for audit
pred ps_reach_Post3 {
    some op: REQ_ADMIN_01 |
        op.post = Post3 &&
        op.grant in Admin &&
        op.initiator in Admin_Team &&
        Transaction_Review_Interface in op.channel &&
        op.pre != Post3 &&
        op.pre != op.post
}
run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_ADMIN_01 |
        (op.post = Post3) =>
            (op.grant in Admin &&
             op.initiator in Admin_Team &&
             Transaction_Review_Interface in op.channel &&
             op.pre != op.post)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_ADMIN_01 |
    Read in op.initiator.mayPerform &&
    some op.target &&
    (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
    op.grant = Read &&
    op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
  some op: REQ_ADMIN_01 |
    Write in op.initiator.mayPerform &&
    some op.target &&
    (some c: op.channel | c.authenticated = True) &&
    op.grant = Write &&
    op.post = Post2
}
run ac_reach_2 for 5

pred ac_reach_3 {
  some op: REQ_ADMIN_01 |
    Admin in op.initiator.mayPerform &&
    some op.target &&
    (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
    op.grant = Admin &&
    op.post = Post3
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sig for edge case 3: represent set of flagged resources
one sig FlaggedTransactions extends Resource {}
-- Assume that a FlaggedTransactions resource is accessible to Admin_Team
fact flagged_transactions_access {
    Admin_Team in FlaggedTransactions.accessible
}
fact flagged_transactions_owner {
    FlaggedTransactions.owner = Admin_Team
}

-- Edge case 1: admin tries to approve a transaction already being escalated
--   Safety: if the pre-state is an escalation state (Pre2 || Post2), no change permitted
assert ec_safe_1 {
    all op: REQ_ADMIN_01 |
        let escalationStates = Pre2 + Post2 |
            op.pre in escalationStates => op.post = op.pre
}

-- Edge case 2: multiple simultaneous actions on same transaction by different admins
--   Safety: any two operations sharing a target must have the same grant (no conflict)
assert ec_safe_2 {
    all disj op1, op2: REQ_ADMIN_01 |
        (op1.target & op2.target != none) => op1.grant = op2.grant
}

-- Edge case 3: no flagged transactions available when admin logs in
--   Safety: if there are no flagged transactions, then the flagged-transactions interface must not be used
assert ec_safe_3 {
    all op: REQ_ADMIN_01 |
        no FlaggedTransactions => Flagged_Transactions_API !in op.channel
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicates && assertions for TC-ADMIN-01 to TC-ADMIN-05 --

pred tc_admin01_holds {
    some op: REQ_ADMIN_01 |
        -- Input: Admin user logs in via UI, authorized
        op.initiator in Admin_Team &&
        op.channel = Transaction_Review_Interface &&
        op.grant = Read &&
        Read in op.initiator.mayPerform &&
        -- Expected output: system displays login screen (channel UI with correct credentials)
        -- We model "correct credentials prompt" as channel authenticated && encrypted
        Transaction_Review_Interface.authenticated = True &&
        Transaction_Review_Interface.encrypted = True &&
        -- The operation must have a state change
        op.target = FlaggedTransactions &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.post != op.pre
}

run tc_admin01_holds for 5

assert tc_admin01_contract {
    all op: REQ_ADMIN_01 |
        (op.initiator in Admin_Team && op.channel = Transaction_Review_Interface && op.grant = Read) =>
        (Transaction_Review_Interface.authenticated = True && Transaction_Review_Interface.encrypted = True)
}

check tc_admin01_contract for 5

pred tc_admin02_holds {
    some op: REQ_ADMIN_01 |
        -- Admin views list of flagged transactions
        op.initiator in Admin_Team &&
        op.grant = Read &&
        op.target = FlaggedTransactions &&
        op.channel = Transaction_Review_Interface &&
        -- Expected: list displayed with details (transaction ID, amount, timestamp)
        -- Model as: post state indicates list shown; we use Post1 as state after viewing
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.post != op.pre &&
        -- Also ensure channel properties: secure connection
        Transaction_Review_Interface.authenticated = True &&
        Transaction_Review_Interface.encrypted = True
}

run tc_admin02_holds for 5

assert tc_admin02_contract {
    all op: REQ_ADMIN_01 |
        (op.initiator in Admin_Team && op.grant = Read && op.target = FlaggedTransactions && op.channel = Transaction_Review_Interface) =>
        (op.pre = Pre1 && op.post = Post1 && Transaction_Review_Interface.authenticated = True && Transaction_Review_Interface.encrypted = True)
}

check tc_admin02_contract for 5

pred tc_admin03_holds {
    some op: REQ_ADMIN_01 |
        -- Admin approves a flagged transaction
        op.initiator in Admin_Team &&
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        op.target = FlaggedTransactions &&
        op.channel = Transaction_Review_Interface &&
        -- Expected: transaction status changed to Approved, action logged in audit trail
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.post != op.pre &&
        -- Ensure channel encrypted && authenticated for secure action
        Transaction_Review_Interface.encrypted = True &&
        Transaction_Review_Interface.authenticated = True
}

run tc_admin03_holds for 5

assert tc_admin03_contract {
    all op: REQ_ADMIN_01 |
        (op.initiator in Admin_Team && op.grant = Write && op.target = FlaggedTransactions && op.channel = Transaction_Review_Interface) =>
        (op.pre = Pre1 && op.post = Post1 && op.post != op.pre && Transaction_Review_Interface.encrypted = True && Transaction_Review_Interface.authenticated = True)
}

check tc_admin03_contract for 5

pred tc_admin04_holds {
    some op: REQ_ADMIN_01 |
        -- Admin rejects a flagged transaction
        op.initiator in Admin_Team &&
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        op.target = FlaggedTransactions &&
        op.channel = Transaction_Review_Interface &&
        -- Expected: status changed to Rejected, action logged
        op.pre = Pre1 &&
        op.post = Post2 &&
        op.post != op.pre &&
        Transaction_Review_Interface.encrypted = True &&
        Transaction_Review_Interface.authenticated = True
}

run tc_admin04_holds for 5

assert tc_admin04_contract {
    all op: REQ_ADMIN_01 |
        (op.initiator in Admin_Team && op.grant = Write && op.target = FlaggedTransactions && op.channel = Transaction_Review_Interface) =>
        (op.pre = Pre1 && op.post = Post2 && op.post != op.pre && Transaction_Review_Interface.encrypted = True && Transaction_Review_Interface.authenticated = True)
}

check tc_admin04_contract for 5

pred tc_admin05_holds {
    some op: REQ_ADMIN_01 |
        -- Admin escalates a flagged transaction
        op.initiator in Admin_Team &&
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        op.target = FlaggedTransactions &&
        op.channel = Transaction_Review_Interface &&
        -- Expected: status changed to Escalated, action logged
        op.pre = Pre1 &&
        op.post = Post3 &&
        op.post != op.pre &&
        Transaction_Review_Interface.encrypted = True &&
        Transaction_Review_Interface.authenticated = True
}

run tc_admin05_holds for 5

assert tc_admin05_contract {
    all op: REQ_ADMIN_01 |
        (op.initiator in Admin_Team && op.grant = Write && op.target = FlaggedTransactions && op.channel = Transaction_Review_Interface) =>
        (op.pre = Pre1 && op.post = Post3 && op.post != op.pre && Transaction_Review_Interface.encrypted = True && Transaction_Review_Interface.authenticated = True)
}

check tc_admin05_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

assert nfr_assert_performance {
    -- PROXY: minimize channel count reduces response time
    -- NFR: response time < 200ms
    all op: REQ_ADMIN_01 | #op.channel <= 2
}
check nfr_assert_performance for 5

assert nfr_assert_availability {
    -- PROXY: each resource accessible by at least two actors ensures redundancy
    -- NFR: uptime >= 99.9%
    all r: Resource | #r.accessible >= 2
}
check nfr_assert_availability for 5

assert nfr_assert_scalability {
    -- PROXY: bound resources per operation to avoid overload
    -- NFR: support up to 100 concurrent operations
    all op: REQ_ADMIN_01 | #op.target <= 3
}
check nfr_assert_scalability for 5

assert nfr_assert_usability {
    -- PROXY: limit authenticated channels simplifies user interaction
    -- NFR: at most 1 authentication prompt per transaction
    all op: REQ_ADMIN_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}
check nfr_assert_usability for 5

assert nfr_assert_maintainability {
    -- PROXY: avoid mutual accessibility between resources owned by same actor
    -- NFR: dependency conflicts < 1%
    no disj r1, r2: Resource | r1.owner = r2.owner && r1 in r2.accessible && r2 in r1.accessible
}
check nfr_assert_maintainability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security Requirement 1: Access to flagged transactions is restricted to admins with appropriate permissions
-- Only actors who have Admin permission can access FlaggedTransactions resources
fact sr_fact_admin_access_to_flagged {
    all op: REQ_ADMIN_01 |
        (FlaggedTransactions in op.target) =>
        (Admin in op.initiator.mayPerform)
}

-- Security Requirement 2: All actions on flagged transactions are logged && accessible to authorized users for audit
-- Define a minimal audit log concept
sig AuditEntry {
    operation: one REQ_ADMIN_01,
    timestamp: one State
}

-- Ensure every operation on FlaggedTransactions has a corresponding audit entry
fact sr_fact_audit_logging {
    all op: REQ_ADMIN_01 |
        (FlaggedTransactions in op.target) =>
        (some e: AuditEntry | e.operation = op)
}

-- Ensure audit entries are accessible to authorized actors (Admin team)
fact sr_fact_audit_accessibility {
    all e: AuditEntry |
        some a: Admin_Team | a in e.operation.channel.accessible
}

-- Assertion: No operation on FlaggedTransactions occurs without Admin permission
assert sr_assert_admin_only_flagged {
    all op: REQ_ADMIN_01 |
        (FlaggedTransactions in op.target) =>
        (Admin in op.initiator.mayPerform)
}

check sr_assert_admin_only_flagged for 5

-- Assertion: Every operation on FlaggedTransactions is logged
assert sr_assert_flagged_operations_logged {
    all op: REQ_ADMIN_01 |
        (FlaggedTransactions in op.target) =>
        (some e: AuditEntry | e.operation = op)
}

check sr_assert_flagged_operations_logged for 5

-- Assertion: Audit entries are accessible to Admin_Team members
assert sr_assert_audit_accessible_to_admin {
    all e: AuditEntry |
        some a: Admin_Team | a in e.operation.channel.accessible
}

check sr_assert_audit_accessible_to_admin for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed FlaggedTransactions: changed from sig with 'resources' field to proper Resource subtype with owner and accessibility facts
-- Summary 2: Fixed test scenario predicates (tc_admin01_holds etc.) to use Transaction_Review_Interface instead of UI sig
-- Summary 3: Corrected edge case assertions (ec_safe_3) to use proper Alloy syntax (none instead of no)
-- Summary 4: Removed unused UI sig reference and used existing Interface subtype
-- Assumption 1: FlaggedTransactions is modeled as a single Resource instance owned by Admin_Team
-- Assumption 2: All security critical operations require Admin permission via fact
-- Assumption 3: Post-states are distinct labels without formal semantics beyond equality
-- Open issue 1: The model does not capture transaction-level details (ID, amount, timestamp) as specified in requirements
-- Open issue 2: Edge case 2 (concurrent actions) reduces to same grant permission, which is an oversimplification
-- Open issue 3: Non-functional requirement assertions use proxy metrics without formal grounding


