module REQ_FUNC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-FUNC-01
 * Title       : Transaction Balance and Limit Validation
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Finance_Team, IT_Development_Team, Customer_Support_Team extends Actor {}
-- Finance_Team: represents stakeholder 'Finance Team'
-- IT_Development_Team: represents stakeholder 'IT Development Team'
-- Customer_Support_Team: represents stakeholder 'Customer Support Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource representing the user balance and limit database
one sig UserBalanceAndLimitDB extends Resource {}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig User_Balance_and_Limit_Database extends Interface {}

fact interface_properties {
    User_Balance_and_Limit_Database.kind = Database  -- The system interacts with this database to retrieve the user's available balance and daily withdrawal limit.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The user has an available balance.
-- Pre2: system is in state where The user has a daily withdrawal limit set.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The transaction is processed successfully if it meets both balance and limit criteria.
-- Post2: system reaches state where The transaction is denied with an appropriate message if either balance or limit criteria are not met.


----------------------------------------------------------------------
-- Core operation: REQ_FUNC_01
----------------------------------------------------------------------

sig REQ_FUNC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_FUNC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_FUNC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_FUNC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_FUNC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_FUNC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_FUNC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_FUNC_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_FUNC_01 {
    some op: REQ_FUNC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_FUNC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_FUNC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_FUNC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_FUNC_01_well_formed {
    all op: REQ_FUNC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_FUNC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_FUNC_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        UserBalanceAndLimitDB in op.target &&
        some c: op.channel | c.authenticated = True
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_FUNC_01 |
        op.post = Post2 &&
        op.pre = Pre2 &&
        Read in op.initiator.mayPerform &&
        op.grant = Read &&
        UserBalanceAndLimitDB in op.target &&
        some c: op.channel | c.authenticated = True
}
run ps_reach_Post2 for 5

assert ps_valid_Post1 {
    all op: REQ_FUNC_01 |
        op.post = Post1 =>
            (op.pre = Pre1 &&
             Write in op.initiator.mayPerform &&
             op.grant = Write &&
             UserBalanceAndLimitDB in op.target &&
             some c: op.channel | c.authenticated = True)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_FUNC_01 |
        op.post = Post2 =>
            (op.pre = Pre2 &&
             Read in op.initiator.mayPerform &&
             op.grant = Read &&
             UserBalanceAndLimitDB in op.target &&
             some c: op.channel | c.authenticated = True)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: The transaction amount does ! exceed the available balance.
-- This means we need a state where the balance is sufficient for the transaction.
-- We map this to: the operation involves a Database resource where the balance
-- (represented by state) is sufficient. Since we have Pre1 && Post1 as states,
-- we can use them to represent balance states.
pred ac_reach_1 {
    some op: REQ_FUNC_01 |
        -- Operation involves Database resource (balance checking)
        op.target in UserBalanceAndLimitDB &&
        -- Initiator has Read permission (to check balance)
        Read in op.initiator.mayPerform &&
        -- State transitions from Pre1 (sufficient balance) to Post1 (transaction processed)
        op.pre = Pre1 &&
        op.post = Post1 &&
        -- Use authenticated channel for secure balance check
        (some c: op.channel | c.authenticated = True) &&
        -- The grant permission is Execute (to perform the transaction)
        op.grant = Execute
}
run ac_reach_1 for 5

-- Criterion 2: The cumulative daily withdrawals including this transaction do ! exceed the daily limit.
-- This means we need a state where the daily limit is ! exceeded after the transaction.
-- We map this to: the operation involves User_Balance_and_Limit_Database resource
-- where daily limit tracking occurs.
pred ac_reach_2 {
    some op: REQ_FUNC_01 |
        -- Operation involves UserBalanceAndLimitDB resource
        op.target in UserBalanceAndLimitDB &&
        -- Initiator has Write permission (to update daily withdrawal count)
        Write in op.initiator.mayPerform &&
        -- State transitions from Pre2 (within daily limit) to Post2 (updated within limit)
        op.pre = Pre2 &&
        op.post = Post2 &&
        -- Use authenticated && encrypted channel for secure limit update
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        -- The grant permission is Execute (to perform the withdrawal)
        op.grant = Execute &&
        -- Initiator must be authorized for this resource
        op.initiator in op.target.accessible
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: User tries to make a transaction equal to their available balance.
-- This means the operation should ! fail || produce an invalid state transition
-- when the transaction amount exactly matches the available balance.
-- We model this by ensuring that if the operation's pre-state is Pre1 (representing
-- a state where balance equals limit), the post-state must be valid (Post1 || Post2).
assert ec_safe_1 {
    all op: REQ_FUNC_01 |
        (op.pre = Pre1) => (op.post in (Post1 + Post2))
}
check ec_safe_1 for 5

-- Edge case 2: Daily withdrawal limit is exactly met during a single day.
-- This means the operation should ! exceed the limit when it is exactly met.
-- We model this by ensuring that if the operation's pre-state is Pre2 (representing
-- a state where the daily limit has been exactly reached), the post-state must
-- ! indicate an over-limit condition (i.e., must be a valid state).
assert ec_safe_2 {
    all op: REQ_FUNC_01 |
        (op.pre = Pre2) => (op.post in (Post1 + Post2))
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicates && assertions for REQ_FUNC_01 scenarios

-- TC-REQ-FUNC-01-01: Valid amount below balance ? processed
pred tc_01_holds {
    some op: REQ_FUNC_01 |
        op.pre = Pre1 && op.post = Post1
}
run tc_01_holds for 5

assert tc_01_contract {
    all op: REQ_FUNC_01 |
        op.pre = Pre1 => op.post = Post1
}
check tc_01_contract for 5

-- TC-REQ-FUNC-01-02: Amount exceeds balance ? denied
pred tc_02_holds {
    some op: REQ_FUNC_01 |
        op.pre = Pre2 && op.post = Post2
}
run tc_02_holds for 5

assert tc_02_contract {
    all op: REQ_FUNC_01 |
        op.pre = Pre2 => op.post = Post2
}
check tc_02_contract for 5

-- TC-REQ-FUNC-01-03: Valid withdrawal to limit ? processed
pred tc_03_holds {
    some op: REQ_FUNC_01 |
        op.pre = Pre1 && op.post = Post1
}
run tc_03_holds for 5

assert tc_03_contract {
    all op: REQ_FUNC_01 |
        op.pre = Pre1 => op.post = Post1
}
check tc_03_contract for 5

-- TC-REQ-FUNC-01-04: Amount exceeds daily limit ? denied
pred tc_04_holds {
    some op: REQ_FUNC_01 |
        op.pre = Pre2 && op.post = Post2
}
run tc_04_holds for 5

assert tc_04_contract {
    all op: REQ_FUNC_01 |
        op.pre = Pre2 => op.post = Post2
}
check tc_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: minimizing channel count reduces latency (performance)
fact nfr_fact_performance_channel_limit {
    all op: REQ_FUNC_01 | #op.channel <= 2
}

-- Proxy: at least one secure (authenticated && encrypted) channel ensures availability
fact nfr_fact_availability_secure_channel {
    all op: REQ_FUNC_01 | some c: op.channel | c.authenticated = True && c.encrypted = True
}

-- Proxy: no two operations share the same initiator && target simultaneously (scalability)
fact nfr_fact_scalability_no_conflict {
    all disj op1, op2: REQ_FUNC_01 | op1.initiator != op2.initiator || op1.target != op2.target
}

-- Proxy: at most one authenticated channel per operation simplifies user interaction (usability)
fact nfr_fact_usability_auth_limit {
    all op: REQ_FUNC_01 | #(op.channel & {c: Interface | c.authenticated = True}) <= 1
}

