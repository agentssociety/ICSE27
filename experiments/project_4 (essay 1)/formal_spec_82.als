module REQ_FUNC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-FUNC-01
 * Title       : Atomic Withdrawal Operations
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Account_Management_Team, Security_Team, Finance_Department extends Actor {}
-- Account_Management_Team: represents stakeholder 'Account Management Team'
-- Security_Team: represents stakeholder 'Security Team'
-- Finance_Department: represents stakeholder 'Finance Department'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource representing user balance
one sig UserBalance extends Resource {}

-- Ensure UserBalance is accessible by multiple actors for scalability
fact user_balance_accessibility {
    #UserBalance.accessible >= 2
}

-- Set initial accessibility: all actors can access UserBalance (proxy for authorization)
fact user_balance_open_access {
    UserBalance.accessible = Actor
}

fact at_least_one_resource {
    some Resource
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Financial_Database, Transaction_API extends Interface {}

fact interface_properties {
    Financial_Database.kind = Database  -- The requirement interacts with the financial database to update user balances and store transaction records.
    Transaction_API.kind = API  -- The requirement uses an internal API to initiate and manage withdrawal transactions.
}


----------------------------------------------------------------------
-- System failure modes (edge cases)
----------------------------------------------------------------------

abstract sig FailureReason {}
one sig NetworkOutage, SystemCrash, InsufficientFunds extends FailureReason {}

-- Global system status
one sig System {
    crashed: one Bool
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system is operational and connected to the necessary financial backend systems.
-- Pre2: system is in state where The user has an active account with sufficient funds.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The user's balance remains unchanged from its initial state before the transaction attempt.
-- Post2: system reaches state where No withdrawal record should be created due to the failure of the transaction.


----------------------------------------------------------------------
-- Core operation: REQ_FUNC_01
----------------------------------------------------------------------

sig REQ_FUNC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State,            -- postcondition that is established
    failure    : lone FailureReason     -- optional failure that occurred
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_FUNC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_FUNC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_FUNC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_FUNC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_FUNC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_FUNC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_FUNC_01 | op.post in Post1 + Post2
}

-- If a failure occurs, the post-state must be Post2 (rollback and no record)
fact failure_leads_to_post2 {
    all op: REQ_FUNC_01 | some op.failure => op.post = Post2
}


----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_FUNC_01 {
    some op: REQ_FUNC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_FUNC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_FUNC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_FUNC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_FUNC_01_well_formed {
    all op: REQ_FUNC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_FUNC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1: balance unchanged (transaction attempt failed)
pred ps_reach_Post1 {
    some op: REQ_FUNC_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        -- Initiator has Read permission only (can't modify balance)
        Read in op.initiator.mayPerform &&
        !(Write in op.initiator.mayPerform) &&
        -- Target is UserBalance (balance-related resource)
        UserBalance in op.target &&
        -- Channel is authenticated but operation fails
        some c: op.channel | c.authenticated = True
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_FUNC_01 |
        (op.post = Post1) =>
            (op.pre = Pre1 &&
             !(Write in op.initiator.mayPerform) &&
             UserBalance in op.target)
}

check ps_valid_Post1 for 5

-- Post2: no withdrawal record created due to failure
pred ps_reach_Post2 {
    some op: REQ_FUNC_01 |
        op.post = Post2 &&
        op.pre = Pre1 &&
        -- Initiator has Write permission (can attempt withdrawal)
        Write in op.initiator.mayPerform &&
        -- Target is UserBalance (withdrawal target)
        UserBalance in op.target &&
        -- Channel requires authentication
        some c: op.channel | c.authenticated = True &&
        -- Transaction fails despite authorization
        !(Admin in op.initiator.mayPerform)
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_FUNC_01 |
        (op.post = Post2) =>
            (op.pre = Pre1 &&
             Write in op.initiator.mayPerform &&
             UserBalance in op.target &&
             some c: op.channel | c.authenticated = True &&
             !(Admin in op.initiator.mayPerform))
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Acceptance criterion 1: User has balance $100 (pre-state Pre1)
pred ac_reach_1 {
    some op: REQ_FUNC_01 |
        op.pre = Pre1
}
run ac_reach_1 for 5

-- Acceptance criterion 2: User initiates withdrawal of $50 (Write permission)
pred ac_reach_2 {
    some op: REQ_FUNC_01 |
        Write in op.initiator.mayPerform &&
        some op.target
}
run ac_reach_2 for 5

-- Acceptance criterion 3: Network failure during transaction (channel insecure)
pred ac_reach_3 {
    some op: REQ_FUNC_01 |
        (some c: op.channel | c.encrypted = False && c.authenticated = False)
}
run ac_reach_3 for 5

-- Acceptance criterion 4: Balance remains $100 (post-state unchanged, using Post2 as failure state)
pred ac_reach_4 {
    some op: REQ_FUNC_01 |
        op.pre = Pre1 &&
        op.post = Post2
}
run ac_reach_4 for 5

-- Acceptance criterion 5: Withdrawal not recorded (post-state shows no change, combined with Write permission)
pred ac_reach_5 {
    some op: REQ_FUNC_01 |
        Write in op.initiator.mayPerform &&
        op.pre = Pre1 &&
        op.post = Post2
}
run ac_reach_5 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Network outage leads to rollback
assert ec_safe_1 {
  all op: REQ_FUNC_01 |
    (op.pre = Pre1 and some op.failure) => (op.post = Post2)
}

-- Edge case 2: Insufficient funds leads to rollback
assert ec_safe_2 {
  all op: REQ_FUNC_01 |
    (op.pre = Pre2 and some op.failure) => (op.post = Post2)
}

-- Edge case 3: System crash leads to rollback
assert ec_safe_3 {
  all op: REQ_FUNC_01 |
    (System.crashed = True and some op.failure) => (op.post = Post2)
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- SCENARIO TC-01: withdrawal sufficient funds + network outage => rollback
pred tc_01_holds {
    some op: REQ_FUNC_01 |
        op.initiator = Account_Management_Team &&
        UserBalance in op.target &&
        op.grant = Write &&
        Write in Account_Management_Team.mayPerform &&
        op.pre = Pre1 &&
        op.post = Post2 &&
        op.channel = Transaction_API
}
run tc_01_holds for 5

assert tc_01_contract {
    all op: REQ_FUNC_01 |
        (op.initiator = Account_Management_Team &&
         UserBalance in op.target &&
         op.grant = Write &&
         Write in Account_Management_Team.mayPerform &&
         op.pre = Pre1 &&
         op.channel = Transaction_API) =>
        (op.post = Post2)
}
check tc_01_contract for 5

-- SCENARIO TC-02: withdrawal insufficient funds + system crash => rollback
pred tc_02_holds {
    some op: REQ_FUNC_01 |
        op.initiator = Account_Management_Team &&
        UserBalance in op.target &&
        op.grant = Write &&
        Write in Account_Management_Team.mayPerform &&
        op.pre = Pre2 &&
        op.post = Post2 &&
        op.channel = Transaction_API
}
run tc_02_holds for 5

assert tc_02_contract {
    all op: REQ_FUNC_01 |
        (op.initiator = Account_Management_Team &&
         UserBalance in op.target &&
         op.grant = Write &&
         Write in Account_Management_Team.mayPerform &&
         op.pre = Pre2 &&
         op.channel = Transaction_API) =>
        (op.post = Post2)
}
check tc_02_contract for 5

-- SCENARIO TC-03: withdrawal attempt with insufficient funds (no crash) => failure
pred tc_03_holds {
    some op: REQ_FUNC_01 |
        op.initiator = Account_Management_Team &&
        UserBalance in op.target &&
        op.grant = Write &&
        Write in Account_Management_Team.mayPerform &&
        op.pre = Pre2 &&
        op.post = Post2 &&
        op.channel = Transaction_API   -- same as TC-02 but pre-state is a different scenario
}
run tc_03_holds for 5

assert tc_03_contract {
    all op: REQ_FUNC_01 |
        (op.initiator = Account_Management_Team &&
         UserBalance in op.target &&
         op.grant = Write &&
         Write in Account_Management_Team.mayPerform &&
         op.pre = Pre2) =>
        (op.post = Post2)
}
check tc_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- Proxy: limit target resources per operation to at most 2 to reduce transaction processing time.
    all op: REQ_FUNC_01 | #op.target <= 2
}

fact nfr_fact_availability {
    -- Proxy: require at least two communication channels per operation for redundancy to support 99.9% uptime.
    all op: REQ_FUNC_01 | #op.channel >= 2
}

fact nfr_fact_scalability {
    -- Proxy: each resource must be accessible by multiple actors to enable horizontal scaling during peak loads.
    all r: Resource | #r.accessible >= 2
}

assert nfr_assert_usability_defined {
    -- Proxy: every operation must have a clearly defined post-state (Post1 || Post2) to ensure user-friendly outcomes.
    all op: REQ_FUNC_01 | op.post in (Post1 + Post2)
}
check nfr_assert_usability_defined for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- (no security requirements provided)


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Models atomic withdrawal with failure scenarios, ensuring balance unchanged and no record on failure.
-- Summary 2: Access control enforced via permissions and resource accessibility.
-- Summary 3: Failure reasons (network outage, system crash, insufficient funds) are modeled and linked to rollback post-state.
-- Summary 4: Acceptance criteria and test cases are verified via reachability predicates and safety assertions.
-- Assumption 1: Only failure scenarios are modeled; successful withdrawals are not considered.
-- Assumption 2: Network outage is represented by insecure channel (encrypted=false, authenticated=false).
-- Assumption 3: System crash is a global flag affecting all operations.
-- Assumption 4: User balance is represented by a single resource (UserBalance) accessible to all actors for simplicity.
-- Assumption 5: Performance is proxied by limiting target resources per operation; availability by requiring multiple channels.
-- Open issue 1: The model does not capture a successful withdrawal outcome; to extend, a third post-state would be needed.
-- Open issue 2: Security requirements (e.g., encryption, authentication) are partially modeled but not fully verified.
-- Open issue 3: Non-functional requirement proxies (e.g., performance, availability) are approximate and may not reflect real system constraints.


