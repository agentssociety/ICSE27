----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Admins, Audit_Team, Compliance_Officers extends Actor {}
-- Admins: represents stakeholder 'Admins'
-- Audit_Team: represents stakeholder 'Audit Team'
-- Compliance_Officers: represents stakeholder 'Compliance Officers'

-- Admins must have Admin permission
fact admin_permission {
    Admin in Admins.mayPerform
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor,
    hasTransactions : one Bool   -- indicates whether this resource has transaction history
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Some resources have transactions, some do not (for edge case modeling)
fact transaction_variety {
    some r: Resource | r.hasTransactions = True
    some r: Resource | r.hasTransactions = False
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig UserManagementAPI, TransactionLogDB extends Interface {}

fact interface_properties {
    UserManagementAPI.kind = API  -- The requirement interacts with the UserManagementAPI to retrieve user details and initiate transaction history retrieval.
    TransactionLogDB.kind = Database  -- The requirement interacts with TransactionLogDB to fetch all financial or activity logs for a selected user.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where I am logged in as an admin

-- Concrete post-states (one per distinct postcondition).
one sig PostDone extends State {}


----------------------------------------------------------------------
-- Core operation: REQ_ADMIN_HIST_01
----------------------------------------------------------------------

sig REQ_ADMIN_HIST_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ADMIN_HIST_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ADMIN_HIST_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ADMIN_HIST_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ADMIN_HIST_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must have the correct precondition (logged in as admin).
fact inv_precondition {
    all op: REQ_ADMIN_HIST_01 | op.pre = Pre1
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ADMIN_HIST_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ADMIN_HIST_01 {
    some op: REQ_ADMIN_HIST_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ADMIN_HIST_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ADMIN_HIST_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ADMIN_HIST_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ADMIN_HIST_01_well_formed {
    all op: REQ_ADMIN_HIST_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre = Pre1
}
check REQ_ADMIN_HIST_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- (no post-states to verify)


----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: I should see a complete list of that user's transactions
-- This means there exists an operation where the initiator (admin) can read
-- a resource that has transactions.
pred ac_reach_1 {
    some op: REQ_ADMIN_HIST_01 |
        op.initiator = Admins &&
        Read in op.initiator.mayPerform &&
        op.grant = Read &&
        op.target.hasTransactions = True &&
        op.initiator in op.target.accessible
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Empty transaction history ? admin should still be able to view (no transactions)
assert ec_safe_1 {
    all op: REQ_ADMIN_HIST_01 |
        (op.initiator = Admins && op.target.hasTransactions = False) =>
            (op.grant = Read && op.initiator in op.target.accessible)
}
check ec_safe_1 for 5

-- Edge case 2: Concurrent requests for multiple users' transaction histories
-- Introduce a minimal helper sig to model concurrent operation pairs
sig ConcurrentPair {
    op1, op2: REQ_ADMIN_HIST_01
}

assert ec_safe_2 {
    all cp: ConcurrentPair |
        -- if two operations target the same resource concurrently,
        -- their grants must be compatible (both are Read, or both grant same permission)
        (cp.op1.target = cp.op2.target && cp.op1.pre = cp.op2.pre) =>
            (cp.op1.grant = cp.op2.grant)
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-ADMIN-HIST-01: Admin views transaction history for a user with transactions
pred tc_ADMIN_HIST_01_holds {
    some op: REQ_ADMIN_HIST_01 |
        op.initiator = Admins &&
        Admin in op.initiator.mayPerform &&
        op.target.hasTransactions = True &&
        op.grant = Read
}

run tc_ADMIN_HIST_01_holds for 5

assert tc_ADMIN_HIST_01_contract {
    all op: REQ_ADMIN_HIST_01 |
        (op.initiator = Admins && Admin in op.initiator.mayPerform && op.target.hasTransactions = True) =>
        op.grant = Read
}

check tc_ADMIN_HIST_01_contract for 5

-- TC-ADMIN-HIST-02: Admin views transaction history for a user with no transactions
pred tc_ADMIN_HIST_02_holds {
    some op: REQ_ADMIN_HIST_01 |
        op.initiator = Admins &&
        Admin in op.initiator.mayPerform &&
        op.target.hasTransactions = False &&
        op.grant = Read
}

run tc_ADMIN_HIST_02_holds for 5

assert tc_ADMIN_HIST_02_contract {
    all op: REQ_ADMIN_HIST_01 |
        (op.initiator = Admins && Admin in op.initiator.mayPerform && op.target.hasTransactions = False) =>
        op.grant = Read
}

check tc_ADMIN_HIST_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting the number of target resources per operation reduces
    -- the processing time, thus improving response time (latency < 200ms proxy).
    all op : REQ_ADMIN_HIST_01 | #op.target <= 2
}

fact nfr_fact_availability {
    -- PROXY: requiring at least two communication channels per operation
    -- provides redundancy, thereby increasing uptime (availability proxy).
    all op : REQ_ADMIN_HIST_01 | #op.channel >= 2
}

assert nfr_assert_scalability {
    -- PROXY: every actor must be capable of initiating an operation;
    -- this ensures the model does not artificially limit concurrency.
    all a : Actor | some op : REQ_ADMIN_HIST_01 | op.initiator = a
}
check nfr_assert_scalability for 5

fact nfr_fact_usability {
    -- PROXY: a small number of authenticated channels reduces authentication
    -- overhead and simplifies the user experience (usability proxy).
    #{ ch : Interface | ch.authenticated = True } <= 2
}

