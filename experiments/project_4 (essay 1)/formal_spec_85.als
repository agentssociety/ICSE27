module REQ_SEC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-SEC-01
 * Title       : Admin Lock and Unlock User Account
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Admins, IT_Support, Security_Team, User_Management_Team, User extends Actor {}
-- Admins: represents stakeholder 'Admins'
-- IT_Support: represents stakeholder 'IT Support'
-- Security_Team: represents stakeholder 'Security Team'
-- User_Management_Team: represents stakeholder 'User Management Team'
-- User: represents the user whose account is managed

-- Set permissions for each actor
fact define_permissions {
    Admins.mayPerform = Admin
    IT_Support.mayPerform = none
    Security_Team.mayPerform = none
    User_Management_Team.mayPerform = none
    User.mayPerform = none
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource representing a user account
one sig UserAccount extends Resource {}

-- Define owner and accessibility for UserAccount
fact account_ownership {
    UserAccount.owner = User
    UserAccount.accessible = User + Admins
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig AccountManagementAPI, UserDatabase extends Interface {}

fact interface_properties {
    AccountManagementAPI.kind = API  -- Provides endpoints for locking, unlocking, and retrieving account status.
    UserDatabase.kind = Database  -- Stores user information, including lock status and reasons for lockout.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The system must have an active user account
-- Pre2: system is in state where The system must be able to identify suspicious activity
-- Pre3: system is in state where The admin must have the necessary permissions to lock/unlock accounts

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The user's account is locked and the user cannot log in when the admin decides to lock it due to suspicious activity
-- Post2: system reaches state where The user's account is unlocked and the user can log in again when the admin resolves the issue and unlocks it


----------------------------------------------------------------------
-- Core operation: REQ_SEC_01
----------------------------------------------------------------------

sig REQ_SEC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_SEC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_SEC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_SEC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_SEC_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_SEC_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_SEC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_SEC_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SEC_01 {
    some op: REQ_SEC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SEC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_SEC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_SEC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_SEC_01_well_formed {
    all op: REQ_SEC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SEC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1: The user's account is locked && the user cannot log in
pred ps_reach_Post1 {
    some op: REQ_SEC_01 |
        op.post = Post1 &&
        -- Admin initiates the lock operation
        op.initiator in Admins &&
        -- Admin must have Admin permission to lock accounts
        Admin in op.initiator.mayPerform &&
        -- The target resource is the user account
        UserAccount in op.target &&
        -- Channel must be authenticated for security-sensitive operation
        (all c: op.channel | c.authenticated = True) &&
        -- State transition: pre-state is not Post1 (account was not locked)
        op.pre != Post1 &&
        -- The grant permission is Write (modifying account state)
        Write in op.grant
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_SEC_01 |
        (op.post = Post1) =>
            (op.initiator in Admins &&
             Admin in op.initiator.mayPerform &&
             UserAccount in op.target &&
             (all c: op.channel | c.authenticated = True) &&
             op.pre != Post1 &&
             Write in op.grant)
}

check ps_valid_Post1 for 5

-- Post2: The user's account is unlocked && the user can log in again
pred ps_reach_Post2 {
    some op: REQ_SEC_01 |
        op.post = Post2 &&
        -- Admin initiates the unlock operation
        op.initiator in Admins &&
        -- Admin must have Admin permission to unlock accounts
        Admin in op.initiator.mayPerform &&
        -- The target resource is the user account
        UserAccount in op.target &&
        -- Channel must be authenticated for security-sensitive operation
        (all c: op.channel | c.authenticated = True) &&
        -- State transition: pre-state must be Post1 (account was locked)
        op.pre = Post1 &&
        -- The grant permission is Write (modifying account state)
        Write in op.grant
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_SEC_01 |
        (op.post = Post2) =>
            (op.initiator in Admins &&
             Admin in op.initiator.mayPerform &&
             UserAccount in op.target &&
             (all c: op.channel | c.authenticated = True) &&
             op.pre = Post1 &&
             Write in op.grant)
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_SEC_01 |
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.initiator = Admins &&
        op.grant = Admin &&
        UserAccount in op.target
}

run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_SEC_01 |
        op.pre = Pre2 &&
        op.post = Post2 &&
        op.initiator = Admins &&
        op.grant = Admin &&
        UserAccount in op.target
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Admin attempts to lock a non-existent account
-- Safety: If the target is not a valid user account, the operation must not change state
assert ec_safe_1 {
    all op: REQ_SEC_01 |
        (UserAccount !in op.target) => (op.post = op.pre)
}
check ec_safe_1 for 5

-- Edge case 2: Multiple concurrent lock/unlock requests for the same account
-- Safety: No two operations can share the same target with conflicting grant permissions
assert ec_safe_2 {
    all disj op1, op2: REQ_SEC_01 |
        (some op1.target & op2.target) => (op1.grant = op2.grant)
}
check ec_safe_2 for 5

-- Edge case 3: System fails to log the reason for locking an account
-- Safety: If the operation grants a permission that changes access control, the post-state must differ from pre-state
assert ec_safe_3 {
    all op: REQ_SEC_01 |
        (op.grant in Write) => (op.post != op.pre)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_01_holds {
    some op: REQ_SEC_01 |
        Admin in op.initiator.mayPerform &&
        op.grant = Admin &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        some c: op.channel | c.authenticated = True
}
assert tc_01_contract {
    all op: REQ_SEC_01 |
        (Admin in op.initiator.mayPerform && op.grant = Admin && op.pre = Pre1) =>
        op.post = Post1
}
run tc_01_holds for 5
check tc_01_contract for 5

pred tc_02_holds {
    some op: REQ_SEC_01 |
        Admin in op.initiator.mayPerform &&
        op.grant = Admin &&
        op.pre = Post1 &&
        op.post = Pre1 &&
        some c: op.channel | c.authenticated = True
}
assert tc_02_contract {
    all op: REQ_SEC_01 |
        (Admin in op.initiator.mayPerform && op.grant = Admin && op.pre = Post1) =>
        op.post = Pre1
}
run tc_02_holds for 5
check tc_02_contract for 5

pred tc_03_holds {
    some op: REQ_SEC_01 |
        Admin ! in op.initiator.mayPerform &&
        op.grant = Admin &&
        op.pre = Pre3 &&
        some c: op.channel | c.authenticated = True
}
assert tc_03_contract {
    all op: REQ_SEC_01 |
        (Admin ! in op.initiator.mayPerform && op.grant = Admin && op.pre = Pre3) =>
        (op.post = Post2)
}
run tc_03_holds for 5
check tc_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_response_time {
    -- PROXY: limiting total resources && channels per operation reduces processing overhead,
    -- thereby modeling a performance bound that helps ensure the system responds within 5 seconds.
    all op: REQ_SEC_01 | #op.target <= 2 && #op.channel <= 2
}

fact nfr_fact_availability_redundancy {
    -- PROXY: requiring at least one channel that is authenticated via True ensures a minimum
    -- level of operational reliability; combined with sufficient actor coverage, this proxies
    -- 99.9% availability by mandating that redundant access paths exist.
    some c: Interface | c.authenticated = True
    all op: REQ_SEC_01 | some c: op.channel | c.authenticated = True
}

fact nfr_fact_scalability_capacity {
    -- PROXY: limiting the number of actors that can be initiators of operations simultaneously
    -- ensures that concurrency is bounded, which proxies the ability to handle up to 1,000
    -- requests per minute without degradation.
    #(REQ_SEC_01.initiator) <= 3
}

fact nfr_fact_usability_error_messages {
    -- PROXY: restricting the number of distinct interfaces that can be involved in an operation
    -- reduces complexity, thus proxying the requirement that error messages remain clear &&
    -- actionable by avoiding convoluted system interactions.
    all op: REQ_SEC_01 | #op.channel <= 2
}

assert nfr_assert_performance_bound {
    -- PROXY: by constraining resource && channel counts, we assert that the operation model
    -- does not exceed a complexity threshold that would violate the 5-second response requirement.
    all op: REQ_SEC_01 | #op.target <= 2 && #op.channel <= 2
}
check nfr_assert_performance_bound for 5

assert nfr_assert_availability_sufficient {
    -- PROXY: ensuring at least one authenticated channel per operation proxies the 99.9%
    -- availability target by mandating reliable communication paths.
    all op: REQ_SEC_01 | some c: op.channel | c.authenticated = True
}
check nfr_assert_availability_sufficient for 5

assert nfr_assert_scalability_handling {
    -- PROXY: bounding the number of distinct initiators in the system models the capacity
    -- to handle up to 1,000 requests per minute without degradation.
    #(REQ_SEC_01.initiator) <= 3
}
check nfr_assert_scalability_handling for 5

assert nfr_assert_usability_clarity {
    -- PROXY: limiting channel variety per operation reduces interface complexity, proxying
    -- the requirement for clear && actionable error messages.
    all op: REQ_SEC_01 | #op.channel <= 2
}
check nfr_assert_usability_clarity for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Helper sig for audit logging  
sig AuditLog { entry: one REQ_SEC_01 }

-- Fact: every operation is logged  
fact sr_fact_audit_log_complete {  
  all op: REQ_SEC_01 | one l: AuditLog | l.entry = op  
}

-- Assertion: only actors with Admin permission can initiate account lock/unlock operations  
assert sr_assert_access_control {  
  all op: REQ_SEC_01 | Admin in op.initiator.mayPerform  
}  
check sr_assert_access_control for 5  

-- Assertion: each operation has exactly one audit log entry (additional check)  
assert sr_assert_audit_log_unique {  
  all op: REQ_SEC_01 | #(AuditLog <: entry).op = 1  
}  
check sr_assert_audit_log_unique for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed type errors by introducing UserAccount (Resource) and User (Actor) to replace incorrect usage of Interface in target fields.
-- Summary 2: Added missing mayPermission definitions for all actors to satisfy authorization invariants.
-- Summary 3: Corrected acceptance criterion and post-state reachability predicates to target UserAccount instead of AccountManagementAPI or UserDatabase.
-- Summary 4: Adjusted edge case assertion ec_safe_1 to check for non-existent accounts using UserAccount set membership.
-- Summary 5: Preserved all original structure and requirements; non-functional and security proxies remain unchanged.
-- Assumption 1: Only Admins have 'Admin' permission; other actors have no permissions, limiting initiators to Admins.
-- Assumption 2: UserAccount owner is 'User' and accessible by User and Admins, satisfying the owner-in-accessible constraint.
-- Assumption 3: Non-existent accounts are not modeled; ec_safe_1 assumes all targets are existing UserAccounts, making the assertion vacuously true.
-- Assumption 4: Test case TC-SEC-03 (non-existent account) is not fully representable; the corresponding assertion tc_03_contract is vacuously true due to invariants.
-- Open issue 1: Test case TC-SEC-03 (error on non-existent account) cannot be modeled precisely without dynamic existence; current assertion is vacuously true.
-- Open issue 2: Edge case of concurrent lock/unlock requests (ec_safe_2) assumes same permission, but real semantics might allow conflicts (e.g., lock vs unlock).
-- Open issue 3: Non-functional requirement proxies (e.g., 5-second response, 99.9% availability) are abstract and not formally verified against concrete bounds.
-- Open issue 4: Audit log sig and facts ensure logging but do not model the content of the log entry (e.g., reason for locking).


