module REQ_AUTH_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-AUTH-01
 * Title       : Card and PIN Authentication
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Security_Team, Customer_Support, IT_Department extends Actor {}
-- Security_Team: represents stakeholder 'Security Team'
-- Customer_Support: represents stakeholder 'Customer Support'
-- IT_Department: represents stakeholder 'IT Department'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Authentication_API, User_Authentication_Database extends Interface {}

fact interface_properties {
    Authentication_API.kind = API  -- Interface for authenticating users using their card and PIN.
    User_Authentication_Database.kind = Database  -- Stores user card and PIN data for authentication purposes.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The user has a valid card and PIN.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The user's account is authenticated.
-- Post2: system reaches state where Failed attempts to authenticate are tracked.


----------------------------------------------------------------------
-- Core operation: REQ_AUTH_01
----------------------------------------------------------------------

sig REQ_AUTH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_AUTH_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_AUTH_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_AUTH_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_AUTH_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_AUTH_01 | op.pre != op.post
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_AUTH_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_AUTH_01 {
    some op: REQ_AUTH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_AUTH_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_AUTH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_AUTH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_AUTH_01_well_formed {
    all op: REQ_AUTH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_AUTH_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_AUTH_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        op.initiator = Security_Team &&
        (some c: Card | c in op.target) &&
        (some p: PIN | p in op.target) &&
        op.grant = Admin &&
        some ch: op.channel | ch.authenticated = True
}

run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_AUTH_01 |
        op.post = Post2 &&
        op.pre = Pre1 &&
        op.initiator = Customer_Support &&
        (some c: Card | c in op.target) &&
        (some p: PIN | p in op.target) &&
        op.grant = Read &&
        some ch: op.channel | ch.authenticated = True
}

run ps_reach_Post2 for 5

assert ps_valid_Post1 {
    all op: REQ_AUTH_01 |
        (op.post = Post1) =>
            (some ch: op.channel | ch.authenticated = True) &&
            (some c: Card | c in op.target) &&
            (some p: PIN | p in op.target) &&
            op.pre = Pre1
}

check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_AUTH_01 |
        (op.post = Post2) =>
            (some ch: op.channel | ch.authenticated = True) &&
            (some c: Card | c in op.target) &&
            (some p: PIN | p in op.target) &&
            op.pre = Pre1
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES ??????????????????????????????????????????????

pred ac_reach_1 {
  some op: REQ_AUTH_01 |
    op.initiator in Customer_Support + Security_Team + IT_Department &&
    op.grant = Read &&
    some c: op.channel | c.authenticated = True && c.encrypted = True &&
    op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
  some op: REQ_AUTH_01 |
    op.initiator in Customer_Support + Security_Team + IT_Department &&
    op.grant = Write &&
    some c: op.channel | c.authenticated = True &&
    op.post = Post2
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_AUTH_01 |
    (some c: op.channel | c.authenticated = False) => op.post != Post1
}

assert ec_safe_2 {
  all op: REQ_AUTH_01 |
    (some c: op.channel | c.encrypted = False) => op.post != Post1
}

assert ec_safe_3 {
  all op: REQ_AUTH_01 |
    (some c: op.channel | c.authenticated = False && c.encrypted = False) => op.post != Post1
}

assert ec_safe_4 {
  all op: REQ_AUTH_01 |
    (some r: op.target | op.initiator ! in r.accessible) => op.post != Post1
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-01: Valid card && PIN entered successfully. Access granted.
pred tc_01_holds {
    some op: REQ_AUTH_01 |
        -- initiator has Admin permission (valid card)
        Admin in op.initiator.mayPerform &&
        -- grant is Read (access to account)
        op.grant = Read &&
        -- target resource owned by initiator
        some r: op.target | r.owner = op.initiator &&
        -- state changes (access granted)
        op.post != op.pre
}
run tc_01_holds for 5

assert tc_01_contract {
    all op: REQ_AUTH_01 |
        (Admin in op.initiator.mayPerform && op.grant = Read &&
         some r: op.target | r.owner = op.initiator) =>
        op.post != op.pre
}
check tc_01_contract for 5

-- Scenario TC-02: Invalid card but valid PIN. Account locked after 3 attempts.
pred tc_02_holds {
    some op: REQ_AUTH_01 |
        -- initiator lacks Admin (invalid card)
        Admin ! in op.initiator.mayPerform &&
        -- grant is Read (valid PIN attempt)
        op.grant = Read &&
        -- target resource exists
        some op.target &&
        -- state changes (account locked after multiple attempts)
        op.post != op.pre
}
run tc_02_holds for 5

assert tc_02_contract {
    all op: REQ_AUTH_01 |
        (Admin ! in op.initiator.mayPerform && op.grant = Read &&
         some op.target) =>
        op.post != op.pre
}
check tc_02_contract for 5

-- Scenario TC-03: Valid card && invalid PIN multiple times. Account locked.
pred tc_03_holds {
    some op: REQ_AUTH_01 |
        -- initiator has Admin (valid card)
        Admin in op.initiator.mayPerform &&
        -- grant is ! Read (invalid PIN - different permission)
        op.grant != Read &&
        -- target resource exists
        some op.target &&
        -- state changes (account locked)
        op.post != op.pre
}
run tc_03_holds for 5

assert tc_03_contract {
    all op: REQ_AUTH_01 |
        (Admin in op.initiator.mayPerform && op.grant != Read &&
         some op.target) =>
        op.post != op.pre
}
check tc_03_contract for 5

-- Scenario TC-04: Expired card entered. Error message displayed.
pred tc_04_holds {
    some op: REQ_AUTH_01 |
        -- initiator lacks Admin (expired card)
        Admin ! in op.initiator.mayPerform &&
        -- any grant attempt
        some op.grant &&
        -- target resource exists
        some op.target &&
        -- state changes (error displayed)
        op.post != op.pre
}
run tc_04_holds for 5

assert tc_04_contract {
    all op: REQ_AUTH_01 |
        (Admin ! in op.initiator.mayPerform && some op.grant &&
         some op.target) =>
        op.post != op.pre
}
check tc_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limit total interfaces per operation to bound latency
fact nfr_fact_performance {
    -- Proxy: fewer interfaces => faster authentication processing
    -- NFR: Authentication process should complete within 2 seconds.
    all op: REQ_AUTH_01 | #op.channel <= 2
}

-- Availability proxy: require at least one redundant channel for critical operations
fact nfr_fact_availability {
    -- Proxy: redundant channels ensure system remains available if one fails
    -- NFR: The system must be available at least 99.9% of the time.
    some op: REQ_AUTH_01 | #op.channel >= 2
}

-- Scalability proxy: ensure multiple actors can simultaneously initiate operations
assert nfr_assert_scalability {
    -- Proxy: all actors can have concurrent operations without conflict
    -- NFR: The system must support up to 10,000 concurrent authentication requests without performance degradation.
    all a: Actor | some op: REQ_AUTH_01 | op.initiator = a
}
check nfr_assert_scalability for 5

-- Usability proxy: authenticated channels should be bounded to ensure clear error handling
fact nfr_fact_usability {
    -- Proxy: limiting authenticated channels reduces complexity && improves error clarity
    -- NFR: Error messages should be clear && guide the user on how to resolve the issue.
    all op: REQ_AUTH_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

sig Card extends Resource {}
sig PIN extends Resource {}

fact sr_fact_card_pin_existence {
    all a: Actor | one c: Card | c.owner = a
    all a: Actor | one p: PIN | p.owner = a
}

fact sr_fact_card_pin_access_control {
    all c: Card | c.accessible = c.owner
    all p: PIN | p.accessible = p.owner
}

assert sr_assert_secure_card_pin_channel {
    all op: REQ_AUTH_01 |
        ((some c: Card | c in op.target) || (some p: PIN | p in op.target)) =>
        (all ch: op.channel | ch.encrypted = True && ch.authenticated = True)
}

check sr_assert_secure_card_pin_channel for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed type error: replaced Interface reference in target with Card and PIN resources.
-- Summary 2: Removed contradictory invariant inv_authenticated_channel_required that prevented reachability of Post2.
-- Summary 3: Extended security assertion to cover PIN in addition to Card.
-- Summary 4: Adjusted post-state reachability predicates to require both Card and PIN in target.
-- Summary 5: Preserved all original structure including acceptance criterion, edge case, and test scenario predicates.
-- Assumption 1: Each actor has exactly one Card and one PIN, enforced by facts.
-- Assumption 2: Channel authentication and encryption are required when card or PIN data is transmitted.
-- Assumption 3: Non-functional requirements are approximated via proxy constraints (e.g., channel count bounds).
-- Open issue 1: Card/PIN uniqueness per actor is assumed but not explicitly combined into a single combination; additional constraint may be needed.
-- Open issue 2: The model does not enforce which actors hold specific permissions (e.g., Admin), which may cause test scenarios to be too permissive.
-- Open issue 3: Non-functional proxies (availability, performance, usability) are coarse approximations and may not fully satisfy the requirements.


