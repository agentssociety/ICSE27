module REQ_BB_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BB-01
 * Title       : Accept and Store Transfusion Requests
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Staff, Clinical_Teams, Patients extends Actor {}
-- Blood_Bank_Staff: represents stakeholder 'Blood Bank Staff'
-- Clinical_Teams: represents stakeholder 'Clinical Teams'
-- Patients: represents stakeholder 'Patients'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Transfusion_Request_Submission_API, Transfusion_Request_Database extends Interface {}

fact interface_properties {
    Transfusion_Request_Submission_API.kind = API  -- The requirement interacts with this API to receive and validate transfusion requests. The API will return success or error responses based on the validation results.
    Transfusion_Request_Database.kind = Database  -- The system stores validated transfusion requests in this database for later matching against available inventory.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The system must be running and accessible to blood bank staff members.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The transfusion request with valid parameters must be stored in a database.
-- Post2: system reaches state where An error message must be displayed if the request has missing or invalid parameters, and it must not be stored.


----------------------------------------------------------------------
-- Core operation: REQ_BB_01
----------------------------------------------------------------------

sig REQ_BB_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BB_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BB_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BB_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BB_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BB_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BB_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BB_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BB_01 {
    some op: REQ_BB_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BB_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BB_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BB_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BB_01_well_formed {
    all op: REQ_BB_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BB_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicate for Post1: transfusion request stored in database.
pred ps_reach_Post1 {
    some op: REQ_BB_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        Database in op.target &&
        Transfusion_Request_Submission_API in op.channel &&
        some c: op.channel | c.authenticated = True
}

run ps_reach_Post1 for 5

-- Semantic assertion for Post1: whenever post-state is Post1, request is stored.
assert ps_valid_Post1 {
    all op: REQ_BB_01 |
        op.post = Post1 =>
            (Database in op.target && Write in op.initiator.mayPerform && op.grant = Write)
}

check ps_valid_Post1 for 5

-- Reachability predicate for Post2: error displayed, request ! stored.
pred ps_reach_Post2 {
    some op: REQ_BB_01 |
        op.post = Post2 &&
        op.pre = Pre1 &&
        Database ! in op.target &&
        API in op.target &&
        Transfusion_Request_Submission_API in op.channel &&
        some c: op.channel | c.authenticated = False &&
        Read in op.initiator.mayPerform &&
        op.grant = Read
}

run ps_reach_Post2 for 5

-- Semantic assertion for Post2: whenever post-state is Post2, error condition holds.
assert ps_valid_Post2 {
    all op: REQ_BB_01 |
        op.post = Post2 =>
            (Database ! in op.target && some c: op.channel | c.authenticated = False)
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_BB_01 |
    op.pre = Pre1 &&
    op.post = Post1 &&
    Write in op.initiator.mayPerform &&
    Transfusion_Request_Database in op.target
}
run ac_reach_1 for 5

pred ac_reach_2 {
  some op: REQ_BB_01 |
    op.pre = Pre1 &&
    op.post = Post2 &&
    Transfusion_Request_Database ! in op.target
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sigs for edge cases involving blood types && Rh factors
abstract sig BloodType {}
one sig A, B, AB, O, InvalidBloodType extends BloodType {}
sig BloodMapping { resource: one Resource, bloodType: one BloodType }
fact { all r: Resource | one bm: BloodMapping | bm.resource = r }

abstract sig RhFactor {}
one sig Plus, Minus, InvalidRh extends RhFactor {}
sig RhMapping { resource: one Resource, rh: one RhFactor }
fact { all r: Resource | one rm: RhMapping | rm.resource = r }

assert ec_safe_1 {
    all op: REQ_BB_01 |
        all c: op.channel |
            c.authenticated = True
}

assert ec_safe_2 {
    all op: REQ_BB_01 |
        all r: op.target |
            let bm = { b: BloodMapping | b.resource = r } |
                bm.bloodType in (A+B+AB+O)
}

assert ec_safe_3 {
    all op: REQ_BB_01 |
        all r: op.target |
            let rm = { m: RhMapping | m.resource = r } |
                rm.rh in (Plus+Minus)
}

assert ec_safe_4 {
    all r: Resource |
        #{op: REQ_BB_01 | r in op.target} <= 2
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-BB-01: Valid request with all parameters provided
pred tc_BB_01_holds {
    some op: REQ_BB_01 |
        op.initiator in (Clinical_Teams + Blood_Bank_Staff) &&
        op.target = Database &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_BB_01_holds for 5

assert tc_BB_01_contract {
    all op: REQ_BB_01 |
        (op.initiator in (Clinical_Teams + Blood_Bank_Staff) &&
         op.target = Database &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.grant = Write &&
         op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_BB_01_contract for 5

-- Scenario TC-BB-02: Request with missing parameters (missing encryption)
pred tc_BB_02_holds {
    some op: REQ_BB_01 |
        op.initiator in (Clinical_Teams + Blood_Bank_Staff) &&
        op.target = Database &&
        some c: op.channel | c.encrypted = False &&
        some c2: op.channel | c2.authenticated = True &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post2
}
run tc_BB_02_holds for 5

assert tc_BB_02_contract {
    all op: REQ_BB_01 |
        (op.initiator in (Clinical_Teams + Blood_Bank_Staff) &&
         op.target = Database &&
         some c: op.channel | c.encrypted = False &&
         some c2: op.channel | c2.authenticated = True &&
         op.grant = Write &&
         op.pre = Pre1) =>
        (op.post = Post2)
}
check tc_BB_02_contract for 5

-- Scenario TC-BB-03: Request with invalid blood type (missing authentication)
pred tc_BB_03_holds {
    some op: REQ_BB_01 |
        op.initiator in (Clinical_Teams + Blood_Bank_Staff) &&
        op.target = Database &&
        some c: op.channel | c.authenticated = False &&
        some c2: op.channel | c2.authenticated = True &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post2
}
run tc_BB_03_holds for 5

assert tc_BB_03_contract {
    all op: REQ_BB_01 |
        (op.initiator in (Clinical_Teams + Blood_Bank_Staff) &&
         op.target = Database &&
         some c: op.channel | c.authenticated = False &&
         some c2: op.channel | c2.authenticated = True &&
         op.grant = Write &&
         op.pre = Pre1) =>
        (op.post = Post2)
}
check tc_BB_03_contract for 5

-- Scenario TC-BB-04: High volume of concurrent requests
pred tc_BB_04_holds {
    #REQ_BB_01 = 5 &&
    all op: REQ_BB_01 |
        op.initiator in (Clinical_Teams + Blood_Bank_Staff) &&
        op.target = Database &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.grant = Write &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_BB_04_holds for 5

assert tc_BB_04_contract {
    all op: REQ_BB_01 |
        (op.initiator in (Clinical_Teams + Blood_Bank_Staff) &&
         op.target = Database &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.grant = Write &&
         op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_BB_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: limit total interfaces per operation to bound latency
fact nfr_fact_performance_latency {
    -- NFR: respond within 5 seconds; proxy: max 3 interfaces per operation
    all op: REQ_BB_01 | #op.channel <= 3
}

-- Scalability proxy: ensure no resource is overloaded by concurrent initiators
fact nfr_fact_scalability_concurrency {
    -- NFR: handle 1000 concurrent requests; proxy: each resource targeted by at most 2 operations
    all r: Resource | #(REQ_BB_01 <: target).r <= 2
}

-- Availability proxy: require at least one redundant channel for every operation
fact nfr_fact_availability_redundancy {
    -- NFR: 99.9% uptime; proxy: at least 2 channels per operation
    all op: REQ_BB_01 | #op.channel >= 2
}

-- Usability proxy: limit number of authenticated channels to keep error messages manageable
assert nfr_assert_usability_error_clarity {
    -- NFR: clear error messages; proxy: at most 2 authenticated channels per operation
    all op: REQ_BB_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 2
}
check nfr_assert_usability_error_clarity for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security property: only authorized blood bank staff may initiate transfusion requests  
fact sr_fact_initiator_is_blood_bank_staff {  
    all op: REQ_BB_01 | op.initiator in Blood_Bank_Staff  
}  

assert sr_assert_initiator_is_blood_bank_staff {  
    all op: REQ_BB_01 | op.initiator in Blood_Bank_Staff  
}  

-- Verify that the property holds under the existing constraints  
check sr_assert_initiator_is_blood_bank_staff for 5  

-- Additional pattern: authorization (least-privilege) is already enforced by  
-- inv_initiator_is_authorized, but we also confirm that initiator may perform the grant  
assert sr_assert_authorized_grant {  
    all op: REQ_BB_01 | op.grant in op.initiator.mayPerform  
}  
check sr_assert_authorized_grant for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model covers acceptance criteria for valid and invalid transfusion requests
-- Summary 2: Security property restricts initiator to Blood_Bank_Staff only
-- Summary 3: Edge cases for blood types and Rh factors are modeled
-- Summary 4: Non-functional requirements are approximated with structural constraints
-- Assumption 1: Blood_Bank_Staff is the only authorized initiator for transfusion requests
-- Assumption 2: Post-state Post1 corresponds to successful storage, Post2 to error
-- Assumption 3: Performance and scalability are proxied by channel count and resource load limits
-- Open issue 1: Fact sr_fact_initiator_is_blood_bank_staff may conflict with test scenarios that allow Clinical_Teams as initiator
-- Open issue 2: Edge case assertions ec_safe_1, ec_safe_2, ec_safe_3 may be too strict or not fully aligned with requirement
-- Open issue 3: The model does not explicitly represent the database or error messages as concrete entities


