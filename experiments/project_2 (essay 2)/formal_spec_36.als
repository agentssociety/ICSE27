module REQ_INV_MANAGE_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-INV-MANAGE-01
 * Title       : Automated Expiration of Blood Units
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Inventory_Manager, Blood_Bank_Staff, Quality_Assurance_Team extends Actor {}
-- Inventory_Manager: represents stakeholder 'Inventory Manager'
-- Blood_Bank_Staff: represents stakeholder 'Blood Bank Staff'
-- Quality_Assurance_Team: represents stakeholder 'Quality Assurance Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Inventory_Database extends Interface {}

fact interface_properties {
    Inventory_Database.kind = Database  -- The requirement interacts with the inventory database to retrieve and update blood unit data.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system has access to the collection date of the blood units.
-- Pre2: system is in state where The current date and time are accurately synchronized.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Expired blood units are no longer available in the inventory pool.
-- Post2: system reaches state where The status of expired blood units is updated to 'expired'.


----------------------------------------------------------------------
-- Core operation: REQ_INV_MANAGE_01
----------------------------------------------------------------------

sig REQ_INV_MANAGE_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_INV_MANAGE_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_INV_MANAGE_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_INV_MANAGE_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_INV_MANAGE_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_INV_MANAGE_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_INV_MANAGE_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_INV_MANAGE_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_INV_MANAGE_01 {
    some op: REQ_INV_MANAGE_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_INV_MANAGE_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_INV_MANAGE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_INV_MANAGE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_INV_MANAGE_01_well_formed {
    all op: REQ_INV_MANAGE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_INV_MANAGE_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates && semantic assertions for Post1 && Post2

-- Post1: Expired blood units are no longer available in the inventory pool.
pred ps_reach_Post1 {
    some op: REQ_INV_MANAGE_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        op.initiator = Inventory_Manager &&
        op.grant = Admin &&
        Admin in op.initiator.mayPerform &&
        op.channel.encrypted = True &&
        op.channel.authenticated = True
}
run ps_reach_Post1 for 5

-- Post2: The status of expired blood units is updated to 'expired'.
pred ps_reach_Post2 {
    some op: REQ_INV_MANAGE_01 |
        op.post = Post2 &&
        op.pre = Pre2 &&
        op.initiator = Blood_Bank_Staff &&
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        op.channel.encrypted = True &&
        op.channel.authenticated = True
}
run ps_reach_Post2 for 5

-- Semantic assertions: verify that every operation reaching Post1/Post2 satisfies domain-specific properties

assert ps_valid_Post1 {
    all op: REQ_INV_MANAGE_01 |
        op.post = Post1 =>
            op.initiator = Inventory_Manager &&
            op.grant = Admin
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_INV_MANAGE_01 |
        op.post = Post2 =>
            (op.initiator = Blood_Bank_Staff || op.initiator = Quality_Assurance_Team) &&
            op.grant = Write
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_INV_MANAGE_01 |
        op.initiator = Inventory_Manager &&
        Admin in op.initiator.mayPerform &&
        some op.target &&
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        op.pre = Pre1 &&
        op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_INV_MANAGE_01 |
        op.initiator = Inventory_Manager &&
        Admin in op.initiator.mayPerform &&
        some op.target &&
        (some c: op.channel | c.authenticated = True) &&
        op.pre = Pre2 &&
        op.post = Post2
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_INV_MANAGE_01 |
        op.initiator = Blood_Bank_Staff &&
        Write in op.initiator.mayPerform &&
        some op.target &&
        (some c: op.channel | c.authenticated = True) &&
        op.post = Post1
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- ec_safe_1: Determinism of operations regardless of system time synchronization.
-- If two operations share the same pre-state, they must produce the same post-state.
assert ec_safe_1 {
    all op1, op2: REQ_INV_MANAGE_01 |
        op1.pre = op2.pre => op1.post = op2.post
}
check ec_safe_1 for 5

-- ec_safe_2: Blood units collected on weekends/holidays must still respect access control.
-- The operation's initiator must hold the required permission && be in the target's accessible set.
-- (This ensures no relaxation of security on non-workdays.)
assert ec_safe_2 {
    all op: REQ_INV_MANAGE_01 |
        op.grant in op.initiator.mayPerform &&
        op.initiator in op.target.accessible
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-INV-MANAGE-01
pred tc_inv_manage_01_holds {
    some op: REQ_INV_MANAGE_01 |
        op.pre = Pre1 && op.post = Post1
}
run tc_inv_manage_01_holds for 5

assert tc_inv_manage_01_contract {
    all op: REQ_INV_MANAGE_01 |
        op.pre = Pre1 => op.post = Post1
}
check tc_inv_manage_01_contract for 5

-- TC-INV-MANAGE-02
pred tc_inv_manage_02_holds {
    some op: REQ_INV_MANAGE_01 |
        op.pre = Pre2 && op.post = Post1
}
run tc_inv_manage_02_holds for 5

assert tc_inv_manage_02_contract {
    all op: REQ_INV_MANAGE_01 |
        op.pre = Pre2 => op.post = Post1
}
check tc_inv_manage_02_contract for 5

-- TC-INV-MANAGE-03
pred tc_inv_manage_03_holds {
    some op: REQ_INV_MANAGE_01 |
        (op.pre = Pre1 || op.pre = Pre2) && op.post = Post1
}
run tc_inv_manage_03_holds for 5

assert tc_inv_manage_03_contract {
    all op: REQ_INV_MANAGE_01 |
        (op.pre = Pre1 || op.pre = Pre2) => op.post = Post1
}
check tc_inv_manage_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_channel_limit {
    -- PROXY: limiting channel count reduces communication overhead, lowering latency
    -- NFR: response time < 200ms
    all op: REQ_INV_MANAGE_01 | #op.channel <= 2
}

fact nfr_fact_availability_channel_redundancy {
    -- PROXY: requiring at least two channels ensures failure resilience for high availability
    -- NFR: system uptime >= 99.9%
    all op: REQ_INV_MANAGE_01 | #op.channel >= 2
}

assert nfr_assert_scalability_actor_participation {
    -- PROXY: every actor must be able to initiate at least one operation, ensuring the system scales to all users
    -- NFR: support all actors simultaneously
    all a: Actor | some op: REQ_INV_MANAGE_01 | op.initiator = a
}
check nfr_assert_scalability_actor_participation for 5

fact nfr_fact_usability_authenticated_simplicity {
    -- PROXY: all channels must be authenticated, simplifying the user model && reducing cognitive load
    -- NFR: usability - consistent authentication
    all op: REQ_INV_MANAGE_01 | all i: op.channel | i.authenticated = True
}

