module REQ_BLD_RES_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BLD-RES-01
 * Title       : Automated Blood Unit Reservation and Release
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Management, Clinical_Staff, IT_Team extends Actor {}
-- Blood_Bank_Management: represents stakeholder 'Blood Bank Management'
-- Clinical_Staff: represents stakeholder 'Clinical Staff'
-- IT_Team: represents stakeholder 'IT Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Reservation_API, Blood_Inventory_Database, Admin_Dashboard extends Interface {}

fact interface_properties {
    Reservation_API.kind = API  -- Used by the transfusion request management system to initiate, check status, and release reservations.
    Blood_Inventory_Database.kind = Database  -- Stores information about available blood units and their compatibility with different types.
    Admin_Dashboard.kind = UI  -- For monitoring reservations and managing system settings.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where There are pending transfusion requests in the system.
-- Pre2: system is in state where Blood units of compatible types are available in stock.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The reserved blood unit is no longer held by the reservation system.
-- Post2: system reaches state where The reserved blood unit becomes immediately available for other requests.


----------------------------------------------------------------------
-- Core operation: REQ_BLD_RES_01
----------------------------------------------------------------------

sig REQ_BLD_RES_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BLD_RES_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BLD_RES_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BLD_RES_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BLD_RES_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BLD_RES_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BLD_RES_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BLD_RES_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BLD_RES_01 {
    some op: REQ_BLD_RES_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BLD_RES_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BLD_RES_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BLD_RES_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BLD_RES_01_well_formed {
    all op: REQ_BLD_RES_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BLD_RES_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_BLD_RES_01 |
        op.post = Post1 &&
        op.grant = Execute &&
        Blood_Inventory_Database in op.target &&
        Reservation_API in op.channel &&
        op.initiator = Blood_Bank_Management
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_BLD_RES_01 |
        (op.post = Post1) => (op.grant = Execute && Blood_Inventory_Database in op.target)
}
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_BLD_RES_01 |
        op.post = Post2 &&
        op.grant = Admin &&
        Blood_Inventory_Database in op.target &&
        Admin_Dashboard in op.channel &&
        op.initiator = IT_Team
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_BLD_RES_01 |
        (op.post = Post2) => (op.grant = Admin && Blood_Inventory_Database in op.target)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: A blood unit is reserved for a pending transfusion request.
pred ac_reach_1 {
    some op: REQ_BLD_RES_01 |
        op.grant = Write &&
        op.target = Blood_Inventory_Database &&
        op.channel = Reservation_API &&
        op.pre = Pre1 &&
        op.post = Post1 &&
        op.initiator = Clinical_Staff
}
run ac_reach_1 for 5

-- Criterion 2: 24 hours have elapsed without the unit being issued.
-- Modeled as the reachability of the pre?state Pre2, which represents
-- the condition that a reservation has been held for 24?h without issue.
pred ac_reach_2 {
    some op: REQ_BLD_RES_01 |
        op.pre = Pre2
}
run ac_reach_2 for 5

-- Criterion 3: The reservation is automatically released && the unit is
-- marked as available for other requests.
pred ac_reach_3 {
    some op: REQ_BLD_RES_01 |
        op.grant = Write &&
        op.target = Blood_Inventory_Database &&
        op.channel = Reservation_API &&
        op.pre = Pre2 &&
        op.post = Post2 &&
        op.initiator = IT_Team
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

--Helper sigs for edge case 2 (multiple reservations for same blood unit)
sig BloodUnit extends Resource { }
one sig BU1, BU2 extends BloodUnit {}

-- Helper sig for edge case 3 (no compatible blood units available)
one sig Pre3 extends State {}

-- Edge case 1: transfusion request within 24-hour period must ! succeed
assert ec_safe_1 {
    all op: REQ_BLD_RES_01 |
        op.pre = Pre2 => op.post != Post1
}
check ec_safe_1 for 5

-- Edge case 2: no two operations can both succeed if they share a target (blood unit)
assert ec_safe_2 {
    all disj op1, op2: REQ_BLD_RES_01 |
        (op1.target & op2.target) != none => (op1.post != Post1 || op2.post != Post1)
}
check ec_safe_2 for 5

-- Edge case 3: if no compatible blood units are available (pre = Pre3), operation must fail
assert ec_safe_3 {
    all op: REQ_BLD_RES_01 |
        op.pre = Pre3 => op.post = Post2
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_bld_res_01_holds {
    some op: REQ_BLD_RES_01 |
        op.initiator in Clinical_Staff &&
        op.grant = Write &&
        op.target in BloodUnit &&
        op.target = BU1 &&
        (all c: op.channel | c.encrypted = True) &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_bld_res_01_holds for 5

assert tc_bld_res_01_contract {
    all op: REQ_BLD_RES_01 |
        (op.initiator in Clinical_Staff &&
         op.grant = Write &&
         op.target in BloodUnit &&
         op.target = BU1 &&
         (all c: op.channel | c.encrypted = True) &&
         op.pre = Pre1) =>
        op.post = Post1
}
check tc_bld_res_01_contract for 5

pred tc_bld_res_02_holds {
    some op: REQ_BLD_RES_01 |
        op.initiator in Blood_Bank_Management &&
        op.grant = Execute &&
        op.target in BloodUnit &&
        op.target = BU1 &&
        (all c: op.channel | c.encrypted = True) &&
        op.pre = Post1 &&
        op.post = Pre1
}
run tc_bld_res_02_holds for 5

assert tc_bld_res_02_contract {
    all op: REQ_BLD_RES_01 |
        (op.initiator in Blood_Bank_Management &&
         op.grant = Execute &&
         op.target in BloodUnit &&
         op.target = BU1 &&
         (all c: op.channel | c.encrypted = True) &&
         op.pre = Post1) =>
        op.post = Pre1
}
check tc_bld_res_02_contract for 5

pred tc_bld_res_03_holds {
    some disj op1, op2: REQ_BLD_RES_01 |
        op1.target = op2.target &&
        op1.target in BloodUnit &&
        op1.target = BU1 &&
        op1.grant = Write &&
        op2.grant = Write &&
        op1.pre = Pre1 &&
        op2.pre = Pre1 &&
        op1.post != op2.post
}
run tc_bld_res_03_holds for 5

assert tc_bld_res_03_contract {
    all disj op1, op2: REQ_BLD_RES_01 |
        (op1.target = op2.target &&
         op1.target in BloodUnit &&
         op1.grant = Write &&
         op2.grant = Write &&
         op1.pre = Pre1 &&
         op2.pre = Pre1) =>
        op1.post != op2.post
}
check tc_bld_res_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_latency {
    -- PROXY: Limiting the number of target resources per operation reduces processing time
    -- NFR: The system should handle reservations && releases within a specified time frame without significant delays
    all op: REQ_BLD_RES_01 | #op.target <= 3
}

fact nfr_fact_availability_redundancy {
    -- PROXY: At least two channels must be available to ensure 99.9% uptime via redundancy
    -- NFR: The system must be available for at least 99.9% of the time during regular business hours
    all op: REQ_BLD_RES_01 | #op.channel >= 2
}

fact nfr_fact_scalability_concurrent_actors {
    -- PROXY: All actors must be able to initiate operations, ensuring the system scales with actor count
    -- NFR: The system should be able to manage an increasing number of requests && reservations as the blood bank grows
    all a: Actor | some op: REQ_BLD_RES_01 | op.initiator = a
}

fact nfr_fact_usability_clear_feedback {
    -- PROXY: Limiting authenticated channels to a small number reduces user confusion && ensures clear feedback
    -- NFR: Error handling should be clear && user-friendly, providing feedback on reservation status
    all op: REQ_BLD_RES_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

assert nfr_assert_availability_uptime {
    -- Every operation must have at least one channel that is authenticated to ensure availability of secure access
    all op: REQ_BLD_RES_01 | some c: op.channel | c.authenticated = True
}
check nfr_assert_availability_uptime for 5

