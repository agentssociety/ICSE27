-- Post-state reachability predicates && semantic verification for REQ_BLOOD_01

-- Post1: Unique identifier for each blood unit
pred ps_reach_Post1 {
    some op: REQ_BLOOD_01 |
        op.post = Post1
        && op.pre != op.post
        && Blood_Unit_Database in op.target
        && Write in op.initiator.mayPerform
        && op.grant = Write
        && Inventory_Management_UI in op.channel
        && (some c: op.channel | c.authenticated = True)
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_BLOOD_01 |
        (op.post = Post1) =>
            (Blood_Unit_Database in op.target
             && Write in op.initiator.mayPerform
