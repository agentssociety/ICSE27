----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

pred missingCollectionDate[s: State] { s = Pre1 }
pred invalidABORh[s: State] { s = Pre2 }
pred duplicateIdentifier[t: set Resource] { some r1, r2: t | r1 != r2 && r1.owner = r2.owner }
pred expiryTooLong[s: State] { s = Pre1 || s = Pre2 }

assert ec_safe_1 {
  all op: REQ_BLOOD_01 |
    missingCollectionDate[op.pre] => (op.post = op.pre)
}

assert ec_safe_2 {
  all op: REQ_BLOOD_01 |
    invalidABORh[op.pre] => (op.post = op.pre)
}

assert ec_safe_3 {
  all op: REQ_BLOOD_01 |
    ! duplicateIdentifier[op.target]
}

assert ec_safe_4 {
  all op: REQ_BLOOD_01 |
    expiryTooLong[op.pre] => (op.post = op.pre)
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5
check ec_safe_4 for 5

