----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting the number of channels && resources per operation reduces processing overhead
    -- NFR: handle large volumes of inventory updates efficiently
    all op: REQ_BLOOD_01 | #op.channel <= 2 && #op.target <= 3
}

fact nfr_fact_availability {
    -- PROXY: requiring at least two channels ensures redundancy for 24/7 operation
    -- NFR: system must be available 24/7
    all op: REQ_BLOOD_01 | #op.channel >= 2
}

fact nfr_fact_scalability {
    -- PROXY: allowing all actors to be initiators simultaneously ensures no bottleneck
    -- NFR: scale with increasing number of blood units && users
    all a: Actor | some op: REQ_BLOOD_01 | op.initiator = a
}

fact nfr_fact_usability {
    -- PROXY: limiting authenticated channels to a small number reduces complexity for user feedback
    -- NFR: error handling should be clear && user-friendly
    all op: REQ_BLOOD_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

assert nfr_assert_performance {
    -- PROXY: no operation uses more than 2 channels && 3 resources
    -- NFR: handle large volumes of inventory updates efficiently
    all op: REQ_BLOOD_01 | #op.channel <= 2 && #op.target <= 3
}
check nfr_assert_performance for 5

assert nfr_assert_availability {
    -- PROXY: every operation has at least 2 channels for redundancy
    -- NFR: system must be available 24/7
    all op: REQ_BLOOD_01 | #op.channel >= 2
}
check nfr_assert_availability for 5

assert nfr_assert_scalability {
    -- PROXY: every actor can initiate at least one operation
    -- NFR: scale with increasing number of blood units && users
    all a: Actor | some op: REQ_BLOOD_01 | op.initiator = a
}
check nfr_assert_scalability for 5

assert nfr_assert_usability {
    -- PROXY: at most one authenticated channel per operation reduces complexity
    -- NFR: error handling should be clear && user-friendly
    all op: REQ_BLOOD_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}
check nfr_assert_usability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security Property: Unique identifiers must be securely stored to prevent unauthorized access.
fact sr_fact_unique_identifier_storage {
    all op: REQ_BLOOD_01 |
        all r: op.target |
            // Only the owner || admin can access the identifier (simulated via resource ownership)
            (r.owner = op.initiator) || (Admin in op.initiator.mayPerform)
}

-- Security Property: Sensitive information (ABO type, Rh factor, collection date) must be protected.
-- This is ensured by encryption-in-transit && access control.
fact sr_fact_sensitive_data_protection {
    all op: REQ_BLOOD_01 |
        // Encryption-in-transit: all channels must be encrypted
        (all c: op.channel | c.encrypted = True) &&
        // Authorization: initiator must be in accessible set for each target resource
        (all r: op.target | op.initiator in r.accessible)
}

-- Assertion: Verify that sensitive data protection holds for all operations
assert sr_assert_sensitive_data_protection {
    all op: REQ_BLOOD_01 |
        // Encryption-in-transit
        (all c: op.channel | c.encrypted = True) &&
        // Authorization for sensitive data (resource access control)
        (all r: op.target | op.initiator in r.accessible)
}

check sr_assert_sensitive_data_protection for 5

-- Assertion: Verify that unique identifiers are never exposed to unauthorized actors
assert sr_assert_unique_id_protection {
    all op: REQ_BLOOD_01 |
        all r: op.target |
            // If the initiator is ! the owner && does ! have Admin, access is forbidden
            !(r.owner != op.initiator && Admin ! in op.initiator.mayPerform)
}

check sr_assert_unique_id_protection for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed contradictory invariant: allowed no state change for edge case preconditions Pre1 and Pre2.
-- Summary 2: All other structural facts and assertions remain unchanged.
-- Summary 3: Model focuses on access control and operational structure, not on concrete blood unit attributes.
-- Assumption 1: Blood unit details (ID, ABO, Rh, dates) are abstracted into Resource and State signatures.
-- Assumption 2: Edge cases for missing collection date or invalid ABO/Rh are modeled as specific pre-states.
-- Assumption 3: Duplicate identifier check uses resource owner as a proxy for identity (under-specified).
-- Open issue 1: Blood unit concrete attributes (unique ID, ABO type, Rh factor, collection date, expiry, status) are not modeled in the Alloy specification.
-- Open issue 2: The duplicateIdentifier predicate uses owner as a proxy for identifier, which may not capture the intended semantics.
-- Open issue 3: Some acceptance criterion reachability predicates may be unsatisfiable due to conflicting non-functional facts (e.g., channels must be exactly 2, with at most 1 authenticated, but all channels must be encrypted makes only one option).


