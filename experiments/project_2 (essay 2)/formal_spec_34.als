module REQ_BBT_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-BBT-01
 * Title       : Exact ABO/Rh Match First
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Blood_Bank_Technicians, Clinical_Staff, Patient_Safety_Committee extends Actor {}
-- Blood_Bank_Technicians: represents stakeholder 'Blood Bank Technicians'
-- Clinical_Staff: represents stakeholder 'Clinical Staff'
-- Patient_Safety_Committee: represents stakeholder 'Patient Safety Committee'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Blood_Unit_Inventory_API, Transfusion_Request_Database extends Interface {}

fact interface_properties {
    Blood_Unit_Inventory_API.kind = API  -- The system will query this API to retrieve the current inventory of blood units.
    Transfusion_Request_Database.kind = Database  -- The system will store and update transfusion requests and their matching results in this database.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system has access to up-to-date blood unit inventory with ABO/Rh type, expiry date, and cross-match status.
-- Pre2: system is in state where The transfusion request includes a specific ABO/Rh type.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Only valid cross-matched units are considered for the transfusion request.
-- Post2: system reaches state where Units are prioritized based on exact ABO/Rh match and then by the closest expiry date among compatible types.


----------------------------------------------------------------------
-- Core operation: REQ_BBT_01
----------------------------------------------------------------------

sig REQ_BBT_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_BBT_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_BBT_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_BBT_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_BBT_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_BBT_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_BBT_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_BBT_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_BBT_01 {
    some op: REQ_BBT_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_BBT_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_BBT_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_BBT_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_BBT_01_well_formed {
    all op: REQ_BBT_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_BBT_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1: Only valid cross-matched units are considered for the transfusion request.
pred ps_reach_Post1 {
    some op: REQ_BBT_01 |
        op.post = Post1 &&
        op.pre != Post1 &&
        Read in op.initiator.mayPerform &&
        some op.target => Resource in op.target
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_BBT_01 |
        (op.post = Post1) =>
            (op.pre != Post1 && Read in op.initiator.mayPerform)
}
check ps_valid_Post1 for 5

-- Post2: Units are prioritized based on exact ABO/Rh match && then by the closest expiry date among compatible types.
pred ps_reach_Post2 {
    some op: REQ_BBT_01 |
        op.post = Post2 &&
        op.pre != Post2 &&
        Read in op.initiator.mayPerform &&
        some op.target => Resource in op.target
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_BBT_01 |
        (op.post = Post2) =>
            (op.pre != Post2 && Read in op.initiator.mayPerform)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Predicate for Criterion 1: exact ABO/Rh match sorted by closest expiry date
pred ac_reach_1 {
  some op: REQ_BBT_01 |
    op.initiator = Blood_Bank_Technicians &&
    op.grant = Read &&
    some r1, r2: Resource | r1 != r2 and r1 in op.target and r2 in op.target &&
    (some c: op.channel | c.encrypted = True) &&
    (some c: op.channel | c.authenticated = True) &&
    op.pre = Pre1 &&
    op.post = Post1
}
run ac_reach_1 for 5

-- Predicate for Criterion 2: compatible types with closest expiry date when no exact match
pred ac_reach_2 {
  some op: REQ_BBT_01 |
    op.initiator = Blood_Bank_Technicians &&
    op.grant = Read &&
    some r: Resource | r in op.target &&
    (some c: op.channel | c.encrypted = True) &&
    (some c: op.channel | c.authenticated = True) &&
    op.pre = Pre2 &&
    op.post = Post2
}
run ac_reach_2 for 5

-- Predicate for Criterion 3: exclude units that have passed cross-match validation (abstracted)
pred ac_reach_3 {
  some op: REQ_BBT_01 |
    op.initiator = Blood_Bank_Technicians &&
    op.grant = Read &&
    some r: Resource | r ! in op.target &&   -- at least one resource excluded (e.g., a non-cross-matched unit)
    (some c: op.channel | c.encrypted = True) &&
    (some c: op.channel | c.authenticated = True) &&
    op.pre = Pre1 &&
    op.post = Post1
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: No compatible blood units available
-- If no blood units are compatible (i.e., no resource in target is accessible to initiator),
-- the operation must not succeed in a way that changes the state.
assert ec_safe_1 {
    all op: REQ_BBT_01 |
        (no r: op.target | op.initiator in r.accessible) =>
        (op.post = op.pre)
}
check ec_safe_1 for 5

-- Edge case 2: Simultaneous requests for same ABO/Rh type
-- Two operations targeting the same resource must have compatible grants
-- or the resource must not be modified inconsistently.
assert ec_safe_2 {
    all disj op1, op2: REQ_BBT_01 |
        (some op1.target & op2.target) =>
        (op1.grant = op2.grant || op1.post = op2.post)
}
check ec_safe_2 for 5

-- Edge case 3: Transfusion request before cross-match validation
-- If a transfusion request occurs before cross-match, the pre-state must be Pre1
-- (representing pre-cross-match state) and cannot transition directly to Post2
-- (representing post-transfusion state) without going through Post1 first.
assert ec_safe_3 {
    all op: REQ_BBT_01 |
        (op.pre = Pre1 && op.grant = Execute) =>
        (op.post != Post2)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_BBT_01_holds {
    some op: REQ_BBT_01 |
        -- Input: Exact ABO/Rh match available with multiple units, one having the closest expiry date
        some unit1, unit2: Resource |
            unit1 in op.target && unit2 in op.target && unit1 != unit2 &&
            -- Expected: Return exact ABO/Rh match unit first and then other compatible types sorted by expiry date
            op.grant = Read &&
            op.initiator in Blood_Bank_Technicians &&
            op.pre = Pre1 && op.post = Post1
}
run tc_BBT_01_holds for 5

assert tc_BBT_01_contract {
    all op: REQ_BBT_01 |
        (op.pre = Pre1 && op.grant = Read && op.initiator in Blood_Bank_Technicians) =>
        (op.post = Post1 && some unit: op.target | unit in Resource)
}
check tc_BBT_01_contract for 5

pred tc_BBT_02_holds {
    some op: REQ_BBT_01 |
        -- Input: No exact ABO/Rh match available, but compatible types exist with varying expiry dates
        no unit: Resource | unit in op.target && unit.owner = op.initiator &&
        some unit: Resource | unit in op.target &&
        -- Expected: Return the compatible type with the closest expiry date
        op.grant = Read &&
        op.initiator in Blood_Bank_Technicians &&
        op.pre = Pre1 && op.post = Post2
}
run tc_BBT_02_holds for 5

assert tc_BBT_02_contract {
    all op: REQ_BBT_01 |
        (op.pre = Pre1 && op.grant = Read && op.initiator in Blood_Bank_Technicians &&
         no unit: Resource | unit in op.target && unit.owner = op.initiator) =>
        (op.post = Post2 && some unit: op.target | unit in Resource)
}
check tc_BBT_02_contract for 5

pred tc_BBT_03_holds {
    some op: REQ_BBT_01 |
        -- Input: A blood unit has not passed cross-match validation and is included in inventory
        some unit: Resource |
            unit in op.target &&
            unit.owner != op.initiator &&  -- abstract representation of a non-cross-matched unit
            -- Expected: Exclude this unit from matching results
            op.grant = Read &&
            op.initiator in Blood_Bank_Technicians &&
            op.pre = Pre1 && op.post = Post1
}
run tc_BBT_03_holds for 5

assert tc_BBT_03_contract {
    all op: REQ_BBT_01 |
        (op.pre = Pre1 && op.grant = Read && op.initiator in Blood_Bank_Technicians &&
         some unit: Resource | unit in op.target && unit.owner != op.initiator) =>
        (op.post = Post1 && no unit: Resource | unit in op.target && unit.owner != op.initiator)
}
check tc_BBT_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: proxy constraint limits number of interfaces per operation to reduce latency
-- NFR: process transfusion requests within 200ms; fewer channels = faster processing
fact nfr_fact_latency_bound {
    all op: REQ_BBT_01 | #op.channel <= 2
}

-- Availability: proxy requires at least one encrypted channel for secure peak-hour operation
-- NFR: system must be available during peak hours; encrypted channel ensures secure uptime
fact nfr_fact_peak_availability {
    all op: REQ_BBT_01 | some c: op.channel | c.encrypted = True
}

-- Scalability: proxy asserts that multiple operations can coexist without resource conflict
-- NFR: handle increase in transfusion requests without degradation
fact nfr_fact_concurrent_operations {
    all disj op1, op2: REQ_BBT_01 | op1.target & op2.target = none
}

-- Usability: proxy ensures error handling by requiring readable post-state for every operation
-- NFR: clear error messages when match not found
fact nfr_fact_user_friendly_error {
    all op: REQ_BBT_01 | op.post in Post1 + Post2
}

-- Reliability: proxy enforces that every operation has a defined post-state
-- NFR: system must reliably reach a defined state after each operation
assert nfr_assert_defined_post_state {
    all op: REQ_BBT_01 | one op.post
}
check nfr_assert_defined_post_state for 5

-- Maintainability: proxy ensures no circular ownership in resource hierarchy
-- NFR: maintainable resource ownership structure
fact nfr_fact_no_circular_ownership {
    all r: Resource | r.owner != r
}

