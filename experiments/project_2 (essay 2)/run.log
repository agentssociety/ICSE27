                <select value={form.rhFactor} onChange={(e) => setForm({ ...form, rhFactor: e.target.value })}>              
                  <option value="+">+</option>                                                                               
                  <option value="-">-</option>                                                                               
                </select>                                                                                                    
              </div>                                                                                                         
              <div>                                                                                                          
                <label style={{ display: 'block', marginBottom: '0.25rem', color: 'var(--text-secondary)', fontSize:         
