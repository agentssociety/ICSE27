                  "bloodType": r.bloodType,                                                                                  
                  "rhFactor": r.rhFactor,                                                                                    
                  "quantity": r.quantity,                                                                                    
              }                                                                                                              
              for r in stored                                                                                                
          ]                                                                                                                  
                                                                                                                             
