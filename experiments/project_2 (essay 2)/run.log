    return api.get<BloodUnit[]>('/blood_units').then((r) => r.data);                                                         
  }                                                                                                                          
                                                                                                                             
  export function getBloodUnit(id: number) {                                                                                 
    return api.get<BloodUnit>(`/blood_units/${id}`).then((r) => r.data);                                                     
