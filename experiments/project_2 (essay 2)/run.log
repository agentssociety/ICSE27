      bloodType: 'A',                                                                                                        
      rhFactor: '+',                                                                                                         
      quantity: 1,                                                                                                           
    });                                                                                                                      
    const [submitting, setSubmitting] = useState(false);                                                                     
                                                                                                                             
    const fetchRequests = () => {                                                                                            
      setLoading(true);                                                                                                      
      listTransfusionRequests()                                                                                              
        .then((data) => {                                                                                                    
          setRequests(data);                                                                                                 
          setLoading(false);                                                                                                 
        })                                                                                                                   
        .catch((err) => {                                                                                                    
          setError(err.message || 'Failed to load requests');                                                                
          setLoading(false);                                                                                                 
        });                                                                                                                  
    };                                                                                                                       
                                                                                                                             
    useEffect(() => {                                                                                                        
      fetchRequests();                                                                                                       
    }, []);                                                                                                                  
                                                                                                                             
