          request_blood_type: str,                                                                                           
          request_rh_factor: str,                                                                                            
      ) -> Optional[ReservationResponse]:                                                                                    
          """Create a reservation for a blood unit matching a transfusion request.                                           
                                                                                                                             
          Matches by ABO/Rh type. Reservation expires in 24 hours.                                                           
          Returns None if the blood unit is not available or type mismatch.                                                  
          """                                                                                                                
          unit = self._blood_unit_repo.get_by_id(blood_unit_id)                                                              
          if unit is None:                                                                                                   
              return None                                                                                                    
          if unit.status != "available":                                                                                     
              return None                                                                                                    
          if unit.aboType != request_blood_type or unit.rhFactor != request_rh_factor:                                       
              return None                                                                                                    
                                                                                                                             
          # Mark blood unit as reserved                                                                                      
          self._blood_unit_repo.update(blood_unit_id, BloodUnitUpdate(status="reserved"))                                    
                                                                                                                             
          now = datetime.now()                                                                                               
          expiry = now + timedelta(hours=24)                                                                                 
          create_data = ReservationCreate(                                                                                   
              bloodUnitId=str(blood_unit_id),                                                                                
              transfusionRequestId=transfusion_request_id,                                                                   
              bloodUnit_id=blood_unit_id,                                                                                    
          )                                                                                                                  
          # We need to store reservation timestamp and expiry                                                                
          # Override: use repo with extra fields like we did for blood unit                                                  
          # Actually the ReservationCreate doesn't have timestamp fields, let me use the same **extra pattern                
          # But the repo create doesn't support **extra. Let me update it.                                                   
          return self._create_with_timestamps(create_data, now, expiry)                                                      
                                                                                                                             
      def _create_with_timestamps(                                                                                           
          self, data: ReservationCreate, now: datetime, expiry: datetime                                                     
      ) -> ReservationResponse:                                                                                              
          """Helper to create reservation with timestamps via session directly."""                                           
          from src.orm.reservation.reservation_orm import ReservationORM                                                     
                                                                                                                             
          row = ReservationORM(**data.model_dump(exclude_unset=True))                                                        
          row.reservationTimestamp = now                                                                                     
          row.expiryTimestamp = expiry                                                                                       
          row.status = "active"                                                                                              
          self._reservation_repo._session.add(row)                                                                           
          self._reservation_repo._session.commit()                                                                           
          self._reservation_repo._session.refresh(row)                                                                       
          return ReservationResponse.model_validate(row)                                                                     
                                                                                                                             
      def release_expired_reservations(self) -> int:                                                                         
          """Release all reservations that have passed their 24-hour expiry.                                                 
                                                                                                                             
          For each expired reservation, mark the blood unit back to available                                                
          and update the reservation status to released.                                                                     
          Returns the number of released reservations.                                                                       
          """                                                                                                                
          all_reservations = self._reservation_repo.get_all()                                                                
          now = datetime.now()                                                                                               
          released_count = 0                                                                                                 
          for res in all_reservations:                                                                                       
              if res.status != "active":                                                                                     
                  continue                                                                                                   
              # Check if expired by trying to get the reservation domain                                                     
              # The response doesn't have timestamp, we need the ORM row                                                     
              # Let's access the ORM directly via session                                                                    
              orm_row = self._reservation_repo._session.get(                                                                 
                  __import__("src.orm.reservation.reservation_orm", fromlist=["ReservationORM"]).ReservationORM,             
                  res.id                                                                                                     
              )                                                                                                              
              if orm_row and now >= orm_row.expiryTimestamp:                                                                 
                  # Release reservation                                                                                      
                  self._reservation_repo.update(                                                                             
                      int(res.id) if isinstance(res.id, str) else res.id,                                                    
                      ReservationUpdate(status="released"),                                                                  
                  )                                                                                                          
                  # Release blood unit                                                                                       
                  blood_unit_id = int(orm_row.bloodUnitId) if isinstance(orm_row.bloodUnitId, str) else orm_row.bloodUnitId  
                  self._blood_unit_repo.update(                                                                              
                      blood_unit_id,                                                                                         
                      BloodUnitUpdate(status="available"),                                                                   
                  )                                                                                                          
                  released_count += 1                                                                                        
          return released_count                                                                                              
                                                                                                                             
      def auto_release_all_expired(self) -> int:                                                                             
          """Convenience wrapper."""                                                                                         
          return self.release_expired_reservations()                                                                         
  '''                                                                                                                        
