----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES ??????????????????????????????????????????????

-- Criterion 1: The system displays the patient at the head of the queue.
-- Semantic encoding: an authorized initiator uses a secure, authenticated channel
-- to read the queue resource, && the system transitions to a state where the
-- head-of-queue patient is visible (represented by Pre1 state transitioning).
pred ac_reach_1 {
    some op: REQ_HEALTHCARE_01 |
        -- Initiator has Read permission (to view queue)
        Read in op.initiator.mayPerform &&
        -- Target resource exists (the queue)
        some op.target &&
        -- Channel is authenticated && encrypted (secure display)
        (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
        -- Operation uses Read grant
        op.grant = Read &&
        -- State transitions from Pre1 (initial queue state) to show head
        op.pre = Pre1 &&
        -- Initiator is authorized to access the target resource
        op.initiator in op.target.accessible
}

run ac_reach_1 for 5

-- Criterion 2: The system removes that patient from the queue.
-- Semantic encoding: an authorized initiator uses Execute permission to modify
-- the queue resource, transitioning to a post-state where the head is removed.
pred ac_reach_2 {
    some op: REQ_HEALTHCARE_01 |
        -- Initiator has Execute permission (to modify queue)
        Execute in op.initiator.mayPerform &&
        -- Target resource exists (the queue to be modified)
        some op.target &&
        -- Channel is authenticated (secure removal operation)
        (some c: op.channel | c.authenticated = True) &&
        -- Operation uses Execute grant (removal action)
        op.grant = Execute &&
        -- State transitions from Pre1 (queue with head) to PostDone (head removed)
        op.pre = Pre1 &&
        op.post = PostDone &&
        -- Initiator is authorized to access the target resource
        op.initiator in op.target.accessible
}

run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sigs to model queue emptiness && patient served status
sig QueueResource extends Resource {
    empty: one Bool
}

sig PatientResource extends Resource {
    served: one Bool
}

-- Safety assertion: never a practitioner requesting next patient from an empty queue
assert ec_safe_1 {
    no op: REQ_HEALTHCARE_01 |
        op.initiator in Healthcare_Practitioners &&
        some q: QueueResource | q in op.target && q.empty = True
}

check ec_safe_1 for 5

-- Safety assertion: never a practitioner attempting to remove a patient who has already been served
assert ec_safe_2 {
    no op: REQ_HEALTHCARE_01 |
        op.initiator in Healthcare_Practitioners &&
        some p: PatientResource | p in op.target && p.served = True
}

check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicates && assertions for REQ_HEALTHCARE_01 scenarios

-- TC-HEALTHCARE-01: Display first patient without removal
pred tc_healthcare_01_holds {
    some op: REQ_HEALTHCARE_01 |
        // Input: request from healthcare practitioner to read queue head
        op.initiator in Healthcare_Practitioners &&
        op.grant = Read &&
        // target includes a queue resource && a patient resource (the head)
        one q: QueueResource, p: PatientResource | q in op.target && p in op.target &&
        // channel must be authenticated && encrypted
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        // pre state is Pre1 (presumably non-empty queue) 
        op.pre = Pre1 &&
        // post state is PostDone (operation completed without removal)
        op.post = PostDone
}

run tc_healthcare_01_holds for 5

assert tc_healthcare_01_contract {
    all op: REQ_HEALTHCARE_01 |
        // Precondition: healthcare practitioner, read permission, authenticated/encrypted channel, pre=Pre1
        (op.initiator in Healthcare_Practitioners &&
         op.grant = Read &&
         one q: QueueResource, p: PatientResource | q in op.target && p in op.target &&
         all c: op.channel | c.encrypted = True && c.authenticated = True &&
         op.pre = Pre1) =>
        // Postcondition: state changed, queue resource unchanged (no removal) ? but static; ensure grant remains Read
        (op.post != op.pre && op.grant = Read)
}

check tc_healthcare_01_contract for 5

-- TC-HEALTHCARE-02: Remove patient after display
pred tc_healthcare_02_holds {
    some op: REQ_HEALTHCARE_01 |
        // Input: healthcare practitioner authorized to write (remove)
        op.initiator in Healthcare_Practitioners &&
        op.grant = Write &&
        // target includes queue && the patient to be removed
        one q: QueueResource, p: PatientResource | q in op.target && p in op.target &&
        // secure channel
        all c: op.channel | c.authenticated = True &&
        // pre state before removal, post state after
        op.pre = Pre1 && op.post = PostDone
}

run tc_healthcare_02_holds for 5

assert tc_healthcare_02_contract {
    all op: REQ_HEALTHCARE_01 |
        // Precondition: healthcare practitioner, write permission, authenticated channel, pre=Pre1, target has queue && patient
        (op.initiator in Healthcare_Practitioners &&
         op.grant = Write &&
         one q: QueueResource, p: PatientResource | q in op.target && p in op.target &&
         all c: op.channel | c.authenticated = True &&
         op.pre = Pre1) =>
        // Postcondition: state changed, grant remains Write, && the patient is no longer accessible to initiator? Not modeled; assume removal means no patient in target after? But target is static.
        // We require that the operation is grant is Write && state changed.
        (op.post != op.pre && op.grant = Write)
}

check tc_healthcare_02_contract for 5

-- TC-HEALTHCARE-03: Empty queue handling
pred tc_healthcare_03_holds {
    some op: REQ_HEALTHCARE_01 |
        // Input: healthcare practitioner tries to read from empty queue
        op.initiator in Healthcare_Practitioners &&
        op.grant = Read &&
        // target includes a queue resource but NO patient resource
        some q: QueueResource | q in op.target && no p: PatientResource | p in op.target &&
        // channel secure
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        // pre state is Pre1 (empty queue) && post state is PostDone
        op.pre = Pre1 && op.post = PostDone
}

run tc_healthcare_03_holds for 5

assert tc_healthcare_03_contract {
    all op: REQ_HEALTHCARE_01 |
        // Precondition: healthcare practitioner, read permission, authenticated/encrypted channel, target has queue but no patient, pre=Pre1
        (op.initiator in Healthcare_Practitioners &&
         op.grant = Read &&
         some q: QueueResource | q in op.target && no p: PatientResource | p in op.target &&
         all c: op.channel | c.authenticated = True && c.encrypted = True &&
         op.pre = Pre1) =>
        // Postcondition: state changed, grant still Read, no removal (implied by absence of patient in target)
        (op.post != op.pre && op.grant = Read && no p: PatientResource | p in op.target)
}

check tc_healthcare_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting the number of channels && targets per operation reduces communication overhead && improves response time (<200ms)
    all op : REQ_HEALTHCARE_01 | #op.channel <= 2 && #op.target <= 2
}

fact nfr_fact_availability {
    -- PROXY: requiring at least two channels per operation ensures redundancy in case of channel failure (uptime target >99.9%)
    all op : REQ_HEALTHCARE_01 | #op.channel >= 2
}

assert nfr_assert_scalability {
    -- PROXY: every actor type can initiate at least one operation, indicating the system scales to handle all roles simultaneously
    all a : Actor | some op : REQ_HEALTHCARE_01 | op.initiator = a
}
check nfr_assert_scalability for 5

fact nfr_fact_usability {
    -- PROXY: limiting the number of authenticated channels per operation avoids excessive authentication steps, improving user experience
    all op : REQ_HEALTHCARE_01 | #{ch : op.channel | ch.authenticated = True} <= 2
}

