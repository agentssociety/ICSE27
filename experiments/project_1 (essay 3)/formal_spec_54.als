module REQ_ITEM_URGENCY_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ITEM-URGENCY-01
 * Title       : Assign Item Urgency Level
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Owners, Project_Managers, Team_Leaders extends Actor {}
-- Product_Owners: represents stakeholder 'Product Owners'
-- Project_Managers: represents stakeholder 'Project Managers'
-- Team_Leaders: represents stakeholder 'Team Leaders'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor,
    urgency    : lone UrgencyLevel   -- urgency level of the resource (item)
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Urgency levels (1 to 5)
----------------------------------------------------------------------

abstract sig UrgencyLevel {}
one sig U1, U2, U3, U4, U5 extends UrgencyLevel {}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Item_Management_API extends Interface {}

fact interface_properties {
    Item_Management_API.kind = API  -- The requirement interacts with the Item Management API to update the urgency level of items.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The item's urgency level is updated to the specified value


----------------------------------------------------------------------
-- Core operation: REQ_ITEM_URGENCY_01
----------------------------------------------------------------------

sig REQ_ITEM_URGENCY_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    urgency    : one  UrgencyLevel,    -- the urgency level being assigned
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ITEM_URGENCY_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ITEM_URGENCY_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ITEM_URGENCY_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ITEM_URGENCY_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ITEM_URGENCY_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ITEM_URGENCY_01 | some c: op.channel | c.authenticated = True
}

-- INV-7: The operation sets the target's urgency to the specified level.
fact inv_urgency_assigned {
    all op: REQ_ITEM_URGENCY_01 | op.target.urgency = op.urgency
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ITEM_URGENCY_01 | op.post in Post1
}


----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ITEM_URGENCY_01 {
    some op: REQ_ITEM_URGENCY_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ITEM_URGENCY_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ITEM_URGENCY_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ITEM_URGENCY_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ITEM_URGENCY_01_well_formed {
    all op: REQ_ITEM_URGENCY_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.urgency   &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ITEM_URGENCY_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_ITEM_URGENCY_01 |
        op.post = Post1 &&
        op.pre = PreIdle &&
        Write in op.initiator.mayPerform &&
        op.channel.encrypted = True &&
        op.channel.authenticated = True &&
        op.grant = Write
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ITEM_URGENCY_01 |
        (op.post = Post1) =>
            (op.pre != op.post &&
             Write in op.initiator.mayPerform &&
             op.channel.encrypted = True &&
             op.channel.authenticated = True &&
             op.grant = Write)
}
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Reachability predicates for REQ_ITEM_URGENCY_01 acceptance criteria.
-- Each predicate witnesses that the system can realize the given criterion.

pred ac_reach_1 {
    some op: REQ_ITEM_URGENCY_01 |
        op.pre = PreIdle &&
        op.grant = Write &&
        op.grant in op.initiator.mayPerform &&
        some op.target &&
        some op.channel &&
        op.urgency = U3   -- assign urgency level 3
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_ITEM_URGENCY_01 |
        op.pre = PreIdle &&
        op.post = Post1 &&
        op.grant = Write &&
        op.grant in op.initiator.mayPerform &&
        some op.target &&
        some op.channel &&
        op.urgency = U3
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_ITEM_URGENCY_01 |
        op.post = Post1 &&
        op.grant = Write &&
        op.grant in op.initiator.mayPerform &&
        some op.target &&
        some op.channel &&
        op.urgency = U3
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_ITEM_URGENCY_01 |
    -- Urgency level assigned must be exactly one of {1, 2, 3, 4, 5}
    op.urgency in U1 + U2 + U3 + U4 + U5
}
check ec_safe_1 for 5

-- Edge case 1: Assigning an urgency level outside the range of 1 to 5
-- Since urgency level is modeled as UrgencyLevel with exactly five atoms,
-- any assignment is inherently within the valid range.

assert ec_safe_2 {
  all op: REQ_ITEM_URGENCY_01 |
    -- The urgency level must be a valid UrgencyLevel atom (no non-numeric values)
    op.urgency in UrgencyLevel
}
check ec_safe_2 for 5

-- Edge case 2: Attempting to assign a non-numeric value as an urgency level
-- Since UrgencyLevel is an abstract sig with only the declared atoms as extensions,
-- any urgency value is inherently a valid UrgencyLevel (numeric analog).

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-ITEM-URGENCY-01: Assign valid urgency level 3
pred tc_ITEM_URGENCY_01_holds {
    some op: REQ_ITEM_URGENCY_01 |
        -- Input: valid urgency level 3 (represented as state transition)
        op.pre = PreIdle &&
        op.post = Post1 &&
        -- The operation succeeds: post differs from pre
        op.post != op.pre &&
        -- Initiator has permission (authorized actor)
        some p: Permission | p in op.initiator.mayPerform &&
        op.grant in op.initiator.mayPerform &&
        op.urgency = U3
}
run tc_ITEM_URGENCY_01_holds for 5

assert tc_ITEM_URGENCY_01_contract {
    all op: REQ_ITEM_URGENCY_01 |
        (op.pre = PreIdle && op.grant in op.initiator.mayPerform && op.urgency = U3) =>
        (op.post = Post1 && op.post != op.pre)
}
check tc_ITEM_URGENCY_01_contract for 5

-- TC-ITEM-URGENCY-02: Invalid urgency level 6 (out of range)
-- This cannot be directly modeled because the type system restricts urgency to UrgencyLevel.
-- We assert that no operation assigns an invalid level.
assert tc_ITEM_URGENCY_02_contract {
    all op: REQ_ITEM_URGENCY_01 |
        op.urgency in U1 + U2 + U3 + U4 + U5
}
check tc_ITEM_URGENCY_02_contract for 5

-- TC-ITEM-URGENCY-03: Non-numeric urgency level ('three')
-- This cannot be directly modeled because the type system restricts urgency to UrgencyLevel.
-- We assert that all urgency values are valid UrgencyLevel atoms.
assert tc_ITEM_URGENCY_03_contract {
    all op: REQ_ITEM_URGENCY_01 |
        op.urgency in UrgencyLevel
}
check tc_ITEM_URGENCY_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- NFR: Performance proxy - minimize number of interfaces per operation to reduce latency
fact nfr_fact_channel_efficiency {
    -- PROXY: Fewer channels per operation => lower communication overhead
    all op: REQ_ITEM_URGENCY_01 | #op.channel <= 1
}

-- NFR: Availability proxy - require at least one redundant channel exists
-- (Removed because it caused inconsistency with single Interface atom)

-- NFR: Scalability proxy - assert all actors can have simultaneous operations
fact nfr_fact_simultaneous_actors {
    -- PROXY: If all actors can initiate operations, the system scales to full user base
    all a: Actor | some op: REQ_ITEM_URGENCY_01 | op.initiator = a
}

-- NFR: Reliability proxy - every operation has exactly one defined post-state
assert nfr_assert_reliable_completion {
    -- PROXY: Single deterministic post-state ensures predictable behavior
    all op: REQ_ITEM_URGENCY_01 | one op.post
}
check nfr_assert_reliable_completion for 5

-- NFR: Usability proxy - limit number of authenticated channels for simplicity
fact nfr_fact_usability_simple_auth {
    -- PROXY: Fewer authenticated channels reduces user complexity
    all op: REQ_ITEM_URGENCY_01 | #(op.channel & encrypted.True) <= 2
}

-- NFR: Maintainability proxy - no circular resource ownership
assert nfr_assert_no_circular_ownership {
    -- PROXY: Acyclic ownership graph simplifies maintenance
    no r: Resource | r in r.^(owner.mayPerform)
}
check nfr_assert_no_circular_ownership for 5

