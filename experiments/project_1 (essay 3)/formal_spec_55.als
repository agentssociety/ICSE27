module REQ_QUEUE_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-QUEUE-01
 * Title       : Order Queue by Urgency and Time
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Owner, Development_Team, QA_Team extends Actor {}
-- Product_Owner: represents stakeholder 'Product Owner'
-- Development_Team: represents stakeholder 'Development Team'
-- QA_Team: represents stakeholder 'QA Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Queue_Storage extends Interface {}

fact interface_properties {
    Queue_Storage.kind = Database  -- The requirement interacts with the database to retrieve and store queue items.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The queue is sorted correctly based on the specified criteria


----------------------------------------------------------------------
-- Core operation: REQ_QUEUE_01
----------------------------------------------------------------------

sig REQ_QUEUE_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_QUEUE_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_QUEUE_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_QUEUE_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_QUEUE_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_QUEUE_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_QUEUE_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_QUEUE_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_QUEUE_01 {
    some op: REQ_QUEUE_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_QUEUE_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_QUEUE_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_QUEUE_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_QUEUE_01_well_formed {
    all op: REQ_QUEUE_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_QUEUE_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Predicate to prove Post1 is reachable: the queue is sorted correctly.
pred ps_reach_Post1 {
    some op: REQ_QUEUE_01 |
        op.post = Post1 &&
        -- The operation must involve a valid state transition from PreIdle
        op.pre = PreIdle &&
        -- The initiator must be authorized to perform a sorting operation (Admin permission)
        Admin in op.initiator.mayPerform &&
        -- The target must be the Queue_Storage resource
        Queue_Storage in op.target &&
        -- At least one authenticated channel must be used
        some ch: op.channel | ch.authenticated = True &&
        -- The grant permission must be Admin to reflect sorting authority
        op.grant = Admin
}

run ps_reach_Post1 for 5

-- Assertion to verify Post1 semantics: whenever Post1 is reached, the queue is sorted correctly.
assert ps_valid_Post1 {
    all op: REQ_QUEUE_01 |
        (op.post = Post1) =>
            -- The pre-state must be PreIdle (queue was awaiting sorting)
            op.pre = PreIdle &&
            -- The initiator must have Admin permission (sorting authority)
            Admin in op.initiator.mayPerform &&
            -- The target must include Queue_Storage
            Queue_Storage in op.target &&
            -- At least one authenticated channel must be used
            some ch: op.channel | ch.authenticated = True &&
            -- The grant must be Admin
            op.grant = Admin
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: queue with items of varying urgencies && timestamps ? multiple targets, both Read && Write permissions required
pred ac_reach_1 {
  some op: REQ_QUEUE_01 |
    #op.target > 1
    && some p: Permission | p in op.initiator.mayPerform && p = Read
    && some q: Permission | q in op.initiator.mayPerform && q = Write
    && some c: op.channel | c.authenticated = True
}
run ac_reach_1 for 5

-- Criterion 2: queue ordered by urgency then time ? state change, encrypted channel, initiator owns at least one target
pred ac_reach_2 {
  some op: REQ_QUEUE_01 |
    op.post != op.pre
    && some c: op.channel | c.encrypted = True
    && Write in op.initiator.mayPerform
    && some r: op.target | r.owner = op.initiator
}
run ac_reach_2 for 5

-- Criterion 3: items sorted by urgency then time ? post-state is Post1, all targets accessible, grant held by initiator
pred ac_reach_3 {
  some op: REQ_QUEUE_01 |
    op.post = Post1
    && all r: op.target | r in op.initiator.accessible
    && op.grant in op.initiator.mayPerform
    && #op.target > 0
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Empty queue handling  
-- Safety: When the queue is idle (PreIdle) && initiator lacks write permission,  
-- the operation must ! change state (to avoid unauthorized modification).  
assert ec_safe_1 {
    all op: REQ_QUEUE_01 |
        (op.pre in PreIdle && Write !in op.initiator.mayPerform) => op.post = op.pre
}
check ec_safe_1 for 5

-- Edge case 2: Concurrent operations on same resource with conflicting grants  
-- Safety: Two different operations sharing any target resource must have consistent grants  
-- (both read || both write) to prevent race conditions.  
assert ec_safe_2 {
    all op1, op2: REQ_QUEUE_01 |
        op1 != op2 && some (op1.target & op2.target) =>
            (op1.grant in Read && op2.grant in Read) ||
            (op1.grant in Write && op2.grant in Write)
}
check ec_safe_2 for 5

-- Edge case 3: Updating an item?s attributes while it is in the queue  
-- Safety: Any operation that changes state must require write permission  
-- (i.e., modification of urgency/timestamp is a write operation).  
assert ec_safe_3 {
    all op: REQ_QUEUE_01 |
        op.post != op.pre => Write in op.initiator.mayPerform
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-QUEUE-01: Verify that an empty queue is returned when there are no items.
pred tc_QUEUE_01_holds {
    some op: REQ_QUEUE_01 |
        op.pre = PreIdle &&
        op.post = Post1 &&
        op.grant = Read &&
        op.initiator = Product_Owner &&
        all r: op.target | r.owner = Product_Owner
}
run tc_QUEUE_01_holds for 5

assert tc_QUEUE_01_contract {
    all op: REQ_QUEUE_01 |
        op.pre = PreIdle && op.grant = Read =>
        op.post = Post1 && some r: op.target | r.owner = Product_Owner
}
check tc_QUEUE_01_contract for 5

-- TC-QUEUE-02: Verify the correct sorting of a queue with multiple items of different urgencies && timestamps.
pred tc_QUEUE_02_holds {
    some op: REQ_QUEUE_01 |
        op.pre = PreIdle &&
        op.post = Post1 &&
        #op.target > 1 &&
        op.initiator = Development_Team &&
        op.grant = Write &&
        all r: op.target | r.owner = Development_Team &&
        some r1, r2: op.target | r1 != r2 &&
            (r1.accessible = Product_Owner) &&
            (r2.accessible = QA_Team)   // representing different urgencies via accessible sets
}
run tc_QUEUE_02_holds for 5

assert tc_QUEUE_02_contract {
    all op: REQ_QUEUE_01 |
        op.pre = PreIdle && #op.target > 1 && op.grant = Write =>
        op.post = Post1 && all r: op.target | r.owner = op.initiator
}
check tc_QUEUE_02_contract for 5

-- TC-QUEUE-03: Verify handling of ties in urgency && time with the same timestamp, same urgency level.
pred tc_QUEUE_03_holds {
    some op: REQ_QUEUE_01 |
        op.pre = PreIdle &&
        op.post = Post1 &&
        op.initiator = Product_Owner &&
        op.grant = Read &&
        all r: op.target | r.owner = Product_Owner &&
        some r1, r2: op.target | r1 != r2 &&
            r1.accessible = r2.accessible   // same urgency (accessible set)
}
run tc_QUEUE_03_holds for 5

assert tc_QUEUE_03_contract {
    all op: REQ_QUEUE_01 |
        op.pre = PreIdle && op.grant = Read =>
        op.post = Post1 && all r: op.target | r.owner = op.initiator
}
check tc_QUEUE_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance: Response time optimized ? proxy: limit the number of resources per operation
-- (fewer targets ? lower processing latency)
fact nfr_fact_performance {
    all op: REQ_QUEUE_01 | #op.target <= 3
}

-- Availability: 99.9% uptime ? proxy: require at least two redundant channels per operation
-- (no single point of failure in communication)
fact nfr_fact_availability {
    all op: REQ_QUEUE_01 | #op.channel >= 2
}

-- Scalability: handle 10? queue size growth ? proxy: ensure at least as many resources as actors
-- (each actor can target a distinct resource, supporting many simultaneous queue entries)
fact nfr_fact_scalability {
    #Resource >= #Actor
}

-- Usability: clear && actionable error messages ? proxy: limit authenticated channels per operation
-- (fewer authenticated channels reduces user confusion && simplifies error explanation)
fact nfr_fact_usability {
    all op: REQ_QUEUE_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 2
}

