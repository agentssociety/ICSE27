module REQ_SYM_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-SYM-01
 * Title       : Register Symptoms
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Patient_Care_Team, System_Administrators, Quality_Assurance extends Actor {}
-- Patient_Care_Team: represents stakeholder 'Patient Care Team'
-- System_Administrators: represents stakeholder 'System Administrators'
-- Quality_Assurance: represents stakeholder 'Quality Assurance'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Symptom_Registration_API, Patient_Database extends Interface {}

fact interface_properties {
    Symptom_Registration_API.kind = API  -- The requirement interacts with the Symptom Registration API to record and store patient symptoms in the database.
    Patient_Database.kind = Database  -- The requirement interacts with the Patient Database to persistently store symptom information.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where I am a patient.
-- Pre2: system is in state where The user is logged in to the system.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The symptom information is recorded and stored in the system database.
-- Post2: system reaches state where A confirmation message is displayed to the patient indicating that their symptoms have been successfully registered.


----------------------------------------------------------------------
-- Core operation: REQ_SYM_01
----------------------------------------------------------------------

sig REQ_SYM_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_SYM_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_SYM_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_SYM_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_SYM_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_SYM_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_SYM_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_SYM_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SYM_01 {
    some op: REQ_SYM_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SYM_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_SYM_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_SYM_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_SYM_01_well_formed {
    all op: REQ_SYM_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SYM_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_SYM_01 |
        op.post = Post1 &&
        op.initiator = Patient_Care_Team &&
        Write in op.initiator.mayPerform &&
        Patient_Database in op.target &&
        Symptom_Registration_API in op.channel &&
        Symptom_Registration_API.authenticated = True &&
        Patient_Care_Team in Patient_Database.accessible &&
        op.pre != Post1
}

run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_SYM_01 |
        op.post = Post2 &&
        op.pre = Post1 &&
        op.initiator = Patient_Care_Team &&
        Read in op.initiator.mayPerform &&
        Patient_Database in op.target &&
        Symptom_Registration_API in op.channel &&
        Symptom_Registration_API.authenticated = True &&
        Patient_Care_Team in Patient_Database.accessible
}

run ps_reach_Post2 for 5

assert ps_valid_Post1 {
    all op: REQ_SYM_01 |
        (op.post = Post1) => (
            Write in op.initiator.mayPerform &&
            Patient_Database in op.target &&
            Symptom_Registration_API in op.channel &&
            op.pre != Post1
        )
}

check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_SYM_01 |
        (op.post = Post2) => (
            op.pre = Post1 &&
            Read in op.initiator.mayPerform &&
            Patient_Database in op.target &&
            Symptom_Registration_API in op.channel
        )
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: The system records my symptom information.
-- Semantic mapping: A patient (Patient_Care_Team actor) uses the Symptom_Registration_API
-- interface (authenticated) to write symptom data to the Patient_Database resource.
-- This requires the Write permission on a target resource that is the Patient_Database,
-- via the Symptom_Registration_API channel with authentication.
pred ac_reach_1 {
    some op: REQ_SYM_01 |
        -- The initiator is a member of Patient_Care_Team (has appropriate permissions)
        Write in op.initiator.mayPerform &&
        -- The target resource is the Patient_Database (symptom data storage)
        Patient_Database in op.target &&
        -- The channel used is the Symptom_Registration_API with authentication
        (some c: op.channel | c in Symptom_Registration_API && c.authenticated = True) &&
        -- The operation results in a state change (postcondition reached)
        op.post = Post1
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_SYM_01 |
    -- Patient inputs symptoms in multiple languages: channel must be encrypted && authenticated
    (op.initiator = Patient_Care_Team && op.target = Symptom_Registration_API) =>
      (all c: op.channel | c.encrypted = True && c.authenticated = True)
}
check ec_safe_1 for 5

assert ec_safe_2 {
  all op: REQ_SYM_01 |
    -- System fails to record symptom information due to network issues: 
    -- if channel is ! authenticated, state cannot change to Post2
    (some c: op.channel | c.authenticated = False) => (op.post != Post2)
}
check ec_safe_2 for 5

assert ec_safe_3 {
  all op: REQ_SYM_01 |
    -- Patient enters duplicate symptom entries:
    -- if initiator is Patient_Care_Team && target is Symptom_Registration_API,
    -- then after operation, no duplicate symptom records exist (simplified: pre && post differ)
    (op.initiator = Patient_Care_Team && Symptom_Registration_API in op.target) =>
      (op.post != op.pre)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-SYM-01: patient registers symptoms successfully
pred tc_sym01_holds {
    some op: REQ_SYM_01 |
        op.initiator = Patient_Care_Team &&
        op.grant = Write &&
        Patient_Database in op.target &&
        all c: op.channel | c.encrypted = True && c.authenticated = True &&
        op.post = Post1
}
run tc_sym01_holds for 5

assert tc_sym01_contract {
    all op: REQ_SYM_01 |
        (op.initiator = Patient_Care_Team &&
         op.grant = Write &&
         Patient_Database in op.target &&
         all c: op.channel | c.encrypted = True && c.authenticated = True) =>
        (op.post != op.pre && op.post = Post1)
}
check tc_sym01_contract for 5

-- TC-SYM-02: network failure handling
pred tc_sym02_holds {
    some op: REQ_SYM_01 |
        op.initiator = Patient_Care_Team &&
        op.grant = Write &&
        Patient_Database in op.target &&
        some c: op.channel | c.encrypted = False &&
        op.post = Post2
}
run tc_sym02_holds for 5

assert tc_sym02_contract {
    all op: REQ_SYM_01 |
        (op.initiator = Patient_Care_Team &&
         op.grant = Write &&
         Patient_Database in op.target &&
         some c: op.channel | c.encrypted = False) =>
        (op.post != op.pre && op.post = Post2)
}
check tc_sym02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance proxy: minimize channel count per operation to reduce latency.
fact nfr_fact_latency_proxy {
    all op: REQ_SYM_01 | #op.channel <= 2
}

-- Availability proxy: ensure at least two distinct interfaces exist for redundancy.
fact nfr_fact_availability_proxy {
    #Interface >= 2
}

-- Scalability proxy: limit number of resources per operation to avoid contention.
fact nfr_fact_scalability_proxy {
    all op: REQ_SYM_01 | #op.target <= 2
}

-- Usability proxy: ensure there is at least one interface that is both encrypted && authenticated for secure error messaging.
fact nfr_fact_usability_proxy {
    some i: Interface | i.encrypted = True && i.authenticated = True
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Requirement: Symptom data must be encrypted during transit && at rest.

-- Encryption in transit: every channel used by an operation must be encrypted.
assert sr_assert_encrypted_transit {
    all op: REQ_SYM_01 | all c: op.channel | c.encrypted = True
}
check sr_assert_encrypted_transit for 5

-- Encryption at rest: require that any operation targeting a Database resource
-- (such as Patient_Database) uses an encrypted channel.
-- Since "at rest" is an indirect property here, we model it as a constraint
-- that if the target includes a Database, the channel must be encrypted.
assert sr_assert_encrypted_at_rest {
    all op: REQ_SYM_01 |
        (some r: op.target | r in Database) =>
        (all c: op.channel | c.encrypted = True)
}
check sr_assert_encrypted_at_rest for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines REQ_SYM_01 operation with actors, resources, interfaces, permissions, and states.
-- Summary 2: Structural invariants ensure well-formedness, authorization, and state change.
-- Summary 3: Safety assertions check unauthorized execution, resource access, and well-formedness.
-- Summary 4: Post-state reachability predicates verify transitions to Post1 and Post2.
-- Summary 5: Edge case assertions model multi-language input, network failure, and duplicate entries.
-- Summary 6: Test scenario predicates and contracts validate TC-SYM-01 and TC-SYM-02.
-- Summary 7: Non-functional requirement invariants proxy performance, availability, scalability, and usability.
-- Summary 8: Security assertions enforce encryption in transit and at rest.
-- Assumption 1: Patient_Care_Team actor represents the patient role.
-- Assumption 2: Symptom_Registration_API and Patient_Database are the only interfaces.
-- Assumption 3: Pre1 and Pre2 are distinct states; Post1 and Post2 are distinct states.
-- Assumption 4: Write permission is required for recording symptoms; Read for confirmation.
-- Assumption 5: Network failure is modeled by unencrypted channels.
-- Assumption 6: Duplicate entries are prevented by ensuring state change.
-- Open issue 1: ec_safe_1 uses op.target = Symptom_Registration_API, but Symptom_Registration_API is an Interface, not a Resource; this assertion may be vacuously true or incorrect.
-- Open issue 2: The model does not explicitly handle retry logic for network failures as described in TC-SYM-02.
-- Open issue 3: The 'stronger' function is defined but not used in any assertion or fact.
-- Open issue 4: The model does not enforce that Patient_Database is a Resource; it is declared as an Interface, which may cause type confusion in assertions like ps_reach_Post1.


