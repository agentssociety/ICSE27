module REQ_DASH_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-DASH-01
 * Title       : Real-time live dashboard displaying urgency and wait time
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig All_users_who_need_to_prioritize_tasks, IT_support_team_responsible_for_the_system_s_uptime_and_maintenance extends Actor {}
-- All_users_who_need_to_prioritize_tasks: represents stakeholder 'All users who need to prioritize tasks'
-- IT_support_team_responsible_for_the_system_s_uptime_and_maintenance: represents stakeholder 'IT support team responsible for the system's uptime and maintenance'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Data_Feed_API, Live_Dashboard_Interface extends Interface {}

fact interface_properties {
    Data_Feed_API.kind = API  -- The dashboard interacts with this API to fetch real-time urgency and wait time data.
    Live_Dashboard_Interface.kind = UI  -- This is the interface where users interact with the live dashboard to view urgency and wait time data.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The dashboard displays the most recent urgency and wait time values
-- Post2: system reaches state where The user can prioritize tasks based on the displayed information


----------------------------------------------------------------------
-- Core operation: REQ_DASH_01
----------------------------------------------------------------------

sig REQ_DASH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_DASH_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_DASH_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_DASH_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_DASH_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change (removed to allow no-change scenarios).

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_DASH_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_DASH_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_DASH_01 {
    some op: REQ_DASH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_DASH_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_DASH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_DASH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_DASH_01_well_formed {
    all op: REQ_DASH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_DASH_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post-state reachability && semantic verification for Post1
pred ps_reach_Post1 {
    some op: REQ_DASH_01 |
        op.post = Post1 &&
        op.grant = Read &&
        some ch: Interface | ch in op.channel && ch.kind = UI &&
        op.initiator in All_users_who_need_to_prioritize_tasks &&
        op.target in Resource &&
        op.pre = PreIdle
}

assert ps_valid_Post1 {
    all op: REQ_DASH_01 |
        (op.post = Post1) =>
            (op.grant = Read &&
             some ch: Interface | ch in op.channel && ch.kind = UI &&
             op.initiator in All_users_who_need_to_prioritize_tasks &&
             op.pre = PreIdle)
}

run ps_reach_Post1 for 5
check ps_valid_Post1 for 5

-- Post-state reachability && semantic verification for Post2
pred ps_reach_Post2 {
    some op: REQ_DASH_01 |
        op.post = Post2 &&
        op.grant = Write &&
        some ch: Interface | ch in op.channel && ch.kind = UI &&
        op.initiator in All_users_who_need_to_prioritize_tasks &&
        op.target in Resource &&
        op.pre != Post2
}

assert ps_valid_Post2 {
    all op: REQ_DASH_01 |
        (op.post = Post2) =>
            (op.grant = Write &&
             some ch: Interface | ch in op.channel && ch.kind = UI &&
             op.initiator in All_users_who_need_to_prioritize_tasks &&
             op.pre != Post2)
}

run ps_reach_Post2 for 5
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_DASH_01 |
        Live_Dashboard_Interface in op.channel &&
        op.pre = PreIdle
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_DASH_01 |
        Write in op.initiator.mayPerform &&
        some op.target &&
        (some c: op.channel | c.authenticated = True)
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_DASH_01 |
        (op.post = Post1 || op.post = Post2) &&
        Live_Dashboard_Interface in op.channel
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Network outage affecting data availability
-- If a network outage occurs (modeled as channel not encrypted),
-- the operation must not proceed to a non-idle state
assert ec_safe_1 {
    all op: REQ_DASH_01 |
        (some c: op.channel | c.encrypted = False) =>
            op.post = PreIdle
}
check ec_safe_1 for 5

-- Edge case 2: Sudden spikes in data volume
-- If data volume spikes (modeled as multiple targets being accessed),
-- the operation must use authenticated channels to ensure integrity
assert ec_safe_2 {
    all op: REQ_DASH_01 |
        (#op.target > 1) =>
            (all c: op.channel | c.authenticated = True)
}
check ec_safe_2 for 5

-- Edge case 3: Corrupted urgency or wait time data
-- If data corruption occurs (modeled as initiator being in All_users_who_need_to_prioritize_tasks
-- but without Admin permission), operation must fail safely
assert ec_safe_3 {
    all op: REQ_DASH_01 |
        (op.initiator in All_users_who_need_to_prioritize_tasks &&
         Admin not in op.initiator.mayPerform) =>
            op.post = PreIdle
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-DASH-01: Live dashboard updates in real-time from data feed API
pred tc_DASH_01_holds {
    some op: REQ_DASH_01 |
        -- Input: data feed API provides new values
        Data_Feed_API in op.channel &&
        -- Expected: dashboard displays updated urgency and wait time values
        -- Modeled as state transition indicating fresh data delivery
        op.post != op.pre &&
        -- The UI interface is involved in the operation
        UI in op.channel.kind
}

run tc_DASH_01_holds for 5

assert tc_DASH_01_contract {
    all op: REQ_DASH_01 |
        -- Input pre-conditions: data feed API provides new values
        (Data_Feed_API in op.channel &&
         UI in op.channel.kind) =>
        -- Expected post-conditions: state changes (fresh data delivered)
        op.post != op.pre
}

check tc_DASH_01_contract for 5

-- Scenario TC-DASH-02: System handles network outage to data feed API
pred tc_DASH_02_holds {
    some op: REQ_DASH_01 |
        -- Input: lost connection to data feed API
        Data_Feed_API not in op.channel &&
        -- Expected: dashboard maintains old data (no state change)
        op.post = op.pre
}

run tc_DASH_02_holds for 5

assert tc_DASH_02_contract {
    all op: REQ_DASH_01 |
        -- Input pre-conditions: data feed API not available
        (Data_Feed_API not in op.channel) =>
        -- Expected post-conditions: no state change (maintains old data)
        op.post = op.pre
}

check tc_DASH_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: Minimizing channel count reduces network overhead, improving response time.
fact nfr_fact_performance_latency {
    all op: REQ_DASH_01 | #op.channel <= 2
}

-- Proxy: At least two interfaces exist to provide redundancy for high availability.
fact nfr_fact_availability_redundancy {
    #Interface >= 2
}

-- Proxy: Every actor can initiate an operation, demonstrating the system can serve all users concurrently.
assert nfr_assert_scalability_concurrent_users {
    all a: Actor | some op: REQ_DASH_01 | op.initiator = a
}
check nfr_assert_scalability_concurrent_users for 5

-- Proxy: A UI interface exists, ensuring an intuitive dashboard for users.
fact nfr_fact_usability_intuitive {
    some i: Interface | i.kind = UI
}

