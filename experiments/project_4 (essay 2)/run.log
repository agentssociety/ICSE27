        )                                                                                                                                                                              
        .finally(() => setLoading(false));                                                                                                                                             
    }, []);                                                                                                                                                                            
                                                                                                                                                                                       
    if (loading) return <p>Loading audit log...</p>;                                                                                                                                   
    if (error)                                                                                                                                                                         
      return (                                                                                                                                                                         
        <div className="card" style={{ borderColor: "var(--danger)" }}>                                                                                                                
