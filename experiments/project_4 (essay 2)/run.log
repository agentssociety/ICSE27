  # Create FlaggedTransactionsPage.tsx - covers User Story 92, 93 (flagged transactions)                                                                                               
  flagged_page = '''import { useState, useEffect } from "react";                                                                                                                       
  import { listAuditLogEntries, updateAuditLogEntry } from "../api/services";                                                                                                          
  import type { AuditLogEntryResponse } from "../types";                                                                                                                               
                                                                                                                                                                                       
  export default function FlaggedTransactionsPage() {                                                                                                                                  
    const [transactions, setTransactions] = useState<AuditLogEntryResponse[]>([]);                                                                                                     
    const [loading, setLoading] = useState(true);                                                                                                                                      
    const [error, setError] = useState("");                                                                                                                                            
                                                                                                                                                                                       
    useEffect(() => {                                                                                                                                                                  
      // Fetch audit entries that could be flagged (those with "FAILED" or suspicious outcomes)                                                                                        
      listAuditLogEntries()                                                                                                                                                            
        .then((data) => {                                                                                                                                                              
          // Simulate flagged transactions: filter entries with suspicious patterns                                                                                                    
          const flagged = data.filter(                                                                                                                                                 
            (e) => e.outcome === "FLAGGED" || e.eventType === "RAPID_WITHDRAWAL"                                                                                                       
          );                                                                                                                                                                           
          // If no actual flagged entries, show recent failed ones for demo                                                                                                            
          setTransactions(flagged.length > 0 ? flagged : data.slice(0, 5));                                                                                                            
        })                                                                                                                                                                             
        .catch((err: unknown) =>                                                                                                                                                       
          setError(err instanceof Error ? err.message : "Failed to load flagged transactions")                                                                                         
        )                                                                                                                                                                              
        .finally(() => setLoading(false));                                                                                                                                             
    }, []);                                                                                                                                                                            
                                                                                                                                                                                       
    const handleAction = async (id: string, action: string) => {                                                                                                                       
      try {                                                                                                                                                                            
        await updateAuditLogEntry(id, { outcome: action === "approve" ? "APPROVED" : action === "deny" ? "DENIED" : "INVESTIGATING" });                                                
        setTransactions((prev) => prev.filter((t) => t.id !== id && t.id !== undefined));                                                                                              
      } catch (err: unknown) {                                                                                                                                                         
