      assert user.userId == "u1"                                                                                                                                                       
      assert user.account == "acc1"                                                                                                                                                    
      assert user.loginSession == "sess1"                                                                                                                                              
      assert user.transactions == []                                                                                                                                                   
                                                                                                                                                                                       
                                                                                                                                                                                       
