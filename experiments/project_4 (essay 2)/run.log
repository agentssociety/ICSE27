          ]                                                                                                                                                                            
                                                                                                                                                                                       
      def updateFlaggedTransactionStatus(self, flagId: str, newStatus: FlaggedTransactionStatus) -> None:                                                                              
          for ft in self.flaggedTransactions:                                                                                                                                          
              if ft.transactionId == flagId:                                                                                                                                           
                  ft.changeStatus(newStatus)                                                                                                                                           
                  break                                                                                                                                                                
                                                                                                                                                                                       
