  "id": "REQ-BAL-01",
  "title": "Enforce daily transaction limits",
  "type": "Functional",
  "status": "Proposed",
  "priority": "High",
  "risk_level": "Medium",
  "version": "1.0",
  "description": "The system shall enforce a daily transaction limit defined per account to prevent excessive spending.",
  "rationale": "This requirement ensures that accounts do not exceed their allowed spending limits, preventing potential overdraws and financial issues for the account holder.",
  "business_value": "Maintains customer trust by ensuring fair and predictable spending, reducing fraudulent transactions, and protecting financial health.",
  "source": {
    "type": "User Story",
    "id": 90,
    "description": "As a account holder I need the system to enforce balance checks and daily transaction limits So that I cannot overdraw my account or make excessive transactions"
  },
  "stakeholders": [
    "Account Holders",
    "Financial Institutions"
  ],
  "acceptance_criteria": [
    "Given an account with a balance of $100 and a daily transaction limit of $200, When a transaction of $150 is attempted, Then the transaction is authorized",
    "Given an account with a balance of $100 and a daily transaction limit of $200, When a transaction of $120 is attempted, Then the transaction is rejected due to insufficient funds",
    "Given an account that has already used $180 of its $200 daily limit, When a transaction of $30 is attempted, Then the transaction is rejected due to exceeding the daily limit",
    "Given an account that has already used $180 of its $200 daily limit, When a transaction of $20 is attempted, Then the transaction is authorized"
  ],
  "preconditions": [
    "The system has access to the current account balance and the daily transaction limit.",
    "The user is attempting a transaction on their account."
  ],
  "postconditions": [
    "If the transaction amount is within the daily limit and sufficient funds are available, the transaction is authorized and debited from the account balance.",
    "If the transaction would exceed the daily limit or insufficient funds are available, the transaction is rejected and an error message is displayed to the user."
  ],
  "functional_constraints": [
    "The system must accurately calculate the remaining daily transaction limit based on previous transactions.",
    "Transactions exceeding the daily limit or exceeding available funds must be rejected immediately without further processing."
  ],
  "security_requirements": [],
  "non_functional_requirements": {
    "performance": "Transaction authorization and balance checks should complete within 50 milliseconds to maintain a responsive system.",
    "availability": "The system must be available at least 99.9% of the time to ensure uninterrupted financial services.",
    "scalability": "The system must handle peak transaction loads of up to 1,000 transactions per minute without degradation in performance or functionality.",
    "usability": "Error messages and notifications should clearly indicate the reason for transaction rejection."
  },
  "edge_cases": [
    "Account balance and daily transaction limit data is missing or corrupted.",
    "User attempts a transaction on an account that does not exist."
  ],
  "dependencies": [
    "A database to store account balances and daily transaction limits.",
    "An external payment processing system for transactions."
  ],
  "interfaces": [
    {
      "type": "Database",
      "name": "Account Database",
      "description": "Retrieves current balance and updates after a transaction is authorized or rejected."
    },
    {
      "type": "External System",
      "name": "Payment Processing System",
      "description": "Handles the actual debiting of funds from user accounts upon successful authorization."
    }
  ],
  "test_cases": [
    {
      "id": "TC-BAL-01",
      "description": "Verify transaction is authorized when balance and limit are sufficient.",
      "expected_result": "Transaction is authorized, account balance decreases by $150."
    },
    {
      "id": "TC-BAL-02",
      "description": "Verify transaction is rejected due to insufficient funds.",
      "expected_result": "Transaction is rejected, error message 'Insufficient funds' displayed."
    },
    {
      "id": "TC-BAL-03",
      "description": "Verify transaction is rejected when daily limit is exceeded.",
      "expected_result": "Transaction is rejected, error message 'Daily limit exceeded' displayed."
    }
  ],
  "traceability": {
    "related_requirements": [
      "REQ-ADM-01",
      "REQ-AUTH-01"
    ],
    "design_components": [
      "Account",
      "Transaction"
    ],
