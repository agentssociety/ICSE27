          return self._repository.create(data)                                                                                                                                         
                                                                                                                                                                                       
      def get_transaction(self, transaction_id: str) -> Optional[TransactionResponse]:                                                                                                 
          return self._repository.get_by_id(transaction_id)                                                                                                                            
                                                                                                                                                                                       
