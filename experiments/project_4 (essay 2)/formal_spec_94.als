module REQ_ACC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ACC-01
 * Title       : Manual Lock/Unlock User Accounts
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Admins, Security_Team extends Actor {}
-- Admins: represents stakeholder 'Admins'
-- Security_Team: represents stakeholder 'Security Team'

fact actor_permissions {
    Admins.mayPerform = Admin
    Security_Team.mayPerform = Read
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resource for user accounts
one sig UserAccount extends Resource {}

fact resource_setup {
    one r: Resource | r.owner in Admins and r.accessible = Admins
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Lock_Unlock_API, User_Management_Database, User_Management_Page extends Interface {}

fact interface_properties {
    Lock_Unlock_API.kind = API  -- Interface for admins to lock or unlock user accounts via a RESTful API.
    User_Management_Database.kind = Database  -- Stores user account information including status (locked/unlocked).
    User_Management_Page.kind = UI  -- Frontend interface where admins can select and lock/unlock user accounts.
}

fact interface_auth {
    Lock_Unlock_API.authenticated = True
    Lock_Unlock_API.encrypted = True
    User_Management_Page.authenticated = True
    User_Management_Page.encrypted = True
    User_Management_Database.authenticated = False
    User_Management_Database.encrypted = True
}

----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where Admin is authenticated with proper authorization
-- Pre2: system is in state where User management interface is accessible

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Selected user account status is updated to 'locked'
-- Post2: system reaches state where Selected locked user account status is updated to 'active'


----------------------------------------------------------------------
-- Core operation: REQ_ACC_01
----------------------------------------------------------------------

sig REQ_ACC_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ACC_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ACC_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ACC_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ACC_01 | op.initiator in op.target.accessible
}

-- INV-5: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ACC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ACC_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ACC_01 {
    some op: REQ_ACC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ACC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ACC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ACC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ACC_01_well_formed {
    all op: REQ_ACC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      
}
check REQ_ACC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Predicate: Post1 is reachable (user account locked)
pred ps_reach_Post1 {
    some op: REQ_ACC_01 |
        op.post = Post1 &&
        op.grant = Admin &&
        -- The initiator must have the Admin permission to lock
        Admin in op.initiator.mayPerform &&
        -- The target resource is the Database (user accounts stored here)
        Database in op.target &&
        -- The channel used is Lock_Unlock_API
        Lock_Unlock_API in op.channel &&
        -- Pre-state is ! already Post1 (state changes)
        op.pre != Post1
}

run ps_reach_Post1 for 5

-- Assertion: whenever Post1 is reached, semantic conditions hold
assert ps_valid_Post1 {
    all op: REQ_ACC_01 |
        (op.post = Post1) =>
            (Admin in op.initiator.mayPerform &&
             Database in op.target &&
             Lock_Unlock_API in op.channel &&
             op.grant = Admin)
}

check ps_valid_Post1 for 5

-- Predicate: Post2 is reachable (user account unlocked/activated)
pred ps_reach_Post2 {
    some op: REQ_ACC_01 |
        op.post = Post2 &&
        op.grant = Admin &&
        -- The initiator must have the Admin permission to unlock
        Admin in op.initiator.mayPerform &&
        -- The target resource is the Database (user accounts stored here)
        Database in op.target &&
        -- The channel used is Lock_Unlock_API
        Lock_Unlock_API in op.channel &&
        -- Pre-state is ! already Post2 (state changes)
        op.pre != Post2
}

run ps_reach_Post2 for 5

-- Assertion: whenever Post2 is reached, semantic conditions hold
assert ps_valid_Post2 {
    all op: REQ_ACC_01 |
        (op.post = Post2) =>
            (Admin in op.initiator.mayPerform &&
             Database in op.target &&
             Lock_Unlock_API in op.channel &&
             op.grant = Admin)
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1-3: Lock user account
pred ac_reach_1 {
    some op: REQ_ACC_01 |
        -- Admin performing the operation
        op.initiator in Admins &&
        -- Using Lock_Unlock_API interface
        op.channel in Lock_Unlock_API &&
        -- Using UI channel (user management page)
        (some c: op.channel | c.kind in UI) &&
        -- Authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        -- Granting Lock permission (Admin has all permissions)
        op.grant in op.initiator.mayPerform &&
        -- Target is a user account (Resource)
        some op.target &&
        -- State changes to locked state (Post1 represents locked)
        op.post = Post1 &&
        -- Pre-state is the active state (Pre1 represents active)
        op.pre = Pre1
}
run ac_reach_1 for 5

-- Criterion 4-6: Unlock user account
pred ac_reach_2 {
    some op: REQ_ACC_01 |
        -- Admin performing the operation
        op.initiator in Admins &&
        -- Using Lock_Unlock_API interface
        op.channel in Lock_Unlock_API &&
        -- Using UI channel (user management page)
        (some c: op.channel | c.kind in UI) &&
        -- Authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        -- Admin has required permission
        op.grant in op.initiator.mayPerform &&
        -- Target is a user account (Resource)
        some op.target &&
        -- State changes to active state (Post2 represents active)
        op.post = Post2 &&
        -- Pre-state is the locked state (Pre2 represents locked)
        op.pre = Pre2
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Admin locking own account should ! be possible (Lock_Unlock_API used for lock operations)
assert ec_safe_1 {
    all op: REQ_ACC_01 |
        (Admin in op.initiator.mayPerform && op.target.owner = op.initiator)
            => Lock_Unlock_API ! in op.channel
}
check ec_safe_1 for 5

-- Edge case 2: Simultaneous lock/unlock on same resource is forbidden (only one operation per resource using Lock_Unlock_API)
assert ec_safe_2 {
    all r: Resource |
        lone op: REQ_ACC_01 |
            r in op.target && Lock_Unlock_API in op.channel
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicate && assertion for TC-ACC-01
pred tc_ACC_01_holds {
    some op: REQ_ACC_01 |
        op.initiator in Admins &&
        some r: op.target | r.owner = op.initiator &&
        op.grant = Admin
}
run tc_ACC_01_holds for 5

assert tc_ACC_01_contract {
    all op: REQ_ACC_01 |
        (op.initiator in Admins && some r: op.target | r.owner = op.initiator && op.grant = Admin) =>
        Lock_Unlock_API ! in op.channel
}
check tc_ACC_01_contract for 5

-- Predicate && assertion for TC-ACC-02
pred tc_ACC_02_holds {
    some op1, op2: REQ_ACC_01 | op1 != op2 &&
        one r: Resource | r in op1.target && r in op2.target &&
        op1.grant = Admin && op2.grant = Admin
}
run tc_ACC_02_holds for 5

assert tc_ACC_02_contract {
    all op1, op2: REQ_ACC_01 |
        (op1 != op2 && one r: Resource | r in op1.target && r in op2.target) =>
        (op1.post != op2.post)
}
check tc_ACC_02_contract for 5

-- Predicate && assertion for TC-ACC-03
pred tc_ACC_03_holds {
    some op: REQ_ACC_01 |
        op.grant = Admin &&
        op.pre = Pre1 &&
        op.post = Pre1
}
run tc_ACC_03_holds for 5

assert tc_ACC_03_contract {
    all op: REQ_ACC_01 |
        (op.grant = Admin && op.pre = Pre1) =>
        op.post = Pre1
}
check tc_ACC_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance_channel_limit {
    -- Proxy: Reducing the number of communication channels per operation
    -- lowers latency by minimizing handshake/negotiation overhead.
    -- NFR: Response time < 200ms.
    all op: REQ_ACC_01 | #op.channel <= 2
}

fact nfr_fact_availability_redundancy {
    -- Proxy: Requiring at least two channels per operation ensures that
    -- if one channel fails, the operation can proceed (99.9% uptime).
    -- NFR: Availability ? 99.9%.
    all op: REQ_ACC_01 | #op.channel >= 2
}

fact nfr_fact_scalability_resource_coverage {
    -- Proxy: Every managed resource must be used by at least one operation,
    -- ensuring the system is fully utilized even under high load (1,000 users).
    -- NFR: Scalability to handle 1,000 active users.
    all r: Resource | some op: REQ_ACC_01 | r in op.target
}

fact nfr_fact_usability_uniform_authentication {
    -- Proxy: All channels in a single operation must share the same
    -- authentication status. This eliminates confusing mixed?auth errors.
    -- NFR: Error messages must be clear && actionable.
    all op: REQ_ACC_01 | all c1, c2: op.channel |
        c1.authenticated = c2.authenticated
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security requirement 1: Authentication mechanism for admins must comply with organizational security standards
-- Admins must use authenticated channels when performing operations
fact sr_fact_admin_authentication {
    all op: REQ_ACC_01 |
        (Admin in op.initiator.mayPerform) =>
        (all c: op.channel | c.authenticated = True)
}

-- Security requirement 2: Access control to the user management page should follow role-based access controls (RBAC)
-- Only actors with Admin permission can access the User_Management_Page resource
fact sr_fact_rbac_user_management {
    all op: REQ_ACC_01 |
        (User_Management_Page in op.target) =>
        (Admin in op.initiator.mayPerform)
}

-- Assertion: No non-admin actor can access User_Management_Page
assert sr_assert_no_unauthorized_user_management_access {
    all op: REQ_ACC_01 |
        (User_Management_Page in op.target) =>
        (Admin in op.initiator.mayPerform)
}
check sr_assert_no_unauthorized_user_management_access for 5

-- Assertion: Admin operations always use authenticated channels
assert sr_assert_admin_authenticated_channels {
    all op: REQ_ACC_01 |
        (Admin in op.initiator.mayPerform) =>
        (all c: op.channel | c.authenticated = True)
}
check sr_assert_admin_authenticated_channels for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines permissions, actors, resources, interfaces, states, and operations for manual lock/unlock of user accounts.
-- Summary 2: Core safety assertions check authorization, resource access, and structural well-formedness.
-- Summary 3: Reachability predicates verify that locked and active post-states can be achieved.
-- Summary 4: Edge case assertions prevent admin self-lock via Lock_Unlock_API and forbid simultaneous operations on the same resource.
-- Summary 5: Non-functional requirements are modeled as constraints on channel count, resource coverage, and authentication uniformity.
-- Summary 6: Security properties enforce authenticated channels for admin operations and RBAC for user management page access.
-- Assumption 1: Only Admins have the Admin permission; Security_Team has only Read permission.
-- Assumption 2: There is exactly one concrete resource (UserAccount) owned by an admin and accessible to admins.
-- Assumption 3: Lock_Unlock_API and User_Management_Page are authenticated; User_Management_Database is not.
-- Assumption 4: Each operation must use exactly two channels (due to combined performance and availability constraints).
-- Assumption 5: Simultaneous lock/unlock on the same resource is forbidden (modeled as at most one operation per resource using Lock_Unlock_API).
-- Assumption 6: The abstract states Pre1/Pre2 and Post1/Post2 represent active and locked statuses respectively, but no explicit status field is modeled.
-- Open issue 1: The model does not explicitly represent account status (locked/active) as a field; it relies on abstract states, which may limit precision for edge cases like unlocking an already active account.
-- Open issue 2: The simultaneous lock/unlock edge case is modeled by forbidding concurrency entirely, which is a simplification of the 'last operation takes precedence' requirement.
-- Open issue 3: The test case TC-ACC-03 (unlock already active) is modeled as an operation with no state change, but the model's non-functional constraints (e.g., channel count) may still apply; the assertion tc_ACC_03_contract is trivial and may not capture the intended behavior.


