module REQ_ADM_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ADM-01
 * Title       : Admin Interface for Flagged Transactions Review
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    p = Read => Read else
    p = Write => Read + Write else
    p = Execute => Read + Execute else
    Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig System_Administrators extends Actor {}
-- System_Administrators: represents stakeholder 'System Administrators'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Transactions and flagged transactions (resources)
abstract sig Transaction extends Resource {}
sig FlaggedTransaction extends Transaction {
    flagReason : one String
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig UI, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Flagged_Transactions_Review_Page, Transactions_Database extends Interface {}

fact interface_properties {
    Flagged_Transactions_Review_Page.kind = UI
    Transactions_Database.kind = Database
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where An admin user is logged in.
-- Pre2: system is in state where The user is on the flagged transactions review page.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The selected action (approve/deny/investigate) has been applied to the transaction.
-- Post2: system reaches state where The transaction's status has been updated accordingly.
-- Post3: system reaches state where The transaction is no longer displayed in the pending review list.


----------------------------------------------------------------------
-- Core operation: REQ_ADM_01
----------------------------------------------------------------------

sig REQ_ADM_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ADM_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ADM_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ADM_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ADM_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ADM_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ADM_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ADM_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ADM_01 {
    some op: REQ_ADM_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ADM_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ADM_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ADM_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ADM_01_well_formed {
    all op: REQ_ADM_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ADM_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_ADM_01 |
        op.post = Post1 &&
        op.initiator = System_Administrators &&
        some ft: FlaggedTransaction | ft in op.target &&
        op.grant = Admin &&
        some iface: op.channel | iface.kind = UI && iface.authenticated = True &&
        op.pre != Post1
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ADM_01 |
        (op.post = Post1) =>
            (op.initiator = System_Administrators &&
             some ft: FlaggedTransaction | ft in op.target &&
             op.grant in op.initiator.mayPerform &&
             some iface: op.channel | iface.kind = UI && iface.authenticated = True &&
             op.pre != Post1)
}
check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_ADM_01 |
        op.post = Post2 &&
        op.initiator = System_Administrators &&
        some ft: FlaggedTransaction | ft in op.target &&
        op.grant = Write &&
        some iface: op.channel | iface.kind = Database && iface.authenticated = True &&
        op.pre != Post2
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_ADM_01 |
        (op.post = Post2) =>
            (op.initiator = System_Administrators &&
             some ft: FlaggedTransaction | ft in op.target &&
             op.grant in op.initiator.mayPerform &&
             some iface: op.channel | iface.kind = Database && iface.authenticated = True &&
             op.pre != Post2)
}
check ps_valid_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_ADM_01 |
        op.post = Post3 &&
        op.initiator = System_Administrators &&
        some ft: FlaggedTransaction | ft in op.target &&
        op.grant = Execute &&
        some iface: op.channel | iface.kind = UI && iface.authenticated = True &&
        op.pre = Pre2
}
run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_ADM_01 |
        (op.post = Post3) =>
            (op.initiator = System_Administrators &&
             some ft: FlaggedTransaction | ft in op.target &&
             op.grant in op.initiator.mayPerform &&
             some iface: op.channel | iface.kind = UI && iface.authenticated = True &&
             op.pre = Pre2)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: All transactions flagged by the system are displayed with relevant details.
-- Semantic encoding: An authorized admin (grant = Admin) must perform a Read operation
-- on the FlaggedTransaction resources, using a UI channel that is authenticated.
-- The pre-state must be Pre1 && post-state must be Post1 to indicate initial display.
pred ac_reach_1 {
  some op: REQ_ADM_01 |
    op.grant = Admin &&
    op.initiator in System_Administrators &&
    some ft: FlaggedTransaction | ft in op.target &&
    (some c: op.channel | c.kind = UI && c.authenticated = True) &&
    op.pre = Pre1 &&
    op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: The system updates the transaction status upon selecting an action (approve/deny/investigate).
-- Semantic encoding: An authorized user (grant = Write) must perform a Write operation
-- on the FlaggedTransaction resource to update status. The channel must be encrypted
-- && authenticated, && the state must transition from Pre1 to Post2.
pred ac_reach_2 {
  some op: REQ_ADM_01 |
    op.grant = Write &&
    op.initiator in System_Administrators &&
    some ft: FlaggedTransaction | ft in op.target &&
    (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
    op.pre = Pre1 &&
    op.post = Post2
}
run ac_reach_2 for 5

-- Criterion 3: The flagged transaction is removed from the pending review list after updating its status.
-- Semantic encoding: An authorized user (grant = Execute) must perform an Execute operation
-- on the FlaggedTransaction resource to remove it from the list. The channel
-- must be authenticated, && the state must transition from Pre2 to Post3 (indicating removal).
pred ac_reach_3 {
  some op: REQ_ADM_01 |
    op.grant = Execute &&
    op.initiator in System_Administrators &&
    some ft: FlaggedTransaction | ft in op.target &&
    (some c: op.channel | c.authenticated = True) &&
    op.pre = Pre2 &&
    op.post = Post3
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

sig NetworkIssue { channel: set Interface }
sig LoginSession { user: Actor }

-- Edge case 1: When there are no flagged transactions, the operation must not change state.
assert ec_safe_1 {
  all op: REQ_ADM_01 |
    no FlaggedTransaction => op.post = op.pre
}
check ec_safe_1 for 5

-- Edge case 2: When a channel used by the operation has a network issue, the operation must not change state.
assert ec_safe_2 {
  all op: REQ_ADM_01 |
    (some c: op.channel | c in NetworkIssue.channel) => op.post = op.pre
}
check ec_safe_2 for 5

-- Edge case 3: If a channel requires authentication, the initiator must have an active login session.
assert ec_safe_3 {
  all op: REQ_ADM_01 |
    all c: op.channel |
      c.authenticated = True => (some s: LoginSession | s.user = op.initiator)
}
check ec_safe_3 for 5

