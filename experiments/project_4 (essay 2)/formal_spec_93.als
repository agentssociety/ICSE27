----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: Limit number of channels per operation to reduce latency for performance (NF: response time < timeframe seconds)
fact nfr_fact_performance_channel_limit {
    all op: REQ_ADM_01 | #op.channel <= 2
}

-- Proxy: At least two channels per operation for redundancy, ensuring 99.5% availability (NF: availability)
fact nfr_fact_availability_redundancy {
    all op: REQ_ADM_01 | #op.channel >= 2
}

-- Proxy: Every actor can be an initiator, supporting scalability (NF: handle increased flagged transactions)
assert nfr_assert_scalability_actor_coverage {
    all a: Actor | some op: REQ_ADM_01 | op.initiator = a
}
check nfr_assert_scalability_actor_coverage for 5

-- Proxy: Limit authenticated channels per operation to avoid excessive prompts (NF: usability ? clear error messages & feedback)
fact nfr_fact_usability_auth_limit {
    all op: REQ_ADM_01 | #(op.channel & {i: Interface | i.authenticated = True}) <= 2
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security requirement: Access to flagged transactions interface restricted to system administrators only.
-- This requires that any operation using the Flagged_Transactions_Review_Page as a channel
-- must have an initiator who is a System_Administrators actor.
fact sr_fact_flagged_transactions_access_control {
    all op: REQ_ADM_01 |
        (Flagged_Transactions_Review_Page in op.channel) =>
        (op.initiator in System_Administrators)
}

-- Security requirement: Sensitive information about transactions should be handled with encryption.
-- This ensures that any operation involving FlaggedTransaction resources uses encrypted channels.
fact sr_fact_sensitive_data_encryption {
    all op: REQ_ADM_01 |
        some ft: FlaggedTransaction | ft in op.target =>
        (all c: op.channel | c.encrypted = True)
}

-- Security requirement: Sensitive information about transactions should be handled with access control.
-- This ensures that only system administrators can access FlaggedTransaction resources.
fact sr_fact_sensitive_data_access_control {
    all op: REQ_ADM_01 |
        some ft: FlaggedTransaction | ft in op.target =>
        (op.initiator in System_Administrators)
}

-- Assertion: No non-admin actor can access flagged transactions through any operation.
assert sr_assert_no_unauthorized_flagged_access {
    all op: REQ_ADM_01 |
        some ft: FlaggedTransaction | ft in op.target =>
        (op.initiator in System_Administrators)
}
check sr_assert_no_unauthorized_flagged_access for 5

-- Assertion: All channels used for flagged transaction operations must be encrypted.
assert sr_assert_flagged_transaction_encryption {
    all op: REQ_ADM_01 |
        some ft: FlaggedTransaction | ft in op.target =>
        (all c: op.channel | c.encrypted = True)
}
check sr_assert_flagged_transaction_encryption for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Revised model fixes syntax errors and type mismatches in permission function, resource usage, and security conditions.
-- Summary 2: Added Transaction and FlaggedTransaction sigs as Resource subtypes for consistent typing.
-- Summary 3: Adjusted all predicates and assertions to refer to FlaggedTransaction atoms instead of Interface atoms where appropriate.
-- Summary 4: Aligned post-state reachability predicates (ps_reach_Post3, ps_valid_Post3) to use Pre2 consistently with acceptance criteria.
-- Assumption 1: Only one actor (System_Administrators) is modeled; access control checks are trivially satisfied but structure is in place.
-- Assumption 2: Every operation uses exactly two channels due to conflicting NF facts (performance and availability).
-- Assumption 3: FlaggedTransaction sig has a flagReason field of type String (unconstrained).
-- Assumption 4: Pre2 represents 'user is on the flagged transactions review page' and is used for removal action (Post3).
-- Assumption 5: Network issues and login sessions are modeled with unconstrained sigs for edge case assertions.
-- Open issue 1: The commented test scenario block references Pre3 and has type errors; it remains commented as requested.
-- Open issue 2: The model does not explicitly enforce that both preconditions (logged in and on page) hold simultaneously; Pre1 and Pre2 are separate states.
-- Open issue 3: No explicit modeling of transaction status or action types (approve/deny/investigate) beyond post-states and grants.
-- Open issue 4: The NF scalability assertion (nfr_assert_scalability_actor_coverage) is vacuously true with only one actor.
-- Open issue 5: Could not safely repair invalid section 'Behavioral contract predicates (test scenarios)'; preserved original commented block.


