module REQ_SEC_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-SEC-01
 * Title       : Account Lock After Three Consecutive Failed PIN Attempts
 * Type        : Security
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Security_Team, Customer_Support, User extends Actor {}

fact actor_permissions {
    Security_Team.mayPerform = Admin
    Customer_Support.mayPerform = Read
    User.mayPerform = Read
}

fun adminActors : set Actor {
    { a: Actor | Admin in a.mayPerform }
}


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig PIN_Attempt_Tracking_API, User_Account_Database, Login_Interface extends Interface {}

fact interface_properties {
    PIN_Attempt_Tracking_API.kind = API
    User_Account_Database.kind = Database
    Login_Interface.kind = UI
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

one sig Pre1, Post0, Post1 extends State {}
-- Pre1: system is in state where system has mechanism to track and store PIN attempts.
-- Post0: unlocked/normal state (default)
-- Post1: locked state


----------------------------------------------------------------------
-- Core operation: REQ_SEC_01
----------------------------------------------------------------------

sig REQ_SEC_01 {
    initiator  : one  Actor,
    target     : some Resource,
    channel    : some Interface,
    grant      : one  Permission,
    pre        : one  State,
    post       : one  State
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

fact inv_operation_requires_channel {
    all op: REQ_SEC_01 | some op.channel
}

fact inv_operation_requires_target {
    all op: REQ_SEC_01 | some op.target
}

fact inv_initiator_is_authorized {
    all op: REQ_SEC_01 | op.grant in op.initiator.mayPerform
}

fact inv_resource_access_control {
    all op: REQ_SEC_01 | op.initiator in op.target.accessible
}

fact inv_state_must_change {
    all op: REQ_SEC_01 | op.pre != op.post
}

fact inv_authenticated_channel_required {
    all op: REQ_SEC_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_SEC_01 {
    some op: REQ_SEC_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_SEC_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

assert no_unauthorized_execution {
    all op: REQ_SEC_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

assert no_unauthorized_resource_access {
    all op: REQ_SEC_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

assert REQ_SEC_01_well_formed {
    all op: REQ_SEC_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_SEC_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_SEC_01 |
        op.post = Post1 &&
        op.initiator in adminActors &&
        op.grant = Admin &&
        op.target = User_Account_Database &&
        op.channel = PIN_Attempt_Tracking_API &&
        op.pre = Pre1
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_SEC_01 |
        (op.post = Post1) =>
            (op.initiator in adminActors && op.grant = Admin && op.target = User_Account_Database && op.channel = PIN_Attempt_Tracking_API)
}
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_SEC_01 |
        op.pre = Pre1 &&
        op.post = Post1 &&
        PIN_Attempt_Tracking_API in op.channel &&
        User_Account_Database in op.target
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_SEC_01 |
        op.pre = Pre1 &&
        op.post = Post1 &&
        Login_Interface in op.channel &&
        User_Account_Database in op.target
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
    all op1, op2: REQ_SEC_01 |
        (op1.target = op2.target && op1.grant = Admin && op2.grant = Admin) =>
            (op1.post = op2.post)
}
check ec_safe_1 for 5

assert ec_safe_2 {
    all op1, op2: REQ_SEC_01 |
        (op1.target = op2.target && op1.initiator != op2.initiator) =>
            !(op1.grant = Admin && op2.grant != Admin)
}
check ec_safe_2 for 5

assert ec_safe_3 {
    all op: REQ_SEC_01 |
        (op.grant ! in op.initiator.mayPerform) =>
            op.post = op.pre
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_TC_SEC_01_holds {
    some op: REQ_SEC_01 |
        op.initiator ! in adminActors &&
        op.pre = Pre1 &&
        some c: op.channel | c.authenticated = True &&
        op.post = Post0
}
run tc_TC_SEC_01_holds for 5

assert tc_TC_SEC_01_contract {
    all op: REQ_SEC_01 |
        (op.initiator ! in adminActors && op.pre = Pre1) =>
        op.post = Post0
}
check tc_TC_SEC_01_contract for 5

pred tc_TC_SEC_02_holds {
    some op: REQ_SEC_01 |
        op.initiator ! in adminActors &&
        op.pre = Pre1 &&
        all c: op.channel | c.authenticated = False &&
        op.post = Post1
}
run tc_TC_SEC_02_holds for 5

assert tc_TC_SEC_02_contract {
    all op: REQ_SEC_01 |
        (op.initiator ! in adminActors && op.pre = Pre1 && all c: op.channel | c.authenticated = False) =>
        op.post = Post1
}
check tc_TC_SEC_02_contract for 5

pred tc_TC_SEC_03_holds {
    some op: REQ_SEC_01 |
        op.initiator in adminActors &&
        op.pre = Post1 &&
        op.post = Post0
}
run tc_TC_SEC_03_holds for 5

assert tc_TC_SEC_03_contract {
    all op: REQ_SEC_01 |
        (op.initiator in adminActors && op.pre = Post1) =>
        op.post = Post0
}
check tc_TC_SEC_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_low_latency {
    all op: REQ_SEC_01 | #op.channel <= 2
}

fact nfr_fact_availability {
    some op: REQ_SEC_01 | some c: op.channel | c.authenticated = False
}

fact nfr_fact_usability {
    all op: REQ_SEC_01 | #(op.channel & {c: Interface | c.authenticated = True}) <= 1
}

assert nfr_assert_low_latency {
    all op: REQ_SEC_01 | #op.channel <= 2
}
check nfr_assert_low_latency for 5

assert nfr_assert_availability {
    all op: REQ_SEC_01 | #op.channel >= 1
}
check nfr_assert_availability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

sig FailedAttempt {
    actor: one Actor,
    count: one Int
}

fact sr_fact_each_actor_has_failed_attempt {
    all a: Actor | one fa: FailedAttempt | fa.actor = a
}

fun lockedActors : set Actor {
    { a: Actor | some fa: FailedAttempt | fa.actor = a && fa.count >= 3 }
}

fact sr_fact_brute_force_lockout {
    all op: REQ_SEC_01 |
        (some c: op.channel | c.kind = Login_Interface) =>
            op.initiator ! in lockedActors
}

assert sr_assert_brute_force_lockout {
    all op: REQ_SEC_01 |
        (some c: op.channel | c.kind = Login_Interface) =>
            op.initiator ! in lockedActors
}
check sr_assert_brute_force_lockout for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines an operation signature REQ_SEC_01 with structural invariants, safety assertions, and test contracts.
-- Summary 2: Added User actor and actor permissions fact.
-- Summary 3: Added Post0 state for unlocked scenario.
-- Summary 4: Fixed type errors where Admin was incorrectly used as an actor.
-- Summary 5: Removed conflicting fact that forced all operations to Post1.
-- Summary 6: Removed overly restrictive scalability fact that prevented shared targets.
-- Summary 7: Security property prevents locked actors from using Login_Interface.
-- Assumption 1: The precondition Pre1 represents the state where the system has a tracking mechanism (interpreted as after three consecutive failed attempts).
-- Assumption 2: Post0 represents the unlocked state; Post1 represents the locked state.
-- Assumption 3: Security_Team actor possesses Admin permission and serves as the admin role.
-- Assumption 4: Each actor has exactly one FailedAttempt record with an integer count (consecutive failures).
-- Open issue 1: The model does not explicitly track the number of consecutive failed attempts dynamically; the lockedActors function is static.
-- Open issue 2: Interface authentication (authenticated=True) is used as a proxy for correct PIN entry.
-- Open issue 3: The edge case for system failure in counting attempts is only partially addressed.


