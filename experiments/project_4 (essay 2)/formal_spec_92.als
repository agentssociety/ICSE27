module REQ_FRAUD_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-FRAUD-01
 * Title       : Detect Suspicious Transaction Patterns
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Fraud_Analysts, IT_Team, Security_Officers, System extends Actor {}
-- Fraud_Analysts: represents stakeholder 'Fraud Analysts'
-- IT_Team: represents stakeholder 'IT Team'
-- Security_Officers: represents stakeholder 'Security Officers'
-- System: represents the automated detection system


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Transaction_Monitoring_API, Fraud_Analyst_Dashboard extends Interface {}

fact interface_properties {
    Transaction_Monitoring_API.kind = API  -- The system will use this API to receive real-time transaction data and monitor for suspicious patterns.
    Fraud_Analyst_Dashboard.kind = UI  -- This interface will be used by fraud analysts to review flagged transactions and update the system status.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where Transactions that meet the suspicious pattern criteria are queued for manual review by fraud analysts.


----------------------------------------------------------------------
-- Core operation: REQ_FRAUD_01
----------------------------------------------------------------------

sig REQ_FRAUD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_FRAUD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_FRAUD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_FRAUD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_FRAUD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_FRAUD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_FRAUD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_FRAUD_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_FRAUD_01 {
    some op: REQ_FRAUD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_FRAUD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_FRAUD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_FRAUD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_FRAUD_01_well_formed {
    all op: REQ_FRAUD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_FRAUD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post1: Transactions that meet the suspicious pattern criteria are queued for manual review by fraud analysts.
pred ps_reach_Post1 {
    some op: REQ_FRAUD_01 |
        op.post = Post1 &&
        -- Initiator must be the System to perform detection
        op.initiator in System &&
        -- The operation must use the Transaction_Monitoring_API interface
        Transaction_Monitoring_API in op.channel &&
        -- The operation must grant the Read permission (reviewing transactions)
        Read in op.grant &&
        -- The target must be a Resource that is accessible to Fraud_Analysts
        all r: op.target | Fraud_Analysts in r.accessible &&
        -- State must change from PreIdle to Post1
        op.pre = PreIdle &&
        op.post = Post1
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_FRAUD_01 |
        (op.post = Post1) =>
            -- The initiator must be the System
            op.initiator in System &&
            -- The operation must use the Transaction_Monitoring_API
            Transaction_Monitoring_API in op.channel &&
            -- The operation must grant Read permission
            Read in op.grant &&
            -- All target resources must be accessible to Fraud_Analysts
            all r: op.target | Fraud_Analysts in r.accessible &&
            -- The state must transition from PreIdle
            op.pre = PreIdle
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? Liveness Predicates for REQ_FRAUD_01 ???????????????

-- Criterion 1: Given a user initiates multiple rapid withdrawals
-- Semantic mapping: An initiator with Write permission (withdrawal capability)
-- performs operations on multiple resources (rapid pattern)
pred ac_reach_1 {
    some op: REQ_FRAUD_01 |
        Write in op.initiator.mayPerform &&
        #op.target > 1 &&
        op.grant = Write &&
        some c: op.channel | c.encrypted = True
}
run ac_reach_1 for 5

-- Criterion 2: When the system detects this pattern
-- Semantic mapping: After the operation, the state transitions to Post1
-- indicating detection has occurred
pred ac_reach_2 {
    some op: REQ_FRAUD_01 |
        op.post = Post1 &&
        op.pre = PreIdle &&
        Write in op.initiator.mayPerform &&
        #op.target > 1
}
run ac_reach_2 for 5

-- Criterion 3: Then the transactions are flagged for review
-- Semantic mapping: The operation involves Fraud_Analysts having access
-- to the flagged resources, && the channel is authenticated (secure flagging)
pred ac_reach_3 {
    some op: REQ_FRAUD_01 |
        Fraud_Analysts in op.target.accessible &&
        some c: op.channel | c.authenticated = True &&
        op.grant = Read &&
        op.initiator in Fraud_Analysts
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sig to model system capacity
one sig Capacity {
  maxPerResource: Int
}
fact { Capacity.maxPerResource = 2 }

-- Edge case 1: No two operations with same initiator && same target have different grants
assert ec_safe_1 {
  all op1, op2: REQ_FRAUD_01 |
    (op1 != op2 && op1.initiator = op2.initiator && op1.target = op2.target)
    => op1.grant = op2.grant
}
check ec_safe_1 for 5

-- Edge case 2: If any channel is ! encrypted, the grant must be Read only
assert ec_safe_2 {
  all op: REQ_FRAUD_01 |
    (some ch: op.channel | ch.encrypted = False) => op.grant = Read
}
check ec_safe_2 for 5

-- Edge case 3: No resource is targeted by more operations than capacity allows
assert ec_safe_3 {
  all res: Resource |
    #(res.~target) <= Capacity.maxPerResource
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_tc01_holds {
    some op: REQ_FRAUD_01 |
        op.initiator = System &&
        op.grant = Read &&
        lt[1, #op.target] &&
        all c: op.channel | c.encrypted = True &&
        op.post = Post1
}

run tc_tc01_holds for 5

assert tc_tc01_contract {
    all op: REQ_FRAUD_01 |
        (op.initiator = System &&
         op.grant = Read &&
         lt[1, #op.target] &&
         all c: op.channel | c.encrypted = True) =>
        op.post = Post1
}

check tc_tc01_contract for 5

pred tc_tc02_holds {
    some op: REQ_FRAUD_01 |
        op.initiator = System &&
        op.grant = Read &&
        lt[#op.target, 2] &&
        all c: op.channel | c.encrypted = True &&
        op.post = Post1
}

run tc_tc02_holds for 5

assert tc_tc02_contract {
    all op: REQ_FRAUD_01 |
        (op.initiator = System &&
         op.grant = Read &&
         lt[#op.target, 2] &&
         all c: op.channel | c.encrypted = True) =>
        op.post = Post1
}

check tc_tc02_contract for 5

pred tc_tc03_holds {
    some op: REQ_FRAUD_01 |
        op.pre = Post1 &&
        op.post = PreIdle &&
        op.initiator = System &&
        some c: op.channel | c.encrypted = False &&
        #op.target <= Capacity.maxPerResource
}

run tc_tc03_holds for 5

assert tc_tc03_contract {
    all op: REQ_FRAUD_01 |
        (op.pre = Post1 &&
         op.initiator = System &&
         some c: op.channel | c.encrypted = False &&
         #op.target <= Capacity.maxPerResource) =>
        op.post = PreIdle
}

check tc_tc03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy for Performance (response time < 5s): fewer channels per operation reduce latency
fact nfr_fact_performance_channels {
    all op: REQ_FRAUD_01 | #op.channel <= 2
}

-- Proxy for Availability (99.9% uptime): multiple interfaces avoid single point of failure
fact nfr_fact_availability_interfaces {
    #Interface >= 2
}

-- Proxy for Scalability (handle many concurrent transactions): ensure no resource/actor contention
assert nfr_assert_scalability_no_contention {
    all op1, op2: REQ_FRAUD_01 | op1 != op2 => {
        (op1.target & op2.target = none) &&
        (op1.channel & op2.channel = none) &&
        (op1.initiator != op2.initiator)
    }
}
check nfr_assert_scalability_no_contention for 5

-- Proxy for Usability (intuitive, error-free UI): all UI interfaces must be authenticated && encrypted, && exactly one UI interface exists
fact nfr_fact_usability_ui_quality {
    all i: Interface | i.kind = UI => (i.authenticated = True && i.encrypted = True)
    one i: Interface | i.kind = UI
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Requirement 1: All transactions securely stored for audit (encryption && authentication)
fact sr_fact_secure_audit_storage {
    all op : REQ_FRAUD_01 |
        all c : op.channel |
            c.encrypted = True && c.authenticated = True
}

-- Requirement 2: Fraud analysts have appropriate access controls to review transactions
assert sr_assert_fraud_analysts_access {
    all op : REQ_FRAUD_01 |
        (Read in Fraud_Analysts.mayPerform) &&
        (op.target in Fraud_Analysts.accessible)
}
check sr_assert_fraud_analysts_access for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Added System actor to represent the detection system, fixing type errors in test predicates and edge case assertions.
-- Summary 2: Corrected initiator type in tc_tc01_holds, tc_tc02_holds, tc_tc03_holds from Interface/IfaceKind to System.
-- Summary 3: Fixed ec_safe_3 to use inverse relation for counting targets per resource.
-- Summary 4: Fixed tc_tc03_holds to use #op.target <= Capacity.maxPerResource instead of invalid set membership.
-- Summary 5: All facts, predicates, assertions, and run/check commands are now type-consistent and coherent.
-- Assumption 1: The detection operation is initiated by the System actor, not by a human user.
-- Assumption 2: Capacity.maxPerResource = 2 is a placeholder for system capacity constraints.
-- Assumption 3: The post-state Post1 is the only defined post-state for this requirement.
-- Open issue 1: The assertion nfr_assert_scalability_no_contention is very strong and likely false; it may need refinement to match actual scalability requirements.
-- Open issue 2: The test case tc_tc03_holds models a reverse state transition (Post1 to PreIdle) which may not accurately represent network outage recovery; the expected behavior is logging and resumption, not state reversal.


