module REQ_TRANS_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-TRANS-01
 * Title       : Implement Atomic Transactions with Rollback Capability
 * Type        : Functional
 * Priority    : Critical
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Development_Team, Quality_Assurance, Business_Stakeholders extends Actor {}
-- Development_Team: represents stakeholder 'Development Team'
-- Quality_Assurance: represents stakeholder 'Quality Assurance'
-- Business_Stakeholders: represents stakeholder 'Business Stakeholders'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig API, Database extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Transaction_Management_API, Data_Storage extends Interface {}

fact interface_properties {
    Transaction_Management_API.kind = API  -- Interface for initiating, committing, rolling back, and querying transactions.
    Data_Storage.kind = Database  -- Stores data changes made during transactions. Must support atomic operations.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The system must be operational and accessible.
-- Pre2: system is in state where All necessary resources (e.g., network, storage) must be available.
-- Pre3: system is in state where Valid data must be provided for each operation in the transaction.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Data changes made as part of a successful transaction must be persisted and visible to other operations or systems.
-- Post2: system reaches state where Any changes made during a failed transaction must be rolled back, leaving no partial state changes.


----------------------------------------------------------------------
-- Core operation: REQ_TRANS_01
----------------------------------------------------------------------

sig REQ_TRANS_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_TRANS_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_TRANS_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_TRANS_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_TRANS_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_TRANS_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_TRANS_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_TRANS_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_TRANS_01 {
    some op: REQ_TRANS_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_TRANS_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_TRANS_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_TRANS_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_TRANS_01_well_formed {
    all op: REQ_TRANS_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_TRANS_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_TRANS_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        op.channel.authenticated = True
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_TRANS_01 |
        (op.post = Post1) =>
            (Write in op.initiator.mayPerform &&
             op.grant = Write &&
             op.channel.authenticated = True)
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_TRANS_01 |
        op.post = Post2 &&
        Read in op.initiator.mayPerform &&
        op.grant = Read
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_TRANS_01 |
        (op.post = Post2) =>
            (Read in op.initiator.mayPerform &&
             op.grant = Read)
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: Transaction committed && changes persisted after all operations succeed
pred ac_reach_1 {
    some op: REQ_TRANS_01 |
        -- All required permissions held by initiator
        Read in op.initiator.mayPerform &&
        Write in op.initiator.mayPerform &&
        Execute in op.initiator.mayPerform &&
        -- Multiple resources affected (transaction with multiple operations)
        #op.target > 1 &&
        -- All operations succeed: state transitions to Post1 (committed state)
        op.post = Post1 &&
        -- Changes persisted: data storage resource is affected
        Data_Storage in op.target &&
        -- Secure authenticated channel used
        (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
        -- Initiator is authorized for all target resources
        all r: op.target | op.initiator in r.accessible
}
run ac_reach_1 for 5

-- Criterion 2: Transaction rolled back && no changes persisted when operations fail
pred ac_reach_2 {
    some op: REQ_TRANS_01 |
        -- Initiator has permissions but some operation fails
        Read in op.initiator.mayPerform &&
        Write in op.initiator.mayPerform &&
        -- Multiple resources involved
        #op.target > 1 &&
        -- Transaction rolled back: state transitions to Post2 (rollback state)
        op.post = Post2 &&
        -- No changes persisted: data storage ! in target (rollback undoes changes)
        Data_Storage ! in op.target &&
        -- Channel still required for rollback communication
        (some c: op.channel | c.authenticated = True) &&
        -- Initiator authorized for resources
        all r: op.target | op.initiator in r.accessible
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case safety assertions
-- ec_safe_1: System crashes should never allow a non-owner to obtain Write permission
assert ec_safe_1 {
    all op: REQ_TRANS_01 |
        (op.grant = Write) => (op.initiator = op.target.owner)
}

check ec_safe_1 for 5

-- ec_safe_2: Network failures must be mitigated by encryption on all channels
assert ec_safe_2 {
    all op: REQ_TRANS_01 |
        all ch: op.channel | ch.encrypted = True
}

check ec_safe_2 for 5

-- ec_safe_3: Invalid data input must ! lead to an inconsistent initial state;
-- each initiator type is only allowed its designated pre-state.
assert ec_safe_3 {
    all op: REQ_TRANS_01 |
        (op.initiator in Development_Team => op.pre = Pre1) &&
        (op.initiator in Quality_Assurance => op.pre = Pre2) &&
        (op.initiator in Business_Stakeholders => op.pre = Pre3)
}

check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-TRANS-01: Transaction commits when all operations succeed
pred tc_TRANS_01_holds {
    some op: REQ_TRANS_01 |
        -- Input: all operations succeed (represented by valid pre/post states)
        op.pre = Pre1 &&
        op.post = Post1 &&
        -- Expected: transaction committed, changes persisted in database
        some r: op.target | r in Data_Storage &&
        op.post != op.pre
}
run tc_TRANS_01_holds for 5

assert tc_TRANS_01_contract {
    all op: REQ_TRANS_01 |
        (op.pre = Pre1 && op.post = Post1) =>
        (some r: op.target | r in Data_Storage && op.post != op.pre)
}
check tc_TRANS_01_contract for 5

-- Scenario TC-TRANS-02: Transaction rolls back when any operation fails
pred tc_TRANS_02_holds {
    some op: REQ_TRANS_01 |
        -- Input: operation fails (represented by pre state ! leading to valid post)
        op.pre = Pre2 &&
        op.post = Post2 &&
        -- Expected: transaction rolled back, no changes persisted
        all r: op.target | r ! in Data_Storage &&
        op.post = op.pre
}
run tc_TRANS_02_holds for 5

assert tc_TRANS_02_contract {
    all op: REQ_TRANS_01 |
        (op.pre = Pre2 && op.post = Post2) =>
        (all r: op.target | r ! in Data_Storage && op.post = op.pre)
}
check tc_TRANS_02_contract for 5

-- Scenario TC-TRANS-03: System crash mid-execution, recovery rolls back
pred tc_TRANS_03_holds {
    some op: REQ_TRANS_01 |
        -- Input: system crash mid-execution (incomplete state transition)
        op.pre = Pre3 &&
        op.post = Post2 &&
        -- Expected: system recovers && rolls back
        all r: op.target | r ! in Data_Storage &&
        op.post = op.pre
}
run tc_TRANS_03_holds for 5

assert tc_TRANS_03_contract {
    all op: REQ_TRANS_01 |
        (op.pre = Pre3 && op.post = Post2) =>
        (all r: op.target | r ! in Data_Storage && op.post = op.pre)
}
check tc_TRANS_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: Performance is proxied by limiting the number of resources (targets) per operation,
-- since processing fewer resources reduces transaction time.
fact nfr_fact_performance {
    all op: REQ_TRANS_01 | #op.target <= 2
}

-- Proxy: Availability is proxied by requiring at least two communication channels per operation,
-- providing redundancy to maintain operation even if one channel fails.
fact nfr_fact_availability {
    all op: REQ_TRANS_01 | #op.channel >= 2
}

-- Proxy: Scalability is proxied by requiring at least two distinct operations to exist,
-- demonstrating that the system can handle multiple transactions concurrently.
fact nfr_fact_scalability {
    #REQ_TRANS_01 >= 2
}

-- Proxy: Usability is proxied by requiring each operation to have a unique pre?state,
-- ensuring that error feedback can be traced unambiguously to a specific transaction.
fact nfr_fact_usability {
    all disj op1, op2: REQ_TRANS_01 | op1.pre != op2.pre
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security Property: Data within transactions must be protected from unauthorized access
-- during both execution && rollback phases.
-- This asserts that every resource involved in a transaction is accessible only to actors
-- who possess the permission being granted by that transaction.
assert sr_assert_data_protection_during_transaction {
    all op: REQ_TRANS_01 |
        all r: op.target |
            r.accessible in { a: Actor | op.grant in a.mayPerform }
}
check sr_assert_data_protection_during_transaction for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model defines atomic transactions with commit/rollback via states Post1/Post2.
-- Summary 2: Safety assertions check authorization, resource access, and well-formedness.
-- Summary 3: Acceptance criteria reachable via ac_reach_1 and ac_reach_2 predicates.
-- Summary 4: Edge case assertions cover crash, network failure, and invalid data scenarios.
-- Assumption 1: Permissions are partially ordered with Admin as top.
-- Assumption 2: Each resource has exactly one owner and a set of accessible actors.
-- Assumption 3: Pre-states Pre1, Pre2, Pre3 map to specific preconditions.
-- Assumption 4: Post-states Post1 and Post2 represent commit and rollback respectively.
-- Open issue 1: The 'stronger' function is defined but not used in any fact or assertion.
-- Open issue 2: Assertion ec_safe_1 may be too strong: a non-owner could be granted Write by the owner.
-- Open issue 3: Assertion ec_safe_2 requires all channels to be encrypted, which may conflict with availability fact requiring multiple channels.
-- Open issue 4: Assertion ec_safe_3 ties initiator type to a specific pre-state, which may not hold in all valid scenarios.


