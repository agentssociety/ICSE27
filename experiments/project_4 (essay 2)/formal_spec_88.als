module REQ_AUTH_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-AUTH-01
 * Title       : Card and PIN Authentication Requirement
 * Type        : Security
 * Priority    : Critical
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Security_Team, System_Administrators, End_Users extends Actor {}
-- Security_Team: represents stakeholder 'Security Team'
-- System_Administrators: represents stakeholder 'System Administrators'
-- End_Users: represents stakeholder 'End Users'

-- Assign permissions to actors (REVISION: added to ensure satisfiability)
fact assign_permissions {
    Security_Team.mayPerform = Admin
    System_Administrators.mayPerform = Write + Execute + Admin
    End_Users.mayPerform = Read + Execute
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Hardware_Interface, Service_Interface extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Card_Reader, PIN_Verification_Service extends Interface {}

fact interface_properties {
    Card_Reader.kind = Hardware_Interface  -- The system will communicate with a card reader to verify the physical card.
    PIN_Verification_Service.kind = Service_Interface  -- The system will interact with a service that verifies the entered PIN against the user's record.
}

-- Security: card readers must be tamper-resistant (encrypted) and both interfaces must be authenticated (REVISION: enforced)
fact interface_security {
    Card_Reader.encrypted = True
    Card_Reader.authenticated = True
    PIN_Verification_Service.authenticated = True
    -- PIN_Verification_Service.encrypted is left unconstrained; can be True or False
}

----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The user has a registered account
-- Pre2: system is in state where The user possesses a valid physical card associated with their account
-- Pre3: system is in state where The user knows their correct PIN

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where The system confirms successful authentication
-- Post2: system reaches state where Access is granted to the system for the authenticated user
-- Post3: system reaches state where No unauthorized access is granted to other users or systems

-- Additional state for lockout (REVISION: added to allow lockout scenarios)
one sig Locked extends State {}

----------------------------------------------------------------------
-- Core operation: REQ_AUTH_01
----------------------------------------------------------------------

sig REQ_AUTH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_AUTH_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_AUTH_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_AUTH_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_AUTH_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_AUTH_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_AUTH_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints (REVISION: includes Locked)
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (including Locked for lockout).
fact postconditions_must_reach_defined_states {
    all op: REQ_AUTH_01 | op.post in Post1 + Post2 + Post3 + Locked
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists (REVISION: added initiator permission)
----------------------------------------------------------------------

pred show_REQ_AUTH_01 {
    some op: REQ_AUTH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_AUTH_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_AUTH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_AUTH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_AUTH_01_well_formed {
    all op: REQ_AUTH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_AUTH_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

--Reachability predicates for post-states
pred ps_reach_Post1 {
    some op: REQ_AUTH_01 |
        op.post = Post1 &&
        op.pre != Post1 &&
        some c: op.channel | c.authenticated = True && c.encrypted = True &&
        some r: op.target | r.owner = op.initiator
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_AUTH_01 |
        op.post = Post2 &&
        op.pre != Post2 &&
        some c: op.channel | c.authenticated = True && c.encrypted = True &&
        all r: op.target | op.initiator in r.accessible
}
run ps_reach_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_AUTH_01 |
        op.post = Post3 &&
        op.pre != Post3 &&
        some c: op.channel | c.authenticated = True && c.encrypted = True &&
        all r: op.target | r.accessible in (op.initiator + r.owner)
}
run ps_reach_Post3 for 5

-- Semantic verification assertions
assert ps_valid_Post1 {
    all op: REQ_AUTH_01 |
        (op.post = Post1) =>
            (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
            (some r: op.target | r.owner = op.initiator)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_AUTH_01 |
        (op.post = Post2) =>
            (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
            (all r: op.target | op.initiator in r.accessible)
}
check ps_valid_Post2 for 5

assert ps_valid_Post3 {
    all op: REQ_AUTH_01 |
        (op.post = Post3) =>
            (some c: op.channel | c.authenticated = True && c.encrypted = True) &&
            (all r: op.target | r.accessible in (op.initiator + r.owner))
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: A registered user with a valid card && known PIN
pred ac_reach_1 {
    some op: REQ_AUTH_01 |
        -- User is authorized (registered)
        op.initiator in Security_Team + System_Administrators + End_Users &&
        -- User has Read permission (can use card reader)
        Read in op.initiator.mayPerform &&
        -- Card reader interface is used
        some c: op.channel | c.kind = Card_Reader &&
        -- PIN verification service is used (authenticated channel)
        some c: op.channel | c.authenticated = True &&
        -- State transitions to Post1 (card inserted, PIN entered)
        op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: The user inserts the card && enters their PIN
pred ac_reach_2 {
    some op: REQ_AUTH_01 |
        -- User is authorized
        op.initiator in Security_Team + System_Administrators + End_Users &&
        -- User has Execute permission (can perform authentication actions)
        Execute in op.initiator.mayPerform &&
        -- Card reader interface is used
        some c: op.channel | c.kind = Card_Reader &&
        -- PIN verification service is used
        some c: op.channel | c.kind = PIN_Verification_Service &&
        -- Channel is authenticated
        some c: op.channel | c.authenticated = True &&
        -- State transitions to Post2 (card inserted, PIN entered, awaiting verification)
        op.post = Post2
}
run ac_reach_2 for 5

-- Criterion 3: The system authenticates the user && grants access
pred ac_reach_3 {
    some op: REQ_AUTH_01 |
        -- User is authorized (initiator can be any actor with Admin permission)
        op.initiator in Security_Team + System_Administrators + End_Users &&
        -- User has Admin permission (can grant access)
        Admin in op.initiator.mayPerform &&
        -- Grant permission is assigned
        op.grant in op.initiator.mayPerform &&
        -- Target resource exists && is accessible
        some op.target &&
        op.initiator in op.target.accessible &&
        -- Authenticated channel is used
        some c: op.channel | c.authenticated = True &&
        -- State transitions to Post3 (access granted)
        op.post = Post3
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- EC-1: Hardware interfaces must be encrypted (already enforced via fact, but asserted here)
assert ec_safe_1 {
  all op: REQ_AUTH_01 |
    all iface: op.channel |
      iface.kind = Hardware_Interface => iface.encrypted = True
}
check ec_safe_1 for 5

-- EC-2: No two operations share the same target resource (modeling assumption for isolation)
assert ec_safe_2 {
  all disj op1, op2: REQ_AUTH_01 |
    op1.target != op2.target
}
check ec_safe_2 for 5

-- EC-3: If precondition is Pre3 (user knows correct PIN), then the operation results in Locked (e.g., after multiple failures)
assert ec_safe_3 {
  all op: REQ_AUTH_01 |
    op.pre = Pre3 => op.post = Locked
}
check ec_safe_3 for 5

-- EC-4: All channels in an operation must be both encrypted and authenticated
assert ec_safe_4 {
  all op: REQ_AUTH_01 |
    all iface: op.channel |
      iface.encrypted = True && iface.authenticated = True
}
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-AUTH-01: Successful authentication
pred tc_a01_holds {
    some op: REQ_AUTH_01 |
        op.initiator = End_Users &&
        all c: op.channel | c.authenticated = True && c.encrypted = True &&
        op.grant = Read &&
        op.post != op.pre
}
run tc_a01_holds for 5

assert tc_a01_contract {
    all op: REQ_AUTH_01 |
        (op.initiator = End_Users && all c: op.channel | c.authenticated = True) =>
        (op.post != op.pre && op.grant = Read)
}
check tc_a01_contract for 5

-- TC-AUTH-02: Lockout after three incorrect PINs (modeled as reaching Locked from Pre3)
pred tc_a02_holds {
    some op: REQ_AUTH_01 |
        op.pre = Pre3 &&
        op.post = Locked &&
        op.initiator = End_Users
}
run tc_a02_holds for 5

assert tc_a02_contract {
    all op: REQ_AUTH_01 |
        (op.pre = Pre3 && op.initiator = End_Users) =>
        op.post = Locked
}
check tc_a02_contract for 5

-- TC-AUTH-03: Valid card but invalid PIN
pred tc_a03_holds {
    some op: REQ_AUTH_01 |
        op.pre = Pre2 &&
        op.post = Post2 &&
        op.initiator = End_Users
}
run tc_a03_holds for 5

assert tc_a03_contract {
    all op: REQ_AUTH_01 |
        (op.pre = Pre2 && op.initiator = End_Users) =>
        op.post = Post2
}
check tc_a03_contract for 5

-- TC-AUTH-04: Card reader malfunction (simulated by a non-authenticated hardware interface)
pred tc_a04_holds {
    some op: REQ_AUTH_01 |
        some c: op.channel | c.kind = Hardware_Interface && c.authenticated = False &&
        op.post = Post1
}
run tc_a04_holds for 5

assert tc_a04_contract {
    all op: REQ_AUTH_01 |
        (some c: op.channel | c.kind = Hardware_Interface && c.authenticated = False) =>
        op.post = Post1
}
check tc_a04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants (REVISION: removed conflicting proxies)
----------------------------------------------------------------------

-- NFR: 99.9% uptime guarantee via redundancy: at least two authenticated interfaces (already enforced)
fact nfr_fact_channel_redundancy {
    #(Interface & {i: Interface | i.authenticated = True}) >= 2
}

-- NFR: Support up to 10,000 concurrent requests: at least three actors (already satisfied)
fact nfr_fact_scalability_capacity {
    #Actor >= 3
}

-- NFR: Performance proxy removed to avoid conflict with two-factor authentication.
-- NFR: Usability proxy removed.

----------------------------------------------------------------------
-- Security properties (REVISION: added missing constraints)
----------------------------------------------------------------------

-- Two-factor authentication: every operation must use both a hardware interface (card reader) and a service interface (PIN verification).
fact sr_fact_two_factor_authentication {
    all op: REQ_AUTH_01 |
        (some c: op.channel | c.kind = Hardware_Interface) &&
        (some c: op.channel | c.kind = Service_Interface)
}

-- Card readers must be tamper?resistant: hardware interfaces are always encrypted.
fact sr_fact_card_reader_secure {
    all c: Interface | c.kind = Hardware_Interface => c.encrypted = True
}

-- PIN length requirement: introduce a minimal Digit && Pin hierarchy.
-- Each PIN has a set of digits; the cardinality of that set is the PIN length.
sig Digit {}
sig Pin { digits: set Digit }
fact sr_fact_pin_length {
    all p: Pin | #p.digits >= 4 && #p.digits <= 12
}

-- A Credential links an Actor to exactly one PIN.
sig Credential { actor: one Actor, pin: one Pin }

-- Every operation must have a corresponding credential for its initiator.
fact sr_fact_operation_has_credential {
    all op: REQ_AUTH_01 | one cr: Credential | cr.actor = op.initiator
}

-- Lockout on authentication failure:
-- any operation that uses a channel that is ! encrypted || ! authenticated
-- results in the Locked state.
assert sr_assert_lockout_on_failure {
    all op: REQ_AUTH_01 |
        (some c: op.channel | c.encrypted = False || c.authenticated = False) =>
        op.post = Locked
}
check sr_assert_lockout_on_failure for 5 but 8 Int, exactly 8 Digit


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed contradictory facts (nfr_fact_auth_latency, nfr_fact_usability_feedback) that made model unsatisfiable.
-- Summary 2: Assigned permissions to actors to ensure satisfiability and match test case requirements.
-- Summary 3: Added Locked to valid post-states to support lockout scenarios.
-- Summary 4: Enforced interface authentication and encryption properties explicitly.
-- Assumption 1: Security_Team has Admin permission; System_Administrators have Write, Execute, Admin; End_Users have Read, Execute.
-- Assumption 2: Card_Reader is always encrypted and authenticated; PIN_Verification_Service is always authenticated.
-- Assumption 3: Every operation uses both hardware and service interfaces (two-factor).
-- Assumption 4: Locked state represents lockout after failure; no explicit count of attempts.
-- Open issue 1: Lockout trigger is modeled via channel insecurity, not three incorrect PIN attempts; might not match exact requirement.
-- Open issue 2: ec_safe_2 assertion (disjoint targets) may fail in realistic scenarios; kept as a strong safety property.
-- Open issue 3: PIN verification service encryption is left unconstrained; could be refined.


