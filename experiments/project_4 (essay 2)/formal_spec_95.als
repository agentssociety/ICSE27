        Admin in op.grant &&
        Audit_Log_Database in op.target &&
        some c: op.channel | c.encrypted = True && c.authenticated = True
}
run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_SEC_LOG_01 |
        (op.post = Post3) =>
            (op.initiator = Security_Administrator &&
             Admin in op.grant &&
             Audit_Log_Database in op.target &&
             some c: op.channel | c.encrypted = True && c.authenticated = True)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_SEC_LOG_01 |
        Audit_Log_Database in op.target &&
        op.grant = Write &&
        op.initiator in (Security_Administrator + IT_Operations_Team) &&
        op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_SEC_LOG_01 |
        one c: op.channel |
            c.encrypted = True &&
            c.authenticated = True &&
            c.kind = API &&
        op.pre = PreIdle &&
        op.post = Post2 &&
        Audit_Log_Database in op.target
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_SEC_LOG_01 |
        op.grant in (Read + Write + Execute + Admin) &&
        op.initiator in (Security_Administrator + IT_Operations_Team) &&
        op.post in (Post1 + Post2 + Post3) &&
        Audit_Log_Database in op.target &&
        (some c: op.channel | c.authenticated = True)
}
run ac_reach_3 for 5

assert ac_safety_4 {
    lone op: REQ_SEC_LOG_01 | Audit_Log_Database in op.target
}
check ac_safety_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Under heavy load, the audit log must still be updated (log entry always written).
assert ec_safe_1 {
    all op: REQ_SEC_LOG_01 | Audit_Log_Database in op.target
}
check ec_safe_1 for 5

-- Edge case 2: Under high volume, all communication channels must be encrypted to ensure security.
assert ec_safe_2 {
    all op: REQ_SEC_LOG_01 |
        all c: op.channel | c.encrypted = True
}
check ec_safe_2 for 5

-- Edge case 3: Clock drift must ! cause a state regression (the pre?state must precede the post?state in the defined lifecycle).
-- We use PreIdle as the initial state && Post1, Post2, Post3 as subsequent states; no operation may revert to PreIdle.
assert ec_safe_3 {
    all op: REQ_SEC_LOG_01 |
        (op.pre = PreIdle) => (op.post in Post1 + Post2 + Post3)
        && (op.pre = Post1) => (op.post in Post2 + Post3)
        && (op.pre = Post2) => (op.post = Post3)
}
check ec_safe_3 for 5

-- Edge case 4: Only administrators (Security_Administrator) may modify (write) the audit log.
assert ec_safe_4 {
    all op: REQ_SEC_LOG_01 |
        (Audit_Log_Database in op.target && op.grant = Write) =>
            (op.initiator = Security_Administrator)
}
check ec_safe_4 for 5

