----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: minimizing channel count reduces latency (NFR: response time < 200ms)
    all op : REQ_SEC_LOG_01 | #op.channel <= 2
}

fact nfr_fact_availability {
    -- PROXY: operations involving Security_Administrator require at least 2 channels (NFR: uptime 99.9%)
    all op : REQ_SEC_LOG_01 | (Security_Administrator in op.initiator) => (#op.channel >= 2)
}

fact nfr_fact_scalability {
    -- PROXY: every Actor must be initiator of at least one operation (NFR: supports 1000 concurrent users)
    all a : Actor | some op : REQ_SEC_LOG_01 | a in op.initiator
}

fact nfr_fact_usability {
    -- PROXY: at most one authenticated channel per operation (NFR: intuitive interface)
    all op : REQ_SEC_LOG_01 | #(op.channel & {i : Interface | i.authenticated = True}) <= 1
}

assert nfr_assert_performance_bound {
    all op : REQ_SEC_LOG_01 | #op.channel <= 2
}
check nfr_assert_performance_bound for 5

assert nfr_assert_availability_redundancy {
    all op : REQ_SEC_LOG_01 | (Security_Administrator in op.initiator) => (#op.channel >= 2)
}
check nfr_assert_availability_redundancy for 5

assert nfr_assert_scalability_coverage {
    all a : Actor | some op : REQ_SEC_LOG_01 | a in op.initiator
}
check nfr_assert_scalability_coverage for 5

assert nfr_assert_usability_simple {
    all op : REQ_SEC_LOG_01 | #(op.channel & {i : Interface | i.authenticated = True}) <= 1
}
check nfr_assert_usability_simple for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security requirement 1: Logs should be searchable && exportable for analysis
-- This requires that all operations on Audit_Log_Database resources are searchable && exportable
-- We model this as: for any operation targeting Audit_Log_Database, the operation must have Read permission
-- && the initiator must be able to access the log data

-- Helper sig for audit log operations
sig AuditOperation {
    logEntry: one REQ_SEC_LOG_01,
    -- The operation must be searchable (can be queried)
    searchable: one Bool,
    -- The operation must be exportable (can be extracted)
    exportable: one Bool
}

fact sr_fact_log_searchable_exportable {
    -- Every operation on Audit_Log_Database must have searchable && exportable properties
    all op: REQ_SEC_LOG_01 |
        (op.target in Audit_Log_Database) =>
        (some a: AuditOperation | a.logEntry = op && a.searchable = True && a.exportable = True)
}

assert sr_assert_log_searchable_exportable {
    all op: REQ_SEC_LOG_01 |
        (op.target in Audit_Log_Database) =>
        (op.grant in Read) && (op.initiator in op.target.accessible)
}
check sr_assert_log_searchable_exportable for 5

-- Security requirement 2: Tamper-proof mechanism must guarantee the integrity of the log
-- This means: Only the log owner || authorized administrators can modify log entries
-- We model this as: For any operation on Audit_Log_Database that involves Write || Execute,
-- the initiator must be the owner || have Admin permission

fact sr_fact_log_integrity {
    all op: REQ_SEC_LOG_01 |
        (op.target in Audit_Log_Database) &&
        (Write in op.initiator.mayPerform || Execute in op.initiator.mayPerform) =>
        (op.initiator = op.target.owner || Admin in op.initiator.mayPerform)
}

assert sr_assert_log_tamper_proof {
    all op: REQ_SEC_LOG_01 |
        (op.target in Audit_Log_Database) =>
        (op.initiator = op.target.owner || Admin in op.initiator.mayPerform)
}
check sr_assert_log_tamper_proof for 5

-- Additional security property: Only authenticated channels can access audit logs
assert sr_assert_audit_log_authentication {
    all op: REQ_SEC_LOG_01 |
        (op.target in Audit_Log_Database) =>
        (all c: op.channel | c.authenticated = True)
}
check sr_assert_audit_log_authentication for 5

-- Security property: Non-repudiation for audit operations
-- Every audit operation must have a uniquely identified initiator
assert sr_assert_non_repudiation {
    all op: REQ_SEC_LOG_01 |
        (op.target in Audit_Log_Database) =>
        one op.initiator
}
check sr_assert_non_repudiation for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model captures audit log maintenance with actors, resources, interfaces, states, and operations.
-- Summary 2: Includes safety assertions for authorization, tamper-proofing, and state progression.
-- Summary 3: Revised to fix type errors: Audit_Log_Database changed from Interface to Resource, Event_Notification_API usage corrected from target to channel, ec_safe_4 fixed to use Actor instead of Permission.
-- Assumption 1: The audit log resource is owned by Security_Administrator.
-- Assumption 2: Operations require at least one authenticated channel.
-- Assumption 3: State progression is linear from PreIdle to Post1/Post2/Post3.
-- Open issue 1: The model does not explicitly model clock drift or high-volume scenarios beyond simple constraints.
-- Open issue 2: The tamper-proof mechanism is modeled via authorization constraints, not cryptographic guarantees.
-- Open issue 3: The AuditOperation sig is introduced but not fully integrated with the rest of the model (no constraints linking it to the log entries' content).


