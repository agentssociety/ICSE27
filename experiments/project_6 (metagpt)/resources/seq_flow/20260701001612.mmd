
sequenceDiagram
    participant User as User
    participant App as Flask App
    participant Auth as Auth Blueprint
    participant Main as Main Blueprint
    participant Admin as Admin Blueprint
    participant DB as Database
    participant Mail as Flask-Mail

    User->>App: POST /register (email, password, username)
    App->>Auth: register()
    Auth->>DB: Create User (email_verified=False)
    Auth->>Mail: Send verification email
    Auth-->>User: Redirect to login with flash message

    User->>App: POST /login (email, password)
    App->>Auth: login()
    Auth->>DB: Verify credentials and email_verified
    Auth->>App: Create session
    App-->>User: Redirect to feed

    User->>App: POST /post (content, images)
    App->>Main: create_post()
    Main->>DB: Insert Post
    Main->>DB: Create notification for followers (optional)
    Main-->>User: Return post JSON

    User->>App: POST /post/<id>/like
    App->>Main: toggle_like()
    Main->>DB: Check existing Like
    alt Like exists
        Main->>DB: Delete Like
    else
        Main->>DB: Insert Like
        Main->>DB: Create notification for post owner
    end
    Main-->>User: Return updated like count

    User->>App: POST /post/<id>/comment (content)
    App->>Main: add_comment()
    Main->>DB: Insert Comment
    Main->>DB: Create notification for post owner
    Main-->>User: Return comment JSON

    User->>App: POST /friend-request/<user_id>
    App->>Main: send_friend_request()
    Main->>DB: Create FriendRequest (status=pending)
    Main->>DB: Create notification for receiver
    Main-->>User: Success message

    User->>App: POST /friend-request/<id>/accept
    App->>Main: accept_friend_request()
    Main->>DB: Update status to accepted
    Main->>DB: Create Follow records (mutual)
    Main-->>User: Redirect to friends list

    User->>App: POST /group/create (name, description, is_public)
    App->>Main: create_group()
    Main->>DB: Insert Group
    Main->>DB: Insert GroupMembership (role=admin)
    Main-->>User: Redirect to group page

    User->>App: POST /group/<id>/join
    App->>Main: join_group()
    alt group is public
        Main->>DB: Insert GroupMembership
    else
        Main->>DB: Create GroupJoinRequest (status=pending)
        Main->>DB: Create notification for group admins
    end
    Main-->>User: Success message

    Admin->>App: GET /admin/reports
    App->>Admin: view_reports()
    Admin->>DB: Query Report with related Post and User
    Admin-->>Admin: Render report list

    Admin->>App: POST /admin/report/<id>/delete-post
    App->>Admin: delete_reported_post()
    Admin->>DB: Soft delete Post
    Admin->>DB: Create AdminLog
    Admin-->>Admin: Redirect with flash

    Admin->>App: POST /admin/user/<id>/suspend
    App->>Admin: suspend_user()
    Admin->>DB: Set User.is_active=False
    Admin->>DB: Create AdminLog
    Admin-->>Admin: Redirect with flash

    Admin->>App: POST /admin/user/<id>/verify
    App->>Admin: toggle_verified()
    Admin->>DB: Toggle User.is_verified
    Admin->>DB: Create AdminLog
    Admin-->>Admin: Redirect with flash

    User->>App: POST /user/<id>/block
    App->>Main: block_user()
    Main->>DB: Insert Block
    Main->>DB: Remove any existing Follow/Friend relationships
    Main-->>User: Success message

    User->>App: POST /settings/notifications (likes, comments, friend_requests)
    App->>Main: update_notification_prefs()
    Main->>DB: Upsert NotificationPreference
    Main-->>User: Success message

    User->>App: POST /account/delete
    App->>Main: delete_account()
    Main->>DB: Set User.is_deleted=True, soft delete posts/comments
    Main->>App: Logout user
    App-->>User: Redirect to home
