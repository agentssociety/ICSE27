    follow2 = Follow(follower_id=fr.sender_id, followed_id=current_user.id)
    db.session.add(follow1)
    db.session.add(follow2)
    db.session.commit()

    flash('Friend request accepted!', 'success')
    return redirect(url_for('main.friends'))


