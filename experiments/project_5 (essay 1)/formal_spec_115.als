 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Students, Instructors extends Actor {}
-- Students: represents stakeholder 'Students'
-- Instructors: represents stakeholder 'Instructors'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Student_Data_Store, Cohort_Settings_API, Leaderboard_Display extends Interface {}

fact interface_properties {
    Student_Data_Store.kind = Database  -- The system retrieves student nugget data from this database to populate the leaderboard.
    Cohort_Settings_API.kind = API  -- This API is used to check if the leaderboard is enabled and retrieve the current time window configuration.
    Leaderboard_Display.kind = UI  -- The user interface displays the leaderboard based on data fetched from the database and settings from the API.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The leaderboard feature is enabled for the student's cohort
-- Pre2: system is in state where The student has not opted out of the leaderboard

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where Student sees their rank based on total nuggets earned within the configured time window
-- Post2: system reaches state where Student sees ranks of other students in the cohort based on total nuggets earned within the configured time window


----------------------------------------------------------------------
-- Core operation: REQ_COHORT_LEADERBOARD_01
----------------------------------------------------------------------

sig REQ_COHORT_LEADERBOARD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_COHORT_LEADERBOARD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_COHORT_LEADERBOARD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_COHORT_LEADERBOARD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_COHORT_LEADERBOARD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_COHORT_LEADERBOARD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_COHORT_LEADERBOARD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_COHORT_LEADERBOARD_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_COHORT_LEADERBOARD_01 {
    some op: REQ_COHORT_LEADERBOARD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_COHORT_LEADERBOARD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_COHORT_LEADERBOARD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_COHORT_LEADERBOARD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_COHORT_LEADERBOARD_01_well_formed {
    all op: REQ_COHORT_LEADERBOARD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_COHORT_LEADERBOARD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? POST-STATE REACHABILITY PREDICATES AND SEMANTIC ASSERTIONS ???????????

pred ps_reach_Post1 {
    some op: REQ_COHORT_LEADERBOARD_01 |
        op.post = Post1
        && Students in op.initiator
        && Read in op.initiator.mayPerform
        && Student_Data_Store in op.target
        && Leaderboard_Display in op.channel
        && op.grant = Read
        && op.pre != op.post
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_COHORT_LEADERBOARD_01 |
        (op.post = Post1) => {
            Students in op.initiator
            && Read in op.initiator.mayPerform
            && Student_Data_Store in op.target
            && some op.channel
            && Leaderboard_Display in op.channel
        }
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_COHORT_LEADERBOARD_01 |
        op.post = Post2
        && Instructors in op.initiator
        && Read in op.initiator.mayPerform
        && Student_Data_Store in op.target
        && Cohort_Settings_API in op.channel
        && op.grant = Read
        && op.pre != op.post
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_COHORT_LEADERBOARD_01 |
        (op.post = Post2) => {
            (Students in op.initiator || Instructors in op.initiator)
            && Read in op.initiator.mayPerform
            && Student_Data_Store in op.target
            && some op.channel
            && some ch: op.channel | ch in (Leaderboard_Display + Cohort_Settings_API)
        }
}

check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_COHORT_LEADERBOARD_01 |
        op.initiator in Students &&
        op.grant = Read &&
        Leaderboard_Display in op.target &&
        Students in Leaderboard_Display.accessible &&
        some c: op.channel | c.authenticated = True &&
        op.pre = Pre1 &&
        op.post = Post2 &&
        op.pre != op.post
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Safety invariant: If the target resource has no accessible actors (empty leaderboard audience), the operation must ! modify state.
assert ec_safe_1 {
  all op: REQ_COHORT_LEADERBOARD_01 |
    no op.target.accessible => op.post = op.pre
}
check ec_safe_1 for 5

-- Safety invariant: When all communication channels are encrypted && authenticated, the initiator must be the owner of the target resource.
assert ec_safe_2 {
  all op: REQ_COHORT_LEADERBOARD_01 |
    (all c: op.channel | c.encrypted = True && c.authenticated = True) =>
      op.target.owner in op.initiator
}
check ec_safe_2 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_cohort_leaderboard_01_holds {
    some op: REQ_COHORT_LEADERBOARD_01 |
        op.initiator in Instructors &&
        op.grant = Admin &&
        Leaderboard_Display in op.target &&
        op.pre = Pre1 &&
        op.post = Post1
}

run tc_cohort_leaderboard_01_holds for 5

assert tc_cohort_leaderboard_01_contract {
    all op: REQ_COHORT_LEADERBOARD_01 |
        (op.initiator in Instructors &&
         op.grant = Admin &&
         Leaderboard_Display in op.target &&
         op.pre = Pre1) =>
        op.post = Post1
}

check tc_cohort_leaderboard_01_contract for 5

pred tc_cohort_leaderboard_02_holds {
    some op: REQ_COHORT_LEADERBOARD_01 |
        op.initiator in Instructors &&
        op.grant = Admin &&
        Cohort_Settings_API in op.target &&
        op.pre = Pre2 &&
        op.post = Post2
}

run tc_cohort_leaderboard_02_holds for 5

assert tc_cohort_leaderboard_02_contract {
    all op: REQ_COHORT_LEADERBOARD_01 |
        (op.initiator in Instructors &&
         op.grant = Admin &&
         Cohort_Settings_API in op.target &&
         op.pre = Pre2) =>
        op.post = Post2
}

check tc_cohort_leaderboard_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Performance NFR: response time < 2 sec
-- Proxy: limit the number of channels && targets per operation to reduce latency
fact nfr_fact_performance {
    all op: REQ_COHORT_LEADERBOARD_01 {
        #op.channel <= 2
        #op.target <= 2
    }
}

-- Availability NFR: 99.5% uptime
-- Proxy: each operation uses at least 2 redundant channels to tolerate single channel failure
fact nfr_fact_availability {
    all op: REQ_COHORT_LEADERBOARD_01 {
        #op.channel >= 2
    }
}

-- Scalability NFR: support up to 10,000 students
-- Proxy: every resource is accessible by at least two actors to avoid bottlenecks at scale
fact nfr_fact_scalability {
    all r: Resource {
        #r.accessible >= 2
    }
}

-- Usability NFR: clear error messages, intuitive interface
-- Proxy: within each operation all interfaces are of the same kind (consistent navigation)
fact nfr_fact_usability {
    all op: REQ_COHORT_LEADERBOARD_01 {
        #(op.channel.kind) <= 1
    }
}

