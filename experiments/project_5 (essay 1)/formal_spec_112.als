module REQ_ANS_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-ANS-01
 * Title       : Streak System Implementation
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Game_Developers, UX_UI_Designers, QA_Engineers extends Actor {}
-- Game_Developers: represents stakeholder 'Game Developers'
-- UX_UI_Designers: represents stakeholder 'UX/UI Designers'
-- QA_Engineers: represents stakeholder 'QA Engineers'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Question_API, Player_Data_Database, Game_Interface extends Interface {}

fact interface_properties {
    Question_API.kind = API  -- Interacts with the Question Management System to fetch and validate player answers.
    Player_Data_Database.kind = Database  -- Stores player streak information and multiplier values.
    Game_Interface.kind = UI  -- Displays the current streak and multiplier to the player.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where The player is actively answering questions within the game environment.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where If the player answers correctly, they receive nuggets multiplied according to their current streak.
-- Post2: system reaches state where If the player answers incorrectly, their streak resets and the multiplier reverts to 1×.


----------------------------------------------------------------------
-- Core operation: REQ_ANS_01
----------------------------------------------------------------------

sig REQ_ANS_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_ANS_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_ANS_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_ANS_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_ANS_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_ANS_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_ANS_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_ANS_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_ANS_01 {
    some op: REQ_ANS_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_ANS_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_ANS_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_ANS_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_ANS_01_well_formed {
    all op: REQ_ANS_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_ANS_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability && semantic verification for Post1 (correct answer)
pred ps_reach_Post1 {
    some op: REQ_ANS_01 |
        op.post = Post1 &&
        op.grant = Write &&
        Player_Data_Database in op.target &&
        Game_Interface in op.channel &&
        op.initiator = Game_Developers &&   -- player role
        op.pre = Pre1                       -- distinct pre-state
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_ANS_01 |
        op.post = Post1 => (
            op.grant = Write &&
            Player_Data_Database in op.target &&
            Game_Interface in op.channel
        )
}
check ps_valid_Post1 for 5

-- Reachability && semantic verification for Post2 (incorrect answer)
pred ps_reach_Post2 {
    some op: REQ_ANS_01 |
        op.post = Post2 &&
        op.grant = Execute &&
        Player_Data_Database in op.target &&
        Question_API in op.channel &&
        op.initiator = Game_Developers &&   -- player role
        op.pre = Pre1                       -- distinct pre-state
}
run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_ANS_01 |
        op.post = Post2 => (
            op.grant = Execute &&
            Player_Data_Database in op.target &&
            Question_API in op.channel
        )
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: First correct answer ? base nuggets (no multiplier)
pred ac_reach_1 {
    some op: REQ_ANS_01 |
        -- Initiator is a game developer answering a question
        Game_Developers in op.initiator &&
        -- Using Question_API interface
        Question_API in op.channel.kind &&
        -- Granting Read permission (accessing question data)
        Read in op.grant &&
        -- Target is Player_Data_Database (where answers are stored)
        Player_Data_Database in op.target &&
        -- Pre-state is Pre1 (initial state before any correct answer)
        op.pre = Pre1 &&
        -- Post-state is Post1 (base nuggets awarded)
        op.post = Post1
}

run ac_reach_1 for 5

-- Criterion 2: Second consecutive correct answer ? 1.5? multiplier
pred ac_reach_2 {
    some op: REQ_ANS_01 |
        Game_Developers in op.initiator &&
        Question_API in op.channel.kind &&
        Read in op.grant &&
        Player_Data_Database in op.target &&
        -- Pre-state is Post1 (after first correct answer)
        op.pre = Post1 &&
        -- Post-state is Post2 (1.5? multiplier applied)
        op.post = Post2
}

run ac_reach_2 for 5

-- Criterion 3: Third consecutive correct answer ? 2? multiplier
pred ac_reach_3 {
    some op: REQ_ANS_01 |
        Game_Developers in op.initiator &&
        Question_API in op.channel.kind &&
        Read in op.grant &&
        Player_Data_Database in op.target &&
        -- Pre-state is Post2 (after second correct answer)
        op.pre = Post2 &&
        -- Post-state must be a new state representing 2? multiplier
        -- Since only Post1 && Post2 are defined, we use Post2 as placeholder
        -- && constrain that the operation changes state
        op.post != op.pre
}

run ac_reach_3 for 5

-- Criterion 4: Fourth consecutive correct answer ? 3? multiplier
pred ac_reach_4 {
    some op: REQ_ANS_01 |
        Game_Developers in op.initiator &&
        Question_API in op.channel.kind &&
        Read in op.grant &&
        Player_Data_Database in op.target &&
        -- Pre-state is Post2 (after third correct answer, using Post2 as placeholder)
        op.pre = Post2 &&
        -- Post-state must be different from pre-state
        op.post != op.pre &&
        -- Initiator has the required permission
        Read in op.initiator.mayPerform
}

run ac_reach_4 for 5

-- Criterion 5: Incorrect answer after streak ? streak resets, multiplier returns to 1?
pred ac_reach_5 {
    some op: REQ_ANS_01 |
        Game_Developers in op.initiator &&
        Question_API in op.channel.kind &&
        -- Granting Write permission (recording incorrect answer)
        Write in op.grant &&
        Player_Data_Database in op.target &&
        -- Pre-state is Post1 || Post2 (had a streak)
        (op.pre = Post1 || op.pre = Post2) &&
        -- Post-state returns to Pre1 (streak reset, multiplier back to 1?)
        op.post = Pre1
}

run ac_reach_5 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
  all op: REQ_ANS_01 | op.grant in op.initiator.mayPerform
}

assert ec_safe_2 {
  all op: REQ_ANS_01 | #op.target <= 1
}

assert ec_safe_3 {
  all op: REQ_ANS_01 | op.grant = Read || op.grant = Write
}

check ec_safe_1 for 5
check ec_safe_2 for 5
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- ?? TC-ANS-01: First correct answer, base nuggets, no multiplier ??
pred tc_ans_01_holds {
    some op: REQ_ANS_01 |
        -- Input: Player answers correctly for the first time
        op.initiator in Game_Developers &&
        op.grant = Read &&
        op.pre = Pre1 &&
        -- Expected: base nuggets with no multiplier (streak = 1)
        op.post = Post1
}
run tc_ans_01_holds for 5

assert tc_ans_01_contract {
    all op: REQ_ANS_01 |
        (op.initiator in Game_Developers &&
         op.grant = Read &&
         op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_ans_01_contract for 5

-- ?? TC-ANS-02: Third consecutive correct answer, 3? multiplier ??
pred tc_ans_02_holds {
    some op: REQ_ANS_01 |
        -- Input: Player answers third question correctly in a row
        op.initiator in Game_Developers &&
        op.grant = Read &&
        op.pre = Pre1 &&
        -- Expected: nuggets multiplied by 3?
        op.post = Post2
}
run tc_ans_02_holds for 5

assert tc_ans_02_contract {
    all op: REQ_ANS_01 |
        (op.initiator in Game_Developers &&
         op.grant = Read &&
         op.pre = Pre1) =>
        (op.post = Post2)
}
check tc_ans_02_contract for 5

-- ?? TC-ANS-03: Incorrect answer after streak of 3, streak resets to 1? ??
pred tc_ans_03_holds {
    some op: REQ_ANS_01 |
        -- Input: Player answers incorrectly after a streak of 3 correct
        op.initiator in Game_Developers &&
        op.grant = Read &&
        op.pre = Pre1 &&
        -- Expected: streak resets, multiplier returns to 1?
        op.post = Post1
}
run tc_ans_03_holds for 5

assert tc_ans_03_contract {
    all op: REQ_ANS_01 |
        (op.initiator in Game_Developers &&
         op.grant = Read &&
         op.pre = Pre1) =>
        (op.post = Post1)
}
check tc_ans_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: limit channels per operation to reduce latency (performance <200ms)
fact nfr_fact_single_channel {
    all op: REQ_ANS_01 | #op.channel <= 1
}

-- Proxy: at least one channel per operation is authenticated to ensure reliable feedback (usability)
fact nfr_fact_authenticated_channel {
    all op: REQ_ANS_01 | some c: op.channel | c.authenticated = True
}

-- Proxy: for scalability (1000 concurrent players), ensure every Actor can initiate an operation
fact nfr_fact_actor_initiates {
    all a: Actor | some op: REQ_ANS_01 | op.initiator = a
}

-- Proxy: require at least two channels per operation for redundancy (availability 99.5%)
fact nfr_fact_redundant_channels {
    all op: REQ_ANS_01 | #op.channel >= 2
}

-- Assertion: usability ? every operation uses a UI-kind interface (proxy for clear display)
assert nfr_assert_ui_channel {
    all op: REQ_ANS_01 | some c: op.channel | c.kind = UI
}
check nfr_assert_ui_channel for 5

-- Assertion: performance ? no operation uses more than one resource (proxy for fast response)
assert nfr_assert_single_target {
    all op: REQ_ANS_01 | #op.target <= 1
}
check nfr_assert_single_target for 5

