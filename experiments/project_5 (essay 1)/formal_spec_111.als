module REQ_EXAM_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-EXAM-01
 * Title       : Single Question Per Screen Exam Interface
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Student, Instructor, IT_Team extends Actor {}
-- Student: represents stakeholder 'Student'
-- Instructor: represents stakeholder 'Instructor'
-- IT_Team: represents stakeholder 'IT Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resources for the exam interface
one sig UI_Resource extends Resource {}
one sig Progress_Database_Resource extends Resource {}

fact concreteResourceAccess {
    UI_Resource.owner = Student
    Progress_Database_Resource.owner = Instructor
    UI_Resource.accessible = Student + Instructor + IT_Team
    Progress_Database_Resource.accessible = Student + Instructor + IT_Team
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Exam_Interface, Question_Service_API, Progress_Tracking_Database extends Interface {}

fact interface_properties {
    Exam_Interface.kind = UI  -- The user interface that displays the exam questions, game-like elements, live timer, progress bar, and nugget counter.
    Question_Service_API.kind = API  -- An API that provides the next question to be displayed during the exam.
    Progress_Tracking_Database.kind = Database  -- A database that stores the student's progress and nugget counts throughout the exam.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1 extends State {}
-- Pre1: system is in state where I am taking an exam

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3, Post4, Post5 extends State {}
-- Post1: system reaches state where One question at a time with game-like interface, live timer, progress bar, and animated nugget counter is visible
-- Post2: system reaches state where Progress bar accurately reflects completion percentage or question count
-- Post3: system reaches state where Current answer is submitted automatically when I submit
-- Post4: system reaches state where Exam ends when the timer reaches zero
-- Post5: system reaches state where Nugget counter animation plays upon earning a nugget


----------------------------------------------------------------------
-- Core operation: REQ_EXAM_01
----------------------------------------------------------------------

sig REQ_EXAM_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_EXAM_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_EXAM_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_EXAM_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_EXAM_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_EXAM_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_EXAM_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_EXAM_01 | op.post in Post1 + Post2 + Post3 + Post4 + Post5
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_EXAM_01 {
    some op: REQ_EXAM_01 |
        some op.target   and
        some op.channel  and
        op.grant in op.initiator.mayPerform
}
run show_REQ_EXAM_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_EXAM_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_EXAM_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_EXAM_01_well_formed {
    all op: REQ_EXAM_01 |
        one  op.initiator and
        some op.target    and
        some op.channel   and
        one  op.grant     and
        one  op.pre       and
        one  op.post      and
        op.pre != op.post
}
check REQ_EXAM_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicate for Post1: one question at a time with game-like interface, live timer, progress bar, and animated nugget counter is visible
pred ps_reach_Post1 {
    some op: REQ_EXAM_01 |
        op.post = Post1 and
        UI_Resource in op.target and
        Exam_Interface in op.channel and
        Read in op.initiator.mayPerform and
        op.grant = Read and
        op.pre = Pre1
}
run ps_reach_Post1 for 5

-- Semantic assertion for Post1: whenever this post-state is reached, the described interface visibility holds
assert ps_valid_Post1 {
    all op: REQ_EXAM_01 |
        (op.post = Post1) implies
            (UI_Resource in op.target) and
            Exam_Interface in op.channel and
            Read in op.initiator.mayPerform and
            op.grant = Read
}
check ps_valid_Post1 for 5

-- Reachability predicate for Post2: progress bar accurately reflects completion percentage or question count
pred ps_reach_Post2 {
    some op: REQ_EXAM_01 |
        op.post = Post2 and
        Progress_Database_Resource in op.target and
        Exam_Interface in op.channel and
        Write in op.initiator.mayPerform and
        op.grant = Write and
        op.pre = Pre1
}
run ps_reach_Post2 for 5

-- Semantic assertion for Post2: progress bar update requires database write via exam interface
assert ps_valid_Post2 {
    all op: REQ_EXAM_01 |
        (op.post = Post2) implies
            (Progress_Database_Resource in op.target) and
            (Exam_Interface in op.channel) and
            Write in op.initiator.mayPerform and
            op.grant = Write
}
check ps_valid_Post2 for 5

-- Reachability predicate for Post3: current answer is submitted automatically when I submit
pred ps_reach_Post3 {
    some op: REQ_EXAM_01 |
        op.post = Post3 and
        UI_Resource in op.target and
        Exam_Interface in op.channel and
        Write in op.initiator.mayPerform and
        op.grant = Write and
        op.pre = Pre1 and
        op.initiator = Student   -- typical submitter
}
run ps_reach_Post3 for 5

-- Semantic assertion for Post3: answer submission entails write to UI via exam interface by a student
assert ps_valid_Post3 {
    all op: REQ_EXAM_01 |
        (op.post = Post3) implies
            (UI_Resource in op.target) and
            (Exam_Interface in op.channel) and
            Write in op.initiator.mayPerform and
            op.grant = Write and
            op.initiator = Student
}
check ps_valid_Post3 for 5

-- Reachability predicate for Post4: exam ends when the timer reaches zero
pred ps_reach_Post4 {
    some op: REQ_EXAM_01 |
        op.post = Post4 and
        Progress_Database_Resource in op.target and
        Exam_Interface in op.channel and
        Write in op.initiator.mayPerform and
        op.grant = Write and
        op.pre = Pre1 and
        (op.initiator = Student or op.initiator = Instructor)   -- either student or instructor ends exam
}
run ps_reach_Post4 for 5

-- Semantic assertion for Post4: exam termination requires write to database via exam interface by authorized actor
assert ps_valid_Post4 {
    all op: REQ_EXAM_01 |
        (op.post = Post4) implies
            (Progress_Database_Resource in op.target) and
            (Exam_Interface in op.channel) and
            Write in op.initiator.mayPerform and
            op.grant = Write and
            (op.initiator = Student or op.initiator = Instructor)
}
check ps_valid_Post4 for 5

-- Reachability predicate for Post5: nugget counter animation plays upon earning a nugget
pred ps_reach_Post5 {
    some op: REQ_EXAM_01 |
        op.post = Post5 and
        UI_Resource in op.target and
        Exam_Interface in op.channel and
        Write in op.initiator.mayPerform and
        op.grant = Write and
        op.pre = Pre1 and
        op.initiator = Student   -- student earns nugget
}
run ps_reach_Post5 for 5

-- Semantic assertion for Post5: animation trigger involves write to UI via exam interface by student
assert ps_valid_Post5 {
    all op: REQ_EXAM_01 |
        (op.post = Post5) implies
            (UI_Resource in op.target) and
            (Exam_Interface in op.channel) and
            Write in op.initiator.mayPerform and
            op.grant = Write and
            op.initiator = Student
}
check ps_valid_Post5 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_EXAM_01 |
        op.post = Post1 and
        op.initiator = Student and
        op.grant = Read and
        some c: op.channel | c = Exam_Interface and c.authenticated = True and
        (UI_Resource in op.target) and (Progress_Database_Resource in op.target)
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_EXAM_01 |
        op.post = Post2 and
        op.initiator = Student and
        op.grant = Write and
        some c: op.channel | c = Exam_Interface and c.authenticated = True and
        (Progress_Database_Resource in op.target) and (UI_Resource in op.target) and
        op.pre = Pre1
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_EXAM_01 |
        op.post = Post3 and
        op.initiator = Student and
        op.grant = Write and
        some c: op.channel | c = Exam_Interface and c.authenticated = True and
        (Progress_Database_Resource in op.target) and (UI_Resource in op.target) and
        op.pre = Pre1
}
run ac_reach_3 for 5

pred ac_reach_4 {
    some op: REQ_EXAM_01 |
        op.post = Post4 and
        op.initiator = Student and
        op.grant = Write and
        some c: op.channel | c = Exam_Interface and c.authenticated = True and
        (Progress_Database_Resource in op.target) and (UI_Resource in op.target) and
        op.pre = Pre1
}
run ac_reach_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: Student skipping a question without answering must not allow unauthenticated access.
assert ec_safe_1 {
    all op: REQ_EXAM_01 |
        (op.initiator = Student) implies (some ch: op.channel | ch.authenticated = True)
}
check ec_safe_1 for 5

-- Edge case 2: Network interruptions must not lead to using unauthenticated channels.
assert ec_safe_2 {
    all op: REQ_EXAM_01 |
        all ch: op.channel | ch.authenticated = True
}
check ec_safe_2 for 5

-- Edge case 3: Students must not be able to write to the progress tracking database (timer/progress manipulation).
assert ec_safe_3 {
    all op: REQ_EXAM_01 |
        (op.initiator = Student and Progress_Database_Resource in op.target) implies op.grant != Write
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-EXAM-01: Student starts an exam
-- Input: Student initiator, exam interface, Pre1 state
-- Output: First question displayed, game-like interface, live timer, progress bar, animated nugget counter

pred tc_exam_01_holds {
    some op: REQ_EXAM_01 |
        -- Input configuration
        op.initiator = Student and
        op.pre = Pre1 and
        some c: op.channel | c = Exam_Interface and
        -- Expected outcome: postconditions
        op.post = Post1 and
        -- State change occurs
        op.post != op.pre
}
run tc_exam_01_holds for 5

assert tc_exam_01_contract {
    all op: REQ_EXAM_01 |
        -- Pre-conditions
        (op.initiator = Student and op.pre = Pre1 and
         some c: op.channel | c = Exam_Interface) implies
        -- Post-conditions
        (op.post = Post1 and op.post != op.pre)
}
check tc_exam_01_contract for 5

-- TC-EXAM-02: Student answers and submits a question
-- Input: Student initiator, Post1/Post2/Post3/Post4 state (mid-exam)
-- Output: Next question appears, progress bar updates

pred tc_exam_02_holds {
    some op: REQ_EXAM_01 |
        -- Input configuration
        op.initiator = Student and
        (op.pre = Post1 or op.pre = Post2 or op.pre = Post3 or op.pre = Post4) and
        -- Expected outcome: next post state
        ((op.pre = Post1 and op.post = Post2) or
         (op.pre = Post2 and op.post = Post3) or
         (op.pre = Post3 and op.post = Post4) or
         (op.pre = Post4 and op.post = Post5))
}
run tc_exam_02_holds for 5

assert tc_exam_02_contract {
    all op: REQ_EXAM_01 |
        -- Pre-conditions
        (op.initiator = Student and
         (op.pre = Post1 or op.pre = Post2 or op.pre = Post3 or op.pre = Post4)) implies
        -- Post-conditions
        ((op.pre = Post1 and op.post = Post2) or
         (op.pre = Post2 and op.post = Post3) or
         (op.pre = Post3 and op.post = Post4) or
         (op.pre = Post4 and op.post = Post5))
}
check tc_exam_02_contract for 5

-- TC-EXAM-03: Timer reaches zero during an exam
-- Input: Student initiator, any mid-exam state
-- Output: Current answer submitted, exam ends, final results displayed

pred tc_exam_03_holds {
    some op: REQ_EXAM_01 |
        -- Input configuration
        op.initiator = Student and
        (op.pre = Post1 or op.pre = Post2 or op.pre = Post3 or op.pre = Post4) and
        -- Expected outcome: final state reached
        op.post = Post5 and
        op.post != op.pre
}
run tc_exam_03_holds for 5

assert tc_exam_03_contract {
    all op: REQ_EXAM_01 |
        -- Pre-conditions
        (op.initiator = Student and
         (op.pre = Post1 or op.pre = Post2 or op.pre = Post3 or op.pre = Post4)) implies
        -- Post-conditions
        (op.post = Post5 and op.post != op.pre)
}
check tc_exam_03_contract for 5

-- TC-EXAM-04: Student earns a nugget
-- Input: Student initiator, any state
-- Output: Nugget counter updates, celebration animation plays

pred tc_exam_04_holds {
    some op: REQ_EXAM_01 |
        -- Input configuration
        op.initiator = Student and
        -- Expected outcome: state transition occurs
        op.post != op.pre
}
run tc_exam_04_holds for 5

assert tc_exam_04_contract {
    all op: REQ_EXAM_01 |
        -- Pre-conditions
        (op.initiator = Student) implies
        -- Post-conditions
        (op.post != op.pre)
}
check tc_exam_04_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Proxy: Performance - limiting resource count per operation reduces complexity and improves response time.
fact nfr_fact_performance_resource_count {
    all op: REQ_EXAM_01 | #op.target <= 2
}

-- Proxy: Availability - requiring at least two channels per operation ensures redundancy if one fails.
-- Note: This fact is commented out to avoid conflict with reachability predicates that assume a single channel.
-- fact nfr_fact_availability_redundant_channels {
--     all op: REQ_EXAM_01 | #op.channel >= 2
-- }

-- Proxy: Scalability - every declared actor must be able to initiate at least one operation,
-- demonstrating the system can accommodate all user roles simultaneously.
assert nfr_assert_scalability_all_actors_can_initiate {
    all a: Student + Instructor + IT_Team | some op: REQ_EXAM_01 | op.initiator = a
}
check nfr_assert_scalability_all_actors_can_initiate for 5

-- Proxy: Usability - limiting the number of authenticated channels per operation to at most 2
-- reduces the authentication burden on the user while still meeting security requirements.
fact nfr_fact_usability_authenticated_channel_limit {
    all op: REQ_EXAM_01 | #{i: Interface | i in op.channel and i.authenticated = True} <= 2
}

