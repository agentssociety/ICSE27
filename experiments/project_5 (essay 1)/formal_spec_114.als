module REQ_STU_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-STU-01
 * Title       : Student should be able to redeem nuggets for rewards
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Student, Instructor, Reward_Store_Administrator extends Actor {}
-- Student: represents stakeholder 'Student'
-- Instructor: represents stakeholder 'Instructor'
-- Reward_Store_Administrator: represents stakeholder 'Reward Store Administrator'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig UI, API, External_System extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Reward_Store_API, Student_Dashboard, Instructor_Configuration_System extends Interface {}

fact interface_properties {
    Reward_Store_API.kind = API  -- The requirement interacts with this API to retrieve available reward items and update the student's nugget balance.
    Student_Dashboard.kind = UI  -- The requirement is implemented through the user interface, allowing students to select and redeem reward items.
    Instructor_Configuration_System.kind = External_System  -- This system provides instructor-configured institutional perks that can be redeemed with nuggets.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The student has earned nuggets in their wallet
-- Pre2: system is in state where The reward store contains items available for redemption

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The student's nugget balance is reduced by the cost of the redeemed item
-- Post2: system reaches state where The selected reward item is provided to the student


----------------------------------------------------------------------
-- Core operation: REQ_STU_01
----------------------------------------------------------------------

sig REQ_STU_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_STU_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_STU_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_STU_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_STU_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_STU_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_STU_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_STU_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_STU_01 {
    some op: REQ_STU_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_STU_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_STU_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_STU_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_STU_01_well_formed {
    all op: REQ_STU_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_STU_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicate for Post1 (student's nugget balance reduced)
pred ps_reach_Post1 {
    some op: REQ_STU_01 |
        op.post = Post1
        && op.initiator = Student
        && Write in op.initiator.mayPerform
        && op.grant = Write
        && op.channel.kind = Reward_Store_API
        && all c: op.channel | c.authenticated = True
        && some r: op.target | r.owner = Student
}
run ps_reach_Post1 for 5

-- Semantic assertion for Post1: every operation that reaches Post1 conforms to the defined meaning
assert ps_valid_Post1 {
    all op: REQ_STU_01 |
        op.post = Post1
        => (
            op.initiator = Student
            && Write in op.initiator.mayPerform
            && op.grant = Write
            && op.channel.kind = Reward_Store_API
            && all c: op.channel | c.authenticated = True
            && some r: op.target | r.owner = Student
        )
}
check ps_valid_Post1 for 5

-- Reachability predicate for Post2 (selected reward item provided to student)
pred ps_reach_Post2 {
    some op: REQ_STU_01 |
        op.post = Post2
        && op.initiator = Student
        && Execute in op.initiator.mayPerform
        && op.grant = Execute
        && op.channel.kind = Reward_Store_API
        && all c: op.channel | c.authenticated = True
        && some r: op.target | r.owner = Reward_Store_Administrator
}
run ps_reach_Post2 for 5

-- Semantic assertion for Post2: every operation that reaches Post2 conforms to the defined meaning
assert ps_valid_Post2 {
    all op: REQ_STU_01 |
        op.post = Post2
        => (
            op.initiator = Student
            && Execute in op.initiator.mayPerform
            && op.grant = Execute
            && op.channel.kind = Reward_Store_API
            && all c: op.channel | c.authenticated = True
            && some r: op.target | r.owner = Reward_Store_Administrator
        )
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_STU_01 |
        op.initiator = Student &&
        op.grant = Write &&
        some op.target &&
        (some c: op.channel | c.kind = API) &&
        op.post = Post1
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_STU_01 |
        op.initiator = Student &&
        op.grant = Write &&
        some op.target &&
        (some c: op.channel | c.kind = API) &&
        op.post = Post2
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sig for item availability (Edge case 1)  
sig RedemptionItem {  
    resource: one Resource,  
    available: one Bool,
    state: one State
}  

assert ec_safe_1 {  
    all op: REQ_STU_01 |  
        some ri: RedemptionItem |  
            (ri.resource in op.target && ri.available = False) => op.post = op.pre  
}  
check ec_safe_1 for 5  

-- Helper sig for nugget balance snapshots (Edge case 2)  
sig NuggetBalance {  
    student: one Student,  
    amount: one Int,  
    state: one State  
}  

assert ec_safe_2 {  
    all op: REQ_STU_01 |  
        all nb_pre: NuggetBalance |  
            (nb_pre.state = op.pre && nb_pre.amount >= 0) =>  
                (all nb_post: NuggetBalance |  
                    (nb_post.state = op.post && nb_post.student = nb_pre.student) =>  
                        nb_post.amount >= 0)  
}  
check ec_safe_2 for 5  

-- Helper sig for item cost over states (Edge case 3)  
sig ItemCost {  
    item: one Resource,  
    cost: one Int,  
    state: one State  
}  

assert ec_safe_3 {  
    all op: REQ_STU_01 |  
        all cost_pre: ItemCost |  
            (cost_pre.state = op.pre) =>  
                (all cost_post: ItemCost |  
                    (cost_post.state = op.post && cost_post.item = cost_pre.item) =>  
                        cost_post.cost = cost_pre.cost)  
}  
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_REQ_STU_01_holds {
    some op: REQ_STU_01 |
        -- Input: Student redeems an item with sufficient balance
        op.initiator = Student
        && some item_pre: RedemptionItem, bal_pre: NuggetBalance, cost_pre: ItemCost |
            item_pre.resource in op.target
            && item_pre.state = op.pre
            && item_pre.available = False
            && bal_pre.student = Student
            && bal_pre.state = op.pre
            && cost_pre.item in op.target
            && cost_pre.state = op.pre
            && bal_pre.amount >= cost_pre.cost
        -- Output: Balance reduced, item becomes available
        && some item_post: RedemptionItem, bal_post: NuggetBalance |
            item_post.resource in op.target
            && item_post.state = op.post
            && item_post.available = True
            && bal_post.student = Student
            && bal_post.state = op.post
            && bal_post.amount = bal_pre.amount - cost_pre.cost
}
run tc_REQ_STU_01_holds for 5

assert tc_REQ_STU_01_contract {
    all op: REQ_STU_01 |
        all item_pre: RedemptionItem, bal_pre: NuggetBalance, cost_pre: ItemCost |
            (op.initiator = Student
             && item_pre.resource in op.target
             && item_pre.state = op.pre
             && item_pre.available = False
             && bal_pre.student = Student
             && bal_pre.state = op.pre
             && cost_pre.item in op.target
             && cost_pre.state = op.pre
             && bal_pre.amount >= cost_pre.cost)
            =>
            some item_post: RedemptionItem, bal_post: NuggetBalance |
                item_post.resource in op.target
                && item_post.state = op.post
                && item_post.available = True
                && bal_post.student = Student
                && bal_post.state = op.post
                && bal_post.amount = bal_pre.amount - cost_pre.cost
}
check tc_REQ_STU_01_contract for 5

pred tc_REQ_STU_02_holds {
    some op: REQ_STU_01 |
        -- Input: Student attempts redemption with insufficient balance
        op.initiator = Student
        && some item_pre: RedemptionItem, bal_pre: NuggetBalance, cost_pre: ItemCost |
            item_pre.resource in op.target
            && item_pre.state = op.pre
            && item_pre.available = False
            && bal_pre.student = Student
            && bal_pre.state = op.pre
            && cost_pre.item in op.target
            && cost_pre.state = op.pre
            && bal_pre.amount < cost_pre.cost
        -- Output: Balance unchanged, item remains unavailable (no new available item)
        && some bal_post: NuggetBalance |
            bal_post.student = Student
            && bal_post.state = op.post
            && bal_post.amount = bal_pre.amount
        && no item_post: RedemptionItem |
            item_post.resource in op.target
            && item_post.state = op.post
            && item_post.available = True
}
run tc_REQ_STU_02_holds for 5

assert tc_REQ_STU_02_contract {
    all op: REQ_STU_01 |
        all item_pre: RedemptionItem, bal_pre: NuggetBalance, cost_pre: ItemCost |
            (op.initiator = Student
             && item_pre.resource in op.target
             && item_pre.state = op.pre
             && item_pre.available = False
             && bal_pre.student = Student
             && bal_pre.state = op.pre
             && cost_pre.item in op.target
             && cost_pre.state = op.pre
             && bal_pre.amount < cost_pre.cost)
            =>
            some bal_post: NuggetBalance |
                bal_post.student = Student
                && bal_post.state = op.post
                && bal_post.amount = bal_pre.amount
            && no item_post: RedemptionItem |
                item_post.resource in op.target
                && item_post.state = op.post
                && item_post.available = True
}
check tc_REQ_STU_02_contract for 5

pred tc_REQ_STU_03_holds {
    some op: REQ_STU_01 |
        -- Input: Student attempts to redeem an item from a non-existent store (no RedemptionItem for that resource)
        op.initiator = Student
        && no item_pre: RedemptionItem |
            item_pre.resource in op.target
            && item_pre.state = op.pre
        && some bal_pre: NuggetBalance |
            bal_pre.student = Student
            && bal_pre.state = op.pre
        -- Output: No item created, balance unchanged
        && some bal_post: NuggetBalance |
            bal_post.student = Student
            && bal_post.state = op.post
            && bal_post.amount = bal_pre.amount
        && no item_post: RedemptionItem |
            item_post.resource in op.target
            && item_post.state = op.post
}
run tc_REQ_STU_03_holds for 5

assert tc_REQ_STU_03_contract {
    all op: REQ_STU_01 |
        all bal_pre: NuggetBalance |
            (op.initiator = Student
             && no item_pre: RedemptionItem |
                item_pre.resource in op.target
                && item_pre.state = op.pre
             && bal_pre.student = Student
             && bal_pre.state = op.pre)
            =>
            some bal_post: NuggetBalance |
                bal_post.student = Student
                && bal_post.state = op.post
                && bal_post.amount = bal_pre.amount
            && no item_post: RedemptionItem |
                item_post.resource in op.target
                && item_post.state = op.post
}
check tc_REQ_STU_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_usability_auth_ratio {
    -- PROXY: limiting authenticated channels per operation improves usability by reducing login friction
    -- NFR: 90% of UI operations should ! require re-authentication
    all op: REQ_STU_01 |
        #(op.channel & {i: Interface | i.authenticated = True}) <= 1
}

fact nfr_fact_performance_resource_limit {
    -- PROXY: minimizing target resources reduces lookup/computation overhead
    -- NFR: query response time < 50ms
    all op: REQ_STU_01 | #op.target <= 3
}

fact nfr_fact_scalability_concurrent_ops {
    -- PROXY: all actors must be reachable by at least one operation, enabling simultaneous operation
    -- NFR: system supports 100+ concurrent users
    all a: Actor | some op: REQ_STU_01 | a in op.initiator
}

fact nfr_fact_availability_redundancy {
    -- PROXY: requiring at least 2 channels ensures fallback if one fails
    -- NFR: uptime >= 99.9%
    all op: REQ_STU_01 | #op.channel >= 2
}

fact nfr_fact_reliability_state_coverage {
    -- PROXY: every balance && cost record must have a state for traceability
    -- NFR: no data loss on failure
    all nb: NuggetBalance | one nb.state
    all ic: ItemCost | one ic.state
}

assert nfr_assert_maintainability_no_cycle {
    -- PROXY: breaking circular owner chains prevents maintenance deadlocks
    -- NFR: system can be updated without cascading dependencies
    no r: Resource | r.owner in r.accessible
}
check nfr_assert_maintainability_no_cycle for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security Requirement 1: Authentication && authorization must be performed before allowing student to redeem nuggets.
-- Assertion: For any operation that targets a resource belonging to a RedemptionItem, all channels used are authenticated && the initiator is a Student holding the required permission.
assert sr_assert_redemption_auth {
    all op: REQ_STU_01 |
        some r: op.target |
            r in RedemptionItem.resource => (
                (all c: op.channel | c.authenticated = True) &&
                (op.initiator in Student) &&
                (op.grant in op.initiator.mayPerform)
            )
}
check sr_assert_redemption_auth for 5

-- Security Requirement 2: Redemption requests must be validated against available nugget balance.
-- Assertion: For any operation that targets a RedemptionItem resource, the initiator (a Student) must have a NuggetBalance in the pre?state that is at least the ItemCost of that resource.
assert sr_assert_balance_sufficient {
    all op: REQ_STU_01 |
        some r: op.target |
            r in RedemptionItem.resource =>
                (op.initiator in Student) &&
                (some nb: NuggetBalance |
                    nb.student = op.initiator &&
                    nb.state = op.pre &&
                    (some ic: ItemCost |
                        ic.item = r &&
                        ic.state = op.pre &&
                        ic.cost <= nb.amount
                    )
                )
}
check sr_assert_balance_sufficient for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model covers student nugget redemption with authentication, authorization, balance checks, and state tracking.
-- Summary 2: Fixed missing state field in RedemptionItem and replaced undefined functions minus/lte with Alloy arithmetic operators.
-- Assumption 1: RedemptionItem.available indicates whether item is owned/unlocked; non-existent items cause denial.
-- Assumption 2: Balance and cost are integers within bounded range (default -8 to 7 for scope 5).
-- Assumption 3: Only one item is considered per operation for simplicity.
-- Open issue 1: Edge case assertion ec_safe_1 denies any state change if any target resource is unavailable, which may be too restrictive.
-- Open issue 2: The 'stronger' function is defined but never used in any fact or assertion.


