module REQ_EXAM_BLD_01

/*
 * Alloy 6 — Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-EXAM-BLD-01
 * Title       : Support multiple question types and tagging
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Instructors, Learning_Management_System_LMS_Developers extends Actor {}
-- Instructors: represents stakeholder 'Instructors'
-- Learning_Management_System_LMS_Developers: represents stakeholder 'Learning Management System (LMS) Developers'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Question_Creation_API, Exam_Builder_Database extends Interface {}

fact interface_properties {
    Question_Creation_API.kind = API  -- Used by the LMS to create new questions with specified details.
    Exam_Builder_Database.kind = Database  -- Stores information about created questions, including their type, competencies, difficulty tiers, and nugget reward multipliers.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system is running and accessible.
-- Pre2: system is in state where An exam creator is logged in.

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where A new question of the specified type has been created with the assigned competencies, difficulty tier, and nugget reward multiplier.


----------------------------------------------------------------------
-- Core operation: REQ_EXAM_BLD_01
----------------------------------------------------------------------

sig REQ_EXAM_BLD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_EXAM_BLD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_EXAM_BLD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_EXAM_BLD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_EXAM_BLD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_EXAM_BLD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_EXAM_BLD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_EXAM_BLD_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_EXAM_BLD_01 {
    some op: REQ_EXAM_BLD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_EXAM_BLD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_EXAM_BLD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_EXAM_BLD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_EXAM_BLD_01_well_formed {
    all op: REQ_EXAM_BLD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_EXAM_BLD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_EXAM_BLD_01 |
        op.post = Post1 &&
        op.grant = Write &&
        Write in op.initiator.mayPerform &&
        Question_Creation_API in op.target &&
        some c: op.channel | c.authenticated = True &&
        op.pre != Post1
}
run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_EXAM_BLD_01 |
        (op.post = Post1) => (
            op.grant = Write &&
            Write in op.initiator.mayPerform &&
            Question_Creation_API in op.target &&
            some c: op.channel | c.authenticated = True &&
            op.pre != Post1
        )
}
check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_EXAM_BLD_01 |
    op.initiator = Instructors &&
    op.grant = Write &&
    Exam_Builder_Database in op.target &&
    op.pre = Pre1 &&
    op.post = Post1
}
run ac_reach_1 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Helper sigs for edge case 2 (multiple difficulty tiers)
abstract sig DifficultyLevel {}
one sig Easy, Medium, Hard extends DifficultyLevel {}
sig DifficultyTag {
    resource: Resource,
    level: one DifficultyLevel
}

assert ec_safe_1 {
    -- Safety: No resource may have an empty set of accessible actors.
    all r: Resource | some r.accessible
}
check ec_safe_1 for 5

assert ec_safe_2 {
    -- Safety: No resource may be tagged with more than one difficulty level.
    no disj t1, t2: DifficultyTag | t1.resource = t2.resource
}
check ec_safe_2 for 5

assert ec_safe_3 {
    -- Safety: Every communication channel used by an operation must be authenticated.
    all op: REQ_EXAM_BLD_01 |
        all c: op.channel | c.authenticated = True
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Predicate for TC-EXAM-BLD-01: successful creation with difficulty
pred tc_TC_EXAM_BLD_01_holds {
    some op: REQ_EXAM_BLD_01 |
        // input: instructor with write permission, target includes a resource owned by Database
        op.initiator in Instructors &&
        Write in op.initiator.mayPerform &&
        some r: op.target | r.owner = Database &&
        // expected: post-state is Post1 && a DifficultyTag links that resource to Easy
        op.post = Post1 &&
        some dt: DifficultyTag | dt.resource in op.target && dt.level = Easy
}
run tc_TC_EXAM_BLD_01_holds for 5

-- Assertion for TC-EXAM-BLD-01: whenever the input conditions hold, the contract is satisfied
assert tc_TC_EXAM_BLD_01_contract {
    all op: REQ_EXAM_BLD_01 |
        (op.initiator in Instructors &&
         Write in op.initiator.mayPerform &&
         some r: op.target | r.owner = Database &&
         op.pre = Pre1) =>
        (op.post = Post1 &&
         some dt: DifficultyTag | dt.resource in op.target && dt.level = Easy)
}
check tc_TC_EXAM_BLD_01_contract for 5

-- Predicate for TC-EXAM-BLD-02: attempt without competency ? error (post != Post1)
pred tc_TC_EXAM_BLD_02_holds {
    some op: REQ_EXAM_BLD_01 |
        // input: pre-state Pre2, instructor with write permission, no DifficultyTag on any target resource
        op.pre = Pre2 &&
        op.initiator in Instructors &&
        Write in op.initiator.mayPerform &&
        no dt: DifficultyTag | dt.resource in op.target &&
        // expected: post-state is ! Post1 (error)
        op.post != Post1
}
run tc_TC_EXAM_BLD_02_holds for 5

-- Assertion for TC-EXAM-BLD-02: whenever the input conditions hold, the error contract is satisfied
assert tc_TC_EXAM_BLD_02_contract {
    all op: REQ_EXAM_BLD_01 |
        (op.pre = Pre2 &&
         op.initiator in Instructors &&
         Write in op.initiator.mayPerform &&
         no dt: DifficultyTag | dt.resource in op.target) =>
        op.post != Post1
}
check tc_TC_EXAM_BLD_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    // Proxy: limiting channels && targets per operation reduces processing time.
    all op: REQ_EXAM_BLD_01 | (#op.channel <= 1) && (#op.target <= 1)
}

assert nfr_assert_availability {
    // Proxy: at least two redundant channels per operation ensures tolerance to single channel failure.
    all op: REQ_EXAM_BLD_01 | #op.channel >= 2
}
check nfr_assert_availability for 5

assert nfr_assert_scalability {
    // Proxy: every actor type can initiate at least one operation, indicating system can handle all actor loads.
    all a: Actor | some op: REQ_EXAM_BLD_01 | op.initiator = a
}
check nfr_assert_scalability for 5

assert nfr_assert_usability {
    // Proxy: small total number of interfaces reduces complexity && cognitive load.
    #Interface <= 3
}
check nfr_assert_usability for 5

