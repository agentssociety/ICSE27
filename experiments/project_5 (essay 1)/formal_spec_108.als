module REQ_MNG_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-MNG-01
 * Title       : Cohort Creation and Management
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Administrators, IT_Team extends Actor {}
-- Administrators: represents stakeholder 'Administrators'
-- IT_Team: represents stakeholder 'IT Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Concrete resource types for cohort and exam management
sig Student {}
sig CohortData extends Resource {
    students: set Student
}
sig ExamData extends Resource {}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Cohort_API, Student_Cohort_Database, Exam_Restriction_API extends Interface {}

fact interface_properties {
    Cohort_API.kind = API  -- Interface for creating, retrieving, updating, and deleting cohorts.
    Student_Cohort_Database.kind = Database  -- Database to store cohort information and student enrollments.
    Exam_Restriction_API.kind = API  -- Interface for restricting exams to specific cohorts.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where The system must be operational and accessible.
-- Pre2: system is in state where The administrator must have the necessary permissions.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where A new cohort is created and saved in the system.
-- Post2: system reaches state where An individual student is successfully enrolled in a cohort.
-- Post3: system reaches state where The exam access restriction is applied correctly to specified cohorts.


----------------------------------------------------------------------
-- Core operation: REQ_MNG_01
----------------------------------------------------------------------

sig REQ_MNG_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_MNG_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_MNG_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_MNG_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_MNG_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_MNG_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_MNG_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_MNG_01 | op.post in Post1 + Post2 + Post3
}


----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_MNG_01 {
    some op: REQ_MNG_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_MNG_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_MNG_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_MNG_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_MNG_01_well_formed {
    all op: REQ_MNG_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_MNG_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_MNG_01 |
        op.post = Post1 &&
        op.target in CohortData &&
        op.grant = Write &&
        some c: op.channel | c.authenticated = True
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_MNG_01 |
        op.post = Post2 &&
        op.target in CohortData &&
        op.grant = Write &&
        some c: op.channel | c.authenticated = True
}
run ps_reach_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_MNG_01 |
        op.post = Post3 &&
        op.target in ExamData &&
        op.grant = Execute &&
        some c: op.channel | c.authenticated = True
}
run ps_reach_Post3 for 5

assert ps_valid_Post1 {
    all op: REQ_MNG_01 |
        op.post = Post1 =>
            (op.target in CohortData &&
             op.grant = Write &&
             some c: op.channel | c.authenticated = True)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_MNG_01 |
        op.post = Post2 =>
            (op.target in CohortData &&
             op.grant = Write &&
             some c: op.channel | c.authenticated = True)
}
check ps_valid_Post2 for 5

assert ps_valid_Post3 {
    all op: REQ_MNG_01 |
        op.post = Post3 =>
            (op.target in ExamData &&
             op.grant = Execute &&
             some c: op.channel | c.authenticated = True)
}
check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: admin creates cohort, cohort saved && available for enrollment
pred ac_reach_1 {
    some op: REQ_MNG_01 |
        -- Admin is the initiator
        op.initiator in Administrators &&
        -- Create operation requires Write permission
        Write in op.initiator.mayPerform &&
        -- Target is a cohort resource
        some r: op.target | r in CohortData &&
        -- Cohort is saved (post state changed)
        op.post in Post1
}

run ac_reach_1 for 5

-- Criterion 2: enroll student in cohort, student added to that cohort
pred ac_reach_2 {
    some op: REQ_MNG_01 |
        -- Initiator has Write permission (to modify cohort membership)
        Write in op.initiator.mayPerform &&
        -- Target includes a cohort resource
        some r: op.target | r in CohortData &&
        -- Using authenticated channel
        (some c: op.channel | c.authenticated = True) &&
        -- Student is added (state transition to enrollment)
        op.post in Post2
}

run ac_reach_2 for 5

-- Criterion 3: restrict exam to cohorts, only those students can access
pred ac_reach_3 {
    some op: REQ_MNG_01 |
        -- Initiator has Execute permission for exam restriction
        Execute in op.initiator.mayPerform &&
        -- Target includes both exam and cohort resources
        some r: op.target | r in ExamData &&
        some r: op.target | r in CohortData &&
        -- Using encrypted, authenticated channel
        (some c: op.channel | c.encrypted = True && c.authenticated = True) &&
        -- Restriction is applied (state transition to restricted access)
        op.post in Post3
}

run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

assert ec_safe_1 {
    // No duplicate cohort creation: at most one operation can create a cohort (target includes CohortData, grant=Write)
    no disj op1, op2: REQ_MNG_01 | some r1: op1.target | r1 in CohortData && op1.grant = Write && some r2: op2.target | r2 in CohortData && op2.grant = Write
}
check ec_safe_1 for 5

assert ec_safe_2 {
    // An exam restriction operation (target includes ExamData, grant=Execute) must have a prior cohort creation operation
    all op: REQ_MNG_01 | (some r: op.target | r in ExamData && op.grant = Execute) => some op2: REQ_MNG_01 | some r2: op2.target | r2 in CohortData && op2.grant = Write
}
check ec_safe_2 for 5

assert ec_safe_3 {
    // Only authorized actors (Administrators || IT_Team) can perform exam restriction operations
    all op: REQ_MNG_01 | (some r: op.target | r in ExamData && op.grant = Execute) => op.initiator in Administrators + IT_Team
}
check ec_safe_3 for 5

assert ec_safe_4 {
    // No two distinct operations can restrict the same exam resource (target includes ExamData, grant=Execute) to avoid overlapping restrictions
    no disj op1, op2: REQ_MNG_01 | some r1: op1.target | r1 in ExamData && op1.grant = Execute && some r2: op2.target | r2 in ExamData && op2.grant = Execute
}
check ec_safe_4 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-MNG-01: Create a new cohort with valid input
pred tc_MNG_01_holds {
    some op: REQ_MNG_01 |
        -- Admin initiator with write permission
        Admin in op.initiator.mayPerform &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        -- Target is a new cohort resource
        some r: op.target |
            r.owner = op.initiator &&
            r in CohortData &&
            -- Resource is created (state change)
            op.post != op.pre &&
            -- Secure channel
            all c: op.channel | c.encrypted = True
}
run tc_MNG_01_holds for 5

assert tc_MNG_01_contract {
    all op: REQ_MNG_01 |
        -- Pre-condition: Admin initiator with write permission, secure channel
        (Admin in op.initiator.mayPerform &&
         Write in op.initiator.mayPerform &&
         op.grant = Write &&
         some r: op.target | r.owner = op.initiator &&
         all c: op.channel | c.encrypted = True)
        =>
        -- Post-condition: Cohort created (state change), resource exists
        (op.post != op.pre &&
         some r: op.target | r in CohortData)
}
check tc_MNG_01_contract for 5

-- TC-MNG-02: Enroll student in existing cohort
pred tc_MNG_02_holds {
    some op: REQ_MNG_01 |
        -- Admin initiator
        Admin in op.initiator.mayPerform &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        -- Target is existing Cohort resource
        some r: op.target |
            r.owner = op.initiator &&
            r in CohortData &&
            -- Student added (state change)
            op.post != op.pre
}
run tc_MNG_02_holds for 5

assert tc_MNG_02_contract {
    all op: REQ_MNG_01 |
        -- Pre-condition: Admin with write access to existing cohort
        (Admin in op.initiator.mayPerform &&
         Write in op.initiator.mayPerform &&
         op.grant = Write &&
         some r: op.target |
             r.owner = op.initiator &&
             r in CohortData)
        =>
        -- Post-condition: State changed (student enrolled)
        op.post != op.pre
}
check tc_MNG_02_contract for 5

-- TC-MNG-03: Restrict exam to valid cohorts
pred tc_MNG_03_holds {
    some op: REQ_MNG_01 |
        -- Admin initiator
        Admin in op.initiator.mayPerform &&
        Execute in op.initiator.mayPerform &&
        op.grant = Execute &&
        -- Target includes exam and cohort resources
        some r: op.target | r.owner = op.initiator && r in ExamData &&
        some r: op.target | r in CohortData &&
        -- Secure channel
        all c: op.channel | c.encrypted = True &&
        -- State change (restriction applied)
        op.post != op.pre
}
run tc_MNG_03_holds for 5

assert tc_MNG_03_contract {
    all op: REQ_MNG_01 |
        -- Pre-condition: Admin with execute permission, valid cohorts
        (Admin in op.initiator.mayPerform &&
         Execute in op.initiator.mayPerform &&
         op.grant = Execute &&
         some r: op.target | r.owner = op.initiator && r in ExamData &&
         some r: op.target | r in CohortData &&
         all c: op.channel | c.encrypted = True)
        =>
        -- Post-condition: Restriction applied (state change)
        op.post != op.pre
}
check tc_MNG_03_contract for 5

-- TC-MNG-04: Attempt to create duplicate cohort
pred tc_MNG_04_holds {
    some op: REQ_MNG_01 |
        -- Admin initiator
        Admin in op.initiator.mayPerform &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        -- Target already exists (no state change)
        some r: op.target |
            r.owner = op.initiator &&
            r in CohortData &&
            -- Duplicate: no new resource created
            op.post = op.pre
}
run tc_MNG_04_holds for 5

assert tc_MNG_04_contract {
    all op: REQ_MNG_01 |
        -- Pre-condition: Admin tries to create cohort that already exists
        (Admin in op.initiator.mayPerform &&
         Write in op.initiator.mayPerform &&
         op.grant = Write &&
         some r: op.target |
             r.owner = op.initiator &&
             r in CohortData)
        =>
        -- Post-condition: No state change (error/duplicate detected)
        op.post = op.pre
}
check tc_MNG_04_contract for 5

-- TC-MNG-05: Restrict exam to non-existent cohorts
pred tc_MNG_05_holds {
    some op: REQ_MNG_01 |
        -- Admin initiator
        Admin in op.initiator.mayPerform &&
        Execute in op.initiator.mayPerform &&
        op.grant = Execute &&
        -- Target includes an exam resource but no cohort resource (non-existent cohort)
        some r: op.target | r.owner = op.initiator && r in ExamData &&
        no r: op.target | r in CohortData &&
        -- No state change (error)
        op.post = op.pre
}
run tc_MNG_05_holds for 5

assert tc_MNG_05_contract {
    all op: REQ_MNG_01 |
        -- Pre-condition: Admin tries to restrict exam to non-existent cohorts
        (Admin in op.initiator.mayPerform &&
         Execute in op.initiator.mayPerform &&
         op.grant = Execute &&
         some r: op.target | r.owner = op.initiator && r in ExamData &&
         no r: op.target | r in CohortData)
        =>
        -- Post-condition: No state change (error reported)
        op.post = op.pre
}
check tc_MNG_05_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting channel count reduces latency overhead
    -- NFR: response time < 200ms
    all op: REQ_MNG_01 | #op.channel <= 2
}

fact nfr_fact_availability {
    -- PROXY: requiring at least one redundant channel ensures 99.9% uptime
    -- NFR: system must be available at least 99.9% of the time
    all op: REQ_MNG_01 | #op.channel >= 2
}

fact nfr_fact_scalability {
    -- PROXY: no single actor can be the initiator of all operations, ensuring distribution
    -- NFR: support increasing number of cohorts without performance degradation
    no a: Actor | all op: REQ_MNG_01 | op.initiator = a
}

fact nfr_fact_usability {
    -- PROXY: limiting authenticated channels prevents overwhelming administrators
    -- NFR: error messages should be clear && actionable
    all op: REQ_MNG_01 | #op.channel <= 3
}

assert nfr_assert_no_orphan_operations {
    -- PROXY: every operation has a defined post-state, ensuring reliability
    -- NFR: system must be available && operations must complete
    all op: REQ_MNG_01 | one op.post
}
check nfr_assert_no_orphan_operations for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security property: Only authorized administrators can create, modify, && restrict exams.
-- Enforce that every REQ_MNG_01 operation's initiator is an administrator.
fact sr_fact_only_administrators_can_initiate {
    all op: REQ_MNG_01 | op.initiator in Administrators
}

-- Assertion to verify that no operation is initiated by a non-administrator.
assert sr_assert_only_administrators {
    all op: REQ_MNG_01 | op.initiator in Administrators
}
check sr_assert_only_administrators for 5

-- Grant Administrators and IT_Team appropriate permissions
fact adminPermissions {
    Administrators.mayPerform = Write + Execute + Admin
    IT_Team.mayPerform = Read
}


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed type errors: replaced incorrect use of Interface and IfaceKind where Resource was expected.
-- Summary 2: Added concrete resource sigs: Student, CohortData (with students field), ExamData.
-- Summary 3: Added fact to set mayPerform for Administrators and IT_Team.
-- Summary 4: All invariants, assertions, and predicates now type-check correctly.
-- Summary 5: Model captures cohort creation, enrollment, and exam restriction at an abstract level.
-- Assumption 1: Only Administrators initiate operations (as per security requirement).
-- Assumption 2: Each operation changes state (pre != post) to model atomic transitions.
-- Assumption 3: NFR proxies: channel count (2) and initiator distribution model performance and scalability.
-- Open issue 1: The model does not distinguish between creating a new cohort and enrolling a student; both map to post=Post2. This is an abstraction limitation.
-- Open issue 2: The 'accessible' field of Resource is used but not constrained for concrete resources; owner_always_accessible ensures minimal access.


