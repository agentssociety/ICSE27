module REQ_DASHBOARD_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-DASHBOARD-01
 * Title       : Instructor Registration and Login
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Instructors extends Actor {}
-- Instructors: represents stakeholder 'Instructors'

-- Assign Read and Write permissions to Instructors for typical operations
fact instructor_permissions {
    Instructors.mayPerform = Read + Write
}


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resources for the dashboard requirement
one sig InstructorAccount extends Resource {}
    -- user account data (created on registration, used for login)

one sig DashboardContent extends Resource {}
    -- active exams, enrollment counts, competency coverage displayed


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Registration_API, Login_API, User_Database, Dashboard_UI extends Interface {}

fact interface_properties {
    Registration_API.kind = API  -- Handles the creation of new instructor accounts.
    Login_API.kind = API  -- Authenticates user credentials and returns a session token.
    User_Database.kind = Database  -- Stores user information including login details and dashboard data.
    Dashboard_UI.kind = UI  -- Displays active exams, enrollment counts, and competency coverage.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where Instructor is not registered (for registration feature).
-- Pre2: system is in state where Instructor has registered and knows valid credentials (for login feature).
-- Pre3: system is in state where Instructor is on their personal dashboard.

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where An instructor's account is created with required details.
-- Post2: system reaches state where An instructor logs in successfully and is redirected to the dashboard.
-- Post3: system reaches state where The dashboard displays active exams, enrollment counts, and competency coverage.


----------------------------------------------------------------------
-- Core operation: REQ_DASHBOARD_01
----------------------------------------------------------------------

sig REQ_DASHBOARD_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_DASHBOARD_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_DASHBOARD_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_DASHBOARD_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_DASHBOARD_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_DASHBOARD_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_DASHBOARD_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_DASHBOARD_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_DASHBOARD_01 {
    some op: REQ_DASHBOARD_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_DASHBOARD_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_DASHBOARD_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_DASHBOARD_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_DASHBOARD_01_well_formed {
    all op: REQ_DASHBOARD_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_DASHBOARD_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- ?? POST-STATE REACHABILITY PREDICATES AND ASSERTIONS ?????????????

pred ps_reach_Post1 {
    some op: REQ_DASHBOARD_01 |
        op.post = Post1 &&
        Write in op.initiator.mayPerform &&
        op.initiator in Instructors &&
        op.grant = Write &&
        op.target in InstructorAccount &&
        op.pre != Post1
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_DASHBOARD_01 |
        (op.post = Post1) => 
            (Write in op.initiator.mayPerform &&
             op.initiator in Instructors &&
             op.grant = Write &&
             op.target in InstructorAccount)
}

check ps_valid_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_DASHBOARD_01 |
        op.post = Post2 &&
        Read in op.initiator.mayPerform &&
        op.initiator in Instructors &&
        op.channel in Login_API &&
        op.pre = Pre2 &&
        op.target in InstructorAccount
}

run ps_reach_Post2 for 5

assert ps_valid_Post2 {
    all op: REQ_DASHBOARD_01 |
        (op.post = Post2) => 
            (Read in op.initiator.mayPerform &&
             op.initiator in Instructors &&
             one c: op.channel | c in Login_API &&
             op.target in InstructorAccount)
}

check ps_valid_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_DASHBOARD_01 |
        op.post = Post3 &&
        Read in op.initiator.mayPerform &&
        op.initiator in Instructors &&
        op.target in DashboardContent &&
        op.channel in UI &&
        Dashboard_UI in op.channel &&
        op.grant = Read
}

run ps_reach_Post3 for 5

assert ps_valid_Post3 {
    all op: REQ_DASHBOARD_01 |
        (op.post = Post3) => 
            (Read in op.initiator.mayPerform &&
             op.initiator in Instructors &&
             op.target in DashboardContent &&
             op.grant = Read)
}

check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
    some op: REQ_DASHBOARD_01 |
        op.initiator = Instructors &&
        Write in op.initiator.mayPerform &&
        op.grant = Write &&
        op.target in InstructorAccount &&
        op.channel = Registration_API &&
        (some c: op.channel | c.authenticated = True)
}
run ac_reach_1 for 5

pred ac_reach_2 {
    some op: REQ_DASHBOARD_01 |
        op.initiator = Instructors &&
        Read in op.initiator.mayPerform &&
        op.grant = Read &&
        op.target = InstructorAccount &&
        op.channel = Login_API &&
        op.post = Post2
}
run ac_reach_2 for 5

pred ac_reach_3 {
    some op: REQ_DASHBOARD_01 |
        op.initiator = Instructors &&
        Read in op.initiator.mayPerform &&
        op.grant = Read &&
        (some t: op.target | t in (InstructorAccount + DashboardContent)) &&
        op.channel = Dashboard_UI &&
        op.post = Post3
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

one sig RecognizedDevices { devices: set Interface }

-- Edge case: duplicate registration should not create account
assert ec_safe_1 {
    all op: REQ_DASHBOARD_01 |
        (op.pre = Pre1 && op.initiator = Instructors) =>
        op.post != Post1
}
check ec_safe_1 for 5

-- Edge case: no concurrent writes to the same resource
assert ec_safe_2 {
    all disj op1, op2: REQ_DASHBOARD_01 |
        (op1.grant = Write && op2.grant = Write) =>
        no (op1.target & op2.target)
}
check ec_safe_2 for 5

-- Edge case: unrecognized device must use authenticated channel
assert ec_safe_3 {
    all op: REQ_DASHBOARD_01 |
        all c: op.channel |
            (c ! in RecognizedDevices.devices) =>
            c.authenticated = True
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-REG-01: Instructor registers with existing credentials -> error message
pred tc_TC_REG_01_holds {
    some op: REQ_DASHBOARD_01 |
        op.initiator = Instructors &&
        op.grant = Write &&
        (some r: op.target | r.owner != none) &&
        (no r: op.target | r.owner = op.initiator) &&
        op.post != op.pre
}
run tc_TC_REG_01_holds for 5

assert tc_TC_REG_01_contract {
    all op: REQ_DASHBOARD_01 |
        (op.initiator = Instructors &&
         op.grant = Write &&
         (some r: op.target | r.owner != none)) =>
        (no r: op.target | r.owner = op.initiator) &&
        op.post != op.pre
}
check tc_TC_REG_01_contract for 5

-- TC-LGN-02: User from unrecognized device -> second factor / blocked
pred tc_TC_LGN_02_holds {
    some op: REQ_DASHBOARD_01 |
        op.initiator != none &&
        (some c: op.channel | c.authenticated = False) &&
        op.post != Post2
}
run tc_TC_LGN_02_holds for 5

assert tc_TC_LGN_02_contract {
    all op: REQ_DASHBOARD_01 |
        (op.initiator != none &&
         (some c: op.channel | c.authenticated = False)) =>
        op.post != Post2
}
check tc_TC_LGN_02_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting the number of channels && resources per operation reduces latency
    -- NFR: Dashboard updates in real-time || near real-time
    all op: REQ_DASHBOARD_01 | #op.channel <= 2 && #op.target <= 3
}

fact nfr_fact_availability {
    -- PROXY: requiring at least one encrypted channel ensures operational continuity
    -- NFR: 99.9% uptime during business hours
    all op: REQ_DASHBOARD_01 | some c: op.channel | c.encrypted = True
}

fact nfr_fact_scalability {
    -- PROXY: ensuring all actors can potentially initiate operations without resource exhaustion
    -- NFR: System should handle an increase in registered instructors && students
    all a: Actor | some op: REQ_DASHBOARD_01 | op.initiator = a
}

fact nfr_fact_usability {
    -- PROXY: limiting authenticated channels reduces complexity for users
    -- NFR: Clear && intuitive interface for easy navigation
    all op: REQ_DASHBOARD_01 | #op.channel <= 3
}

assert nfr_assert_performance {
    -- PROXY: cardinality constraint ensures minimal overhead
    -- NFR: Dashboard updates in real-time || near real-time
    all op: REQ_DASHBOARD_01 | #op.channel <= 2 && #op.target <= 3
}
check nfr_assert_performance for 5

assert nfr_assert_availability {
    -- PROXY: encrypted channel ensures reliable communication
    -- NFR: 99.9% uptime during business hours
    all op: REQ_DASHBOARD_01 | some c: op.channel | c.encrypted = True
}
check nfr_assert_availability for 5

assert nfr_assert_scalability {
    -- PROXY: every actor can initiate an operation
    -- NFR: System should handle increase in registered users
    all a: Actor | some op: REQ_DASHBOARD_01 | op.initiator = a
}
check nfr_assert_scalability for 5

assert nfr_assert_usability {
    -- PROXY: bounded channel count reduces interface complexity
    -- NFR: Clear && intuitive interface
    all op: REQ_DASHBOARD_01 | #op.channel <= 3
}
check nfr_assert_usability for 5

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security Requirement 1: Strong authentication mechanism for user accounts
-- All channels used in the operation must be authenticated
assert sr_assert_strong_authentication {
    all op: REQ_DASHBOARD_01 |
        all c: op.channel |
            c.authenticated = True
}
check sr_assert_strong_authentication for 5

-- Security Requirement 2: Data encryption for sensitive information
-- All channels used in the operation must be encrypted
assert sr_assert_data_encryption {
    all op: REQ_DASHBOARD_01 |
        all c: op.channel |
            c.encrypted = True
}
check sr_assert_data_encryption for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Fixed type errors by introducing concrete Resource sigs (InstructorAccount, DashboardContent).
-- Summary 2: Corrected ps_reach_Post2 precondition from Pre1 to Pre2 for login operation.
-- Summary 3: Revised tc_TC_LGN_02 to assert that unauthenticated channels do not lead to successful login (Post2).
-- Summary 4: Changed ec_safe_1 to assert duplicate registration does not create account (post != Post1).
-- Summary 5: Added instructor_permissions fact to assign Read+Write to Instructors.
-- Assumption 1: Instructors have Read and Write permissions for standard operations.
-- Assumption 2: The dashboard displays data from a single DashboardContent resource.
-- Assumption 3: Registration and login operations target the InstructorAccount resource.
-- Open issue 1: The model does not capture error states (e.g., duplicate registration message, second factor prompt); these are approximated via invariants on post-states.
-- Open issue 2: Edge case ec_safe_2 (no concurrent writes) may be too restrictive; could be relaxed if concurrent writes are allowed.


