module REQ_PROF_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-PROF-01
 * Title       : Create Student Profile During Registration
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Product_Owner, Development_Team, QA_Team extends Actor {}
-- Product_Owner: represents stakeholder 'Product Owner'
-- Development_Team: represents stakeholder 'Development Team'
-- QA_Team: represents stakeholder 'QA Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API, UI extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Registration_API, User_Database, Profile_UI extends Interface {}

fact interface_properties {
    Registration_API.kind = API  -- The requirement interacts with this API to create a student account and generate a personalized profile.
    User_Database.kind = Database  -- The requirement interacts with this database to store user information, avatar details, nugget balance, badges, and competency radar chart data.
    Profile_UI.kind = UI  -- The requirement interacts with this interface to display the personalized profile of the student.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig PreIdle extends State {}

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2 extends State {}
-- Post1: system reaches state where The registered student sees their personalized profile including the avatar, current nugget balance, earned badges, and competency radar chart.
-- Post2: system reaches state where The system updates the profile based on platform activities.


----------------------------------------------------------------------
-- Core operation: REQ_PROF_01
----------------------------------------------------------------------

sig REQ_PROF_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_PROF_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_PROF_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_PROF_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_PROF_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_PROF_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_PROF_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_PROF_01 | op.post in Post1 + Post2
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_PROF_01 {
    some op: REQ_PROF_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_PROF_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_PROF_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_PROF_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_PROF_01_well_formed {
    all op: REQ_PROF_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_PROF_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates for Post1 && Post2
pred ps_reach_Post1 {
    some op: REQ_PROF_01 |
        op.post = Post1 &&
        op.grant = Read &&
        op.channel = Profile_UI &&
        op.target = UI &&
        Read in op.initiator.mayPerform &&
        op.initiator in op.target.accessible &&
        op.initiator = op.target.owner &&
        op.pre = PreIdle
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_PROF_01 |
        op.post = Post2 &&
        op.grant = Write &&
        op.channel = User_Database &&
        op.target = Database &&
        Write in op.initiator.mayPerform &&
        op.initiator in op.target.accessible &&
        op.pre = PreIdle
}
run ps_reach_Post2 for 5

-- Semantic verification assertions for Post1 && Post2
assert ps_valid_Post1 {
    all op: REQ_PROF_01 |
        (op.post = Post1) =>
            (op.grant = Read &&
             op.channel = Profile_UI &&
             op.target = UI &&
             Read in op.initiator.mayPerform &&
             op.initiator in op.target.accessible &&
             op.initiator = op.target.owner)
}
check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_PROF_01 |
        (op.post = Post2) =>
            (op.grant = Write &&
             op.channel = User_Database &&
             op.target = Database &&
             Write in op.initiator.mayPerform &&
             op.initiator in op.target.accessible)
}
check ps_valid_Post2 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Criterion 1: A student account is created upon successful registration.
pred ac_reach_1 {
  some op: REQ_PROF_01 |
    Write in op.initiator.mayPerform &&
    Registration_API in op.channel &&
    User_Database in op.target &&
    op.pre = PreIdle &&
    op.post = Post1
}
run ac_reach_1 for 5

-- Criterion 2: The profile is generated with a default avatar, zero nuggets, no badges, && an empty competency radar chart.
pred ac_reach_2 {
  some op: REQ_PROF_01 |
    Write in op.initiator.mayPerform &&
    Profile_UI in op.channel &&
    op.pre = Post1 &&
    op.post = Post2
}
run ac_reach_2 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: User provides invalid input during registration.
-- Safety: If the operation targets the Registration_API, all channels must be authenticated.
assert ec_safe_1 {
    all op: REQ_PROF_01 |
        (Registration_API in op.target) => (all c: op.channel | c.authenticated = True)
}
check ec_safe_1 for 5

-- Edge case 2: System fails to create a student account upon successful registration due to internal error.
-- Safety: If the operation targets User_Database && the post-state is Post1 (success), the grant must be Write.
assert ec_safe_2 {
    all op: REQ_PROF_01 |
        (User_Database in op.target && op.post = Post1) => op.grant = Write
}
check ec_safe_2 for 5

-- Edge case 3: Avatar customization request is received after the profile has been created.
-- Safety: No operation with pre-state Post1 (profile created) may target Profile_UI.
assert ec_safe_3 {
    all op: REQ_PROF_01 |
        op.pre = Post1 => Profile_UI !in op.target
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-PROF-01: Student account created upon successful registration
pred tc_PROF_01_holds {
    some op: REQ_PROF_01 |
        -- Input: Registration via Registration_API with authentication
        Registration_API in op.channel.kind &&
        some c: op.channel | c.authenticated = True &&
        -- Expected: new resource created with Product_Owner as owner
        some r: op.target | 
            r.owner = Product_Owner &&
            op.post != op.pre
}
run tc_PROF_01_holds for 5

assert tc_PROF_01_contract {
    all op: REQ_PROF_01 |
        -- Pre: Registration via authenticated channel
        (Registration_API in op.channel.kind &&
         some c: op.channel | c.authenticated = True) =>
        -- Post: at least one target resource owned by Product_Owner
        (some r: op.target | r.owner = Product_Owner)
}
check tc_PROF_01_contract for 5

-- TC-PROF-02: Profile page displays correct information
pred tc_PROF_02_holds {
    some op: REQ_PROF_01 |
        -- Input: Profile_UI interface, authenticated channel
        Profile_UI in op.channel.kind &&
        some c: op.channel | c.authenticated = True &&
        -- Expected: target resource accessible to initiator
        op.initiator in op.target.accessible &&
        op.post != op.pre
}
run tc_PROF_02_holds for 5

assert tc_PROF_02_contract {
    all op: REQ_PROF_01 |
        -- Pre: Profile_UI with authenticated channel
        (Profile_UI in op.channel.kind &&
         some c: op.channel | c.authenticated = True) =>
        -- Post: initiator can access target resources
        (op.initiator in op.target.accessible)
}
check tc_PROF_02_contract for 5

-- TC-PROF-03: Invalid input does ! create account
pred tc_PROF_03_holds {
    some op: REQ_PROF_01 |
        -- Input: Registration_API but no authenticated channel
        Registration_API in op.channel.kind &&
        no c: op.channel | c.authenticated = True &&
        -- Expected: no state change (account ! created)
        op.post = op.pre
}
run tc_PROF_03_holds for 5

assert tc_PROF_03_contract {
    all op: REQ_PROF_01 |
        -- Pre: Registration_API without authenticated channel
        (Registration_API in op.channel.kind &&
         no c: op.channel | c.authenticated = True) =>
        -- Post: state unchanged (no account creation)
        (op.post = op.pre)
}
check tc_PROF_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

-- Usability proxy: limit number of channels per operation to reduce complexity && improve error?handling clarity.
fact nfr_fact_usability_channel_limit {
    all op: REQ_PROF_01 | #op.channel <= 2
}

-- Usability proxy: limit number of targets per operation to keep operations focused && user?friendly.
fact nfr_fact_usability_target_limit {
    all op: REQ_PROF_01 | #op.target <= 2
}

