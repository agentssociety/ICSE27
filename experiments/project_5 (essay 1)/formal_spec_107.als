 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Instructors, Students extends Actor {}
-- Instructors: represents stakeholder 'Instructors'
-- Students: represents stakeholder 'Students'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resources for the exam system
one sig ExamDatabaseResource, AttemptResource extends Resource {}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Exam_Access_API, Attempt_Submission_API, Exam_Database extends Interface {}

fact interface_properties {
    Exam_Access_API.kind = API  -- Interface for checking if a student is allowed to access an exam.
    Attempt_Submission_API.kind = API  -- Interface for submitting student attempts with time tracking.
    Exam_Database.kind = Database  -- Stores exam details, access permissions, and attempt records.
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2, Pre3 extends State {}
-- Pre1: system is in state where The exam has been created in the system
-- Pre2: system is in state where The instructor has inputted the open and close dates for the exam
-- Pre3: system is in state where The instructor has optionally set a per-attempt time limit for the exam

-- Concrete post-states (one per distinct postcondition).
one sig Post1, Post2, Post3 extends State {}
-- Post1: system reaches state where Students are only able to access the exam during the specified open date and close date
-- Post2: system reaches state where If a per-attempt time limit is set, students' attempts must be submitted within that time limit
-- Post3: system reaches state where If no per-attempt time limit is set, students can take as much time as needed within the open/close window


----------------------------------------------------------------------
-- Core operation: REQ_EXAM_SCHED_01
----------------------------------------------------------------------

sig REQ_EXAM_SCHED_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_EXAM_SCHED_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_EXAM_SCHED_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_EXAM_SCHED_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_EXAM_SCHED_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_EXAM_SCHED_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_EXAM_SCHED_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_EXAM_SCHED_01 | op.post in Post1 + Post2 + Post3
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_EXAM_SCHED_01 {
    some op: REQ_EXAM_SCHED_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_EXAM_SCHED_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_EXAM_SCHED_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_EXAM_SCHED_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_EXAM_SCHED_01_well_formed {
    all op: REQ_EXAM_SCHED_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_EXAM_SCHED_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Reachability predicates for each post-state

pred ps_reach_Post1 {
    some op: REQ_EXAM_SCHED_01 |
        op.post = Post1 &&
        op.initiator in Instructors + Admin &&
        ExamDatabaseResource in op.target &&
        Write in op.grant &&
        all c: op.channel | c.authenticated = True &&
        op.pre != Post1
}

run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_EXAM_SCHED_01 |
        op.post = Post2 &&
        op.initiator in Instructors &&
        AttemptResource in op.target &&
        Admin in op.grant &&
        all c: op.channel | c.authenticated = True &&
        op.pre != Post2
}

run ps_reach_Post2 for 5

pred ps_reach_Post3 {
    some op: REQ_EXAM_SCHED_01 |
        op.post = Post3 &&
        op.initiator in Instructors &&
        AttemptResource in op.target &&
        Write in op.grant &&
        all c: op.channel | c.authenticated = True &&
        op.pre != Post3
}

run ps_reach_Post3 for 5

-- Semantic verification assertions

assert ps_valid_Post1 {
    all op: REQ_EXAM_SCHED_01 |
        op.post = Post1 =>
            (op.initiator in Instructors + Admin &&
             ExamDatabaseResource in op.target &&
             Write in op.grant &&
             all c: op.channel | c.authenticated = True &&
             op.pre != Post1)
}

check ps_valid_Post1 for 5

assert ps_valid_Post2 {
    all op: REQ_EXAM_SCHED_01 |
        op.post = Post2 =>
            (op.initiator in Instructors &&
             AttemptResource in op.target &&
             Admin in op.grant &&
             all c: op.channel | c.authenticated = True &&
             op.pre != Post2)
}

check ps_valid_Post2 for 5

assert ps_valid_Post3 {
    all op: REQ_EXAM_SCHED_01 |
        op.post = Post3 =>
            (op.initiator in Instructors &&
             AttemptResource in op.target &&
             Write in op.grant &&
             all c: op.channel | c.authenticated = True &&
             op.pre != Post3)
}

check ps_valid_Post3 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- ?? LIVENESS PREDICATES for REQ_EXAM_SCHED_01 ??????????????

-- Criterion 1: Exam outside time window ? ! accessible, message displayed
pred ac_reach_1 {
    some op: REQ_EXAM_SCHED_01 |
        -- Student is initiator
        op.initiator in Students &&
        -- Target is the exam database resource
        ExamDatabaseResource in op.target &&
        -- Grant is Read (accessing exam)
        op.grant = Read &&
        -- State transitions from Pre1 (exam scheduled with window) to Post1 (access denied)
        op.pre = Pre1 &&
        op.post = Post1 &&
        -- Channel is authenticated (message displayed)
        (some c: op.channel | c.authenticated = True)
}

run ac_reach_1 for 5

-- Criterion 2: Per-attempt time limit of 60 minutes, auto-submit on expiry
pred ac_reach_2 {
    some op: REQ_EXAM_SCHED_01 |
        -- Student is initiator
        op.initiator in Students &&
        -- Target includes exam database and attempt resources
        ExamDatabaseResource in op.target &&
        AttemptResource in op.target &&
        -- Grant is Write (submitting attempt)
        op.grant = Write &&
        -- State transitions from Pre2 (attempt started with timer) to Post2 (auto-submitted)
        op.pre = Pre2 &&
        op.post = Post2 &&
        -- Channel is authenticated and encrypted (secure recording)
        (some c: op.channel | c.authenticated = True && c.encrypted = True)
}

run ac_reach_2 for 5

-- Criterion 3: No per-attempt time limit, student takes time within window
pred ac_reach_3 {
    some op: REQ_EXAM_SCHED_01 |
        -- Student is initiator
        op.initiator in Students &&
        -- Target is exam database resource
        ExamDatabaseResource in op.target &&
        -- Grant is Read (accessing exam content)
        op.grant = Read &&
        -- State transitions from Pre3 (no time limit, within window) to Post3 (completed)
        op.pre = Pre3 &&
        op.post = Post3 &&
        -- Channel is authenticated
        (some c: op.channel | c.authenticated = True)
}

run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge case 1: student accesses exam on exact open date
sig Date {}
one sig CurrentDate { date: one Date }
sig Schedule { resource: Resource, openDate: one Date }

assert ec_safe_1 {
  all op: REQ_EXAM_SCHED_01 |
    (op.initiator = Students && some s: Schedule | s.resource in op.target && s.openDate = CurrentDate.date) =>
    (op.grant = Read && Read in op.initiator.mayPerform)
}
check ec_safe_1 for 5

-- Edge case 2: daylight saving time change during exam period
sig DSTInfo { state: State, isDST: one Bool }

assert ec_safe_2 {
  all op: REQ_EXAM_SCHED_01 |
    (some d: DSTInfo | d.state = op.pre && d.isDST = True) =>
    (all c: op.channel | c.encrypted = True)
}
check ec_safe_2 for 5

-- Edge case 3: student device loses internet connection during attempt
sig Connectivity { state: State, connected: one Bool }

assert ec_safe_3 {
  all op: REQ_EXAM_SCHED_01 |
    (some c: Connectivity | c.state = op.pre && c.connected = False) =>
    (ExamDatabaseResource !in op.target)
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- Scenario TC-EXAM-ACCESS-01: Student accesses exam on exact open date ? allowed
pred tc_exam_access_01_holds {
    some op: REQ_EXAM_SCHED_01 |
        op.initiator = Students
        && op.grant = Read
        && all r: op.target | (r.owner = Instructors || r.owner = Admin) -- exam owned by instructor/admin
        && (some c: op.channel | c in Exam_Access_API)
        && op.pre = Pre1
        && op.post = Post1
}
run tc_exam_access_01_holds for 5

assert tc_exam_access_01_contract {
    all op: REQ_EXAM_SCHED_01 |
        (op.initiator = Students && op.grant = Read && op.pre = Pre1) =>
        op.post = Post1
}
check tc_exam_access_01_contract for 5

-- Scenario TC-EXAM-TIME-LIMIT-01: Student submits within 60-min limit ? successful submission
pred tc_exam_time_limit_01_holds {
    some op: REQ_EXAM_SCHED_01 |
        op.initiator = Students
        && op.grant = Write
        && all r: op.target | (r.owner = Instructors || r.owner = Admin)
        && (some c: op.channel | c in Attempt_Submission_API)
        && op.pre = Pre2
        && op.post = Post2
}
run tc_exam_time_limit_01_holds for 5

assert tc_exam_time_limit_01_contract {
    all op: REQ_EXAM_SCHED_01 |
        (op.initiator = Students && op.grant = Write && op.pre = Pre2) =>
        op.post = Post2
}
check tc_exam_time_limit_01_contract for 5

-- Scenario TC-EXAM-TIME-LIMIT-02: Student exceeds 60-min limit ? automatic submission
pred tc_exam_time_limit_02_holds {
    some op: REQ_EXAM_SCHED_01 |
        op.initiator = Students
        && op.grant = Write
        && all r: op.target | (r.owner = Instructors || r.owner = Admin)
        && (some c: op.channel | c in Attempt_Submission_API)
        && op.pre = Pre3
        && op.post = Post3
}
run tc_exam_time_limit_02_holds for 5

assert tc_exam_time_limit_02_contract {
    all op: REQ_EXAM_SCHED_01 |
        (op.initiator = Students && op.grant = Write && op.pre = Pre3) =>
        op.post = Post3
}
check tc_exam_time_limit_02_contract for 5

-- Scenario TC-NO-TIME-LIMIT-01: No time limit set, student can take time within window
-- Pre1 represents the open?window state without a time limit; Post2 represents ongoing attempt.
pred tc_no_time_limit_01_holds {
    some op: REQ_EXAM_SCHED_01 |
        op.initiator = Students
        && op.grant = Write
        && all r: op.target | (r.owner = Instructors || r.owner = Admin)
        && (some c: op.channel | c in Attempt_Submission_API)
        && op.pre = Pre1
        && op.post = Post2
}
run tc_no_time_limit_01_holds for 5

assert tc_no_time_limit_01_contract {
    all op: REQ_EXAM_SCHED_01 |
        (op.initiator = Students && op.grant = Write && op.pre = Pre1) =>
        op.post = Post2
}
check tc_no_time_limit_01_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- Proxy: limiting resources && channels per operation reduces processing overhead, improving response time.
    all op: REQ_EXAM_SCHED_01 | #op.target <= 3 && #op.channel <= 2
}

fact nfr_fact_availability {
    -- Proxy: requiring at least two distinct channels per operation provides redundancy, supporting 99.9% uptime.
    all op: REQ_EXAM_SCHED_01 | #op.channel >= 2
}

fact nfr_fact_scalability {
    -- Proxy: every actor must be able to initiate at least one operation, ensuring the system can handle growth in user count.
    all a: Actor | one op: REQ_EXAM_SCHED_01 | op.initiator = a
}

fact nfr_fact_usability {
    -- Proxy: requiring all channels to be authenticated ensures the system can identify requestors, enabling clear error messages.
    all op: REQ_EXAM_SCHED_01 | all c: op.channel | c.authenticated = True
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security requirement 1: Access to the exam should be restricted outside of the scheduled open && close dates.
-- We constrain that only Pre1 (representing valid date range) can be the pre-state for operations on ExamDatabaseResource.
assert sr_assert_exam_access_date_window {
    all op: REQ_EXAM_SCHED_01 |
        (ExamDatabaseResource in op.target) => op.pre = Pre1
}
check sr_assert_exam_access_date_window for 5

-- Security requirement 2: Student attempts should ! be tampered with on the client side.
-- Prevent students from writing to the ExamDatabaseResource (attempts storage) directly.
assert sr_assert_no_student_tampering {
    all op: REQ_EXAM_SCHED_01 |
        (op.initiator in Students) => (ExamDatabaseResource !in op.target || op.grant != Write)
}
check sr_assert_no_student_tampering for 5

-- Additional integrity: any write to the ExamDatabaseResource must use encrypted && authenticated channels.
assert sr_assert_secure_write_to_database {
    all op: REQ_EXAM_SCHED_01 |
        (ExamDatabaseResource in op.target && Write in op.grant) =>
        (all c: op.channel | c.encrypted = True && c.authenticated = True)
}
check sr_assert_secure_write_to_database for 5


