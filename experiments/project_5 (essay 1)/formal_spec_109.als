module REQ_TEACH_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-TEACH-01
 * Title       : Manual Bonus Nugget Granting with Justification
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin, BonusGrant in Permission {}

fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else (p = BonusGrant) => Read + Write + BonusGrant
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Teacher, IT_Team, Student extends Actor {}
-- Teacher: represents stakeholder 'Teacher'
-- IT_Team: represents stakeholder 'IT Team'
-- Student: represents target student receiving bonus nugget

fact teacher_permissions {
    Teacher.mayPerform = Read + Write + BonusGrant
}

fact itteam_permissions {
    IT_Team.mayPerform = Read
}

fact student_permissions {
    Student.mayPerform = Read
}

----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete resources for bonus nuggets and justifications
sig BonusNugget extends Resource {}
sig JustificationResource extends Resource {}


----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig Teacher_Dashboard, Student_Account_API, Audit_Logging_API extends Interface {}

fact interface_properties {
    Teacher_Dashboard.kind = UI
    Student_Account_API.kind = API
    Audit_Logging_API.kind = API
}

fact interface_authentication {
    Teacher_Dashboard.authenticated = True
    Student_Account_API.authenticated = True
    Audit_Logging_API.authenticated = True
}

----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

one sig Pre1 extends State {}  -- teacher logged in, no justification yet
one sig JustifiedState extends State {}  -- justification provided
one sig Post1 extends State {}  -- bonus nugget added to student account
one sig Post2 extends State {}  -- audit event created
one sig ErrorState extends State {}  -- error/denial state

fact state_distinct {
    #State = 5
    // all distinct by Alloy semantics
}

----------------------------------------------------------------------
-- Core operation: REQ_TEACH_01
----------------------------------------------------------------------

sig REQ_TEACH_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

fact inv_operation_requires_channel {
    all op: REQ_TEACH_01 | some op.channel
}

fact inv_operation_requires_target {
    all op: REQ_TEACH_01 | some op.target
}

fact inv_initiator_is_authorized {
    all op: REQ_TEACH_01 | op.grant in op.initiator.mayPerform
}

fact inv_resource_access_control {
    all op: REQ_TEACH_01 | op.initiator in op.target.accessible
}

fact inv_state_must_change {
    all op: REQ_TEACH_01 | op.pre != op.post
}

fact inv_authenticated_channel_required {
    all op: REQ_TEACH_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

fact postconditions_must_reach_defined_states {
    all op: REQ_TEACH_01 | op.post in Post1 + Post2 + ErrorState
}


----------------------------------------------------------------------
-- Bonus grant specific constraints
----------------------------------------------------------------------

-- Bonus nugget operations require justification (pre state JustifiedState)
fact bonus_requires_justification {
    all op: REQ_TEACH_01 |
        (BonusNugget in op.target) => (op.pre in JustifiedState)
}

-- If no justification, operation goes to ErrorState
fact no_justification_leads_to_error {
    all op: REQ_TEACH_01 |
        (op.pre = Pre1 and op.grant = BonusGrant and BonusNugget in op.target)
        => op.post = ErrorState
}

-- Successful bonus grant (with justification) leads to Post1 and Post2
fact successful_bonus_grant {
    all op: REQ_TEACH_01 |
        (op.pre = JustifiedState and op.grant = BonusGrant and BonusNugget in op.target)
        => (op.post = Post1 or op.post = Post2)  // simplified: could be both in reality
}

-- Only Teacher can grant bonus nuggets
fact only_teacher_grant_bonus {
    all op: REQ_TEACH_01 |
        (op.grant = BonusGrant) => (op.initiator = Teacher)
}

----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_TEACH_01 {
    some op: REQ_TEACH_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_TEACH_01 for 5 but exactly 2 Actor, exactly 10 Interface


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

assert no_unauthorized_execution {
    all op: REQ_TEACH_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

assert no_unauthorized_resource_access {
    all op: REQ_TEACH_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

assert REQ_TEACH_01_well_formed {
    all op: REQ_TEACH_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_TEACH_01_well_formed for 5

assert no_justification_denied {
    all op: REQ_TEACH_01 |
        (op.pre = Pre1 and op.grant = BonusGrant and BonusNugget in op.target)
        implies op.post = ErrorState
}
check no_justification_denied for 5

assert non_teacher_denied_bonus {
    all op: REQ_TEACH_01 |
        (op.initiator != Teacher and op.grant = BonusGrant)
        implies op.post = ErrorState
}
check non_teacher_denied_bonus for 5

assert audit_event_created_on_success {
    all op: REQ_TEACH_01 |
        (op.pre = JustifiedState and op.grant = BonusGrant and BonusNugget in op.target)
        implies (op.post = Post2 or op.post = Post1)  // at least one of the expected postconditions
}
check audit_event_created_on_success for 5

----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

pred ps_reach_Post1 {
    some op: REQ_TEACH_01 |
        op.post = Post1 &&
        op.pre = JustifiedState &&
        op.initiator = Teacher &&
        BonusGrant in op.grant &&
        Student_Account_API in op.channel &&
        BonusNugget in op.target
}
run ps_reach_Post1 for 5

pred ps_reach_Post2 {
    some op: REQ_TEACH_01 |
        op.post = Post2 &&
        op.pre = JustifiedState &&
        op.initiator = Teacher &&
        BonusGrant in op.grant &&
        Audit_Logging_API in op.channel &&
        BonusNugget in op.target
}
run ps_reach_Post2 for 5

pred ps_reach_ErrorState {
    some op: REQ_TEACH_01 |
        op.post = ErrorState &&
        op.pre = Pre1 &&
        BonusNugget in op.target
}
run ps_reach_ErrorState for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

pred ac_reach_1 {
  some op: REQ_TEACH_01 |
    op.initiator = Teacher &&
    some c: op.channel | c.authenticated = True
}
run ac_reach_1 for 5

pred ac_reach_2 {
  some op: REQ_TEACH_01 |
    op.initiator = Teacher &&
    op.grant = BonusGrant &&
    Teacher_Dashboard in op.channel &&
    some t: op.target | t.owner != Teacher
}
run ac_reach_2 for 5

pred ac_reach_3 {
  some op: REQ_TEACH_01 |
    op.post = Post1 &&
    op.initiator = Teacher &&
    op.grant = BonusGrant
}
run ac_reach_3 for 5

pred ac_reach_4 {
  some op: REQ_TEACH_01 |
    op.post = Post2 &&
    op.initiator = Teacher &&
    op.grant = BonusGrant
}
run ac_reach_4 for 5

----------------------------------------------------------------------
-- Edge case safety assertions (revised)
----------------------------------------------------------------------

-- EC1: Teacher without justification leads to error (already asserted above)
-- EC2: Non-teacher denied bonus (already asserted above)
-- EC3: Audit event creation is required when bonus granted with justification
assert ec_audit_event_required {
    all op: REQ_TEACH_01 |
        (op.pre = JustifiedState and op.grant = BonusGrant and BonusNugget in op.target)
        => (Audit_Logging_API in op.channel)
}
check ec_audit_event_required for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

-- TC-TEACH-01: Teacher grants a manual bonus nugget with written justification.
-- Expected: bonus nugget added to student's account, audit event created.
pred tc_01_holds {
    some op: REQ_TEACH_01 |
        op.initiator = Teacher
        && op.grant = BonusGrant
        && op.pre = JustifiedState
        && op.post in (Post1 + Post2)
        && Teacher_Dashboard in op.channel
        && BonusNugget in op.target
}
run tc_01_holds for 5

-- TC-TEACH-02: Teacher attempts to grant a bonus nugget without a justification.
-- Expected: system displays an error message && prevents the grant.
pred tc_02_holds {
    some op: REQ_TEACH_01 |
        op.initiator = Teacher
        && op.grant = BonusGrant
        && op.pre = Pre1
        && op.post = ErrorState
        && Teacher_Dashboard in op.channel
        && BonusNugget in op.target
}
run tc_02_holds for 5

-- TC-TEACH-03: Non-teaching staff (IT_Team) tries to access the bonus granting feature.
-- Expected: system denies access && prompts permission denied message.
pred tc_03_holds {
    some op: REQ_TEACH_01 |
        op.initiator = IT_Team
        && op.grant = BonusGrant
        && op.post = ErrorState
        && Teacher_Dashboard in op.channel
}
run tc_03_holds for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants (adjusted for consistency)
----------------------------------------------------------------------

-- Performance proxy: limiting channel count per operation reduces latency
fact nfr_fact_performance {
    all op: REQ_TEACH_01 | #op.channel <= 2
}

-- Availability proxy: no strict lower bound; channels can be single
-- (removed conflicting fact)

-- Scalability proxy: the system must support at least as many concurrent operations as there are actors
assert nfr_assert_scalability {
    #REQ_TEACH_01 >= #Actor
}
check nfr_assert_scalability for 5 but exactly 3 Actor

-- Usability proxy: limiting the number of authenticated interfaces reduces authentication overhead
fact nfr_fact_usability {
    #{i: Interface | i.authenticated = True} <= 3
}

----------------------------------------------------------------------
-- Security properties (none specified)
----------------------------------------------------------------------


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Model covers manual bonus nugget grant with justification, including teacher authorization, justification precondition, audit logging, and error states.
-- Summary 2: Key safety: only Teacher can grant bonus nuggets; lack of justification leads to ErrorState.
-- Summary 3: Key liveness: runs exist for successful grant, denial, and audit event paths.
-- Assumption 1: Justification is modeled as a distinct state (JustifiedState) that the teacher must reach before granting bonus.
-- Assumption 2: Bonus nugget resource is distinct and owned by a student.
-- Assumption 3: Audit event is mandatory when bonus is granted with justification (Audit_Logging_API must be used).
-- Assumption 4: ErrorState represents any denial or error message.
-- Open issue 1: Amount of bonus nugget is not modeled (intentionally abstract).
-- Open issue 2: The student account balance update is not tracked; only postconditions states are used as proxy.
-- Open issue 3: Non-functional requirements (performance, availability, usability) are simplified and may not fully reflect real system.


