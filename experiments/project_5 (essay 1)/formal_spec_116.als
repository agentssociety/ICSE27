module REQ_REVIEW_01

/*
 * Alloy 6 ? Structural & Behavioral Model for Formal Verification
 * Requirement : REQ-REVIEW-01
 * Title       : Review Past Attempts and Competency Trends
 * Type        : Functional
 * Priority    : High
 * Generated by: deepseek/deepseek-v4-flash
 */


----------------------------------------------------------------------
-- Permission lattice
----------------------------------------------------------------------

abstract sig Permission {}
one sig Read, Write, Execute, Admin extends Permission {}

-- Partial order: a permission subsumes another if it grants strictly more.
-- Used in authorization assertions (see security section).
fun stronger [p: Permission] : set Permission {
    (p = Read)    => Read
    else (p = Write)   => (Read + Write)
    else (p = Execute) => (Read + Execute)
    else Admin
}


----------------------------------------------------------------------
-- Actor / Role hierarchy
----------------------------------------------------------------------

abstract sig Actor {
    mayPerform : set Permission
}

one sig Students, Instructors, Learning_Management_System_LMS_Team extends Actor {}
-- Students: represents stakeholder 'Students'
-- Instructors: represents stakeholder 'Instructors'
-- Learning_Management_System_LMS_Team: represents stakeholder 'Learning Management System (LMS) Team'


----------------------------------------------------------------------
-- Resources (data / objects under operation)
----------------------------------------------------------------------

abstract sig Resource {
    owner      : one  Actor,
    accessible : set  Actor
}

-- Every resource is accessible AT MINIMUM by its owner.
fact owner_always_accessible {
    all r: Resource | r.owner in r.accessible
}

-- Concrete data resources for the review operation
one sig PastAttemptData, DashboardData, TrendData extends Resource {}

fact resource_ownership {
    PastAttemptData.owner = Students
    DashboardData.owner = Students
    TrendData.owner = Students
    PastAttemptData.accessible = Students
    DashboardData.accessible = Students + Instructors
    TrendData.accessible = Students
}

----------------------------------------------------------------------
-- Interfaces (communication channels)
----------------------------------------------------------------------

abstract sig IfaceKind {}
one sig Database, UI, API extends IfaceKind {}

abstract sig Bool {}
one sig True, False extends Bool {}

abstract sig Interface {
    kind          : one IfaceKind,
    encrypted     : one Bool,      -- transport-layer security
    authenticated : one Bool       -- requires caller identity
}

one sig StudentDashboardUI, StudentDataAPI, TrendAPI extends Interface {}

fact interface_properties {
    StudentDashboardUI.kind = UI
    StudentDashboardUI.encrypted = True
    StudentDashboardUI.authenticated = True
    StudentDataAPI.kind = API
    StudentDataAPI.encrypted = True
    StudentDataAPI.authenticated = True
    TrendAPI.kind = API
    TrendAPI.encrypted = True
    TrendAPI.authenticated = True
}


----------------------------------------------------------------------
-- System states and transitions
----------------------------------------------------------------------

abstract sig State {}

-- Concrete pre-states (one per distinct precondition).
one sig Pre1, Pre2 extends State {}
-- Pre1: system is in state where I am a student with multiple completed attempts
-- Pre2: system is in state where Competency trend charts have sufficient data to generate trends

-- Concrete post-states (one per distinct postcondition).
one sig Post1 extends State {}
-- Post1: system reaches state where The user has reviewed past attempts and identified areas needing improvement


----------------------------------------------------------------------
-- Core operation: REQ_REVIEW_01
----------------------------------------------------------------------

sig REQ_REVIEW_01 {
    initiator  : one  Actor,          -- who triggers the operation
    target     : some Resource,        -- what data/objects are affected
    channel    : some Interface,       -- how the operation is communicated
    grant      : one  Permission,      -- what permission is exercised
    pre        : one  State,           -- precondition that must hold
    post       : one  State            -- postcondition that is established
}


----------------------------------------------------------------------
-- Structural well-formedness invariants
----------------------------------------------------------------------

-- INV-1: Every operation must use at least one communication channel.
fact inv_operation_requires_channel {
    all op: REQ_REVIEW_01 | some op.channel
}

-- INV-2: Every operation must affect at least one resource.
fact inv_operation_requires_target {
    all op: REQ_REVIEW_01 | some op.target
}

-- INV-3: The initiator must hold the required permission.
fact inv_initiator_is_authorized {
    all op: REQ_REVIEW_01 | op.grant in op.initiator.mayPerform
}

-- INV-4: The initiator can only access resources they are authorized for.
fact inv_resource_access_control {
    all op: REQ_REVIEW_01 | op.initiator in op.target.accessible
}

-- INV-5: The operation must produce a state change.
-- pre and post share type State, so this constraint is non-trivial.
fact inv_state_must_change {
    all op: REQ_REVIEW_01 | op.pre != op.post
}

-- INV-6: At least one channel must require authentication.
fact inv_authenticated_channel_required {
    all op: REQ_REVIEW_01 | some c: op.channel | c.authenticated = True
}


----------------------------------------------------------------------
-- Post-state reachability constraints
----------------------------------------------------------------------

-- Every operation must reach one of the defined post-states (not an undefined state).
fact postconditions_must_reach_defined_states {
    all op: REQ_REVIEW_01 | op.post in Post1
}



----------------------------------------------------------------------
-- Liveness: at least one valid operation exists
----------------------------------------------------------------------

pred show_REQ_REVIEW_01 {
    some op: REQ_REVIEW_01 |
        some op.target   &&
        some op.channel  &&
        op.grant in op.initiator.mayPerform
}
run show_REQ_REVIEW_01 for 5


----------------------------------------------------------------------
-- Core safety assertions (model-checkable)
----------------------------------------------------------------------

-- SAFETY-1: No unauthorized actor can execute the operation.
assert no_unauthorized_execution {
    all op: REQ_REVIEW_01 | op.grant in op.initiator.mayPerform
}
check no_unauthorized_execution for 5

-- SAFETY-2: No operation accesses a resource its initiator cannot reach.
assert no_unauthorized_resource_access {
    all op: REQ_REVIEW_01 | op.initiator in op.target.accessible
}
check no_unauthorized_resource_access for 5

-- SAFETY-3: Every operation is structurally complete (well-formed).
assert REQ_REVIEW_01_well_formed {
    all op: REQ_REVIEW_01 |
        one  op.initiator &&
        some op.target    &&
        some op.channel   &&
        one  op.grant     &&
        one  op.pre       &&
        one  op.post      &&
        op.pre != op.post
}
check REQ_REVIEW_01_well_formed for 5


----------------------------------------------------------------------
-- Post-state reachability verification
----------------------------------------------------------------------

-- Post-state reachability && semantic verification for Post1
pred ps_reach_Post1 {
    some op: REQ_REVIEW_01 |
        op.post = Post1 &&
        op.pre = Pre1 &&
        Read in op.initiator.mayPerform &&
        PastAttemptData in op.target &&
        op.channel.kind = UI &&
        op.channel.encrypted = True &&
        op.channel.authenticated = True &&
        op.grant = Read
}

run ps_reach_Post1 for 5

assert ps_valid_Post1 {
    all op: REQ_REVIEW_01 |
        op.post = Post1 =>
            (Read in op.initiator.mayPerform &&
             PastAttemptData in op.target &&
             op.channel.encrypted = True &&
             op.channel.authenticated = True &&
             op.grant = Read)
}

check ps_valid_Post1 for 5

----------------------------------------------------------------------
-- Acceptance criterion reachability predicates
----------------------------------------------------------------------

-- Predicate for Criterion 1: "I see a chronological list of my past attempts"
pred ac_reach_1 {
    some op: REQ_REVIEW_01 |
        op.initiator = Students &&
        op.grant = Read &&
        PastAttemptData in op.target &&
        (some c: op.channel | c.authenticated = True) &&
        PastAttemptData.owner = Students
}
run ac_reach_1 for 5

-- Predicate for Criterion 2: "I see for each question: my answer, the correct answer, && a learning nugget"
pred ac_reach_2 {
    some op: REQ_REVIEW_01 |
        op.initiator = Students &&
        op.grant = Read &&
        DashboardData in op.target &&
        (some c: op.channel | c.authenticated = True) &&
        DashboardData.owner = Students
}
run ac_reach_2 for 5

-- Predicate for Criterion 3: "I see graphical trends of my performance over time for each competency"
pred ac_reach_3 {
    some op: REQ_REVIEW_01 |
        op.initiator = Students &&
        op.grant = Read &&
        TrendData in op.target &&
        (some c: op.channel | c.authenticated = True) &&
        TrendData.owner = Students
}
run ac_reach_3 for 5

----------------------------------------------------------------------
-- Edge case safety assertions
----------------------------------------------------------------------

-- Edge Case 1: Student with no past attempts should still be able to request review
-- A student who has never attempted anything must ! be blocked by an empty history precondition
assert ec_safe_1 {
    all op: REQ_REVIEW_01 |
        -- If initiator is a Student, they must still be able to have targets
        (op.initiator in Students) => 
        !(no op.target)  -- target must be non-empty
}
check ec_safe_1 for 5

-- Edge Case 2: Data privacy when displaying competency trends
-- The operation must ! expose resource ownership/access info through channels that lack encryption
assert ec_safe_2 {
    all op: REQ_REVIEW_01 |
        -- If channel is ! encrypted, it must ! carry resource owner information
        (op.channel.encrypted = False) =>
        (no r: op.target | r.owner = op.initiator)
}
check ec_safe_2 for 5

-- Edge Case 3: Error in calculating competency trend charts
-- If there's an error, the post-state must ! claim a different permission than the grant
assert ec_safe_3 {
    all op: REQ_REVIEW_01 |
        -- The grant permission must be consistent with what the initiator can perform
        op.grant in op.initiator.mayPerform
}
check ec_safe_3 for 5

----------------------------------------------------------------------
-- Behavioral contract predicates (test scenarios)
----------------------------------------------------------------------

pred tc_review_01_holds {
    some op: REQ_REVIEW_01 |
        op.initiator = Students &&
        DashboardData in op.target &&
        op.grant = Read &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_review_01_holds for 5

assert tc_review_01_contract {
    all op: REQ_REVIEW_01 |
        (op.initiator = Students &&
         DashboardData in op.target &&
         op.grant = Read &&
         op.pre = Pre1) =>
        op.post = Post1
}
check tc_review_01_contract for 5

pred tc_review_02_holds {
    some op: REQ_REVIEW_01 |
        op.initiator = Students &&
        DashboardData in op.target &&
        op.grant = Read &&
        op.pre = Pre2 &&
        op.post = Post1
}
run tc_review_02_holds for 5

assert tc_review_02_contract {
    all op: REQ_REVIEW_01 |
        (op.initiator = Students &&
         DashboardData in op.target &&
         op.grant = Read &&
         op.pre = Pre2) =>
        op.post = Post1
}
check tc_review_02_contract for 5

pred tc_review_03_holds {
    some op: REQ_REVIEW_01 |
        op.initiator = Students &&
        DashboardData in op.target &&
        op.grant = Read &&
        op.pre = Pre1 &&
        op.post = Post1
}
run tc_review_03_holds for 5

assert tc_review_03_contract {
    all op: REQ_REVIEW_01 |
        (op.initiator = Students &&
         DashboardData in op.target &&
         op.grant = Read &&
         op.pre = Pre1) =>
        op.post = Post1
}
check tc_review_03_contract for 5

----------------------------------------------------------------------
-- Non-functional requirement invariants
----------------------------------------------------------------------

fact nfr_fact_performance {
    -- PROXY: limiting channel count per operation reduces latency, approximating <2s response
    all op: REQ_REVIEW_01 | #op.channel <= 3
}

fact nfr_fact_availability {
    -- PROXY: requiring at least 2 channels per operation ensures redundancy for 99.9% uptime
    all op: REQ_REVIEW_01 | #op.channel >= 2
}

assert nfr_assert_scalability {
    -- PROXY: every actor can initiate an operation, covering 10,000 concurrent users
    all a: Actor | some op: REQ_REVIEW_01 | op.initiator = a
}
check nfr_assert_scalability for 5

fact nfr_fact_usability {
    -- PROXY: limiting the number of authenticated interfaces to 3 reduces complexity for clear error messages
    #{i: Interface | i.authenticated = True} <= 3
}

----------------------------------------------------------------------
-- Security properties
----------------------------------------------------------------------

-- Security properties for REQ_REVIEW_01

-- Fact: Authentication required for all channels when accessing the review section (DashboardData resource)
fact sr_fact_review_authentication {
    all op : REQ_REVIEW_01 |
        (DashboardData in op.target) => (all c : op.channel | c.authenticated = True)
}

-- Assertion: Encryption in transit for any operation involving student data (PastAttemptData or TrendData)
assert sr_assert_encryption_transit {
    all op : REQ_REVIEW_01 |
        (PastAttemptData in op.target || TrendData in op.target) =>
            (all c : op.channel | c.encrypted = True)
}
check sr_assert_encryption_transit for 5


----------------------------------------------------------------------
-- Whole-model verification summary
----------------------------------------------------------------------

-- Summary 1: Core structural model for REQ-REVIEW-01 with actor, permission, resource, interface, and state sigs
-- Summary 2: Safety assertions ensure authorization, access control, and structural well-formedness
-- Summary 3: Reachability predicates for acceptance criteria and test cases
-- Summary 4: Non-functional proxy constraints for performance, availability, scalability, usability
-- Summary 5: Security constraints for authentication and encryption on relevant operations
-- Assumption 1: All data resources (PastAttemptData, DashboardData, TrendData) are owned by Students
-- Assumption 2: Interfaces (StudentDashboardUI, StudentDataAPI, TrendAPI) are separate from resources
-- Assumption 3: State transitions are represented by atomic pre/post fields; no temporal ordering is modeled
-- Assumption 4: Edge case assertions are safety properties that should hold in all valid instances
-- Open issue 1: The nfr_assert_scalability assertion may fail if some actors never initiate operations (e.g., Learning_Management_System_LMS_Team) - could be relaxed if not required
-- Open issue 2: Non-functional proxies are coarse and may not fully capture real performance/availability requirements


